<MudNavMenu Class="pt-4">
    <AuthorizeView Context="navContext">
        <Authorized>
            <div class="px-4 mb-2">
                <MudText Typo="Typo.subtitle2" Class="text-gray-500 fw-bold uppercase tracking-wider mb-2" Style="font-size: 0.7rem;">CASINO</MudText>
            </div>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Lobby</MudNavLink>
            
            <MudNavGroup Title="Slots" Icon="@Icons.Material.Filled.Casino" Expanded="true">
                <MudNavLink Href="game/cloverchase">Clover Chase</MudNavLink>
                <MudNavLink Href="#" Disabled="true">Fruit Blast <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">SOON</MudChip></MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Roulette" Icon="@Icons.Material.Filled.RotateRight">
                <MudNavLink Href="game/roulette?mode=classic">Roulette Royale</MudNavLink>
                <MudNavLink Href="game/roulette?mode=extreme" IconColor="Color.Warning">Extreme Roulette</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Dice Games" Icon="@Icons.Material.Filled.SportsEsports">
                <MudNavLink Href="game/dice?mode=slider">Neon Dice</MudNavLink>
                <MudNavLink Href="game/dice?mode=multi">Crazy Dice</MudNavLink>
            </MudNavGroup>

            <MudNavLink Href="game/blackjack" Icon="@Icons.Material.Filled.Style">Blackjack</MudNavLink>
            <MudNavLink Href="game/baccarat" Icon="@Icons.Material.Filled.TableChart">Baccarat</MudNavLink>

            <MudNavLink Href="leaderboard" Icon="@Icons.Material.Filled.Leaderboard">Leaderboard</MudNavLink>

            <div class="px-4 mt-6 mb-2">
                <MudText Typo="Typo.subtitle2" Class="text-gray-500 fw-bold uppercase tracking-wider mb-2" Style="font-size: 0.7rem;">ACCOUNT</MudText>
            </div>
            <MudNavLink Href="wallet" Icon="@Icons.Material.Filled.AccountBalanceWallet">My Wallet</MudNavLink>
            <MudNavLink Href="history" Icon="@Icons.Material.Filled.History">Bet History</MudNavLink>
            <MudNavLink Href="profile" Icon="@Icons.Material.Filled.Person">Profile</MudNavLink>
            <MudNavLink Href="fairness" Icon="@Icons.Material.Filled.VerifiedUser">Fairness</MudNavLink>

            @if (navContext.User.IsInRole("Admin"))
            {
                <div class="px-4 mt-6 mb-2">
                    <MudText Typo="Typo.subtitle2" Class="text-warning fw-bold uppercase tracking-wider mb-2" Style="font-size: 0.7rem;">ADMIN PANEL</MudText>
                </div>
                <MudNavLink Href="dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Overview</MudNavLink>
                <MudNavLink Href="admin/monitor" Icon="@Icons.Material.Filled.LiveTv">Live Monitor</MudNavLink>
                <MudNavLink Href="admin/players" Icon="@Icons.Material.Filled.People">Player Manager</MudNavLink>
                <MudNavLink Href="admin/vouchers" Icon="@Icons.Material.Filled.ConfirmationNumber">Voucher System</MudNavLink>
                <MudNavLink Href="admin/simulation" Icon="@Icons.Material.Filled.Science">Simulation Center</MudNavLink>
                <MudNavLink Href="admin/settings" Icon="@Icons.Material.Filled.Settings">Platform Settings</MudNavLink>
            }
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="fairness" Icon="@Icons.Material.Filled.VerifiedUser">Fairness</MudNavLink>
            <MudNavLink Href="login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
            <MudNavLink Href="register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    [Inject] IAuthService AuthService { get; set; } = default!;
    [Inject] NavigationManager Navigation { get; set; } = default!;
}
