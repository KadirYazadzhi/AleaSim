<MudNavMenu>
    <div class="pa-4 mb-2 d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.Casino" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight: 900;">ALEASIM</MudText>
    </div>

    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavGroup Title="Lobby" Icon="@Icons.Material.Filled.SportsEsports" Expanded="true">
                <MudNavLink Href="game/cloverchase" Icon="@Icons.Material.Filled.Casino">
                    Clover Chase
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Class="ml-auto" Style="font-weight: bold;">HOT</MudChip>
                </MudNavLink>
                <MudNavLink Href="game/roulette" Icon="@Icons.Material.Filled.RotateRight">Roulette Royale</MudNavLink>
                <MudNavLink Href="game/blackjack" Icon="@Icons.Material.Filled.Style">Blackjack Royale</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Account" Icon="@Icons.Material.Filled.AccountCircle" Expanded="false">
                <MudNavLink Href="wallet" Icon="@Icons.Material.Filled.AccountBalanceWallet">My Wallet</MudNavLink>
                <MudNavLink Href="history" Icon="@Icons.Material.Filled.History">Bet History</MudNavLink>
                <MudNavLink Href="profile" Icon="@Icons.Material.Filled.Person">Profile</MudNavLink>
                <MudNavLink Href="fairness" Icon="@Icons.Material.Filled.VerifiedUser">Fairness</MudNavLink>
            </MudNavGroup>

            @if (context.User.IsInRole("Admin"))
            {
                <MudNavGroup Title="Administration" Icon="@Icons.Material.Filled.Security" Expanded="false">
                    <MudNavLink Href="dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                    <MudNavLink Href="admin/players" Icon="@Icons.Material.Filled.PersonSearch">Players</MudNavLink>
                    <MudNavLink Href="admin/vouchers" Icon="@Icons.Material.Filled.ConfirmationNumber">Vouchers</MudNavLink>
                </MudNavGroup>
            }

            <div class="mt-auto pa-4">
                <MudDivider Class="mb-4" />
                <MudNavLink OnClick="Logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">Logout</MudNavLink>
            </div>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="fairness" Icon="@Icons.Material.Filled.VerifiedUser">Fairness</MudNavLink>
            <MudNavLink Href="login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
            <MudNavLink Href="register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    [Inject] IAuthService AuthService { get; set; } = default!;
    [Inject] NavigationManager Navigation { get; set; } = default!;

    private async Task Logout() {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}
