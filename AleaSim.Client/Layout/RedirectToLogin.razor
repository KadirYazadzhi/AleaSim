@using AleaSim.Client.Services
@inject NavigationManager Navigation
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@code {
    protected override async Task OnInitializedAsync() {
        // Clear broken token to prevent infinite loops
        await LocalStorage.RemoveItemAsync("authToken");
        
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (string.IsNullOrWhiteSpace(returnUrl) || returnUrl.Contains("login")) {
            Navigation.NavigateTo("login?reason=expired");
        } else {
            Navigation.NavigateTo($"login?reason=expired&ReturnUrl={Uri.EscapeDataString(returnUrl)}");
        }
    }
}
