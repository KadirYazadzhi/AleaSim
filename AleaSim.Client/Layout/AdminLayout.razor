@inherits LayoutComponentBase
@using AleaSim.Client.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject LayoutService LayoutService

<MudThemeProvider Theme="@LayoutService.CurrentTheme" IsDarkMode="@LayoutService.IsDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Color="Color.Transparent" Class="glass-appbar px-md-6 px-2 py-2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => LayoutService.ToggleDrawer())" Class="mr-md-4 mr-1" />
        
        <div class="d-flex align-center cursor-pointer" @onclick='@(() => Navigation.NavigateTo("/dashboard"))'>
            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Medium" Color="Color.Error" Class="mr-2" />
            <MudText Typo="Typo.h6" Class="text-gradient font-black tracking-wide admin-title-text">ALEASIM <span class="mud-text-secondary text-xs font-normal d-none d-sm-inline">BACKOFFICE</span></MudText>
        </div>
        
        <MudSpacer />
        
        <div class="d-flex align-center gap-md-3 gap-1">
             <MudIconButton Icon="@(LayoutService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                            Color="Color.Inherit" 
                            OnClick="@(async () => await LayoutService.ToggleDarkMode())" 
                            Size="Size.Small" />
             
             <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ExitAdmin" StartIcon="@Icons.Material.Filled.ExitToApp" Class="rounded-lg border-2 fw-bold d-none d-md-inline-flex">Exit to Casino</MudButton>
             <MudIconButton Icon="@Icons.Material.Filled.ExitToApp" Color="Color.Primary" OnClick="ExitAdmin" Class="d-md-none" Size="Size.Small" />
        </div>
    </MudAppBar>

    <MudDrawer @bind-Open="@LayoutService.IsDrawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Variant="DrawerVariant.Responsive" Class="sidebar-blur">
        <NavMenu />
        <div class="mt-auto pa-4 d-none d-md-block">
            <MudPaper Class="glass-panel pa-4 rounded-xl text-center">
                 <MudText Typo="Typo.caption" Class="d-block mb-1 mud-text-secondary">System Load</MudText>
                 <MudProgressLinear Color="@GetLoadColor(_cpuLoad)" Value="@_cpuLoad" Class="mb-1 rounded-pill" Size="Size.Small" />
                 <MudText Typo="Typo.caption" Class="fw-bold" Color="@GetLoadColor(_cpuLoad)">@_cpuLoad.ToString("F0")%</MudText>
            </MudPaper>
        </div>
    </MudDrawer>

    <MudMainContent Class="pt-16 d-flex flex-column" Style="min-height: 100vh">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="flex-grow-1 px-md-4 px-2 py-md-8 py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<style>
    /* Global Overrides for Premium Feel (Copied from MainLayout for consistency) */
    .glass-appbar {
        background-color: var(--mud-palette-appbar-background) !important;
        color: var(--mud-palette-text-primary) !important;
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--mud-palette-divider);
        transition: all 0.3s ease;
    }
    
    .sidebar-blur {
        background-color: var(--mud-palette-drawer-background) !important;
        border-right: 1px solid var(--mud-palette-divider);
    }

    .glass-panel {
        background-color: @(LayoutService.IsDarkMode ? "rgba(255, 255, 255, 0.03)" : "rgba(0, 0, 0, 0.05)");
        backdrop-filter: blur(10px);
        border: 1px solid var(--mud-palette-divider);
    }

    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .font-black { font-weight: 900; }
    .fw-bold { font-weight: 700; }
    .tracking-wide { letter-spacing: 0.1em; }

    @@media (max-width: 600px) {
        .admin-title-text { font-size: 0.9rem !important; }
    }
</style>

@code {
    private double _cpuLoad = 15;
    private long _ramUsageMb = 256;
    private System.Threading.Timer? _statsTimer;
    [Inject] HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LayoutService.InitializeAsync();
        LayoutService.OnMajorUpdate += StateHasChanged;
        _statsTimer = new System.Threading.Timer(async _ => await RefreshStats(), null, 0, 10000);
    }

    private async Task RefreshStats() {
        try {
            var stats = await Http.GetFromJsonAsync<SystemStatsResponse>("api/Admin/system/stats");
            if (stats != null) {
                _cpuLoad = stats.CpuUsage;
                _ramUsageMb = stats.RamUsageMb;
                await InvokeAsync(StateHasChanged);
            }
        } catch {}
    }

    private Color GetLoadColor(double load) => load switch {
        > 80 => Color.Error,
        > 50 => Color.Warning,
        _ => Color.Success
    };
    
    public void Dispose()
    {
        LayoutService.OnMajorUpdate -= StateHasChanged;
        _statsTimer?.Dispose();
    }

    private void ExitAdmin() {
        Navigation.NavigateTo("/");
    }

    private record SystemStatsResponse(double CpuUsage, long RamUsageMb);
}