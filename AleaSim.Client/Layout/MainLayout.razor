@inherits LayoutComponentBase
@using Blazored.LocalStorage
@using AleaSim.Client.Services

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">AleaSim Casino</MudText>
        <MudSpacer />
        
        <AuthorizeView>
            <Authorized>
                <div class="d-flex align-center gap-4">
                    @if (userProfile != null) {
                        <MudChip T="string" Icon="@Icons.Material.Filled.Stars" Color="Color.Info">Level @userProfile.Progression.CurrentLevel</MudChip>
                        <MudText Typo="Typo.h6" Color="Color.Success">$@userProfile.Balance.ToString("N2")</MudText>
                    }
                    <MudMenu Icon="@Icons.Material.Filled.AccountCircle" AnchorOrigin="Origin.BottomRight">
                        <MudMenuItem Href="/profile">Profile</MudMenuItem>
                        <MudMenuItem OnClick="Logout">Logout</MudMenuItem>
                    </MudMenu>
                </div>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Color="Color.Inherit">Login</MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Secondary" Class="ml-2">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {

    bool _drawerOpen = true;

    private UserProfileDto? userProfile;



    [Inject] IAuthService AuthService { get; set; } = default!;

    [Inject] NavigationManager Navigation { get; set; } = default!;

    [Inject] HttpClient Http { get; set; } = default!;

    [Inject] RealTimeClient RealTime { get; set; } = default!;

    [Inject] ISnackbar Snackbar { get; set; } = default!;

    [Inject] ILocalStorageService LocalStorage { get; set; } = default!;



    protected override async Task OnInitializedAsync() {

        await LoadProfile();

        

        // Start SignalR

        var token = await LocalStorage.GetItemAsync<string>("authToken");

        if (!string.IsNullOrEmpty(token)) {

            await RealTime.StartAsync(token);

            RealTime.OnBigWinReceived += HandleBigWin;

        }

    }



    private async Task LoadProfile() {

        try {

            userProfile = await Http.GetFromJsonAsync<UserProfileDto>("api/Auth/me");

        } catch { /* Silent fail if not auth yet */ }

    }



    private void HandleBigWin(BigWinEventArgs args) {

        Snackbar.Add($"{args.Username} just won {args.Amount:C} ({args.Multiplier:F0}x) on {args.GameName}!", 

            Severity.Warning, config => {

                config.Icon = Icons.Material.Filled.EmojiEvents;

                config.VisibleStateDuration = 10000;

            });

    }



    void DrawerToggle()

    {

        _drawerOpen = !_drawerOpen;

    }



    private async Task Logout() {

        RealTime.OnBigWinReceived -= HandleBigWin;

        await AuthService.Logout();

        Navigation.NavigateTo("/");

    }





    public class UserProfileDto {

        public string Username { get; set; } = "";

        public decimal Balance { get; set; }

        public UserProgressionDto Progression { get; set; } = new();

    }

}


