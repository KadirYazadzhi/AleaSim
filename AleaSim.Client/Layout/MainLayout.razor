@inherits LayoutComponentBase
@implements IDisposable
@using Blazored.LocalStorage
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@using AleaSim.Shared.Models
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IGameService GameService
@inject RealTimeClient RealTime
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject NotificationService NotifService
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@inject LayoutService LayoutService
@inject PlatformStatsService PlatformStats

<MudThemeProvider IsDarkMode="@LayoutService.IsDarkMode" Theme="@LayoutService.CurrentTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />
<CelebrationOverlay @ref="celebrationOverlay" />
<FlowStateIndicator Intensity="@_flowIntensity" />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Color="Color.Transparent" Class="glass-appbar px-6 py-2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => LayoutService.ToggleDrawer())" Class="mr-4" />
        
        <div class="d-flex align-center cursor-pointer" @onclick='@(() => Navigation.NavigateTo("/"))'>
            <MudIcon Icon="@Icons.Material.Filled.Casino" Size="Size.Large" Color="Color.Primary" Class="mr-2 spin-hover" />
            <MudText Typo="Typo.h5" Class="text-gradient font-black tracking-wide">ALEASIM</MudText>
        </div>
        
        <MudSpacer />
        
        <AuthorizeView Context="authContext">
            <Authorized>
                <div class="d-flex align-center gap-3">
                    <!-- Flow State Debug/Visualizer -->
                    @if (_flowIntensity > 0) {
                        <div class="d-flex align-center flow-badge pa-1 px-3 rounded-pill glass-panel">
                             <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="@(_flowIntensity > 0.8 ? Color.Error : Color.Warning)" Size="Size.Small" Class="mr-1 pulse-icon" />
                             <MudText Typo="Typo.caption" Style="font-weight: bold;">FLOW</MudText>
                        </div>
                    }

                    <!-- Level & XP Progress Pill -->
                    <div class='@($"d-none d-sm-flex align-center mr-2 cursor-pointer level-pill-v2 {(_levelUpTriggered ? "levelup-anim" : "")}")' @onclick='@(() => Navigation.NavigateTo("/profile"))'>
                        <div class="level-pill-inner d-flex align-center px-3 py-1 rounded-pill">
                            <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" Color="Color.Error" Size="Size.Small" Class='@($"mr-2 {(_levelUpTriggered ? "fire-flare" : "")}")' />
                            <MudText Typo="Typo.subtitle2" Class='@($"level-number-text {(_levelUpTriggered ? "text-pop" : "")}")'>LVL @(userProfile?.Progression?.CurrentLevel ?? 1)</MudText>
                        </div>
                        
                        <!-- SVG Progress Path Overlay (Starts from Middle Left) -->
                        <svg class="level-svg-container" viewBox="0 0 120 40">
                            <!-- Background Track -->
                            <path d="M 2,20 A 18,18 0 0 1 20,2 H 100 A 18,18 0 0 1 118,20 A 18,18 0 0 1 100,38 H 20 A 18,18 0 0 1 2,20 Z" 
                                  fill="none" class="level-bg-path" />
                            <!-- Active Progress -->
                            <path d="M 2,20 A 18,18 0 0 1 20,2 H 100 A 18,18 0 0 1 118,20 A 18,18 0 0 1 100,38 H 20 A 18,18 0 0 1 2,20 Z" 
                                  fill="none" 
                                  class="level-progress-path"
                                  style='@($"stroke-dasharray: 274; stroke-dashoffset: {274 - (274 * (userProfile?.Progression?.ProgressPercentage ?? 0) / 100)};")' />
                        </svg>
                    </div>

                    <!-- Wallet Display -->
                    @if (userProfile != null) {
                        <div class="wallet-container-premium px-3 py-1 rounded-pill glass-panel" @onclick='@(() => Navigation.NavigateTo("/wallet"))'>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Style="font-size: 1.4rem;" Color="Color.Success" Class="mr-2" />
                                <MudText Typo="Typo.subtitle1" Color="Color.Success" Class="wallet-balance-text">
                                    @userProfile.TotalBalance.ToString("C2")
                                </MudText>
                            </div>
                        </div>
                    }

                    <!-- Notifications -->
                    <MudBadge Content="@NotifService.UnreadCount" Color="Color.Error" Overlap="true" Dot="@(NotifService.UnreadCount > 0)" Class="mx-1">
                        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" OnClick="@ToggleNotifications" />
                        <MudPopover Open="@_notificationsOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-0 mt-2 glass-panel" Style="width: 320px;">
                            <div class="d-flex justify-space-between align-center pa-3 border-b border-white-10">
                                <MudText Typo="Typo.h6">Notifications</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.DoneAll" Size="Size.Small" OnClick="() => NotifService.MarkAllAsRead()" title="Mark all as read" />
                            </div>
                            <MudList T="string" Dense="true" Style="max-height: 300px; overflow-y: auto;">
                                @if (!NotifService.History.Any()) {
                                    <MudListItem>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="pa-4">No new notifications</MudText>
                                    </MudListItem>
                                } else {
                                    @foreach (var item in NotifService.History.Take(5)) {
                                        <MudListItem>
                                            <div class="d-flex flex-column">
                                                <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@item.Title</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Message</MudText>
                                            </div>
                                        </MudListItem>
                                    }
                                }
                            </MudList>
                        </MudPopover>
                    </MudBadge>

                    <!-- Profile Menu & VIP Icon -->
                    <div class="position-relative">
                        <MudMenu AnchorOrigin="Origin.BottomRight" LockScroll="true" TransformOrigin="Origin.TopRight">
                            <ActivatorContent>
                                <div class="position-relative">
                                    <MudAvatar Class="cursor-pointer border-2 border-primary shadow-lg">
                                        <MudImage Src="@userProfile?.AvatarUrl" />
                                    </MudAvatar>
                                    @if (userProfile?.Progression?.Tier > VipTier.Bronze)
                                    {
                                        <div class="vip-badge-mini">
                                            <MudIcon Icon="@GetTierIcon(userProfile.Progression.Tier)" Color="@GetTierColor(userProfile.Progression.Tier)" Style="font-size: 1rem;" />
                                        </div>
                                    }
                                </div>
                            </ActivatorContent>
                        <ChildContent>
                            <div class="pa-4 d-flex flex-column align-center border-b border-white-10">
                                <MudAvatar Size="Size.Large" Class="mb-2">
                                    <MudImage Src="@userProfile?.AvatarUrl" />
                                </MudAvatar>
                                <MudText Typo="Typo.subtitle1" Style="font-weight: bold;">@userProfile?.Username</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetTierColor(userProfile?.Progression?.Tier ?? VipTier.Bronze)" Variant="Variant.Text" Class="mt-1">
                                    @userProfile?.Progression?.TierName
                                </MudChip>
                            </div>
                            <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.Person">Profile</MudMenuItem>
                            <MudMenuItem Href="/wallet" Icon="@Icons.Material.Filled.AccountBalanceWallet">Wallet</MudMenuItem>
                            <MudMenuItem Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudMenuItem>
                            <MudMenuItem Icon="@(LayoutService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" OnClick="@(async () => await LayoutService.ToggleDarkMode())">
                                @(LayoutService.IsDarkMode ? "Light Mode" : "Dark Mode")
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem OnClick="Logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">Logout</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </div>
            </div>
            </Authorized>
            <NotAuthorized>
                <div class="d-flex gap-3">
                    <MudIconButton Icon="@(LayoutService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                                   Color="Color.Inherit" 
                                   OnClick="@(async () => await LayoutService.ToggleDarkMode())" />
                    <MudButton Href="/login" Variant="Variant.Outlined" Class="secondary-btn rounded-lg px-6" Style="font-weight: bold;">Login</MudButton>
                    <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Class="rounded-lg px-6 fw-bold glow-effect">Register</MudButton>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="@LayoutService.IsDrawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Variant="DrawerVariant.Responsive" Class="sidebar-blur">
        <NavMenu />
        <div class="mt-auto pa-4">
             <AuthorizeView Roles="User">
                 <Authorized>
                     <div class="mb-4">
                         <QuestWidget Compact="true" />
                     </div>
                 </Authorized>
             </AuthorizeView>
             
             <MudCard Class="glass-panel pa-3 text-center mb-4">
                 <MudText Typo="Typo.caption" Class="d-block mb-1 mud-text-secondary">Grand Prize Pool</MudText>
                 <MudText Typo="Typo.h6" Class="text-gradient font-black">@PlatformStats.Stats.TournamentPrizePool.ToString("C2")</MudText>
             </MudCard>
        </div>
    </MudDrawer>

    <MudDrawer @bind-Open="_chatOpen" Anchor="Anchor.End" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="@DrawerVariant.Persistent" Class="chat-drawer">
        <ChatRoom />
    </MudDrawer>

    <MudMainContent Class="pt-16 d-flex flex-column" Style="min-height: 100vh">
        <div class="content-wrapper flex-grow-1">
            @Body
        </div>

        <!-- Enhanced Footer -->
        <MudPaper Class="footer-section mt-16 pt-16 pb-8 px-6 px-md-12" Elevation="0" Square="true">
            <MudContainer MaxWidth="MaxWidth.ExtraLarge">
                <MudGrid>
                    <MudItem xs="12" md="4" Class="mb-8 mb-md-0">
                        <div class="d-flex align-center mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Casino" Color="Color.Primary" Size="Size.Large" Class="mr-3" />
                            <MudText Typo="Typo.h5" Style="font-weight: 900; letter-spacing: 1px;">ALEASIM</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Class="mb-6 opacity-70" Style="max-width: 350px; line-height: 1.6;">
                            The next generation of decentralized gaming. Experience provably fair odds, instant payouts, and AI-driven entertainment.
                        </MudText>
                        <div class="d-flex gap-2">
                             <MudIconButton Icon="@Icons.Custom.Brands.Twitter" Color="Color.Inherit" Variant="Variant.Outlined" Class="rounded-circle social-icon" />
                             <MudIconButton Icon="@Icons.Custom.Brands.Discord" Color="Color.Inherit" Variant="Variant.Outlined" Class="rounded-circle social-icon" />
                             <MudIconButton Icon="@Icons.Custom.Brands.Telegram" Color="Color.Inherit" Variant="Variant.Outlined" Class="rounded-circle social-icon" />
                        </div>
                    </MudItem>
                    
                    <MudItem xs="6" md="2">
                        <MudText Typo="Typo.subtitle2" Class="mb-4 text-uppercase font-bold opacity-50">Casino</MudText>
                        <div class="d-flex flex-column gap-2">
                            <MudLink Href="game/cloverchase" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Slots</MudLink>
                            <MudLink Href="game/roulette" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Table Games</MudLink>
                            <MudLink Href="leaderboard" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Leaderboards</MudLink>
                            <MudLink Href="fairness" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Provably Fair</MudLink>
                        </div>
                    </MudItem>

                    <MudItem xs="6" md="2">
                        <MudText Typo="Typo.subtitle2" Class="mb-4 text-uppercase font-bold opacity-50">Support</MudText>
                        <div class="d-flex flex-column gap-2">
                            <MudLink Href="help" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Help Center</MudLink>
                            <MudLink Href="terms" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Terms of Service</MudLink>
                            <MudLink Href="privacy" Color="Color.Inherit" Underline="Underline.None" Class="footer-link">Privacy Policy</MudLink>
                        </div>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-6 glass-panel rounded-xl" Elevation="0">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: bold;" Class="mb-2">Join the Community</MudText>
                            <MudText Typo="Typo.body2" Class="mb-4 opacity-70">Get exclusive bonuses and game updates directly to your inbox.</MudText>
                            <div class="d-flex gap-2">
                                <MudTextField T="string" Placeholder="Enter your email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg bg-dark-transparent" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="rounded-lg px-4" Style="font-weight: bold;">JOIN</MudButton>
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-8 opacity-20" />

                <div class="d-flex flex-wrap justify-space-between align-center gap-4">
                    <MudText Typo="Typo.caption" Class="opacity-50">
                        &copy; 2026 AleaSim Entertainment. All rights reserved.
                    </MudText>
                    
                    <div class="d-flex align-center gap-6 opacity-60">
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" />
                            <MudText Typo="Typo.caption">SSL ENCRYPTED</MudText>
                        </div>
                        <div class="d-flex align-center gap-1">
                             <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" />
                             <MudText Typo="Typo.caption">RNG CERTIFIED</MudText>
                        </div>
                        <div class="border rounded px-2 py-0">
                            <MudText Typo="Typo.caption" Style="font-weight: bold;">18+</MudText>
                        </div>
                    </div>
                </div>
            </MudContainer>
        </MudPaper>
    </MudMainContent>
    <FloatingChat />
</MudLayout>

<style>
    /* Global Overrides for Premium Feel */
    :root {
        --mud-drawer-width-left: 260px;
    }

    .glass-appbar {
        background-color: var(--mud-palette-appbar-background) !important;
        color: var(--mud-palette-text-primary) !important;
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--mud-palette-divider);
        transition: all 0.3s ease;
    }
    
    .sidebar-blur {
        background-color: var(--mud-palette-drawer-background) !important;
        border-right: 1px solid var(--mud-palette-divider);
    }

    .glass-panel {
        background-color: var(--mud-palette-surface);
        backdrop-filter: blur(10px);
        border: 1px solid var(--mud-palette-divider);
    }

    .glass-panel-dark {
        background: rgba(15, 23, 42, 0.6) !important;
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .level-pill-v2 {
        position: relative;
        width: 120px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .level-pill-inner {
        position: relative;
        z-index: 2;
        width: 112px;
        height: 32px;
        background: var(--mud-palette-surface);
        justify-content: center;
    }

    .level-number-text {
        font-weight: 900 !important;
        font-family: 'Rajdhani', sans-serif;
        letter-spacing: 1px;
    }

    .level-svg-container {
        position: absolute;
        inset: 0;
        z-index: 1;
        width: 100%;
        height: 100%;
    }

    .level-bg-path {
        stroke: var(--mud-palette-divider);
        stroke-width: 4;
        opacity: 1;
    }

    .level-progress-path {
        stroke: #f44336; /* Vibrant Red */
        stroke-width: 4;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        filter: drop-shadow(0 0 3px rgba(244, 67, 54, 0.5));
    }

    /* Level Up Animations */
    .levelup-anim {
        animation: levelUpBounce 1s ease forwards;
    }

    .fire-flare {
        animation: fireFlare 1s ease infinite;
    }

    .text-pop {
        animation: textPop 0.5s ease-out forwards;
    }

    @@keyframes levelUpBounce {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); filter: drop-shadow(0 0 15px var(--mud-palette-error)); }
        100% { transform: scale(1); }
    }

    @@keyframes fireFlare {
        0% { filter: brightness(1) drop-shadow(0 0 0px var(--mud-palette-error)); }
        50% { filter: brightness(2) drop-shadow(0 0 10px var(--mud-palette-error)); transform: scale(1.3); }
        100% { filter: brightness(1) drop-shadow(0 0 0px var(--mud-palette-error)); }
    }

    @@keyframes textPop {
        0% { transform: scale(1); }
        50% { transform: scale(1.4); color: var(--mud-palette-warning); }
        100% { transform: scale(1); }
    }

    .wallet-container-premium {
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(76, 175, 80, 0.2);
        background: var(--mud-palette-surface);
    }
    
    .wallet-container-premium:hover {
        background: var(--mud-palette-action-default-hover) !important;
        border-color: rgba(76, 175, 80, 0.5);
        transform: translateY(-1px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .xp-ring-container {
        position: relative;
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .xp-progress-ring {
        position: absolute;
        inset: 0;
    }

    .level-icon-center {
        z-index: 2;
        background: var(--mud-palette-background-grey);
        border-radius: 50%;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 5px rgba(0,0,0,0.2);
    }

    .vip-badge-mini {
        position: absolute;
        bottom: -4px;
        right: -4px;
        background: var(--mud-palette-surface);
        border-radius: 50%;
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--mud-palette-divider);
        box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        z-index: 10;
    }

    .wallet-balance-text {
        font-weight: 900 !important;
        font-family: 'Rajdhani', sans-serif !important;
        font-size: 1.15rem !important;
        letter-spacing: 0.5px;
        text-shadow: 0 0 10px rgba(76, 175, 80, 0.2);
    }

    .wallet-add-btn {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
        color: white;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        box-shadow: 0 2px 8px rgba(76, 175, 80, 0.4);
    }

    .wallet-add-btn:hover {
        transform: rotate(90deg) scale(1.1);
        filter: brightness(1.2);
    }

    .border-glow {
        border: 1px solid var(--mud-palette-lines-default);
        box-shadow: 0 0 10px rgba(239, 68, 68, 0.1);
    }

    .footer-section {
        background: linear-gradient(to bottom, var(--mud-palette-surface), var(--mud-palette-background));
        border-top: 1px solid var(--mud-palette-divider);
        color: var(--mud-palette-text-secondary);
        position: relative;
    }
    
    .footer-section::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--mud-palette-primary), transparent);
        opacity: 0.5;
    }
    
    .footer-link {
        transition: color 0.2s ease;
    }
    .footer-link:hover {
        color: var(--mud-palette-primary) !important;
    }
    
    .social-icon {
        transition: all 0.2s ease;
        border-color: var(--mud-palette-divider) !important;
    }
    .social-icon:hover {
        color: white !important;
        background-color: var(--mud-palette-primary) !important;
        border-color: var(--mud-palette-primary) !important;
        transform: translateY(-2px);
    }
    
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .glow-effect {
        box-shadow: 0 0 15px rgba(124, 58, 237, 0.3);
        transition: box-shadow 0.3s;
    }
    
    .glow-effect:hover {
        box-shadow: 0 0 25px rgba(124, 58, 237, 0.6);
    }
    
    .secondary-btn {
        border: 2px solid var(--mud-palette-primary) !important;
        color: var(--mud-palette-text-primary) !important;
        background: transparent !important;
    }
    .secondary-btn:hover {
        background: rgba(124, 58, 237, 0.1) !important;
    }
    
    .font-black { font-weight: 900; }
    .tracking-wide { letter-spacing: 0.1em; }
</style>

@code {
    bool _chatOpen = false;
    bool _notificationsOpen = false;
    private UserDto? userProfile;
    private CelebrationOverlay celebrationOverlay = default!;
    private float _flowIntensity = 0f;
    private bool _levelUpTriggered = false;

    protected override async Task OnInitializedAsync() {
        await LayoutService.InitializeAsync();
        await Audio.Init(); // Ensure audio system is ready
        NotifService.OnNotificationsChanged += StateHasChanged;
        GameService.OnFlowStateChanged += HandleFlowStateChange; 
        LayoutService.OnMajorUpdate += StateHasChanged;
        LayoutService.OnAvatarChanged += HandleAvatarChanged; // Added
        LayoutService.OnBalanceUpdateSuppressionChanged += HandleSuppressionChanged;
        LayoutService.OnOptimisticDeduction += HandleOptimisticDeduction;
        
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;

        PlatformStats.StartPolling();
        PlatformStats.OnStatsUpdated += StateHasChanged;

        await CheckAuthenticationState();
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task) {
        await InvokeAsync(async () => {
            await CheckAuthenticationState();
            StateHasChanged();
        });
    }

    private async Task CheckAuthenticationState() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true) {
            await LoadProfile();
            
            try {
                if (!RealTime.IsConnected) {
                    var token = await LocalStorage.GetItemAsync<string>("authToken");
                    if (!string.IsNullOrEmpty(token)) {
                        await RealTime.StartAsync(token);
                        RealTime.OnBigWinReceived += HandleBigWin;
                        RealTime.OnGameUpdateReceived += HandleGameUpdate;
                        RealTime.OnBalanceUpdated += HandleBalanceUpdate;
                        RealTime.OnProgressionUpdated += HandleProgressionUpdate;
                    }
                }
            } catch (Exception ex) {
                Console.WriteLine($"SignalR Connection failed: {ex.Message}");
            }
        } else {
            userProfile = null;
            if (RealTime.IsConnected) {
                RealTime.OnBigWinReceived -= HandleBigWin;
                RealTime.OnGameUpdateReceived -= HandleGameUpdate;
                RealTime.OnBalanceUpdated -= HandleBalanceUpdate;
                RealTime.OnProgressionUpdated -= HandleProgressionUpdate;
                await RealTime.StopAsync();
            }
        }
    }

    public void Dispose()
    {
        NotifService.OnNotificationsChanged -= StateHasChanged;
        GameService.OnFlowStateChanged -= HandleFlowStateChange;
        LayoutService.OnMajorUpdate -= StateHasChanged;
        LayoutService.OnAvatarChanged -= HandleAvatarChanged; 
        LayoutService.OnBalanceUpdateSuppressionChanged -= HandleSuppressionChanged;
        LayoutService.OnOptimisticDeduction -= HandleOptimisticDeduction;
        PlatformStats.OnStatsUpdated -= StateHasChanged;
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        if (RealTime.IsConnected) {
            RealTime.OnProgressionUpdated -= HandleProgressionUpdate;
        }
    }

    private void HandleAvatarChanged(string newUrl) {
        if (userProfile != null) {
            userProfile.AvatarUrl = newUrl;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleOptimisticDeduction(decimal amount) {
        if (userProfile != null) {
            userProfile.Balance -= amount;
            InvokeAsync(StateHasChanged);
        }
    }

    private decimal? _pendingBalance;
    private decimal? _pendingBonusBalance;

    private void HandleSuppressionChanged(bool suppressed) {
        if (!suppressed && _pendingBalance.HasValue && userProfile != null) {
            userProfile.Balance = _pendingBalance.Value;
            userProfile.BonusBalance = _pendingBonusBalance ?? 0;
            _pendingBalance = null;
            _pendingBonusBalance = null;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleFlowStateChange(float intensity) {
        _flowIntensity = intensity;
        InvokeAsync(StateHasChanged);
        if (intensity > 0) {
            _ = Task.Delay(5000).ContinueWith(_ => {
                _flowIntensity = 0;
                InvokeAsync(StateHasChanged);
            });
        }
    }

    private void HandleBalanceUpdate(decimal balance, decimal bonusBalance) {
        if (userProfile != null) {
            if (LayoutService.IsBalanceUpdateSuppressed) {
                _pendingBalance = balance;
                _pendingBonusBalance = bonusBalance;
            } else {
                userProfile.Balance = balance;
                userProfile.BonusBalance = bonusBalance;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private void HandleProgressionUpdate(UserProgressionDto prog) {
        Console.WriteLine($"Progression Update Received: Level {prog.CurrentLevel}, XP {prog.CurrentXP}");
        if (userProfile != null) {
            bool isLevelUp = prog.CurrentLevel > (userProfile.Progression?.CurrentLevel ?? 0);
            userProfile.Progression = prog;
            
            if (isLevelUp) {
                _levelUpTriggered = true;
                InvokeAsync(StateHasChanged);
                _ = Task.Delay(3000).ContinueWith(_ => {
                    _levelUpTriggered = false;
                    InvokeAsync(StateHasChanged);
                });
            } else {
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private void HandleGameUpdate(object data) {
        var json = data.ToString();
        if (json != null) {
            if (json.Contains("AchievementUnlocked")) NotifService.Add("Achievement!", "You unlocked a new badge!", "Success");
            else if (json.Contains("LevelUp")) NotifService.Add("Level Up!", "Congratulations on your new rank!", "Info");
            else if (json.Contains("QuestCompleted")) {
                try {
                    using var doc = System.Text.Json.JsonDocument.Parse(json);
                    var title = doc.RootElement.GetProperty("Title").GetString();
                    var reward = doc.RootElement.GetProperty("Reward").GetDecimal();
                    NotifService.Add("Mission Complete!", $"{title} finished! Rewarded {reward:C}.", "Success");
                    Snackbar.Add($"Mission Accomplished: {title}!", Severity.Success);
                } catch {}
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleBigWin(BigWinEventArgs args) {
        celebrationOverlay.Show(args.Username, args.GameName, args.Amount, args.Multiplier);
        Snackbar.Add($"{args.Username} just won {args.Amount:C} ({args.Multiplier:F0}x)!", Severity.Success);
    }

    private async Task LoadProfile() {
        try { 
            userProfile = await AuthService.GetMe(); 
            if (userProfile != null && !string.IsNullOrEmpty(userProfile.PreferencesJson)) {
                LayoutService.SetSkinFromProfile(userProfile.PreferencesJson);
            }
        } catch { }
    }

    private string GetTierIcon(VipTier tier) => tier switch {
        VipTier.Diamond => Icons.Material.Filled.Diamond,
        VipTier.Platinum => Icons.Material.Filled.AutoAwesome,
        VipTier.Gold => Icons.Material.Filled.MilitaryTech,
        VipTier.Silver => Icons.Material.Filled.Stars,
        _ => Icons.Material.Filled.Person
    };

    private Color GetTierColor(VipTier tier) => tier switch {
        VipTier.Diamond => Color.Secondary, // Pinkish/Diamond
        VipTier.Platinum => Color.Info,      // Blue/Platinum
        VipTier.Gold => Color.Warning,       // Gold
        VipTier.Silver => Color.Default,     // Silver/Grey
        _ => Color.Default
    };

    void ToggleNotifications() => _notificationsOpen = !_notificationsOpen;

    private void OpenSettings() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        DialogService.ShowAsync<SettingsDialog>("Settings", options);
    }

    private async Task Logout() {
        await AuthService.Logout();
        Navigation.NavigateTo("/");
    }
}