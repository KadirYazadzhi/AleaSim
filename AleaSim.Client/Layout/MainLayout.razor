@inherits LayoutComponentBase
@using Blazored.LocalStorage
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@using AleaSim.Shared.Models
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject HttpClient Http
@inject RealTimeClient RealTime
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject NotificationService NotifService
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<CelebrationOverlay @ref="celebrationOverlay" />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">AleaSim Casino</MudText>
        <MudSpacer />
        
        <AuthorizeView>
            <Authorized>
                <div class="d-flex align-center gap-4">
                    <div class="d-none d-md-flex align-center mr-2">
                        <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" Color="Color.Error" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle2" Style="color: #ff4500; font-weight: bold;">@userProfile?.CurrentStreak d</MudText>
                    </div>

                    <!-- Settings -->
                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" OnClick="OpenSettings" />

                    <!-- Chat Toggle -->
                    <MudIconButton Icon="@Icons.Material.Filled.Chat" Color="Color.Inherit" OnClick="@((e) => ChatToggle())" />

                    <!-- Notifications -->
                    <MudBadge Content="@NotifService.UnreadCount" Color="Color.Error" Overlap="true" Visible="@(NotifService.UnreadCount > 0)">
                        <MudMenu Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                            <MudText Typo="Typo.subtitle2" Class="pa-4">Recent Activity</MudText>
                            <MudDivider />
                            @if (!NotifService.History.Any()) {
                                <MudText Typo="Typo.body2" Class="pa-4" Color="Color.Secondary">No notifications yet.</MudText>
                            }
                            @foreach (var item in NotifService.History.Take(5)) {
                                <MudMenuItem>
                                    <div style="max-width: 250px;">
                                        <MudText Typo="Typo.body2" Style="font-weight: bold;">@item.Title</MudText>
                                        <MudText Typo="Typo.caption" Class="d-block">@item.Message</MudText>
                                    </div>
                                </MudMenuItem>
                            }
                            <MudDivider />
                            <MudMenuItem OnClick="() => NotifService.MarkAllAsRead()">Mark all as read</MudMenuItem>
                        </MudMenu>
                    </MudBadge>

                    @if (userProfile != null) {
                        <MudChip T="string" Icon="@GetTierIcon(userProfile.Progression.Tier)" Color="@GetTierColor(userProfile.Progression.Tier)" Variant="Variant.Filled">
                            @userProfile.Progression.TierName (Lv. @userProfile.Progression.CurrentLevel)
                        </MudChip>
                        <MudText Typo="Typo.h6" Color="Color.Success">$@userProfile.Balance.ToString("N2")</MudText>
                    }
                    <MudMenu AnchorOrigin="Origin.BottomRight">
                        <ActivatorContent>
                            <MudAvatar Image="@userProfile?.AvatarUrl" Class="ml-2" />
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Href="/profile">Profile</MudMenuItem>
                            <MudMenuItem OnClick="Logout">Logout</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </div>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Color="Color.Inherit">Login</MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Secondary" Class="ml-2">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudDrawer @bind-Open="_chatOpen" Anchor="Anchor.End" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="@DrawerVariant.Persistent" Style="background: #111;">
        <ChatRoom />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _chatOpen = false;
    bool _isDarkMode = true;
    private UserProfileResponse? userProfile;
    private CelebrationOverlay celebrationOverlay = default!;

    private MudTheme _theme = new MudTheme() {
        PaletteDark = new PaletteDark() {
            Primary = "#ffD700",
            Secondary = "#4caf50",
            Background = "#0f0f0f",
            Surface = "#1a1a1a",
            AppbarBackground = "#1a1a1a",
            DrawerBackground = "#111",
            TextPrimary = "#ffffff"
        }
    };

    protected override async Task OnInitializedAsync() {
        NotifService.OnNotificationsChanged += StateHasChanged;
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true) {
            await LoadProfile();
            
            var token = await LocalStorage.GetItemAsync<string>("authToken");
            if (!string.IsNullOrEmpty(token)) {
                await RealTime.StartAsync(token);
                RealTime.OnBigWinReceived += HandleBigWin;
                RealTime.OnGameUpdateReceived += HandleGameUpdate;
                RealTime.OnBalanceUpdated += HandleBalanceUpdate;
            }
        }
    }

    private void HandleBalanceUpdate(decimal newBalance) {
        if (userProfile != null) {
            userProfile.Balance = newBalance;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleGameUpdate(object data) {
        var json = data.ToString();
        if (json != null) {
            if (json.Contains("AchievementUnlocked")) NotifService.Add("Achievement!", "You unlocked a new badge!", "Success");
            else if (json.Contains("LevelUp")) NotifService.Add("Level Up!", "Congratulations on your new rank!", "Info");
            else if (json.Contains("DailyBonus")) NotifService.Add("Bonus Received", "Daily reward added.", "Success");
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleBigWin(BigWinEventArgs args) {
        // Trigger Full Screen Celebration for ALL users
        celebrationOverlay.Show(args.Username, args.GameName, args.Amount, args.Multiplier);

        Snackbar.Add($"{args.Username} just won {args.Amount:C} ({args.Multiplier:F0}x) on {args.GameName}!", 
            Severity.Warning, config => {
                config.Icon = Icons.Material.Filled.EmojiEvents;
                config.VisibleStateDuration = 10000;
            });
    }

    private async Task LoadProfile() {
        try {
            userProfile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
        } catch { }
    }

    private string GetTierIcon(VipTier tier) => tier switch {
        VipTier.Diamond => Icons.Material.Filled.WorkspacePremium,
        VipTier.Platinum => Icons.Material.Filled.AutoAwesome,
        VipTier.Gold => Icons.Material.Filled.MilitaryTech,
        VipTier.Silver => Icons.Material.Filled.Stars,
        _ => Icons.Material.Filled.Stars
    };

    private Color GetTierColor(VipTier tier) => tier switch {
        VipTier.Diamond => Color.Secondary,
        VipTier.Platinum => Color.Info,
        VipTier.Gold => Color.Warning,
        VipTier.Silver => Color.Default,
        _ => Color.Dark
    };

    void DrawerToggle() => _drawerOpen = !_drawerOpen;
    void ChatToggle() => _chatOpen = !_chatOpen;

    private void OpenSettings() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        DialogService.ShowAsync<SettingsDialog>("Settings", options);
    }

    private async Task Logout() {
        RealTime.OnBigWinReceived -= HandleBigWin;
        RealTime.OnGameUpdateReceived -= HandleGameUpdate;
        RealTime.OnBalanceUpdated -= HandleBalanceUpdate;
        await AuthService.Logout();
        Navigation.NavigateTo("/");
    }
}