@page "/login"
@using AleaSim.Client.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="d-flex justify-center align-center" style="min-height: 80vh; position: relative;">
    <!-- Background Decor -->
    <div style="position: absolute; width: 600px; height: 600px; background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: -1;"></div>

    <div class="glass-panel pa-8 pa-md-12 rounded-xl" style="width: 100%; max-width: 480px; position: relative; z-index: 1;">
        <div class="text-center mb-8">
            <MudIcon Icon="@Icons.Material.Filled.Casino" Style="font-size: 4rem;" Color="Color.Primary" Class="mb-4 spin-hover" />
            <MudText Typo="Typo.h4" Class="text-gradient fw-black">WELCOME BACK</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary mt-2">Sign in to continue your winning streak.</MudText>
        </div>

        @if (!_show2FA)
        {
            <MudForm @bind-IsValid="@success" @bind-Errors="@errors">
                <MudTextField T="string" 
                              Label="Username" 
                              Variant="Variant.Outlined" 
                              Class="mb-4 glass-input"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Required="true" 
                              RequiredError="Username is required!" 
                              @bind-Value="model.Username" 
                              OnKeyDown="HandleEnter" />
                              
                <MudTextField T="string" 
                              Label="Password" 
                              Variant="Variant.Outlined" 
                              InputType="InputType.Password" 
                              Class="mb-6 glass-input"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Lock"
                              Required="true" 
                              RequiredError="Password is required!" 
                              @bind-Value="model.Password" 
                              OnKeyDown="HandleEnter" />

                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           FullWidth="true" 
                           Disabled="@(!success || _loading)" 
                           OnClick="OnLogin" 
                           Class="py-3 rounded-lg fw-black hover-scale pulse-neon"
                           Style="font-size: 1.1rem;">
                    @if (_loading) {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">LOGGING IN...</MudText>
                    } else {
                        <MudText>LOGIN</MudText>
                    }
                </MudButton>
            </MudForm>
        }
        else
        {
            <div class="pa-4 rounded-lg bg-dark-transparent mb-6 text-center border-1 border-solid border-primary">
                <MudIcon Icon="@Icons.Material.Filled.PhonelinkLock" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h6">2FA Verification</MudText>
                <MudText Typo="Typo.caption">Enter the 6-digit code from your app</MudText>
            </div>
            
            <MudTextField T="string" 
                          Label="Verification Code" 
                          Variant="Variant.Outlined" 
                          Class="mb-6 glass-input"
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Security"
                          Placeholder="123456"
                          @bind-Value="_2faCode" 
                          OnKeyDown="HandleEnter" />

            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       Size="Size.Large" 
                       FullWidth="true" 
                       Disabled="@(string.IsNullOrEmpty(_2faCode) || _loading)" 
                       OnClick="OnVerify2FA" 
                       Class="py-3 rounded-lg fw-black hover-scale pulse-neon"
                       Style="font-size: 1.1rem;">
                @if (_loading) {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">VERIFYING...</MudText>
                } else {
                    <MudText>VERIFY & LOGIN</MudText>
                }
            </MudButton>
            
            <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" Class="mt-2" OnClick="@(() => _show2FA = false)">Back to Login</MudButton>
        }

        <div class="text-center mt-6">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Don't have an account? 
                <MudLink Href="/register" Color="Color.Secondary" Underline="Underline.Hover" Class="fw-bold ml-1">Create Account</MudLink>
            </MudText>
            <div class="mt-4 opacity-30">
                <MudLink OnClick="NuclearReset" Style="font-size: 0.7rem; color: inherit; cursor: pointer;">Trouble logging in? Click here to Reset Session</MudLink>
            </div>
        </div>
    </div>
</div>

@code {
    LoginRequest model = new LoginRequest("", "");
    bool success;
    bool _loading = false;
    bool _show2FA = false;
    string _2faCode = "";
    string[] errors = { };

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Reason { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    protected override void OnInitialized() {
        if (Reason == "expired") {
            Snackbar.Add("Your session has expired. Please login again.", Severity.Info);
        }
    }

    private async Task HandleEnter(KeyboardEventArgs e) {
        if (e.Key == "Enter") {
            if (!_show2FA && success) await OnLogin();
            else if (_show2FA && !string.IsNullOrEmpty(_2faCode)) await OnVerify2FA();
        }
    }

    private async Task OnLogin() {
        if (_loading) return;
        _loading = true;
        try {
            var response = await AuthService.Login(model);
            
            if (response.RequiresTwoFactor) {
                _show2FA = true;
                Snackbar.Add("2FA Code Required", Severity.Info);
            } else {
                CompleteLogin(response);
            }
        }
        catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally {
            _loading = false;
        }
    }

    private async Task OnVerify2FA() {
        if (_loading) return;
        _loading = true;
        try {
            var response = await AuthService.Login2FA(new TwoFactorLoginRequest { 
                Username = model.Username, 
                Code = _2faCode 
            });
            CompleteLogin(response);
        }
        catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally {
            _loading = false;
        }
    }

    private void CompleteLogin(LoginResponse response) {
        Snackbar.Add("Login successful!", Severity.Success);
        
        if (!string.IsNullOrEmpty(ReturnUrl)) {
            Navigation.NavigateTo(ReturnUrl);
        }
        else if (response.Role == "Admin") {
            Navigation.NavigateTo("/dashboard");
        } else {
            Navigation.NavigateTo("/");
        }
    }

    private async Task NuclearReset() {
        await LocalStorage.ClearAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
