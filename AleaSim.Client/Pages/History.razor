@page "/history"
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@implements IDisposable
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject RealTimeClient RealTime
@inject IAuthService AuthService
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 pb-12">
    <div class="d-flex align-center gap-4 mb-8">
        <div class="history-header-icon">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Color="Color.Primary" />
        </div>
        <div>
            <MudText Typo="Typo.h3" Class="fw-black">Game History</MudText>
            <MudText Typo="Typo.subtitle1" Class="opacity-60">Review your past rounds and verify cryptographic outcomes.</MudText>
        </div>
    </div>

    <MudPaper Class="pa-8 rounded-xl" Elevation="2">
        <div class="d-flex justify-space-between align-center mb-6">
            <MudText Typo="Typo.h5" Class="fw-black">Recent Rounds</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadHistory" Size="Size.Small">Refresh</MudButton>
        </div>

        <MudTable Items="@rounds" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading" Elevation="0" Class="modern-table">
            <HeaderContent>
                <MudTh>DATE</MudTh>
                <MudTh>GAME</MudTh>
                <MudTh Style="text-align: right;">BET</MudTh>
                <MudTh Style="text-align: right;">WIN</MudTh>
                <MudTh>FAIRNESS (NONCE)</MudTh>
                <MudTh Style="text-align: center;">ACTIONS</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Date">
                    <MudText Typo="Typo.caption" Class="opacity-60">@context.PlayedAt.ToString("MMM dd, HH:mm:ss")</MudText>
                </MudTd>
                <MudTd DataLabel="Game">
                    <MudText Typo="Typo.body2" Class="fw-bold">@FormatGameName(context.GameName)</MudText>
                </MudTd>
                <MudTd DataLabel="Bet" Style="text-align: right;">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.BetAmount.ToString("C2")</MudText>
                </MudTd>
                <MudTd DataLabel="Win" Style="text-align: right;">
                    <MudText Typo="Typo.body1" Color="@(context.WinAmount > 0 ? Color.Success : Color.Default)" Class="fw-black">
                        @context.WinAmount.ToString("C2")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="PF">
                    <div class="d-flex align-center gap-2">
                        <MudTooltip Text="@context.ServerSeedHash">
                            <div class="hash-tag">
                                @(string.IsNullOrEmpty(context.ServerSeedHash) ? "N/A" : context.ServerSeedHash.Substring(0, 8))
                            </div>
                        </MudTooltip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="opacity-60">#@context.Nonce</MudChip>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small" Color="Color.Primary" OnClick="() => ViewDetails(context)" title="Inspect Data" />
                    <MudIconButton Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Color="Color.Info" Href='@($"/fairness?game={context.GameName}&nonce={context.Nonce}&clientSeed={context.ClientSeed}")' title="Verify Outcome" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

<style>
    .fw-black { font-weight: 950; }
    .fw-bold { font-weight: 700; }
    .opacity-60 { opacity: 0.6; }

    .history-header-icon {
        width: 64px; height: 64px; background: rgba(var(--mud-palette-primary-rgb), 0.1);
        border-radius: 16px; display: flex; align-items: center; justify-content: center;
    }

    .modern-table .mud-table-head .mud-th { font-weight: 900; letter-spacing: 1px; font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
    .modern-table .mud-table-body .mud-td { padding: 12px 16px; border-bottom: 1px solid var(--mud-palette-divider); }

    .hash-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; background: var(--mud-palette-background-grey); padding: 2px 8px; border-radius: 4px; border: 1px solid var(--mud-palette-divider); }
</style>

@code {
    private List<GameRoundDto> rounds = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() {
        await LoadHistory();
        RealTime.OnGameUpdateReceived += OnGameUpdate;
    }

    private void OnGameUpdate(object data) {
        if (data.ToString()?.Contains("FORCE_LOGOUT") == true) {
            _ = AuthService.Logout().ContinueWith(_ => Navigation.NavigateTo("/login?error=Banned"));
            return;
        }

        // Since we don't have the full GameRoundDto here from the generic game update, 
        // the most reliable way to maintain perfect history is to trigger a silent refresh.
        _ = InvokeAsync(async () => {
            await LoadHistory();
            StateHasChanged();
        });
    }

    public void Dispose() {
        RealTime.OnGameUpdateReceived -= OnGameUpdate;
    }

    private async Task LoadHistory() {
        isLoading = true;
        try {
            rounds = await Http.GetFromJsonAsync<List<GameRoundDto>>("api/Game/history") ?? new();
        } catch {
            Snackbar.Add("Failed to load history.", Severity.Error);
        } finally {
            isLoading = false;
        }
    }

    private string FormatGameName(string raw) => raw.ToLower() switch {
        "slot" => "Clover Chase",
        "fruitblast" => "Fruit Blast",
        "roulette" => "Roulette Royale",
        "blackjack" => "Blackjack",
        "baccarat" => "Baccarat",
        "dice" => "Neon Dice",
        _ => raw
    };

    private async Task ViewDetails(GameRoundDto round) {
        var parameters = new DialogParameters { ["Round"] = round };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        await DialogService.ShowAsync<AleaSim.Client.Components.RoundDetailsDialog>("Round JSON Details", parameters, options);
    }
}
