                <div>
                    <MudText Typo="Typo.h4" Style="font-weight: 900;" Class="text-white mb-1">Welcome, @context.User.Identity?.Name!</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary">Ready to challenge the odds today?</MudText>
                </div>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Secondary" 
                           StartIcon="@Icons.Material.Filled.Autorenew" 
                           OnClick="OpenBonusWheel"
                           Class="py-3 px-6 rounded-pill glow-on-hover"
                           Style="font-weight: 800; letter-spacing: 1px;">
