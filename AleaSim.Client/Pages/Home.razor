                                <MudCardContent>
                                    <div class="d-flex justify-space-between align-center mb-1">
                                        <MudText Typo="Typo.h5" Style="font-weight: 700;">Clover Chase</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Color="Color.Default" Size="Size.Small" />
                                    </div>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Hold & Win, Free Spins, and Lucky Nudges!</MudText>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/game/cloverchase" Style="font-weight: bold;">PLAY NOW</MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>

                        <!-- Game Card 2: Roulette -->
                        <MudItem xs="12" sm="6" lg="4">
                            <MudCard Class="game-showcase-card">
                                <MudCardMedia Image="https://images.unsplash.com/photo-1518893063934-f7142c22732b?auto=format&fit=crop&w=600&q=80" Height="220" />
                                <MudCardContent>
                                    <div class="d-flex justify-space-between align-center mb-1">
                                        <MudText Typo="Typo.h5" Style="font-weight: 700;">Roulette Royale</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Color="Color.Default" Size="Size.Small" />
                                    </div>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Classic European rules with high stakes.</MudText>
                                </MudCardContent>
                                <MudCardActions>
