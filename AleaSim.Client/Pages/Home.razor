@page "/"
@using AleaSim.Client.Components
@using AleaSim.Client.Services
@implements IDisposable
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject LayoutService LayoutService
@inject PlatformStatsService PlatformStats

<PageTitle>AleaSim | Premium Crypto Casino</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-4 pt-12">
            <!-- Header & Daily Bonus -->
            <div class="d-flex justify-space-between align-center mb-8 animate-fade-in">
                <div>
                    <MudText Typo="Typo.h4" Style="font-weight: 900;" Color="Color.Inherit" Class="mb-1">Welcome, @context.User.Identity?.Name!</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">Ready to challenge the odds today?</MudText>
                </div>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Secondary" 
                           StartIcon="@Icons.Material.Filled.Autorenew" 
                           OnClick="OpenBonusWheel"
                           Class="py-3 px-6 rounded-pill glow-on-hover"
                           Style="font-weight: 800; letter-spacing: 1px;">
                    DAILY SPIN
                </MudButton>
            </div>

            <MudGrid>
                <!-- Main Content Area -->
                <MudItem xs="12" md="8" lg="9">
                    
                    <!-- Hero/Tournament Banner -->
                    <div class='@($"{(LayoutService.IsDarkMode ? "tournament-banner" : "tournament-banner light-banner")} mb-10 p-relative overflow-hidden rounded-xl shadow-md animate-slide-up")'>
                        <div class="banner-content d-flex justify-space-between align-center flex-wrap gap-6 pa-8" style="position: relative; z-index: 2;">
                            <div style="max-width: 600px;">
                                <div class="d-flex align-center gap-2 mb-2">
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="fw-bold pulse-red">LIVE</MudChip>
                                    <MudText Typo="Typo.subtitle2" Class="text-warning fw-bold tracking-wide">SEASON 4</MudText>
                                </div>
                                <MudText Typo="Typo.h3" Class='@($"{(LayoutService.IsDarkMode ? "text-white text-shadow-lg" : "mud-text-primary")} fw-black mb-2")'>GRAND TOURNAMENT</MudText>
                                <MudText Typo="Typo.h4" Color="Color.Success" Class="fw-black mb-4">@PlatformStats.Stats.TournamentPrizePool.ToString("C2") <span class='@($"{(LayoutService.IsDarkMode ? "text-white opacity-70" : "mud-text-secondary")} text-sm fw-normal")'>Prize Pool</span></MudText>
                                
                                <div class="d-flex align-center gap-6">
                                    <div class="timer-badge glass-panel px-3 py-1 rounded">
                                        <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" Class="text-warning mr-2" />
                                        <span class='@($"{(LayoutService.IsDarkMode ? "text-white" : "mud-text-primary")} fw-bold")'>@GetTimeLeft(PlatformStats.Stats.TournamentEndsAt)</span>
                                    </div>
                                    <MudAvatarGroup Max="3" Spacing="2" MaxColor="Color.Primary">
                                        <MudAvatar Image="https://i.pravatar.cc/150?u=1" />
                                        <MudAvatar Image="https://i.pravatar.cc/150?u=2" />
                                        <MudAvatar Image="https://i.pravatar.cc/150?u=3" />
                                        <MudAvatar Color="Color.Dark">+2k</MudAvatar>
                                    </MudAvatarGroup>
                                </div>
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/leaderboard" Class="px-8 py-4 rounded-lg fw-black hover-scale">ENTER ARENA</MudButton>
                        </div>
                        <!-- Decorative Background Elements -->
                        <div class="banner-bg-overlay"></div>
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="banner-icon-bg" />
                    </div>

                    <!-- Game Categories -->
                    <div class="d-flex align-center gap-4 mb-6 overflow-x-auto pb-2 hide-scrollbar">
                        <MudButton Variant="@(selectedCategory == "Lobby" ? Variant.Filled : Variant.Text)" 
                                   Color="@(selectedCategory == "Lobby" ? Color.Primary : Color.Inherit)" 
                                   Class='@($"rounded-pill px-6 fw-bold {(selectedCategory == "Lobby" ? "" : "mud-text-secondary")}")'
                                   OnClick='() => SelectCategory("Lobby")'>Lobby</MudButton>
                        <MudButton Variant="@(selectedCategory == "Slots" ? Variant.Filled : Variant.Text)" 
                                   Color="@(selectedCategory == "Slots" ? Color.Primary : Color.Inherit)" 
                                   Class='@($"rounded-pill px-6 fw-bold {(selectedCategory == "Slots" ? "" : "mud-text-secondary")}")'
                                   OnClick='() => SelectCategory("Slots")'>Slots</MudButton>
                        <MudButton Variant="@(selectedCategory == "Live" ? Variant.Filled : Variant.Text)" 
                                   Color="@(selectedCategory == "Live" ? Color.Primary : Color.Inherit)" 
                                   Class='@($"rounded-pill px-6 fw-bold {(selectedCategory == "Live" ? "" : "mud-text-secondary")}")'
                                   OnClick='() => SelectCategory("Live")'>Live Casino</MudButton>
                        <MudButton Variant="@(selectedCategory == "Table" ? Variant.Filled : Variant.Text)" 
                                   Color="@(selectedCategory == "Table" ? Color.Primary : Color.Inherit)" 
                                   Class='@($"rounded-pill px-6 fw-bold {(selectedCategory == "Table" ? "" : "mud-text-secondary")}")'
                                   OnClick='() => SelectCategory("Table")'>Table Games</MudButton>
                        <MudSpacer />
                        <MudTextField @ref="searchField"
                                     @bind-Value="SearchTerm" 
                                     Placeholder="Search games..." 
                                     Variant="Variant.Outlined" 
                                     Margin="Margin.Dense" 
                                     Adornment="Adornment.Start" 
                                     AdornmentIcon="@Icons.Material.Filled.Search" 
                                     OnAdornmentClick="FocusSearch"
                                     Class="rounded-pill glass-input" 
                                     Style="max-width: 250px;" 
                                     Immediate="true" />
                    </div>

                    <!-- Games Grid -->
                    @if (!FilteredGames.Any())
                    {
                        <div class="d-flex flex-column align-center justify-center pa-12 glass-panel rounded-xl animate-fade-in">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mb-4 opacity-50" Style="font-size: 5rem;" />
                            <MudText Typo="Typo.h5" Class="mud-text-secondary fw-bold">No Games Found</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">Try adjusting your search or category.</MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-4" OnClick="ResetFilters">Reset Filters</MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="games-grid">
                            @foreach (var game in FilteredGames)
                            {
                                <a href="@game.Href" class="game-card">
                                    <div class="game-card-inner">
                                        <img src="@game.ImageUrl" alt="@game.Title" class="game-img" />
                                        <div class="game-overlay">
                                            <div class="play-btn-wrapper">
                                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Large" />
                                            </div>
                                            <div class="game-info">
                                                <span class="game-title">@game.Title</span>
                                                <span class="game-provider">@game.Provider</span>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(game.Badge))
                                        {
                                            <div class='@($"game-badge {game.Badge.ToLower()}")'>@game.Badge</div>
                                        }
                                        @if (game.Rtp > 0)
                                        {
                                            <div class="rtp-badge">@game.Rtp.ToString("F1")% RTP</div>
                                        }
                                    </div>
                                </a>
                            }
                        </div>
                    }

                    <!-- Stats Section -->
                    <div class="mt-12 mb-8 animate-fade-in" style="animation-delay: 0.3s;">
                        <MudText Typo="Typo.h5" Class="fw-black mb-4" Color="Color.Inherit">LIVE PLATFORM STATS</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="4">
                                <div class="glass-panel pa-6 rounded-xl text-center hover-scale">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                                    <MudText Typo="Typo.h4" Class="text-gradient fw-black">@PlatformStats.Stats.ActivePlayers.ToString("N0")</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Active Players</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <div class="glass-panel pa-6 rounded-xl text-center hover-scale">
                                    <MudIcon Icon="@Icons.Material.Filled.Percent" Color="Color.Secondary" Size="Size.Large" Class="mb-2" />
                                    <MudText Typo="Typo.h4" Class="text-gradient fw-black">@PlatformStats.Stats.AverageRtp.ToString("F1")%</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Average RTP</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <div class="glass-panel pa-6 rounded-xl text-center hover-scale">
                                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Size="Size.Large" Class="mb-2" />
                                    <MudText Typo="Typo.h4" Class="text-gradient fw-black">@PlatformStats.Stats.TotalRewardsPaid.ToString("C0")+</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Rewards Paid</MudText>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <!-- About Us / The Brain -->
                    <div class="glass-panel pa-8 rounded-xl mb-12 d-flex align-center gap-8 animate-fade-in" style="animation-delay: 0.4s;">
                        <div class="d-none d-md-block">
                            <MudIcon Icon="@Icons.Material.Filled.Psychology" Style="font-size: 8rem; color: rgba(124, 58, 237, 0.2);" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h4" Class="fw-black mb-2" Color="Color.Inherit">POWERED BY <span class="text-gradient">THE BRAIN</span></MudText>
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4" Style="line-height: 1.6;">
                                AleaSim isn't just a casino; it's an intelligent gaming platform. Our proprietary AI engine adapts to your playstyle, 
                                ensuring fair odds and dynamic challenges that keep you in the flow state.
                            </MudText>
                            <div class="d-flex gap-4">
                                <div class="d-flex align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                    <span>Provably Fair</span>
                                </div>
                                <div class="d-flex align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                    <span>Instant Payouts</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Testimonials -->
                    <div class="mb-12 animate-fade-in" style="animation-delay: 0.5s;">
                        <MudText Typo="Typo.h5" Class="fw-black mb-4" Color="Color.Inherit">PLAYER FEEDBACK</MudText>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <div class="glass-panel pa-6 rounded-xl h-100">
                                    <div class="d-flex align-center mb-4">
                                        <MudAvatar Color="Color.Primary" Size="Size.Medium" Class="mr-3">A</MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.subtitle2" Class="fw-bold" Color="Color.Inherit">Alex_W</MudText>
                                            <MudRating ReadOnly="true" SelectedValue="5" Size="Size.Small" />
                                        </div>
                                    </div>
                                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="font-style: italic;">"The withdrawal speed is insane. I hit a jackpot on Clover Chase and had the funds in my wallet in seconds. Absolutely unmatched."</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <div class="glass-panel pa-6 rounded-xl h-100">
                                    <div class="d-flex align-center mb-4">
                                        <MudAvatar Color="Color.Secondary" Size="Size.Large" Class="mr-4">K</MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.h6" Class="fw-bold" Color="Color.Inherit">CryptoKing</MudText>
                                            <MudRating ReadOnly="true" SelectedValue="5" Size="Size.Small" />
                                        </div>
                                    </div>
                                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="font-style: italic;">"Finally, a casino that feels fair. The stats dashboard lets me verify everything. Totally transparent and the community is great."</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <div class="glass-panel pa-6 rounded-xl h-100">
                                    <div class="d-flex align-center mb-4">
                                        <MudAvatar Color="Color.Warning" Size="Size.Large" Class="mr-4">S</MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.h6" Class="fw-bold" Color="Color.Inherit">SarahJ</MudText>
                                            <MudRating ReadOnly="true" SelectedValue="4" Size="Size.Small" />
                                        </div>
                                    </div>
                                    <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="font-style: italic;">"Love the daily missions. It adds a whole new layer to the slot games. Can't wait for the new RPG features to drop!"</MudText>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudItem>

                <!-- Sidebar Area -->
                <MudItem xs="12" md="4" lg="3">
                    <MudStack Spacing="4">
                        <!-- Jackpot Widget -->
                        <div class="glass-panel rounded-xl pa-1 overflow-hidden animate-fade-in">
                            <MultiJackpotWidget />
                        </div>
                        
                        <!-- Leaderboard Widget -->
                        <div class="glass-panel rounded-xl overflow-hidden animate-fade-in" style="animation-delay: 0.1s;">
                            <div class="pa-4 border-b border-solid var(--mud-palette-divider) d-flex justify-space-between align-center">
                                <span class="fw-bold mud-text-primary"><MudIcon Icon="@Icons.Material.Filled.Leaderboard" Size="Size.Small" Class="mr-2 text-primary" />Top Players</span>
                                <MudLink Href="/leaderboard" Class="text-xs">View All</MudLink>
                            </div>
                            <LeaderboardWidget />
                        </div>

                        <!-- Live Feed Widget -->
                        <div class="glass-panel rounded-xl overflow-hidden animate-fade-in" style="animation-delay: 0.2s;">
                             <div class="pa-4 border-b border-solid var(--mud-palette-divider)">
                                <span class="fw-bold mud-text-primary"><MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-2 text-success" />Live Wins</span>
                            </div>
                            <LiveWinnersFeed />
                        </div>
                        
                        <!-- Cashback Promo -->
                        <MudPaper Class="pa-6 rounded-xl gradient-bg-blue position-relative overflow-hidden elevation-10" Elevation="0">
                            <div style="position: relative; z-index: 2;">
                                <MudText Typo="Typo.subtitle2" Class="text-white opacity-80 mb-1">Weekly Benefit</MudText>
                                <MudText Typo="Typo.h5" Class="text-white fw-black mb-3">10% CASHBACK</MudText>
                                <MudButton Variant="Variant.Outlined" Color="Color.Surface" Size="Size.Small" Class="rounded-lg border-2 fw-bold">CLAIM NOW</MudButton>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Savings" Style="position: absolute; right: -20px; bottom: -20px; font-size: 8rem; opacity: 0.1; color: white;" />
                        </MudPaper>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </Authorized>
    
    <NotAuthorized>
        <!-- Hero Section -->
        <div class="@(LayoutService.IsDarkMode ? "hero-section" : "hero-section light-hero")">
            <MudContainer MaxWidth="MaxWidth.Large" Class="h-100 d-flex flex-column align-center justify-center text-center position-relative" Style="z-index: 10;">
                <div class="hero-content animate-slide-up">
                    <MudText Typo="Typo.h1" Class="hero-title mb-4">ALEASIM</MudText>
                    <MudText Typo="Typo.h4" Class="hero-subtitle mb-10">The Future of Fair Gaming</MudText>
                    
                    <div class="d-flex gap-4 justify-center">
                        <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="hero-btn-primary pulse-neon">
                            START PLAYING
                        </MudButton>
                        <MudButton Href="/fairness" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Large" Class="hero-btn-secondary">
                            HOW IT WORKS
                        </MudButton>
                    </div>

                    <div class="mt-16 d-flex justify-center gap-12 hero-stats">
                         <div class="stat-item">
                             <span class="stat-value text-gradient-gold">@((2400000m).ToString("C0"))+</span>
                             <span class="stat-label">Paid Out</span>
                         </div>
                         <div class="stat-item">
                             <span class="stat-value text-gradient-purple">150K+</span>
                             <span class="stat-label">Players</span>
                         </div>
                         <div class="stat-item">
                             <span class="stat-value text-success">100%</span>
                             <span class="stat-label">Verified Fair</span>
                         </div>
                    </div>
                </div>
            </MudContainer>
            <div class="hero-bg-overlay"></div>
            <video autoplay muted loop playsinline class="hero-video-bg">
                <!-- Fallback to image/gradient if no video source -->
                <source src="" type="video/mp4">
            </video>
        </div>

        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-n16 position-relative z-20 pb-16">
            <!-- Features Grid -->
            <div style="margin-bottom: 100px;">
                <MudGrid Spacing="6">
                    <MudItem xs="12" md="4">
                        <div class="feature-card glass-panel pa-8 rounded-xl h-100 hover-scale">
                            <div class="icon-box bg-primary-transparent mb-6">
                                <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h5" Class="fw-bold mb-4" Color="Color.Inherit">Provably Fair</MudText>
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">
                                Cryptographic verification for every single spin. You don't have to trust us—verify it yourself on the blockchain.
                            </MudText>
                        </div>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <div class="feature-card glass-panel pa-8 rounded-xl h-100 hover-scale">
                            <div class="icon-box bg-secondary-transparent mb-6">
                                <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Secondary" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h5" Class="fw-bold mb-4" Color="Color.Inherit">Instant Withdrawals</MudText>
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">
                                Our automated vault system processes payouts in milliseconds. Your winnings are yours, instantly.
                            </MudText>
                        </div>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <div class="feature-card glass-panel pa-8 rounded-xl h-100 hover-scale">
                            <div class="icon-box bg-info-transparent mb-6">
                                <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Info" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h5" Class="fw-bold mb-4" Color="Color.Inherit">AI "Brain" Engine</MudText>
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">
                                AleaSim adapts to your playstyle, offering dynamic missions and difficulty adjustments to keep you in the flow.
                            </MudText>
                        </div>
                    </MudItem>
                </MudGrid>
            </div>

            <!-- About Us / The Brain -->
            <div class="glass-panel pa-12 rounded-xl d-flex align-center gap-12 animate-fade-in" style="margin-bottom: 100px;">
                <div class="d-none d-md-block">
                    <MudIcon Icon="@Icons.Material.Filled.Psychology" Style="font-size: 12rem; color: rgba(124, 58, 237, 0.2);" />
                </div>
                <div>
                    <MudText Typo="Typo.h3" Class="fw-black mb-4" Color="Color.Inherit">POWERED BY <span class="text-gradient">THE BRAIN</span></MudText>
                    <MudText Typo="Typo.h6" Class="mud-text-secondary mb-6" Style="line-height: 1.6; font-weight: 400;">
                        AleaSim isn't just a casino; it's an intelligent gaming platform. Our proprietary AI engine adapts to your playstyle, 
                        ensuring fair odds and dynamic challenges that keep you in the flow state.
                    </MudText>
                    <div class="d-flex gap-8">
                        <div class="d-flex align-center mud-text-secondary">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" Class="mr-3" />
                            <MudText Typo="Typo.body1" Class="fw-bold">Provably Fair</MudText>
                        </div>
                        <div class="d-flex align-center mud-text-secondary">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" Class="mr-3" />
                            <MudText Typo="Typo.body1" Class="fw-bold">Instant Payouts</MudText>
                        </div>
                        <div class="d-flex align-center mud-text-secondary">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" Class="mr-3" />
                            <MudText Typo="Typo.body1" Class="fw-bold">Dynamic RTP</MudText>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="animate-fade-in" style="margin-bottom: 100px;">
                <MudText Typo="Typo.h3" Class="fw-black mb-12 text-center" Color="Color.Inherit">LIVE PLATFORM STATS</MudText>
                <MudGrid Justify="Justify.Center" Spacing="6">
                    <MudItem xs="12" sm="4">
                        <div class="glass-panel pa-8 rounded-xl text-center hover-scale">
                            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Style="font-size: 4rem;" Class="mb-4" />
                            <MudText Typo="Typo.h2" Class="text-gradient fw-black mb-2">150K+</MudText>
                            <MudText Typo="Typo.h6" Class="mud-text-secondary">Registered Players</MudText>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <div class="glass-panel pa-8 rounded-xl text-center hover-scale">
                            <MudIcon Icon="@Icons.Material.Filled.Percent" Color="Color.Secondary" Style="font-size: 4rem;" Class="mb-4" />
                            <MudText Typo="Typo.h2" Class="text-gradient fw-black mb-2">98.4%</MudText>
                            <MudText Typo="Typo.h6" Class="mud-text-secondary">Average Return to Player</MudText>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <div class="glass-panel pa-8 rounded-xl text-center hover-scale">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Style="font-size: 4rem;" Class="mb-4" />
                            <MudText Typo="Typo.h2" Class="text-gradient fw-black mb-2">@((4200000m).ToString("C0"))+</MudText>
                            <MudText Typo="Typo.h6" Class="mud-text-secondary">Total Winnings Paid</MudText>
                        </div>
                    </MudItem>
                </MudGrid>
            </div>

            <!-- CTA -->
            <MudPaper Class="pa-16 rounded-xxl text-center position-relative overflow-hidden shadow-2xl" Style="background: linear-gradient(135deg, #4f46e5 0%, #9333ea 100%); margin-bottom: 100px;">
                <div style="position: relative; z-index: 2;">
                    <MudText Typo="Typo.h3" Class="fw-black text-white mb-6">READY TO WIN BIG?</MudText>
                    <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Large" Class="px-16 py-5 rounded-xl fw-black shadow-lg hover-scale pulse-neon" Style="font-size: 1.4rem;">CREATE FREE ACCOUNT</MudButton>
                    <MudText Typo="Typo.body2" Class="mt-6 text-white opacity-80 fw-bold">NO DEPOSIT REQUIRED • INSTANT SETUP</MudText>
                </div>
