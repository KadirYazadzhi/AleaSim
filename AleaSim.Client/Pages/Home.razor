                                            <MudRating ReadOnly="true" SelectedValue="5" Size="Size.Small" />
                                        </div>
                                    </div>
                                    <MudText Typo="Typo.body2" Class="text-gray-400">"Finally, a casino that feels fair. The stats dashboard lets me verify everything. Totally transparent."</MudText>
                                </div>
                            </MudItem>
