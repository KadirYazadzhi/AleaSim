@code {
    private string selectedCategory = "Lobby";
    private string _searchTerm = "";
    private MudTextField<string>? searchField;

    public string SearchTerm {
        get => _searchTerm;
        set {
            if (_searchTerm != value) {
                _searchTerm = value;
                StateHasChanged();
            }
        }
    }

    private List<GameItem> allGames = new() {
        new GameItem("Clover Chase", "AleaSim Originals", "Slots", "https://images.unsplash.com/photo-1596838132731-3301c3fd4317?auto=format&fit=crop&w=600&q=80", "/game/cloverchase", "HOT", 98.5),
        new GameItem("Roulette Royale", "Table Games", "Table", "https://images.unsplash.com/photo-1518893063934-f7142c22732b?auto=format&fit=crop&w=600&q=80", "/game/roulette", "", 97.3),
        new GameItem("Blackjack", "Card Games", "Table", "https://images.unsplash.com/photo-1511193311914-0346f16efe90?auto=format&fit=crop&w=600&q=80", "/game/blackjack", "NEW", 99.2),
        new GameItem("Crazy Dice", "AleaSim Originals", "Slots", "https://images.unsplash.com/photo-1518133835878-5a93cc3f89e5?auto=format&fit=crop&w=600&q=80", "/game/cloverchase", "", 96.5),
        new GameItem("Baccarat", "Live Casino", "Live", "https://images.unsplash.com/photo-1596838132731-3301c3fd4317?auto=format&fit=crop&w=600&q=80", "/register", "LIVE", 98.9)
    };

    private IEnumerable<GameItem> FilteredGames => allGames
        .Where(g => (selectedCategory == "Lobby" || g.Category == selectedCategory))
        .Where(g => string.IsNullOrWhiteSpace(SearchTerm) || g.Title.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || g.Provider.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        LayoutService.OnMajorUpdate += StateHasChanged;
        PlatformStats.OnStatsUpdated += StateHasChanged;
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true) {
            try {
                var response = await Http.PostAsync("api/Game/streak/claim", null);
                if (response.IsSuccessStatusCode) {
                    var res = await response.Content.ReadFromJsonAsync<StreakResult>();
                    if(res != null && res.Amount > 0)
                        Snackbar.Add(res?.Message ?? "Daily bonus claimed!", Severity.Success);
                }
            } catch { }
        }
    }

    private void SelectCategory(string category) {
        selectedCategory = category;
        StateHasChanged();
    }

    private void ResetFilters() {
        selectedCategory = "Lobby";
        SearchTerm = "";
        StateHasChanged();
    }

    private async Task FocusSearch() {
        if (searchField != null) {
            await searchField.FocusAsync();
        }
    }

    private string GetTimeLeft(DateTime endsAt) {
        if (endsAt == default) return "LOADING...";
        var diff = endsAt - DateTime.UtcNow;
        if (diff.Ticks <= 0) return "FINISHED";
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays}d {diff.Hours}h {diff.Minutes}m";
        return $"{diff.Hours}h {diff.Minutes}m {diff.Seconds}s";
    }
    
    public void Dispose()
    {
        LayoutService.OnMajorUpdate -= StateHasChanged;
        PlatformStats.OnStatsUpdated -= StateHasChanged;
    }

    private async Task OpenBonusWheel() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<BonusWheel>("Daily Luck Wheel", options);
    }

    public class StreakResult { public int Streak { get; set; } public decimal Amount { get; set; } public string Message { get; set; } = ""; }
    public class GameItem {
        public string Title { get; set; }
        public string Provider { get; set; }
        public string Category { get; set; }
        public string ImageUrl { get; set; }
        public string Href { get; set; }
        public string Badge { get; set; }
        public double Rtp { get; set; }

        public GameItem(string title, string provider, string category, string imageUrl, string href, string badge, double rtp) {
            Title = title; Provider = provider; Category = category; ImageUrl = imageUrl; Href = href; Badge = badge; Rtp = rtp;
        }
    }
}