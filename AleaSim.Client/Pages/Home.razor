@page "/"
@using AleaSim.Client.Components
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>AleaSim Casino</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h4">Welcome back, @context.User.Identity?.Name!</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.RotateRight" OnClick="OpenBonusWheel">Claim Daily Spin</MudButton>
            </div>

            <MudGrid>
                <!-- Main Lobby Content -->
                <MudItem xs="12" md="8" lg="9">
                    <!-- Tournament Banner -->
                    <MudPaper Class="pa-6 mb-6" Style="background: linear-gradient(90deg, #6a11cb 0%, #2575fc 100%); color: white; border-radius: 15px;">
                        <div class="d-flex justify-space-between align-center">
                            <div>
                                <MudText Typo="Typo.h4" Style="font-weight: 900;">MONTHLY GRAND TOURNAMENT</MudText>
                                <MudText Typo="Typo.h6">Current Prize Pool: <span style="color: #ffD700; font-weight: bold;">$20,000.00</span></MudText>
                                <MudText Typo="Typo.body1" Class="mt-2">Ends in: <b>14 Days, 05:22:10</b></MudText>
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Large" Href="/leaderboard">View Rankings</MudButton>
                        </div>
                    </MudPaper>

                    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4">Explore Games</MudText>
                    
                    <MudGrid>
                        <!-- Game Card 1: Clover Chase -->
                        <MudItem xs="12" sm="6" lg="4">
                            <MudCard Class="hover-card">
                                <MudCardMedia Image="https://images.unsplash.com/photo-1596838132731-3301c3fd4317?auto=format&fit=crop&w=600&q=80" Height="200" />
                                <MudCardContent>
                                    <MudText Typo="Typo.h5">Clover Chase</MudText>
                                    <MudText Typo="Typo.body2">Hold & Win, Free Spins, and Lucky Nudges!</MudText>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/game/cloverchase">Play Now</MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>

                        <!-- Game Card 2: Roulette -->
                        <MudItem xs="12" sm="6" lg="4">
                            <MudCard Class="hover-card">
                                <MudCardMedia Image="https://images.unsplash.com/photo-1518893063934-f7142c22732b?auto=format&fit=crop&w=600&q=80" Height="200" />
                                <MudCardContent>
                                    <MudText Typo="Typo.h5">Roulette Royale</MudText>
                                    <MudText Typo="Typo.body2">Classic European rules with high stakes.</MudText>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Href="/game/roulette">Play Now</MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>

                        <!-- Game Card 3: Blackjack -->
                        <MudItem xs="12" sm="6" lg="4">
                            <MudCard Class="hover-card">
                                <MudCardMedia Image="https://images.unsplash.com/photo-1511193311914-0346f16efe90?auto=format&fit=crop&w=600&q=80" Height="200" />
                                <MudCardContent>
                                    <MudText Typo="Typo.h5">Blackjack Royale</MudText>
                                    <MudText Typo="Typo.body2">Classic 21 with strategic Hit or Stand choices.</MudText>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Href="/game/blackjack">Play Now</MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <!-- Sidebar Content -->
                <MudItem xs="12" md="4" lg="3">
                    <MudStack Spacing="4">
                        <JackpotTicker Title="GLOBAL" CurrentValue="12450.23m" MustDropAt="15000m" ProgressPercentage="83" />
                        
                        <LeaderboardWidget />

                        <LiveWinnersFeed />
                        
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">Your Activity</MudText>
                            <MudAlert Severity="Severity.Info" Class="mt-2" Dense="true">10% Cashback Active</MudAlert>
                            <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/history" Class="mt-2" Size="Size.Small">View History</MudButton>
                        </MudPaper>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
            <MudCarousel Class="mud-width-full" Style="height:400px; border-radius: 12px; overflow:hidden;" ShowArrows="true" ShowBullets="true" AutoCycle="true" TData="object">
                <MudCarouselItem Transition="Transition.Slide" Color="@Color.Dark">
                    <div class="d-flex flex-column align-center justify-center h-100" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1596838132731-3301c3fd4317?auto=format&fit=crop&w=1200&q=80'); background-size: cover;">
                        <MudText Typo="Typo.h2" Style="font-weight: 900; color: white;">CLOVER CHASE</MudText>
                        <MudText Typo="Typo.h5" Class="mb-4" Style="color: #eee;">Experience the luck of the Irish with our AI-driven slots!</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/register">Play Now</MudButton>
                    </div>
                </MudCarouselItem>
                <MudCarouselItem Transition="Transition.Slide" Color="@Color.Primary">
                    <div class="d-flex flex-column align-center justify-center h-100" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1518893063934-f7142c22732b?auto=format&fit=crop&w=1200&q=80'); background-size: cover;">
                        <MudText Typo="Typo.h2" Style="font-weight: 900; color: white;">NEW RPG LEVELS</MudText>
                        <MudText Typo="Typo.h5" Class="mb-4" Style="color: #eee;">Level up your account and unlock permanent perks!</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" Href="/login">Join the Club</MudButton>
                    </div>
                </MudCarouselItem>
            </MudCarousel>

            <MudGrid Class="mt-12 mb-16" Justify="Justify.Center">
                <MudItem xs="12" md="4" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">AI Engine</MudText>
                    <MudText Typo="Typo.body2">Our "Brain" adapts to your playstyle for maximum engagement.</MudText>
                </MudItem>
                <MudItem xs="12" md="4" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6">Fast Payouts</MudText>
                    <MudText Typo="Typo.body2">Instant cashout options and secure financial vault.</MudText>
                </MudItem>
                <MudItem xs="12" md="4" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Large" Color="Color.Warning" />
                    <MudText Typo="Typo.h6">Big Jackpots</MudText>
                    <MudText Typo="Typo.body2">Global progressive jackpots that must drop daily!</MudText>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true) {
            try {
                var response = await Http.PostAsync("api/Game/streak/claim", null);
                if (response.IsSuccessStatusCode) {
                    var res = await response.Content.ReadFromJsonAsync<StreakResult>();
                    Snackbar.Add(res?.Message ?? "Daily bonus claimed!", Severity.Success);
                }
            } catch { }
        }
    }

    private async Task OpenBonusWheel() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        await DialogService.ShowAsync<BonusWheel>("Daily Luck Wheel", options);
    }

    public class StreakResult { public int Streak { get; set; } public decimal Amount { get; set; } public string Message { get; set; } = ""; }
}