                        <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="rounded-pill px-6 text-gray-400">Live Casino</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="rounded-pill px-6 text-gray-400">Table Games</MudButton>
