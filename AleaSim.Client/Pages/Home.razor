@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true) {
            try {
                var response = await Http.PostAsync("api/Game/streak/claim", null);
                if (response.IsSuccessStatusCode) {
                    var res = await response.Content.ReadFromJsonAsync<StreakResult>();
                    Snackbar.Add(res?.Message ?? "Daily bonus claimed!", Severity.Success);
                }
            } catch { }
        }
    }

    private async Task OpenBonusWheel() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        await DialogService.ShowAsync<BonusWheel>("Daily Luck Wheel", options);
    }

    public class StreakResult { public int Streak { get; set; } public decimal Amount { get; set; } public string Message { get; set; } = ""; }
}