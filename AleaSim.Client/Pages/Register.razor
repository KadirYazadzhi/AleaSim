@page "/register"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<div class="d-flex justify-center align-center" style="min-height: 80vh; position: relative;">
    <!-- Background Decor -->
    <div style="position: absolute; width: 600px; height: 600px; background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: -1;"></div>

    <div class="glass-panel pa-8 pa-md-12 rounded-xl" style="width: 100%; max-width: 480px; position: relative; z-index: 1;">
        <div class="text-center mb-8">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="font-size: 4rem;" Color="Color.Secondary" Class="mb-4 spin-hover" />
            <MudText Typo="Typo.h4" Class="text-gradient fw-black">JOIN THE CLUB</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary mt-2">Create your account and claim your welcome bonus.</MudText>
        </div>

        <MudForm @bind-IsValid="@success">
            <MudTextField T="string" 
                          Label="Username" 
                          Variant="Variant.Outlined" 
                          Class="mb-4 glass-input"
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Required="true" 
                          @bind-Value="model.Username"
                          OnKeyDown="HandleEnter" />
                          
            <MudTextField T="string" 
                          Label="Email" 
                          Variant="Variant.Outlined" 
                          InputType="InputType.Email" 
                          Class="mb-4 glass-input"
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          Required="true" 
                          @bind-Value="model.Email"
                          OnKeyDown="HandleEnter" />
                          
            <MudTextField T="string" 
                          Label="Password" 
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password" 
                          Class="mb-6 glass-input"
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          Required="true" 
                          @bind-Value="model.Password"
                          OnKeyDown="HandleEnter" />

            <MudButton Variant="Variant.Filled" 
                       Color="Color.Secondary" 
                       Size="Size.Large" 
                       FullWidth="true" 
                       Disabled="@(!success || _loading)" 
                       OnClick="OnRegister" 
                       Class="py-3 rounded-lg fw-black hover-scale pulse-neon"
                       Style="font-size: 1.1rem;">
                @if (_loading) {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">CREATING ACCOUNT...</MudText>
                } else {
                    <MudText>START WINNING</MudText>
                }
            </MudButton>
        </MudForm>

        <div class="text-center mt-6">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Already have an account? 
                <MudLink Href="/login" Color="Color.Primary" Underline="Underline.Hover" Class="fw-bold ml-1">Login Here</MudLink>
            </MudText>
        </div>
    </div>
</div>

@code {
    RegisterRequest model = new RegisterRequest("", "", "");
    bool success;
    bool _loading = false;

    [Parameter][SupplyParameterFromQuery(Name = "ref")] public string? RefParam { get; set; }

    protected override void OnInitialized() {
        if (!string.IsNullOrEmpty(RefParam)) {
            model.ReferralCode = RefParam;
        }
    }

    private async Task HandleEnter(KeyboardEventArgs e) {
        if (e.Key == "Enter" && success) {
            await OnRegister();
        }
    }

    private async Task OnRegister() {
        if (_loading) return;
        _loading = true;
        try {
            await AuthService.Register(model);
            Snackbar.Add("Registration successful! Please login.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally {
            _loading = false;
        }
    }
}
