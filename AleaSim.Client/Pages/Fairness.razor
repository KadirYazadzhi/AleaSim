@page "/fairness"
@using AleaSim.Client.Services
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@using System.Security.Cryptography
@using System.Text
@inject IGameService GameService
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-4">Provably Fair System</MudText>
    <MudText Typo="Typo.body1" Class="mb-8">
        We use a deterministic HMAC-SHA512 algorithm. You can verify every outcome.
    </MudText>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <MudPaper Class="pa-6 mb-6">
                <MudText Typo="Typo.h5" Class="mb-4">Simulation & Testing (Admin Only)</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="serverSeed" Label="Server Seed" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="clientSeed" Label="Client Seed" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VerifyRound">Verify Outcome</MudButton>
                    </MudItem>
                </MudGrid>
                @if (verificationResult != null)
                {
                    <MudAlert Severity="Severity.Success" Class="mt-4">
                        Result: @verificationResult
                    </MudAlert>
                }
            </MudPaper>
        </Authorized>
    </AuthorizeView>

    <MudPaper Class="pa-6">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h5">Recent Chain (Blockchain View)</MudText>
            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.Lock">IMMUATABLE LEDGER ACTIVE</MudChip>
        </div>
        
        <MudTable Items="@auditChain" Hover="true" RowsPerPage="10" Striped="true" Loading="@isLoadingChain">
            <HeaderContent>
                <MudTh>Timestamp</MudTh>
                <MudTh>Event Type</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Hash (Prev / Current)</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Time">@context.Timestamp.ToString("HH:mm:ss.fff")</MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small" Color="@GetEventColor(context.EventType)" Variant="Variant.Filled">@context.EventType</MudChip>
                </MudTd>
                <MudTd DataLabel="Desc">@context.Description</MudTd>
                <MudTd DataLabel="Hash" Style="font-family: monospace; font-size: 0.75rem;">
                    <div class="mud-text-secondary" style="opacity: 0.5;">@context.PreviousHash.Substring(0, 8)...</div>
                    <div class="fw-bold">@context.Hash.Substring(0, 16)...</div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private string serverSeed = "";
    private string clientSeed = "";
    private string? verificationResult;
    private List<AuditLogDto> auditChain = new();
    private bool isLoadingChain = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAuditChain();
    }

    private async Task LoadAuditChain()
    {
        isLoadingChain = true;
        try {
            auditChain = await Http.GetFromJsonAsync<List<AuditLogDto>>("api/Game/audit-chain") ?? new();
        } catch {
            Snackbar.Add("Failed to load audit chain.", Severity.Error);
        } finally {
            isLoadingChain = false;
        }
    }

    private Color GetEventColor(string type) => type switch {
        "BetPlaced" => Color.Info,
        "GameOutcome" => Color.Success,
        "JackpotWon" => Color.Warning,
        "Simulation" => Color.Secondary,
        "SystemUpdate" => Color.Primary,
        _ => Color.Default
    };

    private string GetShortHash(string input) {
        if (string.IsNullOrEmpty(input)) return "N/A";
        using var sha = SHA256.Create();
        var bytes = sha.ComputeHash(Encoding.UTF8.GetBytes(input));
        return Convert.ToHexString(bytes).Substring(0, 16) + "...";
    }

    private async Task VerifyRound()
    {
        // Simulation logic for Admin verification
        await Task.Delay(500);
        verificationResult = "Hash Valid. Outcome matches Seed pair.";
    }
}