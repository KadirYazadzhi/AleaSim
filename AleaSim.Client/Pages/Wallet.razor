@page "/wallet"
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6">My Wallet</MudText>

    <MudGrid>
        <!-- Deposit / Faucet Section -->
        <MudItem xs="12" md="4">
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <MudPaper Class="pa-6 mb-4" Elevation="2">
                        <MudText Typo="Typo.h6" Class="mb-4">Admin Deposit (God Mode)</MudText>
                        <MudText Typo="Typo.body2" Class="mb-4">Select an amount to instantly top up your balance.</MudText>
                        
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var amt in depositAmounts)
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='() => PerformDeposit(amt)'>$@amt</MudButton>
                            }
                        </div>

                        <MudNumericField @bind-Value="customAmount" Label="Custom Amount" Variant="Variant.Outlined" Class="mt-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-4" OnClick='() => PerformDeposit(customAmount)'>Deposit Now</MudButton>
                    </MudPaper>
                </Authorized>
            </AuthorizeView>

            <MudPaper Class="pa-6" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Bankruptcy Relief</MudText>
                <MudText Typo="Typo.body2" Class="mb-4">Ran out of funds? Claim $100.00 free credits once every hour if your balance is below $10.00.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" OnClick="ClaimFaucet">Claim Free Credits</MudButton>
            </MudPaper>
        </MudItem>

        <!-- Transaction History -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4 ml-2">Transaction History</MudText>
                @if (transactions == null) {
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                } else {
                    <MudTable Items="@transactions" Hover="true" Dense="true" RowsPerPage="10" Elevation="0" Class="glass-panel">
                        <HeaderContent>
                            <MudTh>Type</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Amount</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Type">
                                <MudText Typo="Typo.body2" Style="font-weight: bold;">@context.Type</MudText>
                            </MudTd>
                            <MudTd DataLabel="Date">
                                <MudText Typo="Typo.caption">@context.Timestamp.ToString("g")</MudText>
                            </MudTd>
                            <MudTd DataLabel="Amount">
                                <MudText Typo="Typo.body2" Color="@(context.Amount > 0 ? Color.Success : Color.Error)" Style="font-weight: bold;">
                                    @(context.Amount > 0 ? "+" : "")@context.Amount.ToString("C2")
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                        </PagerContent>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<TransactionDto>? transactions;
    private decimal[] depositAmounts = { 50, 100, 500, 1000 };
    private decimal customAmount = 50;

    protected override async Task OnInitializedAsync() {
        await LoadTransactions();
    }

    private async Task LoadTransactions() {
        transactions = await Http.GetFromJsonAsync<List<TransactionDto>>("api/Vault/transactions");
    }

    private async Task PerformDeposit(decimal amount) {
        var response = await Http.PostAsJsonAsync("api/Vault/deposit", amount);
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Deposit successful!", Severity.Success);
            await LoadTransactions();
        } else {
            Snackbar.Add("Deposit failed. Only Admins can deposit manually.", Severity.Error);
        }
    }

    private async Task ClaimFaucet() {
        var response = await Http.PostAsync("api/Vault/faucet", null);
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Relief claimed! Added $100.00.", Severity.Success);
            await LoadTransactions();
        } else {
            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Failed: {error}", Severity.Warning);
        }
    }
}
