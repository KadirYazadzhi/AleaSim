@page "/privacy"
@using AleaSim.Client.Services
@inject LayoutService LayoutService
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-12 mb-16">
    <MudText Typo="Typo.h3" Class="text-gradient fw-black mb-4">PRIVACY POLICY</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-8">Last Updated: March 2026</MudText>

    <MudPaper Class="pa-8 rounded-xl glass-panel" Elevation="0">
        <div class="dynamic-content">
            @((MarkupString)_content)
        </div>
    </MudPaper>
</MudContainer>

@code {
    private string _content = "Loading privacy policy...";
    protected override async Task OnInitializedAsync() {
        try {
            var settings = await Http.GetFromJsonAsync<List<AleaSim.Client.Pages.Admin.Settings.GlobalSettingDto>>("api/Admin/settings/global");
            var priv = settings?.FirstOrDefault(s => s.Key == "Content_Privacy");
            if (priv != null) _content = priv.Value;
        } catch { _content = "Error loading privacy policy."; }
    }
}

<style>
    .fw-black { font-weight: 900; }
    .fw-bold { font-weight: 700; }
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .glass-panel {
        background-color: @(LayoutService.IsDarkMode ? "rgba(255, 255, 255, 0.03)" : "rgba(0, 0, 0, 0.05)");
        backdrop-filter: blur(10px);
        border: 1px solid var(--mud-palette-divider);
    }
    .dynamic-content { line-height: 1.6; white-space: pre-wrap; }
</style>
