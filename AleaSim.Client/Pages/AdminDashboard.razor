@page "/dashboard"
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@implements IAsyncDisposable
@inject IAdminService AdminService
@inject RealTimeClient RealTime
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6" Style="font-weight: 900;">BACKOFFICE HUB</MudText>

    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" Color="Color.Dark">
        <MudTabPanel Text="Real-time Stats" Icon="@Icons.Material.Filled.Speed">
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-6 mud-theme-dark" Elevation="2" Style="border-left: 6px solid #4caf50;">
                        <MudText Typo="Typo.subtitle2">EST. GGR (Today)</MudText>
                        <MudText Typo="Typo.h4">$@stats.Ggr.ToString("N2")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-6 mud-theme-dark" Elevation="2" Style="border-left: 6px solid #2196f3;">
                        <MudText Typo="Typo.subtitle2">ACTIVE PLAYERS</MudText>
                        <MudText Typo="Typo.h4">@stats.ActivePlayerCount</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-6 mud-theme-dark" Elevation="2" Style="border-left: 6px solid #ff9800;">
                        <MudText Typo="Typo.subtitle2">GLOBAL RTP</MudText>
                        <MudText Typo="Typo.h4">@stats.CurrentRtp.ToString("F1")%</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-6 mud-theme-dark" Elevation="2" Style="border-left: 6px solid #f44336;">
                        <MudText Typo="Typo.subtitle2">EMERGENCY STOP</MudText>
                        <MudSwitch @bind-Value="_emergencyStop" Color="Color.Error" UncheckedColor="Color.Success" Label="@(_emergencyStop ? "STOPPED" : "ACTIVE")" T="bool" @onclick="ToggleStop" />
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="2" Style="background: #111; height: 300px; overflow-y: auto;">
                        <MudText Typo="Typo.h6" Class="mb-2" Color="Color.Primary">LIVE EVENT FEED</MudText>
                        @foreach (var log in _liveLogs)
                        {
                            <div class="d-flex gap-4 py-1 border-bottom border-dark">
                                <MudText Typo="Typo.caption" Style="color: #666;">@DateTime.Now.ToString("HH:mm:ss")</MudText>
                                <MudText Typo="Typo.body2">@log</MudText>
                            </div>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Configuration" Icon="@Icons.Material.Filled.Settings">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-6">
                        <MudText Typo="Typo.h6" Class="mb-4">Global RTP Settings</MudText>
                        <MudSlider T="decimal" @bind-Value="_targetRtp" Min="80" Max="105" Step="0.5m" Color="Color.Primary">Target RTP: @_targetRtp%</MudSlider>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="UpdateRtp" Class="mt-4">Apply Global RTP</MudButton>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-6">
                        <MudText Typo="Typo.h6" Class="mb-4">Simulation Test</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" OnClick="RunQuickSimulation">Run 10,000 Spin Stress Test</MudButton>
                        @if (_simInProgress) { <MudProgressLinear Color="Color.Info" Indeterminate="true" Class="mt-2" /> }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private AdminDashboardStats stats = new();
    private decimal _targetRtp = 95.0m;
    private bool _emergencyStop = false;
    private List<string> _liveLogs = new();
    private bool _simInProgress = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
        
        RealTime.OnBigWinReceived += (args) => {
            _liveLogs.Insert(0, $"🔥 BIG WIN: {args.Username} won {args.Amount:C} on {args.GameName} ({args.Multiplier}x)");
            InvokeAsync(StateHasChanged);
        };
    }

    private async Task LoadStats()
    {
        try {
            stats = await AdminService.GetDashboardStats();
            _targetRtp = stats.CurrentRtp > 0 ? stats.CurrentRtp : 95.0m;
            _emergencyStop = stats.IsEmergencyStopActive;
        } catch {}
    }

    private async Task UpdateRtp()
    {
        await AdminService.UpdateRtp(_targetRtp);
        Snackbar.Add("System-wide RTP updated.", Severity.Success);
    }

    private async Task ToggleStop()
    {
        await AdminService.ToggleEmergencyStop(!_emergencyStop);
        Snackbar.Add("Emergency Stop Toggled.", Severity.Warning);
    }

    private async Task RunQuickSimulation()
    {
        _simInProgress = true;
        var report = await AdminService.RunSimulation(new SimulationRequest { GameType = "Slot", Iterations = 10000 });
        _simInProgress = false;
        if (report != null) {
            _liveLogs.Insert(0, $"✅ SIMULATION COMPLETE: Slot RTP resulted in {report.ActualRTP}%");
            Snackbar.Add("Stress test complete.", Severity.Info);
        }
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
