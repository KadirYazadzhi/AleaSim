@page "/dashboard"
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@using Microsoft.AspNetCore.Authorization
@using System.Text
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@implements IAsyncDisposable
@inject IAdminService AdminService
@inject RealTimeClient RealTime
@inject ISnackbar Snackbar
@inject LayoutService LayoutService
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-16 animate-fade-in">
    <div class="d-flex justify-space-between align-center mb-8">
        <div>
            <MudText Typo="Typo.h3" Class="text-gradient fw-black mb-2">BACKOFFICE HUB</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Real-time System Monitoring</MudText>
        </div>
        <div class="d-flex align-center gap-4">
             <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportToCsv" Size="Size.Small" Class="mr-2">EXPORT CSV</MudButton>
             <MudSelect T="string" Value="@_selectedPeriod" ValueChanged="OnPeriodChanged" Label="Reporting Period" Variant="Variant.Outlined" Dense="true" Class="bg-glass rounded-lg" Style="width: 150px;">
                 <MudSelectItem Value="@("Day")">Today</MudSelectItem>
                 <MudSelectItem Value="@("Week")">Last 7 Days</MudSelectItem>
                 <MudSelectItem Value="@("Month")">Last 30 Days</MudSelectItem>
             </MudSelect>
             @if (RealTime.IsConnected) {
                <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Icon="@Icons.Material.Filled.LiveTv" Class="fw-bold pulse-red">LIVE: CONNECTED</MudChip>
             } else {
                <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Pause" Class="fw-bold">@RealTime.State.ToString().ToUpper()</MudChip>
             }
        </div>
    </div>

    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="6" md="3">
            <div class="dashboard-card pa-6 rounded-xl hover-scale h-100">
                <div class="d-flex justify-space-between align-start mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Large" />
                     <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.h4" Class="fw-black mb-1" Color="Color.Success">@stats.Ggr.ToString("C2")</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase fw-bold">EST. GGR (@_selectedPeriod)</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="dashboard-card pa-6 rounded-xl hover-scale h-100">
                 <div class="d-flex justify-space-between align-start mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Large" />
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">+@(_selectedPeriod == "Day" ? "12%" : "5%")</MudChip>
                </div>
                <MudText Typo="Typo.h4" Class="fw-black mb-1" Color="Color.Info">@stats.ActivePlayerCount</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase fw-bold">Active Players (@_selectedPeriod)</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="dashboard-card pa-6 rounded-xl hover-scale h-100">
                 <div class="d-flex justify-space-between align-start mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Percent" Color="Color.Warning" Size="Size.Large" />
                     <MudIcon Icon="@Icons.Material.Filled.Functions" Color="Color.Warning" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.h4" Class="fw-black mb-1" Color="Color.Warning">@stats.CurrentRtp.ToString("F2")%</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase fw-bold">Average RTP (@_selectedPeriod)</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
             <div class='@($"dashboard-card pa-6 rounded-xl hover-scale h-100 {(_emergencyStop ? "border-red" : "")}")'>
                 <div class="d-flex justify-space-between align-start mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.PanTool" Color="@(_emergencyStop ? Color.Error : Color.Success)" Size="Size.Large" />
                    <MudSwitch T="bool" Value="@_emergencyStop" ValueChanged="ToggleStopValue" Color="Color.Error" UncheckedColor="Color.Success" Class="ml-auto" />
                </div>
                <MudText Typo="Typo.h5" Class="fw-black mb-1" Color="@(_emergencyStop ? Color.Error : Color.Success)">@(_emergencyStop ? "STOPPED" : "ACTIVE")</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase fw-bold">System Status</MudText>
            </div>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mb-8">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 rounded-xl dashboard-card" Elevation="0">
                <div class="d-flex justify-space-between align-center mb-6">
                    <div>
                        <MudText Typo="Typo.h6" Class="fw-black">WAGER VOLUME</MudText>
                        <MudText Typo="Typo.caption" Class="opacity-50">Total incoming bets (Last 24h)</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Info" />
                </div>
                @if (trendData.Any()) {
                    <MudChart ChartType="ChartType.Line" 
                              ChartSeries="@(new List<ChartSeries>() { new ChartSeries { Name = "Wagers ($)", Data = trendData.Select(t => t.Bets).ToArray() } })" 
                              XAxisLabels="@(trendData.Select(t => t.Label).ToArray())" 
                              Width="100%" Height="250px" 
                              ChartOptions="@(new ChartOptions { InterpolationOption = trendData.Count >= 4 ? InterpolationOption.NaturalSpline : InterpolationOption.Straight, YAxisTicks = 5 })" />
                } else {
                    <div class="d-flex justify-center align-center py-12 opacity-30"><MudText>Awaiting data...</MudText></div>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 rounded-xl dashboard-card" Elevation="0">
                <div class="d-flex justify-space-between align-center mb-6">
                    <div>
                        <MudText Typo="Typo.h6" Class="fw-black">PAYOUT VOLUME</MudText>
                        <MudText Typo="Typo.caption" Class="opacity-50">Total winnings paid (Last 24h)</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Success" />
                </div>
                @if (trendData.Any()) {
                    <MudChart ChartType="ChartType.Line" 
                              ChartSeries="@(new List<ChartSeries>() { new ChartSeries { Name = "Payouts ($)", Data = trendData.Select(t => t.Wins).ToArray() } })" 
                              XAxisLabels="@(trendData.Select(t => t.Label).ToArray())" 
                              Width="100%" Height="250px" 
                              ChartOptions="@(new ChartOptions { InterpolationOption = trendData.Count >= 4 ? InterpolationOption.NaturalSpline : InterpolationOption.Straight, YAxisTicks = 5 })" />
                } else {
                    <div class="d-flex justify-center align-center py-12 opacity-30"><MudText>Awaiting data...</MudText></div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mb-8">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6 rounded-xl dashboard-card h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Game Performance Analytics</MudText>
                <MudTable Items="@stats.GameStats" Hover="true" Dense="true" Elevation="0" Class="bg-transparent">
                    <HeaderContent>
                        <MudTh>Game</MudTh>
                        <MudTh>Wagered</MudTh>
                        <MudTh>Payout</MudTh>
                        <MudTh>Max Win</MudTh>
                        <MudTh>RTP</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.GameName</MudTd>
                        <MudTd>@context.TotalWagered.ToString("C2")</MudTd>
                        <MudTd>@context.TotalWon.ToString("C2")</MudTd>
                        <MudTd>@context.MaxWin.ToString("C2")</MudTd>
                        <MudTd>
                            <MudText Color="@(context.Rtp > 100 ? Color.Error : (context.Rtp > 97 ? Color.Warning : Color.Success))" Class="fw-bold">
                                @context.Rtp.ToString("F2")%
                            </MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-6 rounded-xl dashboard-card h-100" Elevation="0">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4">Top Profit Players</MudText>
                <MudList T="PlayerRankDto">
                    @foreach (var player in stats.TopPlayers)
                    {
                        <MudListItem Class="px-0">
                            <div class="d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.body1" Class="fw-bold">@player.Username</MudText>
                                    <MudText Typo="Typo.caption" Class="opacity-60">Won: @player.TotalWon.ToString("C0")</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Color="@(player.Profit > 0 ? Color.Success : Color.Error)" Class="fw-black">
                                    @(player.Profit > 0 ? "+" : "")@player.Profit.ToString("C2")
                                </MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
    
    <MudGrid>
         <MudItem xs="12" md="8">
            <div class="dashboard-card pa-6 rounded-xl" style="height: 400px; display: flex; flex-direction: column;">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6" Class="fw-bold"><MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2"/>Live Event Feed</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" OnClick="LoadStats" />
                </div>
                <div class="flex-grow-1 overflow-auto pr-2 custom-scroll">
                     @if (!_liveLogs.Any())
                     {
                         <div class="d-flex flex-column align-center justify-center h-100 opacity-50">
                             <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Large" />
                             <MudText>Waiting for events...</MudText>
                         </div>
                     }
                     else
                     {
                         @foreach (var log in _liveLogs)
                         {
                             <div class="d-flex gap-4 py-3 border-b-glass animate-slide-in-left">
                                 <MudText Typo="Typo.caption" Class="mud-text-secondary font-mono pt-1">@DateTime.Now.ToString("HH:mm:ss")</MudText>
                                 <div>@((MarkupString)log)</div>
                             </div>
                         }
                     }
                </div>
            </div>
        </MudItem>
        
        <MudItem xs="12" md="4">
             <div class="dashboard-card pa-6 rounded-xl h-100">
                <MudText Typo="Typo.h6" Class="fw-bold mb-6">Quick Actions</MudText>
                <MudStack Spacing="3">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Refresh" Class="rounded-lg py-3" OnClick="OnClearCache">Reset Cache</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" FullWidth="true" StartIcon="@Icons.Material.Filled.NotificationsActive" Class="rounded-lg py-3" OnClick="OnSendAlert">Send Global Alert</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true" StartIcon="@Icons.Material.Filled.Backup" Class="rounded-lg py-3" OnClick="OnBackup">Backup Database</MudButton>
                    <MudDivider Class="my-2" />
                    <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" StartIcon="@Icons.Material.Filled.Block" Class="rounded-lg py-3" OnClick="OnBlockIp">Block IP Range</MudButton>
                </MudStack>
             </div>
        </MudItem>
    </MudGrid>

    <!-- Support Messages Section -->
    <MudText Typo="Typo.h5" Class="fw-black mt-12 mb-6" Color="Color.Inherit">SUPPORT MESSAGES</MudText>
    <MudPaper Class="pa-6 rounded-xl dashboard-card" Elevation="0">
        @if (supportMessages == null)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!supportMessages.Any())
        {
            <div class="text-center pa-8 opacity-50">
                <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Size="Size.Large" Class="mb-2" />
                <MudText>No pending support messages.</MudText>
            </div>
        }
        else
        {
            <MudTable Items="@supportMessages" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="bg-transparent">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Sender</MudTh>
                    <MudTh>Subject</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.CreatedAt.ToString("g")</MudTd>
                    <MudTd DataLabel="Sender">
                        <MudText Typo="Typo.body2">@context.SenderName</MudText>
                        <MudText Typo="Typo.caption" Class="opacity-60">@context.SenderEmail</MudText>
                    </MudTd>
                    <MudTd DataLabel="Subject" Class="fw-bold">@context.Subject</MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsRead) { <MudChip T="string" Size="Size.Small" Color="Color.Default">Read</MudChip> }
                        else { <MudChip T="string" Size="Size.Small" Color="Color.Info">New</MudChip> }
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => ViewMessage(context)">View</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

<style>
    .fw-black { font-weight: 900; }
    .fw-bold { font-weight: 700; }
    
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .dashboard-card {
        background: @(LayoutService.IsDarkMode ? "rgba(30, 41, 59, 0.7)" : "rgba(255, 255, 255, 0.7)");
        backdrop-filter: blur(12px);
        border: 1px solid var(--mud-palette-divider);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .bg-glass {
        background: rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(4px);
    }
    
    .border-b-glass {
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .hover-scale { transition: transform 0.2s; }
    .hover-scale:hover { transform: translateY(-5px); }

    .pulse-red { animation: pulseRed 2s infinite; }
    @@keyframes pulseRed {
        0% { box-shadow: 0 0 0 0 rgba(244, 63, 94, 0.7); }
        70% { box-shadow: 0 0 0 10px rgba(244, 63, 94, 0); }
        100% { box-shadow: 0 0 0 0 rgba(244, 63, 94, 0); }
    }

    .pulse-neon { animation: pulseNeon 2s infinite; }
    @@keyframes pulseNeon {
        0% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(124, 58, 237, 0); }
        100% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0); }
    }
    
    .border-red { border: 1px solid var(--mud-palette-error) !important; }
    
    .font-mono { font-family: 'Roboto Mono', monospace; }
    
    .animate-fade-in { animation: fadeIn 0.5s ease-out forwards; }
    .animate-slide-in-left { animation: slideInLeft 0.3s ease-out forwards; }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideInLeft { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
    
    .custom-scroll::-webkit-scrollbar { width: 6px; }
    .custom-scroll::-webkit-scrollbar-track { background: transparent; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
</style>

@code {
    private AdminDashboardStats stats = new();
    private List<RtpTrendPoint> trendData = new();
    private string _selectedPeriod = "Day";
    private decimal _targetRtp = 95.0m;
    private bool _emergencyStop = false;
    private List<string> _liveLogs = new();
    private List<SupportMessageDto>? supportMessages;
    [Inject] IDialogService DialogService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        LayoutService.OnMajorUpdate += StateHasChanged;
        await LoadStats();
        await LoadMessages();
        
        RealTime.OnAdminEventReceived += HandleAdminEvent;

        RealTime.OnBigWinReceived += (args) => {
            var logHtml = $"<span class='text-warning fw-bold'>BIG WIN:</span> <b>{args.Username}</b> won <span class='text-success'>{args.Amount:C}</span> on {args.GameName} ({args.Multiplier}x)";
            _liveLogs.Insert(0, logHtml);
            if (_liveLogs.Count > 50) _liveLogs.RemoveAt(_liveLogs.Count - 1);
            InvokeAsync(StateHasChanged);
        };

        // Async join with retry
        _ = Task.Run(async () => {
            int retries = 0;
            while (!RealTime.IsConnected && retries < 15) {
                await Task.Delay(1000);
                retries++;
            }
            await RealTime.JoinAdminFeed();
            await InvokeAsync(StateHasChanged);
        });
    }

    private void HandleAdminEvent(AdminRoundEvent ev) {
        if (ev == null) return;

        // 1. Update Live Logs
        var logHtml = $"<b>{ev.Username}</b> bet <span class='opacity-70'>{ev.Bet:C}</span> on <b>{ev.Game}</b> and won <span class='{(ev.Win > 0 ? "text-success fw-bold" : "opacity-50")}'>{ev.Win:C}</span>";
        _liveLogs.Insert(0, logHtml);
        if (_liveLogs.Count > 50) _liveLogs.RemoveAt(_liveLogs.Count - 1);

        // 2. Update Stats (only if viewing 'Day' period for better accuracy)
        if (_selectedPeriod == "Day" && stats != null) {
            stats.TotalBets += ev.Bet;
            stats.TotalWins += ev.Win;
            stats.Ggr = stats.TotalBets - stats.TotalWins;
            if (stats.TotalBets > 0) stats.CurrentRtp = (stats.TotalWins / stats.TotalBets) * 100;

            // Update Game Stats
            var gStat = stats.GameStats.FirstOrDefault(g => 
                (g.GameType != null && g.GameType.Equals(ev.Game, StringComparison.OrdinalIgnoreCase)) || 
                (g.GameName != null && g.GameName.Equals(ev.Game, StringComparison.OrdinalIgnoreCase)));
            
            if (gStat != null) {
                gStat.TotalWagered += ev.Bet;
                gStat.TotalWon += ev.Win;
                if (ev.Win > gStat.MaxWin) gStat.MaxWin = ev.Win;
            } else {
                stats.GameStats.Add(new GameStatDto {
                    GameName = ev.Game,
                    GameType = ev.Game,
                    TotalWagered = ev.Bet,
                    TotalWon = ev.Win,
                    MaxWin = ev.Win
                });
            }

            // Update Top Players
            var player = stats.TopPlayers.FirstOrDefault(p => p.Username == ev.Username);
            if (player != null) {
                player.TotalWagered += ev.Bet;
                player.TotalWon += ev.Win;
                player.Profit = player.TotalWon - player.TotalWagered;
            } else if (ev.Win > 0 || ev.Bet > 10) {
                stats.TopPlayers.Add(new PlayerRankDto { Username = ev.Username, TotalWagered = ev.Bet, TotalWon = ev.Win, Profit = ev.Win - ev.Bet });
            }
            
            // Re-sort players
            stats.TopPlayers = stats.TopPlayers.OrderByDescending(p => p.TotalWon).Take(10).ToList();
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task LoadMessages() {
        try {
            supportMessages = await AdminService.GetSupportMessages();
        } catch { supportMessages = new(); }
    }

    private async Task ViewMessage(SupportMessageDto msg) {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters { ["Message"] = msg };
        
        var dialog = await DialogService.ShowAsync<AdminMessageDialog>("Support Message", parameters, options);
        var result = await dialog.Result;
        
        if (!msg.IsRead) {
            await AdminService.MarkSupportMessageRead(msg.Id);
            msg.IsRead = true;
            StateHasChanged();
        }
    }

    private async Task OnPeriodChanged(string period) {
        _selectedPeriod = period;
        await LoadStats();
    }

    private async Task LoadStats() {
        try {
            stats = await AdminService.GetDashboardStats(_selectedPeriod);
            _targetRtp = Math.Round(stats.CurrentRtp > 0 ? (decimal)stats.CurrentRtp : 95.0m, 2);
            _emergencyStop = stats.IsEmergencyStopActive;
            
            trendData = await AdminService.GetRtpTrend();
        } catch {}
    }

    private async Task ToggleStopValue(bool enabled)
    {
        await AdminService.ToggleEmergencyStop(enabled);
        _emergencyStop = enabled;
        Snackbar.Add(_emergencyStop ? "Emergency Stop ACTIVATED" : "Emergency Stop DEACTIVATED", _emergencyStop ? Severity.Error : Severity.Success);
    }

    private async Task OnClearCache() {
        await AdminService.TriggerAction("ClearCache");
        Snackbar.Add("System cache cleared.", Severity.Success);
    }

    private async Task OnSendAlert() {
        await AdminService.TriggerAction("GlobalAlert");
        Snackbar.Add("Global alert broadcasted.", Severity.Warning);
    }

    private async Task OnBackup() {
        await AdminService.TriggerAction("BackupDb");
        Snackbar.Add("Database backup started in background.", Severity.Info);
    }

    private async Task OnBlockIp() {
        await AdminService.TriggerAction("BlockIp"); // Simplified for demo
        Snackbar.Add("Suspicious IP ranges blocked.", Severity.Error);
    }

    private async Task ExportToCsv() {
        if (stats == null) return;
        
        var sb = new StringBuilder();
        sb.AppendLine("REPORTING PERIOD," + _selectedPeriod);
        sb.AppendLine("METRIC,VALUE");
        sb.AppendLine($"GGR,{stats.Ggr}");
        sb.AppendLine($"Total Bets,{stats.TotalBets}");
        sb.AppendLine($"Total Wins,{stats.TotalWins}");
        sb.AppendLine($"Platform RTP,{stats.CurrentRtp:F2}%");
        sb.AppendLine($"Active Players,{stats.ActivePlayerCount}");
        sb.AppendLine();
        
        sb.AppendLine("GAME,WAGERED,WON,MAX WIN,RTP");
        foreach(var g in stats.GameStats) {
            var rtp = g.TotalWagered > 0 ? (g.TotalWon / g.TotalWagered * 100) : 0;
            sb.AppendLine($"{g.GameName},{g.TotalWagered},{g.TotalWon},{g.MaxWin},{rtp:F2}%");
        }
        sb.AppendLine();

        sb.AppendLine("PLAYER,WAGERED,WON,PROFIT");
        foreach(var p in stats.TopPlayers) {
            sb.AppendLine($"{p.Username},{p.TotalWagered},{p.TotalWon},{p.Profit}");
        }

        var csvContent = sb.ToString();
        var fileName = $"AleaSim_Report_{DateTime.Now:yyyyMMdd_HHmm}.csv";
        await JSRuntime.InvokeVoidAsync("aleaUtils.downloadTextFile", fileName, "text/csv;charset=utf-8;", csvContent);
        Snackbar.Add("Report exported successfully.", Severity.Success);
    }

    public ValueTask DisposeAsync() {
        LayoutService.OnMajorUpdate -= StateHasChanged;
        return ValueTask.CompletedTask;
    }
}