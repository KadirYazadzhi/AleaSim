@page "/admin/settings"
@using AleaSim.Client.Services
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@implements IDisposable
@inject IAdminService AdminService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LayoutService LayoutService
@inject RealTimeClient RealTime
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 mb-16 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-space-between align-md-center mb-8 gap-4">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black mb-1 settings-title text-gradient">COMMAND CENTER</MudText>
            <MudText Typo="Typo.subtitle1" Class="opacity-60 d-none d-sm-block">Architect the platform's core parameters and user experience.</MudText>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadAll" StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="flex-grow-1">Sync</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAllChanges" StartIcon="@Icons.Material.Filled.Save" Size="Size.Small" Class="flex-grow-1">Deploy Changes</MudButton>
        </div>
    </div>

    <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pa-md-8 pa-4 custom-settings-tabs" Class="rounded-xl overflow-hidden shadow-2xl">
        
        <!-- 1. RISK & MECHANICS -->
        <MudTabPanel Text="RISK" Icon="@Icons.Material.Filled.SettingsInputComponent">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="8">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-6">Mathematical Core</MudText>
                        <MudGrid Spacing="4">
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Class="fw-bold mb-1">
                                    Global Target RTP (%)
                                    <MudTooltip Text="The mathematical anchor of the system. All game engines attempt to gravitate toward this percentage over a long-term rolling window.">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="opacity: 0.5; cursor: help; font-size: 0.7rem; margin-left: 4px;" />
                                    </MudTooltip>
                                </MudText>
                                <div class="d-flex align-center gap-4 pa-4 bg-grey-darken-4 rounded-lg">
                                    <MudSlider T="decimal" @bind-Value="_targetRtp" Min="80" Max="105" Step="0.1m" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Class="fw-black text-primary" Style="min-width: 70px;">@_targetRtp.ToString("F1")%</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="fw-bold mb-1">
                                    Volatility Profile
                                    <MudTooltip Text="Controls the win curve. Low: frequent small hits. High: rare but massive payouts.">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="opacity: 0.5; cursor: help; font-size: 0.7rem; margin-left: 4px;" />
                                    </MudTooltip>
                                </MudText>
                                <MudSelect T="string" @bind-Value="_volatilityMode" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="@("Low")">Low (Frequent small wins)</MudSelectItem>
                                    <MudSelectItem Value="@("Medium")">Medium (Balanced)</MudSelectItem>
                                    <MudSelectItem Value="@("High")">High (Huge wins, high risk)</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <div class="d-flex align-center gap-2">
                                    <MudSwitch @bind-Value="_shadowMode" Label="Global Shadow Mode (Simulation only)" Color="Color.Secondary" T="bool" />
                                    <MudTooltip Text="When enabled, the platform operates on pure RNG, disabling all behavioral intervention (The Brain) for all users. Ideal for math certification.">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="opacity: 0.5; cursor: help;" />
                                    </MudTooltip>
                                </div>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField @bind-Value="_minBet" Label="Minimum Bet ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField @bind-Value="_maxBet" Label="Maximum Bet ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudItem>

                <MudItem xs="12" md="4">
                    <div class="settings-group-card h-100 border-error-subtle">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4 text-error">System Override</MudText>
                        <div class='@($"emergency-box {(_emergencyStop ? "active" : "")}")'>
                            <MudSwitch @bind-Value="_emergencyStop" Color="Color.Error" UncheckedColor="Color.Success" Size="Size.Large" T="bool" />
                            <MudText Typo="Typo.h5" Class="fw-black mt-2">@(_emergencyStop ? "EMERGENCY HALT" : "SYSTEM ONLINE")</MudText>
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-4 d-block opacity-60">Instantly pauses all game engines and prevents new bets.</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- 2. ECONOMY & PROMOTIONS -->
        <MudTabPanel Text="ECON" Icon="@Icons.Material.Filled.AccountBalance">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Relief System (Faucet)</MudText>
                        <MudStack Spacing="3">
                            <MudNumericField @bind-Value="_faucetAmount" Label="Grant Amount ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudNumericField @bind-Value="_faucetThreshold" Label="Trigger Threshold ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudText Typo="Typo.caption" Class="opacity-60">Allows users to claim funds when below threshold.</MudText>
                        </MudStack>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Loyalty & Growth</MudText>
                        <MudStack Spacing="3">
                            <MudNumericField @bind-Value="_baseCashback" Label="Base Cashback (%)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudNumericField @bind-Value="_welcomeBonus" Label="Welcome Bonus ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudNumericField @bind-Value="_xpMultiplier" Label="Global XP Multiplier" Variant="Variant.Outlined" Margin="Margin.Dense" Step="0.1m" />
                        </MudStack>
                    </div>
                </MudItem>
                <MudItem xs="12">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Tournament Prize Pool</MudText>
                        <MudNumericField @bind-Value="_tournamentPrizePool" Label="Monthly Prize Pool ($)" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- 3. COMMUNITY & CHAT -->
        <MudTabPanel Text="SOCIAL" Icon="@Icons.Material.Filled.Chat">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Chat Governance</MudText>
                        <MudStack Spacing="3">
                            <MudSwitch @bind-Value="_chatEnabled" Label="Enable Public Chat" Color="Color.Primary" T="bool" />
                            <MudNumericField @bind-Value="_minLevelChat" Label="Min Level to Chat" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudNumericField @bind-Value="_chatSlowMode" Label="Slow Mode (Seconds)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudStack>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Content Filter</MudText>
                        <MudTextField @bind-Value="_prohibitedWords" Label="Prohibited Words (Comma separated)" Variant="Variant.Outlined" Lines="4" Placeholder="badword1, badword2..." />
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- 4. CONTENT & BRANDING -->
        <MudTabPanel Text="CONTENT" Icon="@Icons.Material.Filled.Article">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="4">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">General</MudText>
                        <MudTextField @bind-Value="_platformName" Label="Platform Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </div>
                </MudItem>
                <MudItem xs="12" md="8">
                    <div class="settings-group-card">
                        <MudTabs Elevation="0" Rounded="true" PanelClass="pt-4">
                            <MudTabPanel Text="Help">
                                <MudTextField @bind-Value="_contentHelp" Label="Help Center Markdown" Variant="Variant.Outlined" Lines="10" />
                            </MudTabPanel>
                            <MudTabPanel Text="Terms">
                                <MudTextField @bind-Value="_contentTerms" Label="Terms of Service Markdown" Variant="Variant.Outlined" Lines="10" />
                            </MudTabPanel>
                            <MudTabPanel Text="Privacy">
                                <MudTextField @bind-Value="_contentPrivacy" Label="Privacy Policy Markdown" Variant="Variant.Outlined" Lines="10" />
                            </MudTabPanel>
                        </MudTabs>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- 5. JACKPOTS -->
        <MudTabPanel Text="POTS" Icon="@Icons.Material.Filled.Diamond">
            <div class="settings-group-card border-warning-subtle bg-warning-darken-4">
                <div class="d-flex justify-space-between align-center mb-6">
                    <div>
                        <MudText Typo="Typo.h5" Class="fw-black mb-1 text-warning">PROGRESSIVE POOLS</MudText>
                        <MudText Typo="Typo.body2" Class="opacity-60">Manage and trigger global jackpot drops manually.</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Warning" Size="Size.Large" />
                </div>

                <div class="table-responsive rounded-xl overflow-hidden border border-white-10">
                    <MudTable Items="@_jackpots" Hover="true" Dense="true" Elevation="0" Class="bg-transparent" Context="jackpot">
                        <HeaderContent>
                            <MudTh Style="background: rgba(0,0,0,0.3); color: white;">TIER</MudTh>
                            <MudTh Style="background: rgba(0,0,0,0.3); color: white;">CURRENT VALUE</MudTh>
                            <MudTh Style="background: rgba(0,0,0,0.3); color: white;">CEILING (MUST DROP)</MudTh>
                            <MudTh Style="background: rgba(0,0,0,0.3); color: white; text-align: center;">ACTIONS</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Tier">
                                <div class="d-flex align-center gap-2">
                                    <div class='@($"tier-dot {jackpot.Tier.ToLower()}")'></div>
                                    <MudTooltip Text="@GetJackpotInfo(jackpot.Tier)">
                                        <MudText Typo="Typo.body1" Class="fw-black cursor-help">@jackpot.Tier.ToUpper()</MudText>
                                    </MudTooltip>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Value">
                                <MudText Typo="Typo.h6" Class="fw-black text-warning">@jackpot.CurrentValue.ToString("C2")</MudText>
                            </MudTd>
                            <MudTd DataLabel="Target">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Class="opacity-70">
                                    @(jackpot.MustDropAt?.ToString("C0") ?? "UNLIMITED")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Action" Class="text-center">
                                <MudButton Variant="Variant.Filled" 
                                           Color="Color.Error" 
                                           Size="Size.Small" 
                                           StartIcon="@Icons.Material.Filled.FlashOn"
                                           OnClick="() => ConfirmJackpotDrop(jackpot)"
                                           Class="rounded-pill fw-bold px-4">
                                    TRIGGER DROP
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
                
                <div class="mt-6 pa-4 rounded-lg bg-error-darken-4 border-error-subtle d-flex align-center gap-4">
                    <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" />
                    <MudText Typo="Typo.caption" Class="text-error fw-bold">DANGER: Triggering a manual drop will immediately reset the pool and broadcast a global notification to all players.</MudText>
                </div>
            </div>
        </MudTabPanel>

        <!-- 6. SYSTEM MAINTENANCE -->
        <MudTabPanel Text="SYS" Icon="@Icons.Material.Filled.Dns">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-6 text-center">Data Integrity</MudText>
                        <div class="d-flex flex-column align-center py-4">
                            <div class='@($"integrity-shield {(_integrityResult?.IsValid == true ? "secure" : "warning")}")'>
                                <MudIcon Icon="@(_integrityResult?.IsValid == true ? Icons.Material.Filled.GppGood : Icons.Material.Filled.GppMaybe)" Style="font-size: 3rem;" />
                            </div>
                            <MudText Typo="Typo.body2" Class="mt-4 text-center opacity-60">@(_integrityResult?.Message ?? "Ready for scan")</MudText>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true" Class="py-3 rounded-lg fw-black" OnClick="RunIntegrityCheck" Disabled="_verifyingIntegrity">EXECUTE SCAN</MudButton>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <div class="settings-group-card h-100">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Quick Operations</MudText>
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.CleaningServices" FullWidth="true" OnClick="OnClearCache" Size="Size.Small">Purge Memory Cache</MudButton>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.RestartAlt" FullWidth="true" OnClick="OnRestartRng" Size="Size.Small">Synchronize RNG Service</MudButton>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Backup" FullWidth="true" OnClick="OnTriggerBackup" Size="Size.Small">Manual Database Backup</MudButton>
                            <MudDivider Class="my-2" />
                            <MudSwitch @bind-Value="_perfLogging" Label="Detailed Performance Logging" Color="Color.Warning" T="bool" />
                        </MudStack>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

<style>
    .table-responsive { width: 100%; overflow-x: auto; }
    
    @@media (max-width: 600px) {
        .settings-title { font-size: 1.75rem !important; }
        .settings-group-card { padding: 1.5rem !important; }
    }

    .fw-black { font-weight: 950; }
    .fw-bold { font-weight: 700; }
    .text-gradient { background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .custom-settings-tabs { background: var(--mud-palette-surface); }
    .settings-group-card { padding: 32px; border-radius: 24px; background: var(--mud-palette-background-grey); border: 1px solid var(--mud-palette-divider); box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    
    .bg-grey-darken-4 { background: rgba(0,0,0,0.2); }
    .border-error-subtle { border-color: rgba(var(--mud-palette-error-rgb), 0.3); }
    .bg-error-darken-4 { background: rgba(var(--mud-palette-error-rgb), 0.1); }
    .border-warning-subtle { border-color: rgba(var(--mud-palette-warning-rgb), 0.3); }
    .bg-warning-darken-4 { background: rgba(var(--mud-palette-warning-rgb), 0.05); }

    .tier-dot { width: 12px; height: 12px; border-radius: 50%; box-shadow: 0 0 10px currentColor; }
    .tier-dot.mega { background-color: var(--mud-palette-error); color: var(--mud-palette-error); }
    .tier-dot.major { background-color: var(--mud-palette-warning); color: var(--mud-palette-warning); }
    .tier-dot.minor { background-color: var(--mud-palette-info); color: var(--mud-palette-info); }
    .tier-dot.mini { background-color: var(--mud-palette-success); color: var(--mud-palette-success); }
    .tier-dot.special { background-color: var(--mud-palette-secondary); color: var(--mud-palette-secondary); }
    .tier-dot.tournament { background-color: var(--mud-palette-primary); color: var(--mud-palette-primary); }

    .emergency-box { padding: 24px; border-radius: 16px; border: 2px solid var(--mud-palette-success); background: rgba(var(--mud-palette-success-rgb), 0.05); color: var(--mud-palette-success); text-align: center; transition: all 0.3s; }
    .emergency-box.active { border-color: var(--mud-palette-error); background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); animation: pulse-error 2s infinite; }

    .integrity-shield { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid var(--mud-palette-divider); transition: all 0.5s; }
    .integrity-shield.secure { border-color: var(--mud-palette-success); color: var(--mud-palette-success); background: rgba(var(--mud-palette-success-rgb), 0.05); }
    .integrity-shield.warning { border-color: var(--mud-palette-warning); color: var(--mud-palette-warning); background: rgba(var(--mud-palette-warning-rgb), 0.05); }

    @@keyframes pulse-error { 0% { box-shadow: 0 0 0 0 rgba(var(--mud-palette-error-rgb), 0.4); } 70% { box-shadow: 0 0 0 15px rgba(var(--mud-palette-error-rgb), 0); } 100% { box-shadow: 0 0 0 0 rgba(var(--mud-palette-error-rgb), 0); } }
</style>

@code {
    private decimal _targetRtp = 95.0m;
    private string _volatilityMode = "Medium";
    private bool _emergencyStop = false;
    private bool _shadowMode = false;
    private decimal _minBet = 0.10m;
    private decimal _maxBet = 1000.0m;

    private decimal _faucetAmount = 100.0m;
    private decimal _faucetThreshold = 10.0m;
    private decimal _baseCashback = 10.0m;
    private decimal _welcomeBonus = 50.0m;
    private decimal _xpMultiplier = 1.0m;
    private decimal _tournamentPrizePool = 25000.0m;

    private bool _chatEnabled = true;
    private int _minLevelChat = 1;
    private int _chatSlowMode = 0;
    private string _prohibitedWords = "";

    private string _platformName = "AleaSim";
    private string _contentHelp = "";
    private string _contentTerms = "";
    private string _contentPrivacy = "";

    private bool _perfLogging = false;

    private bool _verifyingIntegrity = false;
    private IntegrityResponse? _integrityResult;
    private List<GlobalSettingDto> _globalSettings = new();
    private List<JackpotDto> _jackpots = new();

    protected override async Task OnInitializedAsync() {
        RealTime.OnJackpotUpdated += HandleJackpotUpdate;
        await LoadAll();
    }

    private void HandleJackpotUpdate(JackpotDto dto) {
        var existing = _jackpots.FirstOrDefault(j => j.Id == dto.Id);
        if (existing != null) {
            existing.CurrentValue = dto.CurrentValue;
            existing.MustDropAt = dto.MustDropAt;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAll() {
        await LoadCurrentPlatformStats();
        await LoadGlobalSettings();
        await LoadJackpots();
    }

    private async Task LoadJackpots() {
        try {
            _jackpots = await Http.GetFromJsonAsync<List<JackpotDto>>("api/Admin/jackpots") ?? new();
        } catch {}
    }

    private async Task ConfirmJackpotDrop(JackpotDto jackpot) {
        bool? result = await DialogService.ShowMessageBox(
            "CRITICAL ACTION", 
            $"Are you sure you want to FORCE DROP the {jackpot.Tier} Jackpot? Current value: {jackpot.CurrentValue:C2}. This will reset the pool and pick a lucky winner from active players.", 
            yesText:"CONFIRM DROP", cancelText:"Cancel");

        if (result == true) {
            await ForceJackpotDrop(jackpot.Id, jackpot.Name);
        }
    }

    private async Task ForceJackpotDrop(Guid id, string name) {
        var winner = await AdminService.ForceJackpotDrop(id);
        if (winner != null || true) { // winner might be null if no online players, but success is still possible
            string winnerMsg = !string.IsNullOrEmpty(winner) 
                ? $"Winner: {winner}!" 
                : "A lucky player has been awarded!";
                
            Snackbar.Add($"SUCCESS: {name} dropped! {winnerMsg}", Severity.Success);
            await LoadJackpots();
        } else {
            Snackbar.Add("Failed to trigger jackpot drop.", Severity.Error);
        }
    }

    private string GetJackpotInfo(string tier) => tier.ToLower() switch {
        "mega" => "Seeds: $10,000 | Contrib: 0.05% | Prob: 1:1,000,000 | Uncapped",
        "major" => "Seeds: $1,000 | Contrib: 0.20% | Prob: 1:50,000 | Cap: $50,000",
        "minor" => "Fixed: 5000x Denom | Hard-cap: 3 per bonus | Clover Chase specific.",
        "mini" => "Fixed: 1000x Denom | High probability | Clover Chase specific.",
        "tournament" => "Base Pool: $25,000 | Grows via rollover and bets. Paid monthly based on ROI.",
        "grand" => "Seeds: $10,000 | Prob: 1:20,000 | High-tier progressive pool.",
        _ => "Progressive platform jackpot pool."
    };

    private async Task LoadGlobalSettings() {
        try {
            _globalSettings = await Http.GetFromJsonAsync<List<GlobalSettingDto>>("api/Admin/settings/global") ?? new();
            
            _targetRtp = GetDecimalSetting("GlobalTargetRtp", 95.0m);
            _volatilityMode = GetStringSetting("VolatilityMode", "Medium");
            _emergencyStop = GetBoolSetting("EmergencyStop", false);
            _shadowMode = GetBoolSetting("GlobalShadowMode", false);
            _minBet = GetDecimalSetting("Risk_MinBet", 0.10m);
            _maxBet = GetDecimalSetting("Risk_MaxBet", 1000.0m);

            _faucetAmount = GetDecimalSetting("Economy_FaucetAmount", 100);
            _faucetThreshold = GetDecimalSetting("Economy_FaucetThreshold", 10);
            _baseCashback = GetDecimalSetting("Economy_CashbackPercent", 10);
            _welcomeBonus = GetDecimalSetting("Economy_WelcomeBonus", 5000);
            _xpMultiplier = GetDecimalSetting("Economy_XpMultiplier", 1.0m);
            _tournamentPrizePool = GetDecimalSetting("TournamentPrizePool", 25000);

            _chatEnabled = GetBoolSetting("Community_ChatEnabled", true);
            _minLevelChat = GetIntSetting("Community_MinLevelChat", 1);
            _chatSlowMode = GetIntSetting("Community_ChatSlowMode", 0);
            _prohibitedWords = GetStringSetting("Community_ProhibitedWords", "");

            _platformName = GetStringSetting("Content_PlatformName", "AleaSim");
            _contentHelp = GetStringSetting("Content_Help", "");
            _contentTerms = GetStringSetting("Content_Terms", "");
            _contentPrivacy = GetStringSetting("Content_Privacy", "");

            _perfLogging = GetBoolSetting("System_PerfLogging", false);

        } catch {}
    }

    private async Task SaveAllChanges() {
        try {
            var tasks = new List<Task>();
            tasks.Add(SaveSetting("GlobalTargetRtp", _targetRtp.ToString()));
            tasks.Add(SaveSetting("VolatilityMode", _volatilityMode));
            tasks.Add(SaveSetting("EmergencyStop", _emergencyStop.ToString().ToLower()));
            tasks.Add(SaveSetting("GlobalShadowMode", _shadowMode.ToString().ToLower()));
            tasks.Add(SaveSetting("Risk_MinBet", _minBet.ToString()));
            tasks.Add(SaveSetting("Risk_MaxBet", _maxBet.ToString()));

            tasks.Add(SaveSetting("Economy_FaucetAmount", _faucetAmount.ToString()));
            tasks.Add(SaveSetting("Economy_FaucetThreshold", _faucetThreshold.ToString()));
            tasks.Add(SaveSetting("Economy_CashbackPercent", _baseCashback.ToString()));
            tasks.Add(SaveSetting("Economy_WelcomeBonus", _welcomeBonus.ToString()));
            tasks.Add(SaveSetting("Economy_XpMultiplier", _xpMultiplier.ToString()));
            tasks.Add(SaveSetting("TournamentPrizePool", _tournamentPrizePool.ToString()));

            tasks.Add(SaveSetting("Community_ChatEnabled", _chatEnabled.ToString().ToLower()));
            tasks.Add(SaveSetting("Community_MinLevelChat", _minLevelChat.ToString()));
            tasks.Add(SaveSetting("Community_ChatSlowMode", _chatSlowMode.ToString()));
            tasks.Add(SaveSetting("Community_ProhibitedWords", _prohibitedWords));

            tasks.Add(SaveSetting("Content_PlatformName", _platformName));
            tasks.Add(SaveSetting("Content_Help", _contentHelp));
            tasks.Add(SaveSetting("Content_Terms", _contentTerms));
            tasks.Add(SaveSetting("Content_Privacy", _contentPrivacy));

            tasks.Add(SaveSetting("System_PerfLogging", _perfLogging.ToString().ToLower()));

            await Task.WhenAll(tasks);
            
            // Sync specific services that might be caching these
            await AdminService.UpdateRtp(_targetRtp);
            await AdminService.UpdateVolatility(_volatilityMode);
            await AdminService.ToggleEmergencyStop(_emergencyStop);

            Snackbar.Add("Configuration Deployed Successfully!", Severity.Success);
        } catch (Exception ex) {
            Snackbar.Add($"Deployment failed: {ex.Message}", Severity.Error);
        }
    }

    private decimal GetDecimalSetting(string key, decimal def) => decimal.TryParse(_globalSettings.FirstOrDefault(s => s.Key == key)?.Value, out var v) ? v : def;
    private string GetStringSetting(string key, string def) => _globalSettings.FirstOrDefault(s => s.Key == key)?.Value ?? def;
    private bool GetBoolSetting(string key, bool def) => bool.TryParse(_globalSettings.FirstOrDefault(s => s.Key == key)?.Value, out var v) ? v : def;
    private int GetIntSetting(string key, int def) => int.TryParse(_globalSettings.FirstOrDefault(s => s.Key == key)?.Value, out var v) ? v : def;

    private async Task SaveSetting(string key, string value) { await Http.PostAsJsonAsync("api/Admin/settings/update", new { Key = key, Value = value }); }

    private async Task LoadCurrentPlatformStats() {
        try {
            var stats = await AdminService.GetDashboardStats();
            _targetRtp = Math.Round(stats.CurrentRtp > 0 ? stats.CurrentRtp : 95.0m, 2);
            _emergencyStop = stats.IsEmergencyStopActive;
        } catch {}
    }

    private async Task RunIntegrityCheck() {
        _verifyingIntegrity = true;
        _integrityResult = await AdminService.VerifyIntegrity();
        _verifyingIntegrity = false;
    }

    private async Task OnClearCache() { await AdminService.TriggerAction("ClearCache"); Snackbar.Add("Memory Cache Purged", Severity.Success); }
    private async Task OnRestartRng() { await AdminService.TriggerAction("RestartRng"); Snackbar.Add("RNG Service Synchronized", Severity.Warning); }
    private async Task OnTriggerBackup() { await AdminService.TriggerAction("BackupDb"); Snackbar.Add("Manual Backup Initialized", Severity.Info); }

    public void Dispose() { RealTime.OnJackpotUpdated -= HandleJackpotUpdate; }
    public class GlobalSettingDto { public string Key { get; set; } = ""; public string Value { get; set; } = ""; }
}
