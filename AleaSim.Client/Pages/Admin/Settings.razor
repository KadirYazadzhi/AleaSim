@page "/admin/settings"
@using AleaSim.Client.Services
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@implements IDisposable
@inject IAdminService AdminService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LayoutService LayoutService
@inject RealTimeClient RealTime
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 mb-16 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-space-between align-md-center mb-8 gap-4">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black mb-1 settings-title text-gradient">CONTROL CENTER</MudText>
            <MudText Typo="Typo.subtitle1" Class="opacity-60 d-none d-sm-block">Architect the platform's economy and risk.</MudText>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadAll" StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="flex-grow-1">Sync</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAllChanges" StartIcon="@Icons.Material.Filled.Save" Size="Size.Small" Class="flex-grow-1">Deploy</MudButton>
        </div>
    </div>

    <MudTabs Elevation="4" Rounded="true" Color="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pa-md-8 pa-4 custom-settings-tabs" Class="rounded-xl overflow-hidden shadow-2xl">
        
        <!-- 1. RISK & GAME ENGINE -->
        <MudTabPanel Text="RISK" Icon="@Icons.Material.Filled.SettingsInputComponent">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="8">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-6">Mathematical Core</MudText>
                        <MudGrid Spacing="4">
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Class="fw-bold mb-1">Global Target RTP</MudText>
                                <div class="d-flex align-center gap-4 pa-4 bg-grey-darken-4 rounded-lg">
                                    <MudSlider T="decimal" @bind-Value="_targetRtp" Min="80" Max="105" Step="0.1m" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Class="fw-black text-primary" Style="min-width: 70px;">@_targetRtp.ToString("F1")%</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="string" @bind-Value="_volatilityMode" Label="Volatility" Variant="Variant.Outlined">
                                    <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                                    <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                                    <MudSelectItem Value="@("High")">High</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudItem>

                <MudItem xs="12" md="4">
                    <div class="settings-group-card h-100 border-error-subtle">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4 text-error">Kill-Switch</MudText>
                        <div class='@($"emergency-box {(_emergencyStop ? "active" : "")}")'>
                            <MudSwitch @bind-Value="_emergencyStop" Color="Color.Error" UncheckedColor="Color.Success" Size="Size.Large" T="bool" />
                            <MudText Typo="Typo.h5" Class="fw-black mt-2">@(_emergencyStop ? "HALTED" : "ONLINE")</MudText>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- 2. ECONOMY -->
        <MudTabPanel Text="ECON" Icon="@Icons.Material.Filled.AccountBalance">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Relief (Faucet)</MudText>
                        <MudStack Spacing="3">
                            <MudNumericField @bind-Value="_faucetAmount" Label="Amount ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudNumericField @bind-Value="_faucetThreshold" Label="Threshold ($)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudStack>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Cashback</MudText>
                        <MudNumericField @bind-Value="_baseCashback" Label="Base (%)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- 3. JACKPOTS -->
        <MudTabPanel Text="POTS" Icon="@Icons.Material.Filled.Diamond">
            <div class="settings-group-card">
                <div class="table-responsive">
                    <MudTable Items="@_jackpots" Hover="true" Dense="true" Elevation="0" Class="bg-transparent">
                        <HeaderContent>
                            <MudTh>TIER</MudTh>
                            <MudTh>VALUE</MudTh>
                            <MudTh>ACTION</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Tier.ToUpper()</MudTd>
                            <MudTd>@context.CurrentValue.ToString("C2")</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.FlashOn" Color="Color.Error" Size="Size.Small" OnClick="() => ForceJackpotDrop(context.Id)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </div>
        </MudTabPanel>

        <!-- 4. SYSTEM -->
        <MudTabPanel Text="SYS" Icon="@Icons.Material.Filled.Dns">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <div class="settings-group-card">
                        <MudText Typo="Typo.h6" Class="fw-black mb-6 text-center">Integrity</MudText>
                        <div class="d-flex flex-column align-center py-4">
                            <div class='@($"integrity-shield {(_integrityResult?.IsValid == true ? "secure" : "warning")}")'>
                                <MudIcon Icon="@(_integrityResult?.IsValid == true ? Icons.Material.Filled.GppGood : Icons.Material.Filled.GppMaybe)" Style="font-size: 3rem;" />
                            </div>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true" Class="py-3 rounded-lg fw-black" OnClick="RunIntegrityCheck" Disabled="_verifyingIntegrity">SCAN</MudButton>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <div class="settings-group-card h-100">
                        <MudText Typo="Typo.h6" Class="fw-black mb-4">Maint</MudText>
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.CleaningServices" FullWidth="true" OnClick="OnClearCache" Size="Size.Small">Purge Cache</MudButton>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.RestartAlt" FullWidth="true" OnClick="OnRestartRng" Size="Size.Small">Reseed RNG</MudButton>
                        </MudStack>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

<style>
    .table-responsive { width: 100%; overflow-x: auto; }
    
    @@media (max-width: 600px) {
        .settings-title { font-size: 1.75rem !important; }
        .settings-group-card { padding: 1.5rem !important; }
    }

    .fw-black { font-weight: 950; }
    .fw-bold { font-weight: 700; }
    .text-gradient { background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .custom-settings-tabs { background: var(--mud-palette-surface); }
    .settings-group-card { padding: 32px; border-radius: 24px; background: var(--mud-palette-background-grey); border: 1px solid var(--mud-palette-divider); }
    
    .bg-grey-darken-4 { background: rgba(0,0,0,0.2); }
    .border-error-subtle { border-color: rgba(var(--mud-palette-error-rgb), 0.3); }

    .emergency-box { padding: 24px; border-radius: 16px; border: 2px solid var(--mud-palette-success); background: rgba(var(--mud-palette-success-rgb), 0.05); color: var(--mud-palette-success); text-align: center; transition: all 0.3s; }
    .emergency-box.active { border-color: var(--mud-palette-error); background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); animation: pulse-error 2s infinite; }

    .integrity-shield { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid var(--mud-palette-divider); transition: all 0.5s; }
    .integrity-shield.secure { border-color: var(--mud-palette-success); color: var(--mud-palette-success); background: rgba(var(--mud-palette-success-rgb), 0.05); }
    .integrity-shield.warning { border-color: var(--mud-palette-warning); color: var(--mud-palette-warning); background: rgba(var(--mud-palette-warning-rgb), 0.05); }

    @@keyframes pulse-error { 0% { box-shadow: 0 0 0 0 rgba(var(--mud-palette-error-rgb), 0.4); } 70% { box-shadow: 0 0 0 15px rgba(var(--mud-palette-error-rgb), 0); } 100% { box-shadow: 0 0 0 0 rgba(var(--mud-palette-error-rgb), 0); } }
</style>

@code {
    private decimal _targetRtp = 95.0m;
    private string _volatilityMode = "Medium";
    private bool _emergencyStop = false;
    private decimal _faucetAmount = 100.0m;
    private decimal _faucetThreshold = 10.0m;
    private decimal _baseCashback = 10.0m;
    private bool _verifyingIntegrity = false;
    private IntegrityResponse? _integrityResult;
    private List<GlobalSettingDto> _globalSettings = new();
    private List<JackpotDto> _jackpots = new();

    protected override async Task OnInitializedAsync() {
        RealTime.OnJackpotUpdated += HandleJackpotUpdate;
        await LoadAll();
    }

    private void HandleJackpotUpdate(JackpotDto dto) {
        var existing = _jackpots.FirstOrDefault(j => j.Id == dto.Id);
        if (existing != null) {
            existing.CurrentValue = dto.CurrentValue;
            existing.MustDropAt = dto.MustDropAt;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAll() {
        await LoadCurrentPlatformStats();
        await LoadGlobalSettings();
        await LoadJackpots();
    }

    private async Task LoadJackpots() {
        try {
            _jackpots = await Http.GetFromJsonAsync<List<JackpotDto>>("api/Admin/jackpots") ?? new();
        } catch {}
    }

    private async Task ForceJackpotDrop(Guid id) {
        var response = await Http.PostAsync($"api/Admin/jackpots/{id}/force-drop", null);
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Jackpot dropped!", Severity.Success);
            await LoadJackpots();
        }
    }

    private async Task LoadGlobalSettings() {
        try {
            _globalSettings = await Http.GetFromJsonAsync<List<GlobalSettingDto>>("api/Admin/settings/global") ?? new();
            _faucetAmount = GetDecimalSetting("Economy_FaucetAmount", 100);
            _faucetThreshold = GetDecimalSetting("Economy_FaucetThreshold", 10);
            _baseCashback = GetDecimalSetting("Economy_CashbackPercent", 10);
        } catch {}
    }

    private async Task SaveAllChanges() {
        await SaveSetting("Economy_FaucetAmount", _faucetAmount.ToString());
        await SaveSetting("Economy_FaucetThreshold", _faucetThreshold.ToString());
        await SaveSetting("Economy_CashbackPercent", _baseCashback.ToString());
        await AdminService.UpdateRtp(_targetRtp);
        await AdminService.UpdateVolatility(_volatilityMode);
        await AdminService.ToggleEmergencyStop(_emergencyStop);
        Snackbar.Add("Deployed!", Severity.Success);
    }

    private decimal GetDecimalSetting(string key, decimal def) => decimal.TryParse(_globalSettings.FirstOrDefault(s => s.Key == key)?.Value, out var v) ? v : def;
    private async Task SaveSetting(string key, string value) { await Http.PostAsJsonAsync("api/Admin/settings/update", new { Key = key, Value = value }); }

    private async Task LoadCurrentPlatformStats() {
        try {
            var stats = await AdminService.GetDashboardStats();
            _targetRtp = Math.Round(stats.CurrentRtp > 0 ? stats.CurrentRtp : 95.0m, 2);
            _emergencyStop = stats.IsEmergencyStopActive;
        } catch {}
    }

    private async Task RunIntegrityCheck() {
        _verifyingIntegrity = true;
        _integrityResult = await AdminService.VerifyIntegrity();
        _verifyingIntegrity = false;
    }

    private async Task OnClearCache() { await AdminService.TriggerAction("ClearCache"); Snackbar.Add("Cache Cleared", Severity.Success); }
    private async Task OnRestartRng() { await AdminService.TriggerAction("RestartRng"); Snackbar.Add("RNG Restarted", Severity.Warning); }

    public void Dispose() { RealTime.OnJackpotUpdated -= HandleJackpotUpdate; }
    public class GlobalSettingDto { public string Key { get; set; } = ""; public string Value { get; set; } = ""; }
}