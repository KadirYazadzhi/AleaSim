@page "/admin/simulation"
@using AleaSim.Client.Services
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject IAdminService AdminService
@inject SimulationStateService SimState
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LayoutService LayoutService
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 mb-16 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-space-between align-md-center mb-8 gap-4">
        <div>
            <MudText Typo="Typo.h3" Class="text-gradient fw-black mb-1 sim-title">SIM CENTER</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary d-none d-sm-block">Stress test game engines and mathematical integrity.</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" OnClick="RefreshHistory" Size="Size.Small">Refresh History</MudButton>
    </div>

    <MudGrid>
        <!-- Simulation Control -->
        <MudItem xs="12" lg="4">
            <div class="stats-card pa-md-8 pa-4 rounded-xl h-100 relative overflow-hidden">
                <MudText Typo="Typo.h5" Class="fw-bold mb-6">New Simulation</MudText>
                
                <MudSelect T="string" @bind-Value="GameType" Label="Game Engine" Variant="Variant.Outlined" Class="mb-4 glass-input" Disabled="@SimState.IsSimulationRunning">
                    <MudSelectItem Value="@("Slot")">Clover Chase</MudSelectItem>
                    <MudSelectItem Value="@("FruitBlast")">Fruit Blast</MudSelectItem>
                    <MudSelectItem Value="@("Roulette")">Roulette</MudSelectItem>
                    <MudSelectItem Value="@("Blackjack")">Blackjack</MudSelectItem>
                    <MudSelectItem Value="@("Baccarat")">Baccarat</MudSelectItem>
                    <MudSelectItem Value="@("Dice")">Dice</MudSelectItem>
                </MudSelect>

                @if (_request.GameType == "Roulette")
                {
                    <MudSelect T="string" @bind-Value="_request.GameMode" Label="Roulette Mode" Variant="Variant.Outlined" Class="mb-4 glass-input" Disabled="@SimState.IsSimulationRunning">
                        <MudSelectItem Value="@("Classic")">Classic (36x)</MudSelectItem>
                        <MudSelectItem Value="@("Extreme")">Extreme (Multipliers)</MudSelectItem>
                    </MudSelect>
                }
                else if (_request.GameType == "Dice")
                {
                    <MudSelect T="string" @bind-Value="_request.GameMode" Label="Dice Strategy" Variant="Variant.Outlined" Class="mb-4 glass-input" Disabled="@SimState.IsSimulationRunning">
                        <MudSelectItem Value="@("Slider")">Slider (50/50)</MudSelectItem>
                        <MudSelectItem Value="@("Multi")">Multi (Single Number)</MudSelectItem>
                    </MudSelect>
                }

                <div class="d-flex gap-2 mb-4">
                    <MudNumericField T="decimal" @bind-Value="_request.BetAmount" Label="Bet" Variant="Variant.Outlined" Min="0.1m" Max="1000" Step="1" Format="C2" Class="flex-grow-1" Disabled="@SimState.IsSimulationRunning" Margin="Margin.Dense" />
                    <MudSelect T="int" @bind-Value="_request.Iterations" Label="Rounds" Variant="Variant.Outlined" Class="flex-grow-1" Disabled="@SimState.IsSimulationRunning" Margin="Margin.Dense">
                        <MudSelectItem Value="100">100</MudSelectItem>
                        <MudSelectItem Value="1000">1K</MudSelectItem>
                        <MudSelectItem Value="5000">5K</MudSelectItem>
                        <MudSelectItem Value="10000">10K</MudSelectItem>
                    </MudSelect>
                </div>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="RunSimulation" Disabled="@SimState.IsSimulationRunning" Size="Size.Large" Class="rounded-lg py-4 pulse-neon">
                    @if (SimState.IsSimulationRunning) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/> <MudText Class="ms-2">BUSY</MudText> }
                    else { <MudText>LAUNCH</MudText> }
                </MudButton>

                @if (SimState.IsSimulationRunning) {
                    <MudProgressLinear Color="Color.Info" Indeterminate="true" Class="mt-4 rounded-xl" />
                }
            </div>
        </MudItem>

        <!-- Current/Last Result -->
        <MudItem xs="12" lg="8">
            <div class="stats-card pa-md-8 pa-4 rounded-xl h-100 relative">
                @if (SimState.IsSimulationRunning)
                {
                    <div class="d-flex flex-column align-center justify-center h-100 py-12">
                        <div class="simulation-loader mb-4">
                            <div class="inner-circle"></div>
                            <div class="outer-glow"></div>
                        </div>
                        <MudText Typo="Typo.h5" Class="fw-black mb-1">IN PROGRESS</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Running @SimState.ActiveRequest?.Iterations.ToString("N0") iterations...</MudText>
                    </div>
                }
                else if (_lastReport == null)
                {
                    <div class="d-flex flex-column align-center justify-center h-100 opacity-50 py-12">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Style="font-size: 5rem;" />
                        <MudText>Ready for deployment</MudText>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-space-between align-start mb-6">
                        <div>
                            <MudText Typo="Typo.h5" Class="fw-black">@_lastReport.GameType ANALYSIS</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Time: @((_lastReport.ExecutionTimeMs / 1000.0).ToString("F2"))s</MudText>
                        </div>
                        <MudChip T="string" Color="@(GetRtpColor((double)_lastReport.ActualRTP))" Variant="Variant.Filled" Class="fw-bold">@_lastReport.ActualRTP.ToString("F1")% RTP</MudChip>
                    </div>

                    <MudGrid Class="mb-6">
                        <MudItem xs="12" sm="4">
                            <div class="pa-3 glass-inner rounded-lg text-center">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase">Bet</MudText>
                                <MudText Typo="Typo.body1" Class="fw-black">@_lastReport.TotalBet.ToString("C0")</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <div class="pa-3 glass-inner rounded-lg text-center">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase">Win</MudText>
                                <MudText Typo="Typo.body1" Class="fw-black text-success">@_lastReport.TotalWin.ToString("C0")</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <div class="pa-3 glass-inner rounded-lg text-center">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase">Max</MudText>
                                <MudText Typo="Typo.body1" Class="fw-black text-warning">@_lastReport.MaxWin.ToString("C0")</MudText>
                            </div>
                        </MudItem>
                    </MudGrid>

                    <div class="mt-4">
                        <MudText Typo="Typo.caption" Class="mb-2 fw-bold d-block">DECISION ENGINE LOGIC</MudText>
                        <div class="d-flex flex-column gap-2">
                             @foreach(var kv in _lastReport.DecisionDistribution) {
                                 <div>
                                     <div class="d-flex justify-space-between mb-1">
                                         <MudText Typo="Typo.caption" Class="text-xs">@kv.Key</MudText>
                                         <MudText Typo="Typo.caption" Class="fw-bold text-xs">@((kv.Value * 100.0 / _lastReport.TotalIterations).ToString("F0"))%</MudText>
                                     </div>
                                     <MudProgressLinear Value="@(kv.Value * 100.0 / _lastReport.TotalIterations)" Color="@(GetDecisionColor(kv.Key))" Rounded="true" Size="Size.Small" />
                                 </div>
                             }
                        </div>
                    </div>
                }
            </div>
        </MudItem>

        <!-- History Table -->
        <MudItem xs="12">
            <div class="stats-card pa-md-6 pa-2 rounded-xl">
                <MudText Typo="Typo.h6" Class="fw-bold mb-4 ml-2">History</MudText>
                <div class="table-responsive">
                    <MudTable Items="@_historyItems" Dense="true" Hover="true" Elevation="0" Class="bg-transparent" RowsPerPage="5">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Game</MudTh>
                            <MudTh>Iter</MudTh>
                            <MudTh>RTP</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Log.Timestamp.ToLocalTime().ToString("MM/dd HH:mm")</MudTd>
                            <MudTd>@context.Report?.GameType</MudTd>
                            <MudTd>@(context.Report?.TotalIterations)</MudTd>
                            <MudTd>
                                <MudText Color="@(GetRtpColor((double)(context.Report?.ActualRTP ?? 0)))" Class="fw-bold">
                                    @(context.Report?.ActualRTP.ToString("F1"))%
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ShowDetails(context))" />
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] {5, 10}" />
                        </PagerContent>
                    </MudTable>
                </div>
            </div>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .table-responsive { width: 100%; overflow-x: auto; }
    
    @@media (max-width: 600px) {
        .sim-title { font-size: 1.75rem !important; }
    }

    .fw-black { font-weight: 950; }
    .fw-bold { font-weight: 700; }
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .stats-card {
        background: @(LayoutService.IsDarkMode ? "rgba(30, 41, 59, 0.7)" : "rgba(255, 255, 255, 0.7)");
        backdrop-filter: blur(12px);
        border: 1px solid var(--mud-palette-divider);
    }
    .glass-inner {
        background: @(LayoutService.IsDarkMode ? "rgba(0, 0, 0, 0.2)" : "rgba(0, 0, 0, 0.05)");
    }
    .pulse-neon { animation: pulseNeon 2s infinite; }
    @@keyframes pulseNeon {
        0% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(124, 58, 237, 0); }
        100% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0); }
    }
    .animate-fade-in { animation: fadeIn 0.5s ease-out forwards; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .simulation-loader {
        position: relative; width: 64px; height: 64px;
    }
    .inner-circle {
        width: 100%; height: 100%; border: 4px solid var(--mud-palette-primary);
        border-top-color: transparent; border-radius: 50%;
        animation: spin 1s linear infinite;
    }
    .outer-glow {
        position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px;
        border: 2px solid var(--mud-palette-primary); border-radius: 50%;
        opacity: 0.2; animation: pulse 2s ease-out infinite;
    }

    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    @@keyframes pulse { 0% { transform: scale(0.8); opacity: 0.5; } 100% { transform: scale(1.2); opacity: 0; } }
</style>

@code {
    private SimulationRequest _request = new() { GameType = "Slot", BetAmount = 1.0m, Iterations = 1000 };
    
    private string GameType {
        get => _request.GameType;
        set {
            if (_request.GameType != value) {
                _request.GameType = value;
                // Set default modes
                if (value == "Roulette") _request.GameMode = "Classic";
                else if (value == "Dice") _request.GameMode = "Slider";
                else _request.GameMode = null;
            }
        }
    }

    private SimulationReport? _lastReport;
    private List<SimHistoryItem> _historyItems = new();

    public class SimHistoryItem {
        public AuditLogDto Log { get; set; } = new();
        public SimulationReport? Report { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        LayoutService.OnMajorUpdate += StateHasChanged;
        SimState.OnStateChanged += StateHasChanged;
        await RefreshHistory();
    }

    private async Task RefreshHistory()
    {
        try {
            var logs = await AdminService.GetSimulationHistory();
            _historyItems = logs.Select(l => new SimHistoryItem {
                Log = l,
                Report = TryDeserialize(l.MetadataJson)
            }).ToList();
        } catch {}
    }

    private SimulationReport? TryDeserialize(string json) {
        try { return JsonSerializer.Deserialize<SimulationReport>(json); } catch { return null; }
    }

    private async Task RunSimulation()
    {
        SimState.StartSimulation(_request);
        StateHasChanged();

        try {
            _lastReport = await AdminService.RunSimulation(_request);
            if (_lastReport != null) {
                Snackbar.Add($"{_request.GameType} simulation complete!", Severity.Success);
                await RefreshHistory();
            }
        } catch (Exception ex) {
            Snackbar.Add($"Simulation failed: {ex.Message}", Severity.Error);
        } finally {
            SimState.FinishSimulation();
            StateHasChanged();
        }
    }

    private Color GetRtpColor(double rtp) => rtp switch {
        > 100 => Color.Error,
        > 98 => Color.Warning,
        > 90 => Color.Success,
        _ => Color.Info
    };

    private Color GetDecisionColor(string type) => type switch {
        "Random" => Color.Primary,
        "RetentionHook" => Color.Success,
        "RTP Correction (High)" => Color.Error,
        _ => Color.Default
    };

    private void ShowDetails(SimHistoryItem item) {
        if (item.Report != null) {
            _lastReport = item.Report;
            Snackbar.Add("Report loaded", Severity.Info);
        }
    }

    public void Dispose() {
        LayoutService.OnMajorUpdate -= StateHasChanged;
        SimState.OnStateChanged -= StateHasChanged;
    }
}