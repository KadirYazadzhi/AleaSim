@page "/admin/errors"
@using AleaSim.Shared.Models
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 pb-16 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-space-between align-md-center mb-8 gap-4">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black text-error exceptions-title">SYSTEM EXCEPTIONS</MudText>
            <MudText Typo="Typo.subtitle1" Class="opacity-60 d-none d-sm-block">Real-time database-logged application errors.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearErrors" Class="fw-black py-3 px-6 rounded-lg purge-btn-mobile">PURGE ALL</MudButton>
    </div>

<style>
    @@media (max-width: 600px) {
        .exceptions-title { font-size: 1.75rem !important; }
        .purge-btn-mobile { width: 100% !important; }
    }
    .fw-black { font-weight: 900; }
    .animate-fade-in { animation: fadeIn 0.5s ease-out forwards; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

    <MudPaper Class="pa-6 rounded-xl" Elevation="4">
        @if (errors == null) {
            <div class="d-flex justify-center pa-12">
                <MudProgressCircular Indeterminate="true" Color="Color.Error" Size="Size.Large" />
            </div>
        } else if (!errors.Any()) {
            <div class="text-center py-12 opacity-20">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 6rem;" />
                <MudText Typo="Typo.h5">System is running clean.</MudText>
            </div>
        } else {
            <MudTable Items="@errors" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true" FixedHeader="true" Height="600px">
                <HeaderContent>
                    <MudTh>TIME</MudTh>
                    <MudTh>MESSAGE</MudTh>
                    <MudTh>PATH</MudTh>
                    <MudTh>USER</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="TIME">@context.CreatedAt.ToString("HH:mm:ss")</MudTd>
                    <MudTd DataLabel="MESSAGE">
                        <MudText Color="Color.Error" Class="fw-bold" Style="font-size: 0.8rem;">@context.Message</MudText>
                    </MudTd>
                    <MudTd DataLabel="PATH"><code>@context.Path</code></MudTd>
                    <MudTd DataLabel="USER">@(context.UserId ?? "Guest")</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" OnClick="() => InspectError(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private List<SystemErrorDto>? errors;

    protected override async Task OnInitializedAsync() {
        await LoadErrors();
    }

    private async Task LoadErrors() {
        errors = await Http.GetFromJsonAsync<List<SystemErrorDto>>("api/Admin/system/errors");
    }

    private async Task ClearErrors() {
        await Http.DeleteAsync("api/Admin/system/errors");
        Snackbar.Add("Error logs purged.", Severity.Info);
        await LoadErrors();
    }

    private async Task InspectError(SystemErrorDto error) {
        await Http.PostAsJsonAsync("api/Admin/debug/echo", error); // Just example
        Snackbar.Add("Full stacktrace sent to developer console.", Severity.Warning);
        Console.WriteLine(error.StackTrace);
    }
}
