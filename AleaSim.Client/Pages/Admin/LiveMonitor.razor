@page "/admin/monitor"
@using AleaSim.Client.Services
@using System.Collections.Concurrent
@layout AleaSim.Client.Layout.AdminLayout
@implements IDisposable
@inject RealTimeClient RealTime

<MudText Typo="Typo.h4" Class="mb-4">Live Activity Stream</MudText>

<MudTable Items="@events" Hover="true" Dense="true" Elevation="2">
    <HeaderContent>
        <MudTh>Time</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Details</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Time">@context.Timestamp.ToLongTimeString()</MudTd>
        <MudTd DataLabel="Type">
            <MudChip T="string" Color="@GetColor(context.Type)" Size="Size.Small">@context.Type</MudChip>
        </MudTd>
        <MudTd DataLabel="Details" Style="font-family: monospace;">@context.Data</MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <div class="pa-12 d-flex flex-column align-center justify-center">
            <MudIcon Icon="@Icons.Material.Filled.Stream" Color="Color.Surface" Style="font-size: 3rem; opacity: 0.2;" Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mud-text-secondary">Waiting for live activity...</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">New bets and wins will appear here in real-time.</MudText>
        </div>
    </NoRecordsContent>
</MudTable>

@code {
    private List<StreamEvent> events = new();

    protected override void OnInitialized() {
        // We reuse the existing events, but in a real admin app we'd need a dedicated "AdminHub" channel
        // For now, we listen to public broadcasts + simulate catching others if we were on a firehose
        RealTime.OnGameUpdateReceived += OnGameUpdate;
        RealTime.OnBigWinReceived += OnBigWin;
    }

    private void OnGameUpdate(object data) {
        AddEvent("GameAction", data.ToString() ?? "{}");
    }

    private void OnBigWin(BigWinEventArgs args) {
        AddEvent("BigWin", $"{args.Username} won {args.Amount:C} on {args.GameName}");
    }

    private void AddEvent(string type, string data) {
        events.Insert(0, new StreamEvent(DateTime.Now, type, data));
        if (events.Count > 50) events.RemoveAt(50);
        InvokeAsync(StateHasChanged);
    }

    private Color GetColor(string type) => type switch {
        "BigWin" => Color.Warning,
        "GameAction" => Color.Info,
        _ => Color.Default
    };

    public void Dispose() {
        RealTime.OnGameUpdateReceived -= OnGameUpdate;
        RealTime.OnBigWinReceived -= OnBigWin;
    }

    private record StreamEvent(DateTime Timestamp, string Type, string Data);
}