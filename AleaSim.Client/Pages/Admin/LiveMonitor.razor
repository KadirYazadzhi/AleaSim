@page "/admin/monitor"
@using AleaSim.Client.Services
@using System.Collections.Concurrent
@layout AleaSim.Client.Layout.AdminLayout
@implements IDisposable
@inject RealTimeClient RealTime
@inject IAdminService AdminService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 pb-16">
    <div class="d-flex justify-space-between align-center mb-8">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black mb-2">Platform Sentinel</MudText>
            <div class="d-flex align-center gap-2">
                <div class="live-pulse"></div>
                <MudText Typo="Typo.subtitle1" Class="opacity-60 fw-bold">Live real-time activity stream and health metrics.</MudText>
            </div>
        </div>
        <div class="d-flex gap-4">
            <div class="status-box">
                <MudText Typo="Typo.caption" Class="fw-black opacity-40">SIGNALR</MudText>
                @if (RealTime.IsConnected) {
                    <MudText Typo="Typo.body2" Class="fw-black text-success">CONNECTED</MudText>
                } else {
                    <MudText Typo="Typo.body2" Class="fw-black text-error">@RealTime.State.ToString().ToUpper()</MudText>
                }
            </div>
            <div class="status-box">
                <MudText Typo="Typo.caption" Class="fw-black opacity-40">EVENTS/MIN</MudText>
                <MudText Typo="Typo.body2" Class="fw-black">@eventsPerMinute</MudText>
            </div>
        </div>
    </div>

    <!-- Live Metrics Grid -->
    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-6 metric-card" Elevation="2">
                <MudText Typo="Typo.caption" Class="fw-black opacity-40">SESSION VOLUME (LB)</MudText>
                <MudText Typo="Typo.h4" Class="fw-black">@totalBets.ToString("C0")</MudText>
                <MudProgressLinear Color="Color.Primary" Value="75" Class="mt-2" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-6 metric-card" Elevation="2">
                <MudText Typo="Typo.caption" Class="fw-black opacity-40">PAYOUTS (LB)</MudText>
                <MudText Typo="Typo.h4" Class="fw-black text-warning">@totalWins.ToString("C0")</MudText>
                <MudProgressLinear Color="Color.Warning" Value="60" Class="mt-2" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-6 metric-card" Elevation="2">
                <MudText Typo="Typo.caption" Class="fw-black opacity-40">GGR (NET HOUSE)</MudText>
                <MudText Typo="Typo.h4" Class='@($"fw-black {(totalBets - totalWins >= 0 ? "text-success" : "text-error")}")'>@((totalBets - totalWins).ToString("C0"))</MudText>
                <MudProgressLinear Color="Color.Success" Value="100" Class="mt-2" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-6 metric-card" Elevation="2">
                <MudText Typo="Typo.caption" Class="fw-black opacity-40">ACTIVE PLAYERS</MudText>
                <MudText Typo="Typo.h4" Class="fw-black text-info">@activeUserCount</MudText>
                <MudProgressLinear Color="Color.Info" Value="45" Class="mt-2" />
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Main Live Table -->
    <MudPaper Class="pa-8 rounded-xl overflow-hidden" Elevation="4">
        <div class="d-flex justify-space-between align-center mb-6">
            <div class="d-flex align-center gap-4">
                <MudText Typo="Typo.h5" Class="fw-black">Activity Pipeline</MudText>
                <MudSwitch T="bool" @bind-Value="showOnlyBigWins" Color="Color.Warning" Label="Only Big Wins" Class="ml-4" />
                <MudNumericField T="decimal" @bind-Value="minBetFilter" Label="Min Bet ($)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 120px;" />
            </div>
            <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.ClearAll" OnClick="() => events.Clear()">Clear Stream</MudButton>
        </div>

        <MudTable Items="@FilteredEvents" Hover="true" Dense="true" Elevation="0" Class="modern-monitor-table" FixedHeader="true" Height="600px">
            <HeaderContent>
                <MudTh>TIME</MudTh>
                <MudTh>CONTEXT</MudTh>
                <MudTh>PAYLOAD</MudTh>
                <MudTh Style="text-align: right;">IMPACT</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Time">
                    <MudText Typo="Typo.caption" Class="font-mono opacity-60">@context.Timestamp.ToString("HH:mm:ss.fff")</MudText>
                </MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Color="@GetColor(context.Type)" Size="Size.Small" Variant="Variant.Filled" Class="fw-black text-xs">@context.Type.ToUpper()</MudChip>
                </MudTd>
                <MudTd DataLabel="Details">
                    <div class="payload-box">@context.Data</div>
                </MudTd>
                <MudTd DataLabel="Impact" Style="text-align: right;">
                    @if (context.Data.Contains("Win")) {
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Warning" Size="Size.Small" />
                    } else {
                        <MudIcon Icon="@Icons.Material.Filled.TrendingFlat" Class="opacity-20" Size="Size.Small" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="pa-12 d-flex flex-column align-center justify-center text-center opacity-20">
                    <MudIcon Icon="@Icons.Material.Filled.Radar" Style="font-size: 6rem;" />
                    <MudText Typo="Typo.h5" Class="fw-black">SCANNING NETWORK...</MudText>
                    <MudText>Waiting for first event from the game engine.</MudText>
                </div>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudContainer>

<style>
    .fw-black { font-weight: 950; }
    .fw-bold { font-weight: 700; }
    .opacity-60 { opacity: 0.6; }
    .opacity-40 { opacity: 0.4; }
    .font-mono { font-family: 'JetBrains Mono', monospace; }

    .status-box { padding: 8px 16px; background: var(--mud-palette-background-grey); border-radius: 12px; text-align: center; min-width: 100px; }
    .metric-card { border-radius: 20px; border: 1px solid var(--mud-palette-divider); }

    .live-pulse {
        width: 12px; height: 12px; background: #4caf50; border-radius: 50%;
        box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7);
        animation: pulse 2s infinite;
    }

    .modern-monitor-table .mud-table-head .mud-th { font-weight: 900; font-size: 0.7rem; letter-spacing: 1px; color: var(--mud-palette-text-secondary); }
    .modern-monitor-table .mud-table-body .mud-td { padding: 12px 16px; border-bottom: 1px solid var(--mud-palette-divider); }

    .payload-box { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--mud-palette-primary); background: rgba(var(--mud-palette-primary-rgb), 0.05); padding: 4px 12px; border-radius: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 600px; }

    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(76, 175, 80, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(76, 175, 80, 0); }
    }
</style>

@code {
    private List<StreamEvent> events = new();
    private decimal totalBets = 0;
    private decimal totalWins = 0;
    private int activeUserCount = 0;
    private int eventsPerMinute = 0;
    private DateTime lastMinuteStart = DateTime.Now;
    private int minuteCounter = 0;
    private HashSet<string> activeUsers = new();
    
    // Filtering
    private bool showOnlyBigWins = false;
    private decimal minBetFilter = 0;
    private IEnumerable<StreamEvent> FilteredEvents => events.Where(e => 
        (!showOnlyBigWins || e.Type.Equals("BigWin", StringComparison.OrdinalIgnoreCase)) &&
        (e.Bet >= minBetFilter)
    );

    protected override async Task OnInitializedAsync() {
        RealTime.OnAdminEventReceived += OnAdminEvent;
        RealTime.OnBigWinReceived += OnBigWin;

        // Load Initial Stats for Day
        try {
            var stats = await AdminService.GetDashboardStats("Day");
            totalBets = stats.TotalBets;
            totalWins = stats.TotalWins;
            activeUserCount = stats.ActivePlayerCount;
        } catch { }
        
        // Wait for connection if needed
        _ = Task.Run(async () => {
            int retries = 0;
            while (!RealTime.IsConnected && retries < 15) {
                await Task.Delay(1000);
                retries++;
            }
            await RealTime.JoinAdminFeed();
            await InvokeAsync(StateHasChanged);
        });
    }

    private void OnAdminEvent(AdminRoundEvent ev) {
        totalBets += ev.Bet;
        totalWins += ev.Win;
        activeUsers.Add(ev.Username);
        activeUserCount = activeUsers.Count;
        
        AddEvent(ev.Game, $"{ev.Username}: {ev.Bet:C} -> {ev.Win:C} ({ev.Decision})", ev.Bet);
    }

    private void OnBigWin(BigWinEventArgs args) {
        AddEvent("BigWin", $"🏆 {args.Username} hit {args.Amount:C} on {args.GameName}!", 0); // Bet amount is unknown here, default to 0 for BigWin to pass filter
    }

    private void AddEvent(string type, string data, decimal bet) {
        events.Insert(0, new StreamEvent(DateTime.Now, type, data, bet));
        if (events.Count > 100) events.RemoveAt(100);
        
        minuteCounter++;
        if ((DateTime.Now - lastMinuteStart).TotalSeconds >= 60) {
            eventsPerMinute = minuteCounter;
            minuteCounter = 0;
            lastMinuteStart = DateTime.Now;
        }

        InvokeAsync(StateHasChanged);
    }

    private Color GetColor(string type) => type.ToLower() switch {
        "bigwin" => Color.Warning,
        "slot" => Color.Primary,
        "fruitblast" => Color.Tertiary,
        "blackjack" => Color.Secondary,
        "roulette" => Color.Warning,
        _ => Color.Info
    };

    public void Dispose() {
        RealTime.OnAdminEventReceived -= OnAdminEvent;
        RealTime.OnBigWinReceived -= OnBigWin;
    }

    private record StreamEvent(DateTime Timestamp, string Type, string Data, decimal Bet);
}
