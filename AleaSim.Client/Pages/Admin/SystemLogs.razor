@page "/admin/logs"
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject LayoutService LayoutService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 mb-16 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-space-between align-md-center mb-8 gap-4">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black text-gradient audit-title">SYSTEM AUDIT LOGS</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary d-none d-sm-block">Comprehensive history of administrative and critical events.</MudText>
        </div>
        <div class="d-flex align-center gap-2">
             <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VerifyIntegrity" StartIcon="@Icons.Material.Filled.Security" Class="flex-grow-1 flex-md-grow-0 py-2">VERIFY LEDGER</MudButton>
             <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadLogs" Color="Color.Inherit" Size="Size.Small" />
        </div>
    </div>

    <MudPaper Class="pa-6 rounded-xl dashboard-card" Elevation="0">
        <MudTable T="AuditLogDto" Items="@logs" Hover="true" Striped="true" Loading="@isLoading" Filter="new Func<AuditLogDto,bool>(FilterFunc)" @bind-SelectedItem="selectedLog" RowsPerPage="20" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Audit Records</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Timestamp</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>User</MudTh>
                <MudTh>Description</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Time">@context.Timestamp.ToString("HH:mm:ss")</MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small" Color="@GetEventColor(context.EventType)" Variant="Variant.Filled">@context.EventType</MudChip>
                </MudTd>
                <MudTd DataLabel="User">@context.UserId</MudTd>
                <MudTd DataLabel="Event">@context.Description</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="() => ShowDetails(context)" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

<style>
    @@media (max-width: 600px) {
        .audit-title { font-size: 1.75rem !important; }
    }
    .fw-black { font-weight: 900; }
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .dashboard-card {
        background: @(LayoutService.IsDarkMode ? "rgba(30, 41, 59, 0.7)" : "rgba(255, 255, 255, 0.7)");
        backdrop-filter: blur(12px);
        border: 1px solid var(--mud-palette-divider);
    }
</style>

@code {
    private List<AuditLogDto> logs = new();
    private bool isLoading = true;
    private string searchString = "";
    private AuditLogDto? selectedLog;
    [Inject] IDialogService DialogService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        isLoading = true;
        try {
            logs = await Http.GetFromJsonAsync<List<AuditLogDto>>("api/Admin/audit-logs") ?? new();
        } catch {
            Snackbar.Add("Failed to load audit logs.", Severity.Error);
        } finally {
            isLoading = false;
        }
    }

    private bool FilterFunc(AuditLogDto element)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (element.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (element.EventType.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (element.UserId?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    private Color GetEventColor(string type) => type switch {
        "ADMIN_LOGIN" => Color.Primary,
        "SECURITY_ALERT" => Color.Error,
        "ADMIN_EDIT_BALANCE" => Color.Warning,
        "ADMIN_FORCE_COOLDOWN" => Color.Warning,
        "SYSTEM_START" => Color.Info,
        "DATABASE_BACKUP" => Color.Success,
        _ => Color.Default
    };

    private async Task ShowDetails(AuditLogDto log)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters { 
            ["Content"] = log.MetadataJson,
            ["Title"] = $"Event Details: {log.EventType}"
        };
        await DialogService.ShowAsync<AleaSim.Client.Components.JsonDetailsDialog>("Metadata Viewer", parameters, options);
    }

    private async Task VerifyIntegrity() {
        var response = await Http.GetFromJsonAsync<IntegrityResponse>("api/Admin/audit/verify");
        if (response != null && response.IsValid) {
            Snackbar.Add(response.Message, Severity.Success);
        } else {
            Snackbar.Add(response?.Message ?? "Integrity check failed!", Severity.Error);
        }
    }

    private record IntegrityResponse(bool IsValid, string Message);
}
