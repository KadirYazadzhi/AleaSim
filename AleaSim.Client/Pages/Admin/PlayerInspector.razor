@page "/admin/players"
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6">Player Inspector</MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">
                <MudTextField @bind-Value="searchQuery" Label="Search Player (Username/Email)" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" OnAdornmentClick="Search" />
                <MudList T="PlayerSearchResultDto" Class="mt-4">
                    @foreach (var p in searchResults)
                    {
                        <MudListItem OnClick="() => SelectPlayer(p)">
                            <div class="d-flex justify-space-between">
                                <MudText>@p.Username</MudText>
                                <MudText Typo="Typo.caption">@p.Balance.ToString("C")</MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            @if (selectedPlayer != null)
            {
                <MudPaper Class="pa-6" Elevation="3">
                    <MudText Typo="Typo.h4">@selectedPlayer.Username</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">ID: @selectedPlayer.Id</MudText>

                    <MudExpansionPanels>
                        <MudExpansionPanel Text="God Mode Controls" Icon="@Icons.Material.Filled.Bolt" Style="background: #fff9c4;">
                            <MudText Typo="Typo.body2" Class="mb-4">Manipulate the next spin for @selectedPlayer.Username:</MudText>
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick='() => ForceSpin(50, "Admin Gift")'>Force 50x Win</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick='() => ForceSpin(0, "Force Bonus", true)'>Force Bonus</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick='() => ForceSpin(0, "Admin Cooldown", false, true)'>Force Near Miss</MudButton>
                            </div>
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Inject Bonus Cash">
                            <MudNumericField @bind-Value="bonusAmount" Label="Amount" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="bonusReason" Label="Reason" Variant="Variant.Outlined" Class="mt-2" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="InjectBonus">Add Bonus</MudButton>
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Activity Logs">
                            <MudAlert Severity="Severity.Info">Recent bets and logins will appear here.</MudAlert>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudPaper>
            }
            else
            {
                <MudAlert Severity="Severity.Info">Search and select a player to inspect details.</MudAlert>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private string searchQuery = "";
    private List<PlayerSearchResultDto> searchResults = new();
    private PlayerSearchResultDto? selectedPlayer;
    private decimal bonusAmount = 100;
    private string bonusReason = "VIP Reward";

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        searchResults = await Http.GetFromJsonAsync<List<PlayerSearchResultDto>>($"api/Admin/players/search/{searchQuery}") ?? new();
    }

    private void SelectPlayer(PlayerSearchResultDto player)
    {
        selectedPlayer = player;
    }

    private async Task InjectBonus()
    {
        if (selectedPlayer == null) return;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/bonus", new { Amount = bonusAmount, Reason = bonusReason });
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Bonus injected successfully!", Severity.Success);
        }
    }

    private async Task ForceSpin(decimal targetWinMult, string reason, bool forceBonus = false, bool nearMiss = false) {
        if (selectedPlayer == null) return;
        
        var directive = new {
            DecisionType = forceBonus ? "ForceBonus" : (targetWinMult > 0 ? "RetentionHook" : "ManualOverride"),
            TargetWinAmount = targetWinMult,
            IsNearMiss = nearMiss,
            Reason = reason
        };

        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/force-outcome", directive);
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Directive sent! Next spin will be forced.", Severity.Success);
        }
    }

    public class PlayerSearchResultDto
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public decimal Balance { get; set; }
        public string Role { get; set; } = "";
    }
}