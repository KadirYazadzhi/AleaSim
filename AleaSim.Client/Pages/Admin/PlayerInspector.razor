@page "/admin/players"
@using AleaSim.Shared.Models
@using AleaSim.Client.Components
@using AleaSim.Shared
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@implements IDisposable
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject RealTimeClient RealTime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 pb-16">
    <div class="d-flex align-center gap-4 mb-8">
        <div class="players-header-icon d-none d-sm-flex">
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
        </div>
        <div>
            <MudText Typo="Typo.h3" Class="fw-black intel-title">Player Intel</MudText>
            <MudText Typo="Typo.subtitle1" Class="opacity-60 d-none d-sm-block">Search, inspect and manage user accounts.</MudText>
        </div>
    </div>

    <MudGrid>
        <!-- LEFT: Search & Directory -->
        <MudItem xs="12" lg="4">
            <MudStack Spacing="4">
                <!-- Search Card -->
                <MudPaper Class="pa-md-6 pa-4 rounded-xl" Elevation="2">
                    <MudTextField @bind-Value="searchQuery" Label="Search Directory" Variant="Variant.Outlined" 
                                 Placeholder="Username..." Adornment="Adornment.Start" 
                                 AdornmentIcon="@Icons.Material.Filled.Search" OnKeyDown="HandleSearchKey" 
                                 Margin="Margin.Dense" Class="modern-search" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4 py-2 rounded-lg fw-black" OnClick="Search">QUERY SYSTEM</MudButton>
                </MudPaper>

                <!-- Search Results / Directory -->
                <MudPaper Class="pa-2 pa-md-4 rounded-xl overflow-hidden" Elevation="2" Style="min-height: 300px;">
                    <div class="pa-2 border-b border-solid var(--mud-palette-divider) mb-2">
                        <MudText Typo="Typo.caption" Class="fw-black opacity-40">DIRECTORY</MudText>
                    </div>
                    
                    @if (isSearching) {
                        <div class="d-flex justify-center py-12"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
                    } else if (!searchResults.Any()) {
                        <div class="d-flex flex-column align-center py-12 opacity-20 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Style="font-size: 3rem;" />
                            <MudText>No matches.</MudText>
                        </div>
                    } else {
                        <MudList T="PlayerSearchResultDto" SelectionMode="SelectionMode.SingleSelection" Class="player-list-scroll">
                            @foreach (var p in searchResults.Where(x => x.Role != "Admin" && !x.Username.StartsWith("Sim_")))
                            {
                                <MudListItem OnClick="() => SelectPlayer(p)" Class='@($"player-list-item {(selectedPlayer?.Id == p.Id ? "selected" : "")}")'>
                                    <div class="d-flex align-center gap-2">
                                        <MudAvatar Size="Size.Small"><MudImage Src="@p.AvatarUrl" /></MudAvatar>
                                        <div class="flex-grow-1">
                                            <MudText Typo="Typo.body2" Class="fw-bold text-truncate" Style="max-width: 120px;">@p.Username</MudText>
                                            <MudText Typo="Typo.caption" Class="opacity-60">@p.TotalWagered.ToString("C0")</MudText>
                                        </div>
                                        <div class="text-right">
                                            <MudText Typo="Typo.caption" Class="fw-black text-success d-block">@((p.Balance + p.BonusBalance).ToString("C0"))</MudText>
                                        </div>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudStack>
        </MudItem>

        <!-- RIGHT: Detailed Inspection -->
        <MudItem xs="12" lg="8">
            @if (selectedPlayer != null)
            {
                <MudStack Spacing="4">
                    <!-- Player Header Card -->
                    <MudPaper Class="pa-md-8 pa-4 rounded-xl profile-hero overflow-hidden" Elevation="4">
                        <div class="d-flex flex-column flex-sm-row align-center gap-4 gap-md-6 p-relative z-10 text-center text-sm-left">
                            <MudAvatar Class="profile-avatar-adaptive">
                                <MudImage Src="@selectedPlayer.AvatarUrl" />
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <div class="d-flex flex-wrap align-center justify-center justify-sm-start gap-2 mb-1">
                                    <MudText Typo="Typo.h4" Class="fw-black text-white player-name-text">@selectedPlayer.Username</MudText>
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Filled" Class="fw-black">@selectedPlayer.Role</MudChip>
                                </div>
                                <MudText Typo="Typo.caption" Class="text-white opacity-60 font-mono text-xs d-block">ID: @selectedPlayer.Id</MudText>
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Surface" StartIcon="@Icons.Material.Filled.Chat" OnClick="OpenChat" Class="rounded-lg py-2 px-4 fw-bold">COMMS</MudButton>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.ContactPage" Class="hero-bg-icon" />
                    </MudPaper>

                    <!-- Stats Quick View -->
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-3 text-center rounded-xl" Elevation="1">
                                <MudText Typo="Typo.caption" Class="fw-bold opacity-40">WAGERED</MudText>
                                <MudText Typo="Typo.body1" Class="fw-black">@((fullDossier?.TotalWagered ?? selectedPlayer.TotalWagered).ToString("C0"))</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-3 text-center rounded-xl" Elevation="1">
                                <MudText Typo="Typo.caption" Class="fw-bold opacity-40">WON</MudText>
                                <MudText Typo="Typo.body1" Class="fw-black text-success">@((fullDossier?.TotalWon ?? selectedPlayer.TotalWon).ToString("C0"))</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-3 text-center rounded-xl" Elevation="1">
                                <MudText Typo="Typo.caption" Class="fw-bold opacity-40">RISK SCORE</MudText>
                                <MudText Typo="Typo.body1" Class='@($"fw-black {(selectedPlayer.RiskScore > 50 ? "text-error" : "text-info")}")'>@selectedPlayer.RiskScore</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-3 text-center rounded-xl" Elevation="1">
                                <MudText Typo="Typo.caption" Class="fw-bold opacity-40">PROFIT</MudText>
                                @if (fullDossier != null) {
                                    <MudText Typo="Typo.body1" Class="@(fullDossier.NetProfit > 0 ? "text-success fw-black" : "text-error fw-black")">@fullDossier.NetProfit.ToString("C0")</MudText>
                                } else {
                                    <MudText Typo="Typo.body1" Class="fw-black opacity-40">---</MudText>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @if (selectedPlayer.RedFlags?.Any() == true) {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="rounded-lg">
                            <div class="d-flex flex-wrap gap-2">
                                @foreach(var flag in selectedPlayer.RedFlags) {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Surface" Variant="Variant.Text">@flag</MudChip>
                                }
                            </div>
                        </MudAlert>
                    }

                    <!-- Control Panels -->
                    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-md-6 pa-4" Class="rounded-xl overflow-hidden" Color="Color.Primary">
                        <MudTabPanel Text="INFO" Icon="@Icons.Material.Filled.Badge">
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.caption" Class="fw-black opacity-40">EMAIL</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold mb-3 text-truncate">@selectedPlayer.Email</MudText>
                                    
                                    <MudText Typo="Typo.caption" Class="fw-black opacity-40">JOINED</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold mb-3">@(fullDossier?.CreatedAt.ToString("d") ?? "---")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <div class="d-flex justify-space-between align-center mb-2">
                                        <MudText Typo="Typo.caption" Class="fw-black opacity-40">STATUS</MudText>
                                        <MudChip T="string" Color="@(selectedPlayer.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Filled">
                                            @(selectedPlayer.IsActive ? "ACTIVE" : "BANNED")
                                        </MudChip>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="fw-black opacity-40">REAL / BONUS</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold">@selectedPlayer.Balance.ToString("C2") / @selectedPlayer.BonusBalance.ToString("C2")</MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField T="string" Label="Staff Notes" Variant="Variant.Outlined" Lines="3" 
                                                 @bind-Value="staffNotes" Class="mt-2" />
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="SaveNotes" Class="mt-1">Save Notes</MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudTabPanel>

                        <MudTabPanel Text="MOD" Icon="@Icons.Material.Filled.Gavel">
                            <MudStack Spacing="3">
                                <div class="d-flex flex-wrap gap-2">
                                    <MudButton Variant="Variant.Filled" Color="@(selectedPlayer.IsActive ? Color.Error : Color.Success)" 
                                               OnClick="ToggleAccountStatus" Class="flex-grow-1">
                                        @(selectedPlayer.IsActive ? "DEACTIVATE / BAN" : "RESTORE ACCOUNT")
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="KillUserSession" Class="flex-grow-1">KILL SESSION</MudButton>
                                </div>
                                <MudDivider />
                                <MudText Typo="Typo.caption" Class="fw-black opacity-40">RESPONSIBLE GAMBLING</MudText>
                                <div class="d-flex gap-2 align-center">
                                    <MudSelect T="int" Label="Cooldown Period" @bind-Value="cooldownMinutes" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="60">1 Hour</MudSelectItem>
                                        <MudSelectItem Value="1440">24 Hours</MudSelectItem>
                                        <MudSelectItem Value="10080">7 Days</MudSelectItem>
                                    </MudSelect>
                                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ApplyCooldown">ENFORCE</MudButton>
                                </div>
                            </MudStack>
                        </MudTabPanel>

                        <MudTabPanel Text="FORCE" Icon="@Icons.Material.Filled.Bolt">
                            <MudStack Spacing="2">
                                <div class="d-flex flex-column flex-sm-row gap-2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" OnClick='() => ForceSpin(25, "VIP Bonus")' Size="Size.Small">FORCE 25X</MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" OnClick='() => ForceSpin(0, "Force Bonus", true)' Size="Size.Small">FORCE BONUS</MudButton>
                                </div>
                                <div class="d-flex flex-column flex-sm-row gap-2">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true" OnClick='() => ForceSpin(0, "Cool-down", false, true)' Size="Size.Small">FORCE NEAR MISS</MudButton>
                                </div>
                            </MudStack>
                        </MudTabPanel>

                        <MudTabPanel Text="CASH" Icon="@Icons.Material.Filled.Payments">
                            <div class="d-flex gap-2 mb-4">
                                <MudNumericField @bind-Value="bonusAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="fw-black" OnClick="InjectBonus">INJECT</MudButton>
                            </div>
                            <MudText Typo="Typo.caption" Class="opacity-50">Note: Injected funds go to Real Balance by default.</MudText>
                        </MudTabPanel>

                        <MudTabPanel Text="LOGS" Icon="@Icons.Material.Filled.History">
                            <div class="table-responsive">
                                <MudTable Items="@fullDossier?.RecentBets" Dense="true" Hover="true" Elevation="0" Height="250px" FixedHeader="true">
                                    <HeaderContent>
                                        <MudTh>GAME</MudTh>
                                        <MudTh>BET</MudTh>
                                        <MudTh>WIN</MudTh>
                                        <MudTh>DECISION</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.GameName</MudTd>
                                        <MudTd>@context.BetAmount.ToString("C0")</MudTd>
                                        <MudTd><span class="@(context.WinAmount > 0 ? "text-success fw-bold" : "opacity-60")">@context.WinAmount.ToString("C0")</span></MudTd>
                                        <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.DecisionType</MudChip></MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        </MudTabPanel>
                    </MudTabs>
                </MudStack>
            }
            else
            {
                <div class="empty-inspector-state">
                    <MudIcon Icon="@Icons.Material.Filled.Radar" Style="font-size: 5rem;" Class="opacity-10 mb-4" />
                    <MudText Typo="Typo.h6" Class="fw-black opacity-20 uppercase">SELECT TARGET</MudText>
                </div>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .table-responsive { width: 100%; overflow-x: auto; }
    
    @@media (max-width: 600px) {
        .intel-title { font-size: 1.75rem !important; }
        .player-name-text { font-size: 1.5rem !important; }
        .profile-avatar-adaptive { height: 64px !important; width: 64px !important; border: 2px solid white !important; }
        .profile-hero { padding: 1.5rem !important; }
    }

    .fw-black { font-weight: 950; }
    .fw-bold { font-weight: 700; }
    .font-mono { font-family: 'JetBrains Mono', monospace; }

    .players-header-icon {
        width: 56px; height: 56px; background: rgba(var(--mud-palette-primary-rgb), 0.1);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
    }

    .player-list-scroll { max-height: 400px; overflow-y: auto; }
    .player-list-item { border-radius: 8px; margin-bottom: 2px; }
    .player-list-item.selected { background: rgba(var(--mud-palette-primary-rgb), 0.1); border: 1px solid var(--mud-palette-primary); }

    .profile-hero { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); position: relative; border-radius: 20px; }
    .hero-bg-icon { position: absolute; right: -10px; bottom: -10px; font-size: 10rem !important; opacity: 0.05; transform: rotate(15deg); color: white; }
    .text-white { color: #fff !important; }

    .empty-inspector-state { height: 100%; min-height: 400px; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed var(--mud-palette-divider); border-radius: 24px; }
</style>

@code {
    private string searchQuery = "";
    private bool isSearching = false;
    private List<PlayerSearchResultDto> searchResults = new();
    private PlayerSearchResultDto? selectedPlayer;
    private PlayerDossierDto? fullDossier;
    private decimal bonusAmount = 100;
    private string bonusReason = "VIP Loyalty Bonus";
    private bool isLoadingDossier = false;

    private string staffNotes = "";
    private int cooldownMinutes = 60;

    protected override async Task OnInitializedAsync() {
        try {
            searchResults = await Http.GetFromJsonAsync<List<PlayerSearchResultDto>>("api/Admin/players/active") ?? new();
        } catch {}

        RealTime.OnAdminEventReceived += HandleLiveAdminEvent;
        RealTime.OnAuditLogReceived += HandleLiveAuditLog;
        
        _ = Task.Run(async () => {
            int retries = 0;
            while (!RealTime.IsConnected && retries < 15) {
                await Task.Delay(1000);
                retries++;
            }
            await RealTime.JoinAdminFeed();
            await InvokeAsync(StateHasChanged);
        });
    }

    private void HandleLiveAdminEvent(AdminRoundEvent ev) {
        var existing = searchResults.FirstOrDefault(p => p.Username == ev.Username);
        if (existing != null) {
            existing.Balance = ev.Balance;
            existing.BonusBalance = ev.BonusBalance;
            existing.TotalWagered = ev.LifetimeWagered;
            existing.TotalWon = ev.LifetimeWon;
        } else {
            searchResults.Insert(0, new PlayerSearchResultDto {
                Username = ev.Username,
                Balance = ev.Balance,
                BonusBalance = ev.BonusBalance,
                TotalWagered = ev.LifetimeWagered,
                TotalWon = ev.LifetimeWon,
                Role = "User",
                AvatarUrl = $"https://api.dicebear.com/7.x/bottts/svg?seed={ev.Username}"
            });
            if (searchResults.Count > 50) searchResults.RemoveAt(50);
        }

        if (selectedPlayer != null && selectedPlayer.Username == ev.Username) {
            selectedPlayer.Balance = ev.Balance;
            selectedPlayer.BonusBalance = ev.BonusBalance;
            selectedPlayer.TotalWagered = ev.LifetimeWagered;
            selectedPlayer.TotalWon = ev.LifetimeWon;

            if (fullDossier != null) {
                fullDossier.Balance = ev.Balance;
                fullDossier.BonusBalance = ev.BonusBalance;
                fullDossier.TotalWagered = ev.LifetimeWagered;
                fullDossier.TotalWon = ev.LifetimeWon;
                fullDossier.RecentBets.Insert(0, new GameRoundSummaryDto {
                    Id = Guid.NewGuid(),
                    Timestamp = ev.Timestamp,
                    GameName = ev.Game,
                    BetAmount = ev.Bet,
                    WinAmount = ev.Win,
                    DecisionType = ev.Decision
                });
                if (fullDossier.RecentBets.Count > 50) fullDossier.RecentBets.RemoveAt(50);
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleLiveAuditLog(AuditLogDto log) {
        if (selectedPlayer != null && log.UserId == selectedPlayer.Id.ToString()) {
            if (fullDossier != null) {
                fullDossier.BehaviorLogs.Insert(0, log);
                if (fullDossier.BehaviorLogs.Count > 50) fullDossier.BehaviorLogs.RemoveAt(50);
                InvokeAsync(StateHasChanged);
            }
        }
    }

    public void Dispose() {
        RealTime.OnAdminEventReceived -= HandleLiveAdminEvent;
        RealTime.OnAuditLogReceived -= HandleLiveAuditLog;
    }

    private async Task HandleSearchKey(KeyboardEventArgs e) {
        if (e.Key == "Enter") await Search();
    }

    private async Task Search() {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        isSearching = true;
        try {
            searchResults = await Http.GetFromJsonAsync<List<PlayerSearchResultDto>>($"api/Admin/players/search/{searchQuery}") ?? new();
        } finally { isSearching = false; }
    }

    private async Task SelectPlayer(PlayerSearchResultDto player) {
        selectedPlayer = player;
        isLoadingDossier = true;
        StateHasChanged();
        try {
            fullDossier = await Http.GetFromJsonAsync<PlayerDossierDto>($"api/Admin/players/{player.Id}");
            if (fullDossier != null) {
                staffNotes = fullDossier.AdminNotes;
                // Sync status if dossier has fresher info
                selectedPlayer.IsActive = fullDossier.IsActive;
            }
        } catch (Exception ex) {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        } finally {
            isLoadingDossier = false;
        }
    }

    private async Task SaveNotes() {
        if (selectedPlayer == null) return;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/notes", new UpdateNotesDto { Notes = staffNotes });
        if (response.IsSuccessStatusCode) Snackbar.Add("Notes saved", Severity.Success);
    }

    private async Task ToggleAccountStatus() {
        if (selectedPlayer == null) return;
        bool newStatus = !selectedPlayer.IsActive;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/status", new ToggleStatusDto { IsActive = newStatus });
        if (response.IsSuccessStatusCode) {
            selectedPlayer.IsActive = newStatus;
            Snackbar.Add(newStatus ? "Account restored" : "Account deactivated", newStatus ? Severity.Success : Severity.Error);
        }
    }

    private async Task ApplyCooldown() {
        if (selectedPlayer == null) return;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/cooldown", new ForceCooldownDto { DurationMinutes = cooldownMinutes, Reason = "Responsible Gambling Admin Action" });
        if (response.IsSuccessStatusCode) Snackbar.Add($"Cooldown enforced for {cooldownMinutes}m", Severity.Warning);
    }

    private async Task KillUserSession() {
        if (selectedPlayer == null) return;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/kill-session", new { });
        if (response.IsSuccessStatusCode) Snackbar.Add("Session killed", Severity.Info);
    }

    private async Task OpenChat() {
        if (selectedPlayer == null) return;
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters { 
            ["OtherUserId"] = selectedPlayer.Id,
            ["OtherUserName"] = selectedPlayer.Username,
            ["OtherUserAvatar"] = selectedPlayer.AvatarUrl
        };
        await DialogService.ShowAsync<PrivateChatDialog>("Comms", parameters, options);
    }

    private async Task InjectBonus() {
        if (selectedPlayer == null) return;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/bonus", new { Amount = bonusAmount, Reason = bonusReason });
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Success", Severity.Success);
            selectedPlayer.Balance += bonusAmount;
        }
    }

    private async Task ForceSpin(decimal targetWinMult, string reason, bool forceBonus = false, bool nearMiss = false) {
        if (selectedPlayer == null) return;
        var directive = new {
            DecisionType = forceBonus ? "ForceBonus" : (targetWinMult > 0 ? "RetentionHook" : "ManualOverride"),
            TargetWinAmount = targetWinMult,
            IsNearMiss = nearMiss,
            Reason = reason
        };
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/force-outcome", directive);
        if (response.IsSuccessStatusCode) Snackbar.Add("Locked", Severity.Success);
    }

    private async Task BanPermanently() {
        if (selectedPlayer == null) return;
        var response = await Http.PostAsJsonAsync($"api/Admin/players/{selectedPlayer.Id}/status", new { IsActive = false });
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Banned", Severity.Error);
            selectedPlayer.IsActive = false;
        }
    }
}