@page "/admin/vouchers"
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h3">Voucher Management</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ToggleCreateForm">
            @(showCreateForm ? "Cancel" : "Create New Voucher")
        </MudButton>
    </div>

    @if (showCreateForm)
    {
        <MudPaper Class="pa-6 mb-6" Elevation="4">
            <MudText Typo="Typo.h6" Class="mb-4">Generate New Promo Code</MudText>
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="newVoucher.Code" Label="Code" Placeholder="e.g. SUMMER2026" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="newVoucher.Amount" Label="Bonus Amount ($)" Variant="Variant.Outlined" Min="1" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="newVoucher.MaxUses" Label="Max Uses" Variant="Variant.Outlined" Min="1" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveVoucher" Class="mt-2">Save Voucher</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudTable Items="@vouchers" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading" Elevation="2">
        <HeaderContent>
            <MudTh></MudTh>
            <MudTh>Code</MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Usage</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Expires</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => ShowBtnPress(context.Id))">@(context.ShowDetails ? "HIDE" : "SHOW")</MudTd>
            <MudTd DataLabel="Code"><MudChip T="string" Color="Color.Info" Variant="Variant.Text">@context.Code</MudChip></MudTd>
            <MudTd DataLabel="Amount">@context.Amount.ToString("C2")</MudTd>
            <MudTd DataLabel="Usage">@context.CurrentUses / @context.MaxUses</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.IsActive ? "ACTIVE" : "INACTIVE")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Expires">@(context.ExpiresAt?.ToShortDateString() ?? "Never")</MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (context.ShowDetails) {
                <MudTr>
                    <td colspan="6">
                        <MudCard Elevation="0" Class="pa-4 bg-transparent border-t-solid border-divider">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold mb-2">Redemption History (@context.UsageHistory.Count records)</MudText>
                            @if(context.UsageHistory.Any()) {
                                <MudTable Items="@context.UsageHistory" Context="usageContext" Dense="true" Hover="true" Elevation="0" Class="bg-transparent">
                                    <HeaderContent>
                                        <MudTh>Player</MudTh>
                                        <MudTh>Redeemed At</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@usageContext.Username</MudTd>
                                        <MudTd>@usageContext.RedeemedAt.ToString("g")</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            } else {
                                <MudText Typo="Typo.body2" Class="opacity-50">No redemptions yet.</MudText>
                            }
                        </MudCard>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
        <NoRecordsContent>
            <div class="pa-12 d-flex flex-column align-center justify-center">
                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Color="Color.Surface" Style="font-size: 4rem; opacity: 0.2;" Class="mb-4" />
                <MudText Typo="Typo.h6" Class="mud-text-secondary">No active vouchers found.</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">Create your first promo code to attract more players!</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ToggleCreateForm">CREATE VOUCHER</MudButton>
            </div>
        </NoRecordsContent>
    </MudTable>
</MudContainer>

@code {
    private List<VoucherDto> vouchers = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private CreateVoucherModel newVoucher = new();

    protected override async Task OnInitializedAsync() {
        await LoadVouchers();
    }

    private async Task LoadVouchers() {
        isLoading = true;
        try {
            vouchers = await Http.GetFromJsonAsync<List<VoucherDto>>("api/Admin/vouchers") ?? new();
        } catch {
            Snackbar.Add("Failed to load vouchers.", Severity.Error);
        } finally {
            isLoading = false;
        }
    }

    private void ToggleCreateForm() => showCreateForm = !showCreateForm;

    private void ShowBtnPress(Guid id) {
        var voucher = vouchers.FirstOrDefault(f => f.Id == id);
        if (voucher != null) {
            voucher.ShowDetails = !voucher.ShowDetails;
        }
    }

    private async Task SaveVoucher() {
        if (string.IsNullOrWhiteSpace(newVoucher.Code)) return;
        
        try {
            var response = await Http.PostAsJsonAsync("api/Admin/vouchers/create", newVoucher);
            if (response.IsSuccessStatusCode) {
                Snackbar.Add("Voucher created successfully!", Severity.Success);
                showCreateForm = false;
                newVoucher = new();
                await LoadVouchers();
            }
        } catch {
            Snackbar.Add("Failed to create voucher.", Severity.Error);
        }
    }

    public class CreateVoucherModel {
        public string Code { get; set; } = "";
        public decimal Amount { get; set; } = 10;
        public int MaxUses { get; set; } = 100;
    }
}
