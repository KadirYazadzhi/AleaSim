@page "/admin/vouchers"
@using AleaSim.Shared.Models
@using Microsoft.AspNetCore.Authorization
@layout AleaSim.Client.Layout.AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject LayoutService LayoutService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-md-8 mt-4 pb-16 animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-space-between align-md-center mb-8 gap-4">
        <div>
            <MudText Typo="Typo.h3" Class="fw-black text-gradient voucher-title">VOUCHER ARMORY</MudText>
            <MudText Typo="Typo.subtitle1" Class="opacity-60 d-none d-sm-block">Generate and track promotional credit codes.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="ToggleCreateForm" Class="py-3 px-6 rounded-lg fw-black forge-btn-mobile">
            @(showCreateForm ? "DISCARD" : (LayoutService.IsMobile ? "FORGE" : "FORGE NEW VOUCHER"))
        </MudButton>
    </div>

    @if (showCreateForm)
    {
        <MudPaper Class="pa-md-8 pa-4 rounded-xl mb-8 glass-card border-glow" Elevation="0">
            <MudText Typo="Typo.h6" Class="fw-black mb-6">Forge New Promo Code</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="newVoucher.Code" Label="Voucher Code" Placeholder="e.g. ALPHA2026" Variant="Variant.Outlined" Class="bg-dark-transparent" />
                </MudItem>
                <MudItem xs="6" sm="4">
                    <MudNumericField @bind-Value="newVoucher.Amount" Label="Value ($)" Variant="Variant.Outlined" Min="1" Adornment="Adornment.Start" AdornmentText="$" Class="bg-dark-transparent" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6" sm="4">
                    <MudNumericField @bind-Value="newVoucher.MaxUses" Label="Limit" Variant="Variant.Outlined" Min="1" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.People" Class="bg-dark-transparent" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" Class="text-md-right text-center pt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" OnClick="SaveVoucher" Class="px-12 py-3 rounded-lg fw-black w-100-mobile">ACTIVATE CODE</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudPaper Class="pa-6 rounded-xl overflow-hidden" Elevation="4">
        <MudTable Items="@vouchers" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading" Elevation="0" Class="modern-vouchers-table">
            <HeaderContent>
                <MudTh></MudTh>
                <MudTh>IDENTIFIER</MudTh>
                <MudTh>CREDIT</MudTh>
                <MudTh>REDEMPTIONS</MudTh>
                <MudTh>STATUS</MudTh>
                <MudTh>EXPIRATION</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudIconButton Icon="@(context.ShowDetails ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" 
                                   Color="Color.Primary" Size="Size.Small" OnClick="@(() => ShowBtnPress(context.Id))" />
                </MudTd>
                <MudTd DataLabel="Code"><MudText Class="fw-black font-mono" Style="letter-spacing: 1px;">@context.Code</MudText></MudTd>
                <MudTd DataLabel="Amount"><MudText Color="Color.Success" Class="fw-bold">@context.Amount.ToString("C2")</MudText></MudTd>
                <MudTd DataLabel="Usage">
                    <div class="d-flex align-center gap-2">
                        <MudProgressLinear Color="Color.Info" Value="@((double)context.CurrentUses / context.MaxUses * 100)" Class="rounded-pill" Style="width: 60px;" />
                        <MudText Typo="Typo.caption" Class="fw-bold">@context.CurrentUses / @context.MaxUses</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Filled" Class="fw-bold">
                        @(context.IsActive ? "ACTIVE" : "EXPIRED")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Expires"><MudText Typo="Typo.caption" Class="opacity-60">@(context.ExpiresAt?.ToShortDateString() ?? "PERMANENT")</MudText></MudTd>
            </RowTemplate>
            <ChildRowContent>
                @if (context.ShowDetails) {
                    <MudTr>
                        <td colspan="6" class="pa-0">
                            <div class="pa-6 redemption-drawer">
                                <MudText Typo="Typo.subtitle2" Class="fw-black mb-4"><MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-2"/>Usage History (@context.UsageHistory.Count)</MudText>
                                @if(context.UsageHistory.Any()) {
                                    <MudTable Items="@context.UsageHistory" Context="usageContext" Dense="true" Hover="true" Elevation="0" Class="bg-transparent rounded-lg border border-solid border-divider">
                                        <HeaderContent>
                                            <MudTh>PLAYER</MudTh>
                                            <MudTh>TIMESTAMP</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>
                                                <div class="d-flex align-center gap-2">
                                                    <MudAvatar Size="Size.Small" Class="bg-dark-transparent">@usageContext.Username.Substring(0,1).ToUpper()</MudAvatar>
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@usageContext.Username</MudText>
                                                </div>
                                            </MudTd>
                                            <MudTd>@usageContext.RedeemedAt.ToString("g")</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                } else {
                                    <div class="py-8 text-center opacity-30 border border-dashed rounded-lg">
                                        <MudText>No one has redeemed this code yet.</MudText>
                                    </div>
                                }
                            </div>
                        </td>
                    </MudTr>
                }
            </ChildRowContent>
            <NoRecordsContent>
                <div class="pa-12 d-flex flex-column align-center justify-center opacity-20 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Style="font-size: 6rem;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="fw-black">Vault is Empty</MudText>
                    <MudText>Forge your first voucher to begin promotional campaigns.</MudText>
                </div>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudContainer>

<style>
    @@media (max-width: 600px) {
        .voucher-title { font-size: 1.75rem !important; }
        .forge-btn-mobile { width: 100% !important; }
        .w-100-mobile { width: 100% !important; }
    }
    .fw-black { font-weight: 950; }
    .font-mono { font-family: 'JetBrains Mono', monospace; }
    .text-gradient { background: linear-gradient(135deg, var(--mud-palette-primary), var(--mud-palette-secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    
    .glass-card { background: rgba(var(--mud-palette-surface-rgb), 0.4); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.05); }
    .border-glow { border: 1px solid var(--mud-palette-primary); box-shadow: 0 0 20px rgba(var(--mud-palette-primary-rgb), 0.1); }
    .bg-dark-transparent { background: rgba(0,0,0,0.1) !important; }
    
    .redemption-drawer { background: rgba(var(--mud-palette-primary-rgb), 0.02); border-top: 2px solid var(--mud-palette-primary); }
    
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private List<VoucherDto> vouchers = new();
    private bool isLoading = true;
    private bool showCreateForm = false;
    private CreateVoucherModel newVoucher = new();

    protected override async Task OnInitializedAsync() {
        await LoadVouchers();
    }

    private async Task LoadVouchers() {
        isLoading = true;
        try {
            vouchers = await Http.GetFromJsonAsync<List<VoucherDto>>("api/Admin/vouchers") ?? new();
        } catch {
            Snackbar.Add("Failed to load vouchers.", Severity.Error);
        } finally {
            isLoading = false;
        }
    }

    private void ToggleCreateForm() => showCreateForm = !showCreateForm;

    private void ShowBtnPress(Guid id) {
        var voucher = vouchers.FirstOrDefault(f => f.Id == id);
        if (voucher != null) {
            voucher.ShowDetails = !voucher.ShowDetails;
        }
    }

    private async Task SaveVoucher() {
        if (string.IsNullOrWhiteSpace(newVoucher.Code)) return;
        
        try {
            var response = await Http.PostAsJsonAsync("api/Admin/vouchers/create", newVoucher);
            if (response.IsSuccessStatusCode) {
                Snackbar.Add("Voucher forged successfully!", Severity.Success);
                showCreateForm = false;
                newVoucher = new();
                await LoadVouchers();
            }
        } catch {
            Snackbar.Add("Failed to forge voucher.", Severity.Error);
        }
    }

    public class CreateVoucherModel {
        public string Code { get; set; } = "";
        public decimal Amount { get; set; } = 10;
        public int MaxUses { get; set; } = 100;
    }
}
