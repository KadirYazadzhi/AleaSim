@page "/profile"
@using AleaSim.Shared.Models
@using AleaSim.Shared
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6">Player Profile</MudText>

    <MudGrid>
        <!-- VIP Card Section -->
        <MudItem xs="12">
            <MudPaper Class="pa-8 vip-card mb-4" Elevation="6" Style="@GetVipCardStyle(profile?.Progression.Tier ?? VipTier.Bronze)">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.h6" Style="opacity: 0.8; letter-spacing: 2px;">ALEASIM LOYALTY CARD</MudText>
                        <MudText Typo="Typo.h3" Style="font-weight: 900; margin: 20px 0;">@profile?.Progression.TierName TIER</MudText>
                        <MudText Typo="Typo.h5">@profile?.Username</MudText>
                    </div>
                    <MudIcon Icon="@GetTierIcon(profile?.Progression.Tier ?? VipTier.Bronze)" Style="font-size: 8rem; opacity: 0.3;" />
                </div>
            </MudPaper>
        </MudItem>

        <!-- Profile Header Section -->
        <MudItem xs="12">
            <MudPaper Class="pa-6" Elevation="2">
                <div class="d-flex align-center gap-4 mb-4">
                    <div class="position-relative">
                        <MudAvatar Image="@profile?.AvatarUrl" Style="height:100px; width:100px;" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Class="avatar-edit-btn" OnClick="OpenAvatarPicker" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h4">@profile?.Username</MudText>
                        <MudText Typo="Typo.subtitle1" Color="Color.Info">
                            @profile?.Progression.TierName TIER - Level @profile?.Progression.CurrentLevel
                        </MudText>
                        @if (GetLuckySymbol() != null) {
                            <MudChip T="string" Icon="@Icons.Material.Filled.AutoFixHigh" Color="Color.Secondary" Size="Size.Small">
                                Your Lucky Symbol: @GetLuckySymbol()
                            </MudChip>
                        }
                    </div>
                </div>

                <MudText Typo="Typo.body1" Class="mb-1">Progress to Level @(profile?.Progression.CurrentLevel + 1)</MudText>
                <MudProgressLinear Color="Color.Info" Value="@(profile?.Progression.ProgressPercentage ?? 0)" Height="20" Class="rounded-lg">
                    <MudText Typo="Typo.subtitle2" Color="Color.Dark">
                        <b>@(profile?.Progression.CurrentXP.ToString("N0")) / @profile?.Progression.NextLevelXP.ToString("N0") XP</b>
                    </MudText>
                </MudProgressLinear>
                
                <MudText Typo="Typo.caption" Class="mt-2 d-block">Lifetime Experience: @profile?.Progression.LifetimeXP.ToString("N0") XP</MudText>
            </MudPaper>
        </MudItem>

        <!-- Stats and Perks -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-4">Financial Overview</MudText>
                <MudList T="string">
                    <MudListItem Icon="@Icons.Material.Filled.AccountBalanceWallet">Real Balance: <b>@profile?.Balance.ToString("C2")</b></MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.CardGiftcard">Bonus Balance: <b>@profile?.BonusBalance.ToString("C2")</b></MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-4">Redeem Promo Code</MudText>
                <MudTextField @bind-Value="voucherCode" Label="Voucher Code" Variant="Variant.Outlined" Placeholder="e.g. FREE100" />
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Class="mt-4" OnClick="RedeemVoucher" Disabled="@string.IsNullOrEmpty(voucherCode)">Redeem Code</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-4">RPG Skill Shop (Available Points: @profile?.Progression.SkillPoints)</MudText>
                
                <div class="mb-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.body1">Lucky Clover (Lv. @profile?.LuckyCloverLevel)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">+@profile?.LuckyCloverLevel% Bonus Trigger Chance</MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Primary" OnClick='() => UpgradeSkill("clover")' Disabled="@(profile?.Progression.SkillPoints == 0)" />
                </div>

                <div class="mb-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.body1">Cashback King (Lv. @profile?.CashbackLevel)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@(10 + profile?.CashbackLevel)% Daily Cashback</MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Primary" OnClick='() => UpgradeSkill("cashback")' Disabled="@(profile?.Progression.SkillPoints == 0)" />
                </div>

                <div class="mb-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.body1">XP Booster (Lv. @profile?.XpBoostLevel)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">+@(profile?.XpBoostLevel * 10)% Experience Gain</MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Primary" OnClick='() => UpgradeSkill("xp")' Disabled="@(profile?.Progression.SkillPoints == 0)" />
                </div>
            </MudPaper>
        </MudItem>

        <!-- Achievements Section -->
        <MudItem xs="12">
            <MudPaper Class="pa-6" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Hall of Achievements</MudText>
                <div class="d-flex flex-wrap gap-4">
                    @if (profile != null && profile.Achievements.Any())
                    {
                        @foreach (var ach in profile.Achievements)
                        {
                            <MudTooltip Text="@ach.Description">
                                <MudPaper Class="pa-4 d-flex flex-column align-center justify-center" Style="width: 120px; background: #fffde7; border: 2px solid #fbc02d;">
                                    <MudText Typo="Typo.h3">@ach.Icon</MudText>
                                    <MudText Typo="Typo.caption" Align="Align.Center" Style="font-weight: bold;">@ach.Name</MudText>
                                </MudPaper>
                            </MudTooltip>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No achievements unlocked yet. Keep playing!</MudText>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private UserProfileResponse? profile;
    private string voucherCode = "";

    protected override async Task OnInitializedAsync() {
        try {
            profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
        } catch {
            Snackbar.Add("Failed to load profile.", Severity.Error);
        }
    }

    private async Task OpenAvatarPicker() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<AleaSim.Client.Components.AvatarPicker>("Select Your Avatar", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is string newUrl) {
            await UpdateAvatar(newUrl);
        }
    }

    private async Task UpdateAvatar(string url) {
        var response = await Http.PostAsJsonAsync("api/Auth/avatar", url);
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Avatar updated!", Severity.Success);
            await OnInitializedAsync();
        }
    }

    private async Task RedeemVoucher() {
        try {
            var response = await Http.PostAsync($"api/Game/vouchers/redeem/{voucherCode}", null);
            if (response.IsSuccessStatusCode) {
                Snackbar.Add("Success! Bonus credited.", Severity.Success);
                voucherCode = "";
                await OnInitializedAsync();
            } else {
                Snackbar.Add(await response.Content.ReadAsStringAsync(), Severity.Warning);
            }
        } catch { }
    }

    private async Task UpgradeSkill(string name) {
        var response = await Http.PostAsync($"api/Game/skills/upgrade/{name}", null);
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Perk Upgraded!", Severity.Success);
            await OnInitializedAsync();
        }
    }

    private string? GetLuckySymbol() {
        try {
            var affinity = JsonSerializer.Deserialize<Dictionary<int, double>>(profile?.SymbolAffinityJson ?? "{}");
            if (affinity == null || !affinity.Any()) return null;
            int symId = affinity.OrderByDescending(x => x.Value).First().Key;
            return symId switch { 7 => "7️⃣", 8 => "🍀", 10 => "💰", _ => "💎" };
        } catch { return null; }
    }

    private string GetVipCardStyle(VipTier tier) => tier switch {
        VipTier.Diamond => "background: linear-gradient(135deg, #2c3e50 0%, #000000 100%); border: 2px solid #e0e0e0; color: #fff;",
        VipTier.Platinum => "background: linear-gradient(135deg, #607d8b 0%, #263238 100%); color: #fff;",
        VipTier.Gold => "background: linear-gradient(135deg, #ffD700 0%, #b8860b 100%); color: #000;",
        VipTier.Silver => "background: linear-gradient(135deg, #bdc3c7 0%, #2c3e50 100%); color: #fff;",
        _ => "background: linear-gradient(135deg, #cd7f32 0%, #8b4513 100%); color: #fff;"
    };

    private string GetTierIcon(VipTier tier) => tier switch {
        VipTier.Diamond => Icons.Material.Filled.WorkspacePremium,
        VipTier.Platinum => Icons.Material.Filled.AutoAwesome,
        VipTier.Gold => Icons.Material.Filled.MilitaryTech,
        _ => Icons.Material.Filled.Stars
    };
}

<style>
    .avatar-edit-btn { position: absolute; bottom: -10px; right: -10px; background: white !important; box-shadow: 0 2px 5px rgba(0,0,0,0.2); }
    .vip-card { border-radius: 20px; transition: transform 0.3s ease; cursor: default; }
    .vip-card:hover { transform: translateY(-5px); }
</style>