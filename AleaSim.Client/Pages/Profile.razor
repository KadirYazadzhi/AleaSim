    .vip-card { border-radius: 20px; transition: transform 0.3s ease; cursor: default; }
    .vip-card:hover { transform: translateY(-5px); }
    .ach-card { width: 120px; background: var(--mud-palette-background-grey); border: 2px solid var(--mud-palette-divider); transition: all 0.2s; }
    .ach-card:hover { border-color: var(--mud-palette-primary); transform: scale(1.05); }
    .bg-dark-lighten { background: rgba(255,255,255,0.03); }
</style>

