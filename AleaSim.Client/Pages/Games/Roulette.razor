@page "/game/roulette"
@using System.Text.Json
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@attribute [Authorize]
@implements IAsyncDisposable
@inject IGameService GameService
@inject AudioService Audio
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IAuthService AuthService
@inject LayoutService layoutService
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2 mt-md-4" Style="padding-top: 10px; position: relative;" @onmouseup='() => isMouseDown = false'>
    
    @if (layoutService.IsMobile)
    {
        <!-- 1. MOBILE VIEW: PiP Wheel and Vertical Flow -->
        <div class='@($"mobile-pip-container {(_wheelExpanded ? "expanded" : "pip")}")' 
             style='@(_wheelExpanded ? "" : $"left: {_wheelX}px; top: {_wheelY}px;")'
             @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove" @onpointerup="OnPointerUp" @onpointerleave="OnPointerUp">
            
            <MudPaper Class="pa-1 wheel-paper" 
                      Style='@($"background: radial-gradient(circle, #1a4a1a 0%, #0a2a0a 100%); border: 3px solid #3d2b1f; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); cursor: {(_isDragging ? "grabbing" : "pointer")};")'
                      @onclick="ToggleWheelSize">
                
                <!-- SINGLE ID FOR BOTH MODES -->
                <div id="roulette-pro-container" class="canvas-container-pip"></div>
                
                @if (winningNumber.HasValue && !isSpinning) {
                    <div class="result-badge-mini">
                        <MudText Typo="Typo.h6" Style='@($"font-weight: 900; color: {(winningNumber == 0 ? "#4caf50" : (GetNumberColor(winningNumber.Value) == "red" ? "#ff5252" : "#ffffff"))};")'>
                            @winningNumber
                        </MudText>
                    </div>
                }
                @if (!_wheelExpanded) {
                    <div class="pip-hint"><MudIcon Icon="@Icons.Material.Filled.ZoomOutMap" Size="Size.Small" /></div>
                }
            </MudPaper>
        </div>

        <div class="mobile-stack-layout">
            <!-- Table (Top) -->
            <div class="roulette-board-container">
                <MudPaper Class="pa-1" Style="background: #004d00; border: 4px solid #3d2b1f; border-radius: 10px;">
                    <div class="roulette-table mobile-vertical" @onmouseup='() => isMouseDown = false'>
                        <div @key='"cell-0"' class='@($"cell zero {GetCursorClass("number", "0")} {(currentLuckyNumbers.ContainsKey(0) ? "lucky-cell lightning-flash" : "")}")' 
                             @onmousedown='() => HandleMouseDown("number", "0")' @onmouseenter='() => HandleMouseEnter("number", "0")' @onmousedown:stopPropagation>
                            0 @GetBetBadge("number", "0") @GetLuckyBadge(0)
                        </div>                                
                        <div class="mobile-piles-container">
                            @foreach (var pile in new[] { Enumerable.Range(1, 12), Enumerable.Range(13, 12), Enumerable.Range(25, 12) }) {
                                <div class="pile">
                                    @foreach (int i in pile) {
                                        <div @key='"cell-" + i' class='@($"cell {GetNumberColor(i)} {GetCursorClass("number", i.ToString())} {(currentLuckyNumbers.ContainsKey(i) ? "lucky-cell lightning-flash" : "")}")' 
                                             @onmousedown='() => HandleMouseDown("number", i.ToString())' @onmouseenter='() => HandleMouseEnter("number", i.ToString())'>
                                            @i @GetBetBadge("number", i.ToString()) @GetLuckyBadge(i)
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="outside-grid-mobile">
                            <div class="outside-row">
                                <div @key='"outside-red"' class='@($"cell red {GetCursorClass("color", "red")}")' @onmousedown='() => HandleMouseDown("color", "red")' @onmouseenter='() => HandleMouseEnter("color", "red")'>RED @GetBetBadge("color", "red")</div>
                                <div @key='"outside-black"' class='@($"cell black {GetCursorClass("color", "black")}")' @onmousedown='() => HandleMouseDown("color", "black")' @onmouseenter='() => HandleMouseEnter("color", "black")'>BLK @GetBetBadge("color", "black")</div>
                            </div>
                            <div class="outside-row">
                                <div @key='"outside-even"' class='@($"cell even {GetCursorClass("evenodd", "even")}")' @onmousedown='() => HandleMouseDown("evenodd", "even")' @onmouseenter='() => HandleMouseEnter("evenodd", "even")'>EVN @GetBetBadge("evenodd", "even")</div>
                                <div @key='"outside-odd"' class='@($"cell odd {GetCursorClass("evenodd", "odd")}")' @onmousedown='() => HandleMouseDown("evenodd", "odd")' @onmouseenter='() => HandleMouseEnter("evenodd", "odd")'>ODD @GetBetBadge("evenodd", "odd")</div>
                            </div>
                        </div>
                    </div>
                </MudPaper>
            </div>

            <!-- Controls (Middle) -->
            <MudPaper Class="pa-2 glass-panel mt-2">
                <div class="d-flex justify-space-between align-center px-2 mb-2">
                    <MudText Typo="Typo.caption" Class="opacity-70 fw-bold">BALANCE</MudText>
                    <MudText Typo="Typo.body1" Style="color: #4caf50; font-weight: 900;">@balance.ToString("C2")</MudText>
                </div>
                <div class="d-flex gap-2 spin-controls-row">
                    <MudNumericField @bind-Value="chipValue" Label="Chip" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSpin" Disabled="@(isSpinning || !currentBets.Any())" 
                               Class="rounded-lg fw-black px-6" Style="height: 40px;">SPIN</MudButton>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ClearBets" Disabled="isSpinning" Size="Size.Small" FullWidth="true" Class="mt-2">CLEAR</MudButton>
            </MudPaper>

            <!-- Profile (Bottom) -->
            <div class="pa-2 rounded-xl glass-panel d-flex gap-2 border border-solid var(--mud-palette-divider) mt-2">
                 <div class='@($"mode-btn-mobile {(selectedMode == "Classic" ? "active-classic" : "")} flex-grow-1")' @onclick='@(() => SetMode("Classic"))'>CLASSIC</div>
                 <div class='@($"mode-btn-mobile {(selectedMode == "Extreme" ? "active-extreme" : "")} flex-grow-1")' @onclick='@(() => SetMode("Extreme"))'>EXTREME</div>
            </div>
        </div>
    }
    else
    {
        <!-- 2. DESKTOP VIEW: Full Original Layout -->
        <MudGrid Spacing="1">
            <MudItem xs="12" lg="9">
                <div class="d-flex gap-3 h-100 align-stretch">
                    <!-- WHEEL AREA (50%) -->
                    <MudPaper Class="pa-2 d-flex justify-center align-center overflow-hidden desktop-wheel-card flex-1" 
                              Style="background: radial-gradient(circle, #1a4a1a 0%, #0a2a0a 100%); border: 6px solid #3d2b1f; border-radius: 16px; box-shadow: 0 0 25px rgba(0,0,0,0.8); position: relative; min-height: 400px;">
                        <!-- SHARED ID -->
                        <div id="roulette-pro-container" style="width: 420px; height: 380px;"></div>
                        @if (winningNumber.HasValue && !isSpinning) {
                            <div class="result-overlay-pro animate-fade-in">
                                <MudText Typo="Typo.h3" Style='@($"font-weight: 900; color: {(winningNumber == 0 ? "#4caf50" : (GetNumberColor(winningNumber.Value) == "red" ? "#ff5252" : "#ffffff"))};")'>@winningNumber</MudText>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.6);">Winning Number</MudText>
                            </div>
                        }
                    </MudPaper>

                    <!-- STATS DASHBOARD (50%) -->
                    <MudPaper Class="pa-4 glass-panel flex-1" Style="border-radius: 16px; display: flex; flex-direction: column; gap: 12px; min-height: 400px; background: rgba(0,0,0,0.4);">
                        <div class="d-flex justify-space-between align-center border-b border-solid border-white opacity-20 pb-2 mb-1">
                            <MudText Typo="Typo.subtitle1" Class="fw-black text-warning">ROULETTE TRACKER</MudText>
                            <MudText Typo="Typo.caption" Class="opacity-50">Last 100 Rounds</MudText>
                        </div>
                        
                        <div class="stats-scroll-area flex-grow-1 d-flex flex-column gap-4">
                            <!-- HOT NUMBERS -->
                            <div class="stat-group">
                                <MudText Typo="Typo.caption" Class="text-danger fw-bold mb-2 d-block">🔥 HOT NUMBERS (TOP 5)</MudText>
                                <div class="d-flex gap-4">
                                    @foreach (var hot in hotNumbers.Take(5)) {
                                        <div class="stat-v3-item">
                                            <div class='@($"stat-v3-circle {GetNumberColor(hot.Number)}")'>@hot.Number</div>
                                            <span class="stat-v3-label">@hot.Count hits</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- COLD NUMBERS -->
                            <div class="stat-group">
                                <MudText Typo="Typo.caption" Class="text-info fw-bold mb-2 d-block">❄️ COLD NUMBERS (RARE)</MudText>
                                <div class="d-flex gap-4">
                                    @foreach (var cold in coldNumbers.Take(5)) {
                                        <div class="stat-v3-item">
                                            <div class='@($"stat-v3-circle {GetNumberColor(cold.Number)}")'>@cold.Number</div>
                                            <span class="stat-v3-label">@cold.Count spins</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- RECENT -->
                            <div class="stat-group">
                                <MudText Typo="Typo.caption" Class="opacity-60 fw-bold mb-2 d-block">🕘 RECENT RESULTS</MudText>
                                <div class="d-flex gap-3 flex-wrap">
                                    @foreach (var num in historyNumbers.Take(10)) {
                                        <div class='@($"stat-v3-circle mini {GetNumberColor(num)}")'>@num</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="mt-auto d-flex justify-space-between align-center pa-2 rounded bg-black opacity-60">
                             <MudText Typo="Typo.caption" Style="font-family: monospace;">SESSION: @(sessionId?.ToString().Substring(0,8).ToUpper() ?? "...")</MudText>
                             <MudText Typo="Typo.caption" Class="text-success fw-bold">LAST WIN: @lastWinAmount.ToString("C2")</MudText>
                        </div>
                    </MudPaper>
                </div>
            </MudItem>

            <MudItem xs="12" lg="3">
                <MudPaper Class="pa-6 d-flex flex-column gap-4 h-100 glass-panel">
                    <div class="pa-4 rounded-xl border border-solid var(--mud-palette-divider)" style='@($"background: {(layoutService.IsDarkMode ? "rgba(0,0,0,0.2)" : "rgba(255,255,255,0.5)")};")'>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary fw-bold">BALANCE</MudText>
                        <MudText Typo="Typo.h4" Style="color: #4caf50; font-weight: 900;">@balance.ToString("C2")</MudText>
                    </div>
                    <MudNumericField @bind-Value="chipValue" Label="Chip Value" Variant="Variant.Outlined" Min="1" Max="100" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AddCard" />
                    <div class="pa-4 rounded-xl border border-solid var(--mud-palette-divider)" style='@($"background: {(layoutService.IsDarkMode ? "rgba(0,0,0,0.2)" : "rgba(255,255,255,0.5)")};")'>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary fw-bold">TOTAL WAGER</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold" Color="Color.Primary">@currentBets.Sum(x => x.Amount).ToString("C2")</MudText>
                    </div>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="OnSpin" Disabled="@(isSpinning || !currentBets.Any())" Class="rounded-xl pulse-neon" Style="height: 100px; font-size: 1.5rem; font-weight: 900;">SPIN</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ClearBets" Disabled="isSpinning" Class="rounded-lg border-2">CLEAR ALL</MudButton>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="9">
                <MudPaper Class="pa-4" Style="background: #004d00; border: 10px solid #3d2b1f; border-radius: 10px; box-shadow: 0 10px 20px rgba(0,0,0,0.5);">
                    <div class="roulette-table-v3" @onmouseup='() => isMouseDown = false'>
                        <div @key='"cell-0"' class='@($"cell zero {GetCursorClass("number", "0")} {(currentLuckyNumbers.ContainsKey(0) ? "lucky-cell lightning-flash" : "")}")' @onmousedown='() => HandleMouseDown("number", "0")' @onmouseenter='() => HandleMouseEnter("number", "0")'>
                            0 @GetBetBadge("number", "0") @GetLuckyBadge(0)
                        </div>                                
                        <div class="numbers-grid-v3">
                            @for (int i = 1; i <= 36; i++) {
                                var num = i;
                                <div @key='"cell-" + num' class='@($"cell {GetNumberColor(num)} {GetCursorClass("number", num.ToString())} {(currentLuckyNumbers.ContainsKey(num) ? "lucky-cell lightning-flash" : "")}")' @onmousedown='() => HandleMouseDown("number", num.ToString())' @onmouseenter='() => HandleMouseEnter("number", num.ToString())'>
                                    @num @GetBetBadge("number", num.ToString()) @GetLuckyBadge(num)
                                </div>
                            }
                        </div>
                        <div class="outside-bets-v3">
                            <div @key='"outside-red"' class='@($"cell red {GetCursorClass("color", "red")}")' @onmousedown='() => HandleMouseDown("color", "red")' @onmouseenter='() => HandleMouseEnter("color", "red")'>RED @GetBetBadge("color", "red")</div>
                            <div @key='"outside-black"' class='@($"cell black {GetCursorClass("color", "black")}")' @onmousedown='() => HandleMouseDown("color", "black")' @onmouseenter='() => HandleMouseEnter("color", "black")'>BLACK @GetBetBadge("color", "black")</div>
                            <div @key='"outside-even"' class='@($"cell even {GetCursorClass("evenodd", "even")}")' @onmousedown='() => HandleMouseDown("evenodd", "even")' @onmouseenter='() => HandleMouseEnter("evenodd", "even")'>EVEN @GetBetBadge("evenodd", "even")</div>
                            <div @key='"outside-odd"' class='@($"cell odd {GetCursorClass("evenodd", "odd")}")' @onmousedown='() => HandleMouseDown("evenodd", "odd")' @onmouseenter='() => HandleMouseEnter("evenodd", "odd")'>ODD @GetBetBadge("evenodd", "odd")</div>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="3">
                 <div class="pa-4 rounded-xl glass-panel h-100 d-flex flex-column gap-3 border border-solid var(--mud-palette-divider)">
                     <MudText Typo="Typo.subtitle2" Class="fw-bold d-flex align-center">
                         <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-2" Color="Color.Primary" /> Game Profile
                     </MudText>
                     <MudDivider />
                     <div class='@($"mode-rect-card {(selectedMode == "Classic" ? "active-classic" : "")}")' @onclick='() => SetMode("Classic")'>CLASSIC</div>
                     <div class='@($"mode-rect-card {(selectedMode == "Extreme" ? "active-extreme" : "")}")' @onclick='@(() => SetMode("Extreme"))'>EXTREME</div>
                     
                     <div class="mt-auto pa-2 border-t border-solid var(--mud-palette-divider)">
                         <MudText Typo="Typo.caption" Class='@($"fw-bold d-flex align-center justify-center {(selectedMode == "Extreme" ? "text-warning" : "text-info")}")'>
                             <MudIcon Icon="@(selectedMode == "Extreme" ? Icons.Material.Filled.AutoAwesome : Icons.Material.Filled.Info)" Size="Size.Small" Class="mr-1" />
                             @(selectedMode == "Extreme" ? "EXTREME ACTIVE" : "CLASSIC ACTIVE")
                         </MudText>
                     </div>
                 </div>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

<style>
    /* DESKTOP STYLES (v3 Precision Alignment) */
    .roulette-table-v3 { 
        display: flex; 
        height: 220px; /* Fixed height container */
        gap: 8px; 
        color: white; 
        user-select: none; 
    }
    .roulette-table-v3 .zero { 
        width: 70px; 
        height: 100%; 
        background: #008000; 
        border: 1px solid white; 
        border-radius: 6px; 
        display: flex; align-items: center; justify-content: center; cursor: pointer; position: relative;
    }
    .numbers-grid-v3 { 
        display: grid; 
        grid-template-columns: repeat(12, 1fr); 
        grid-template-rows: repeat(3, 1fr); 
        gap: 8px 6px; /* 8px vertical gap pushes them down to align */
        flex-grow: 1; 
    }
    .outside-bets-v3 { 
        display: flex; 
        flex-direction: column; 
        width: 120px; 
        gap: 6px; 
    }
    .numbers-grid-v3 .cell, .outside-bets-v3 .cell { 
        height: 100%; 
        border: 1px solid rgba(255,255,255,0.3); 
        border-radius: 4px;
        display: flex; align-items: center; justify-content: center; cursor: pointer; position: relative; font-weight: bold;
    }

    /* STATS V3 STYLES */
    .stat-v3-circle {
        width: 40px; height: 40px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 1rem; border: 2px solid rgba(255,255,255,0.4);
        box-shadow: 0 4px 8px rgba(0,0,0,0.5);
    }
    .stat-v3-circle.mini { width: 30px; height: 30px; font-size: 0.8rem; border-width: 1px; }
    .stat-v3-circle.red { background: linear-gradient(145deg, #ff5252, #b30000); }
    .stat-v3-circle.black { background: linear-gradient(145deg, #424242, #1a1a1a); }
    .stat-v3-circle.zero { background: linear-gradient(145deg, #66bb6a, #004d00); }
    .stat-v3-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .stat-v3-label { font-size: 0.6rem; font-weight: 800; opacity: 0.8; color: #ff9800; text-transform: uppercase; letter-spacing: 0.5px; }

    .bet-badge { position: absolute; top: -5px; right: -5px; background: #ffD700; color: black; border-radius: 50%; width: 22px; height: 22px; font-size: 0.65rem; display: flex; align-items: center; justify-content: center; border: 2px solid white; font-weight: 900; z-index: 5; }
    .lucky-cell { border: 2px solid #ff9800 !important; box-shadow: 0 0 15px #ff9800; background: rgba(255, 152, 0, 0.2) !important; }
    .lightning-flash { animation: lightning-strike 0.5s ease-out infinite alternate; }
    @@keyframes lightning-strike { 0% { filter: brightness(1); } 100% { filter: brightness(1.6); } }
    .result-overlay-pro { position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.85); padding: 12px 20px; border-radius: 12px; border: 2px solid #d4af37; text-align: center; }
    .mode-rect-card { padding: 18px; border-radius: 12px; cursor: pointer; background: rgba(255,255,255,0.05); text-align: center; font-weight: 900; border: 2px solid transparent; }
    .active-classic { border-color: var(--mud-palette-primary) !important; background: rgba(124, 58, 237, 0.1) !important; }
    .active-extreme { border-color: var(--mud-palette-warning) !important; background: rgba(255, 152, 0, 0.1) !important; }

    .lucky-badge { 
        position: absolute; 
        bottom: 2px; right: 2px; 
        background: #ff9800; 
        color: #000; font-size: 0.65rem; font-weight: 950; 
        padding: 1px 4px; border-radius: 4px; border: 1px solid #fff;
        z-index: 10; pointer-events: none;
    }

    /* MOBILE PiP SYSTEM */
    @@media (max-width: 960px) {
        .mobile-pip-container { position: fixed; z-index: 2000; touch-action: none; }
        .mobile-pip-container.expanded { position: fixed; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; background: rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; transform: none !important; }
        .pip .wheel-paper { width: 100px; height: 100px; }
        .expanded .wheel-paper { width: 320px; height: 320px; }
        .canvas-container-pip canvas { width: 100% !important; height: 100% !important; }
        .pip .canvas-container-pip { width: 90px; height: 90px; }
        .expanded .canvas-container-pip { width: 300px; height: 300px; }
        .pip-hint { position: absolute; bottom: 2px; right: 2px; font-size: 0.6rem; color: #fff; opacity: 0.5; }
        .result-badge-mini { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.8); padding: 4px 8px; border-radius: 8px; z-index: 10; }

        .mobile-vertical { display: flex; flex-direction: column; gap: 8px; }
        .mobile-piles-container { display: flex; flex-direction: row; justify-content: space-between; gap: 12px; }
        .pile { display: flex; flex-direction: column; gap: 3px; flex: 1; }
        .cell { height: 34px !important; font-size: 1rem !important; border-radius: 4px; }
        .zero { width: 100% !important; height: 30px !important; margin-bottom: 4px; }
        .outside-grid-mobile { display: flex; flex-direction: column; gap: 4px; margin-top: 8px; }
        .outside-row { display: flex; width: 100%; gap: 4px; }
        .outside-row .cell { flex: 1; height: 35px !important; }
        .spin-controls-row {
            display: flex !important;
            flex-direction: row;
            align-items: center;
            justify-content: center;
        }
        .mode-btn-mobile { padding: 10px; text-align: center; font-size: 0.8rem; font-weight: 900; background: rgba(255,255,255,0.05); border-radius: 8px; cursor: pointer; border: 2px solid transparent; }
    }
</style>

@code {
    private decimal balance = 0;
    private decimal chipValue = 5.0m;
    private int? winningNumber;
    private bool isSpinning = false;
    private bool isMouseDown = false;
    private Guid? sessionId;
    private List<RouletteBetDto> currentBets = new();
    private string selectedMode = "Classic";
    private Dictionary<int, int> currentLuckyNumbers = new();
    private bool _wheelExpanded = false;

    // STATS TRACKING
    private List<int> historyNumbers = new();
    private List<NumberStat> hotNumbers = new();
    private List<NumberStat> coldNumbers = new();
    private decimal lastWinAmount = 0;

    public class NumberStat { public int Number { get; set; } public int Count { get; set; } }

    private async Task RefreshStats() {
        try {
            var allHistory = await Http.GetFromJsonAsync<List<GameHistoryDto>>("api/Game/public-history");
            var rouletteRounds = allHistory?.Where(h => h.GameName == "Roulette").Take(100).ToList() ?? new();
            
            historyNumbers = rouletteRounds.Select(r => {
                try {
                    var data = JsonSerializer.Deserialize<RouletteResult>(r.FullResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    return data?.Number ?? -1;
                } catch { return -1; }
            }).Where(n => n != -1).ToList();

            // Calculate Hot/Cold
            var counts = historyNumbers.GroupBy(n => n).Select(g => new NumberStat { Number = g.Key, Count = g.Count() }).ToList();
            hotNumbers = counts.OrderByDescending(c => c.Count).Take(5).ToList();
            
            // Cold = Numbers not in recent history, or least frequent
            var neverHit = Enumerable.Range(0, 37).Where(n => !historyNumbers.Contains(n)).Select(n => new NumberStat { Number = n, Count = 0 }).ToList();
            coldNumbers = neverHit.Concat(counts.OrderBy(c => c.Count)).Take(5).ToList();
            
            StateHasChanged();
        } catch { }
    }

    // Draggable Logic
    private double _wheelX = 250; 
    private double _wheelY = 80;
    private bool _isDragging = false;
    private double _dragStartX, _dragStartY;

    private void OnPointerDown(PointerEventArgs e) {
        if (!layoutService.IsMobile || _wheelExpanded) return;
        _isDragging = true;
        _dragStartX = e.ClientX - _wheelX;
        _dragStartY = e.ClientY - _wheelY;
    }
    private void OnPointerMove(PointerEventArgs e) {
        if (!_isDragging) return;
        _wheelX = e.ClientX - _dragStartX;
        _wheelY = e.ClientY - _dragStartY;
    }
    private void OnPointerUp(PointerEventArgs e) => _isDragging = false;
    
    private void ToggleWheelSize() {
        if (layoutService.IsMobile && !_isDragging) {
            _wheelExpanded = !_wheelExpanded;
            StateHasChanged();
        }
    }

    [Parameter] [SupplyParameterFromQuery] public string? Mode { get; set; }
    private bool turboMode = false;
    private bool lowGraphics = false;

    protected override void OnParametersSet() {
        if (!string.IsNullOrEmpty(Mode)) {
            if (Mode.Equals("Extreme", StringComparison.OrdinalIgnoreCase)) selectedMode = "Extreme";
            else if (Mode.Equals("Classic", StringComparison.OrdinalIgnoreCase)) selectedMode = "Classic";
        }
    }

    private void SetMode(string mode) { if (!isSpinning) { selectedMode = mode; StateHasChanged(); } }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            await Task.Delay(1500); // Wait longer for DOM
            await JSRuntime.InvokeVoidAsync("roulettePro.init", "roulette-pro-container");
        }
    }

    protected override async Task OnInitializedAsync() {
        await Audio.Init();
        await LoadInitialData();
        
        RealTime.OnGameUpdateReceived += async (data) => {
            try {
                var json = data.ToString();
                var update = JsonSerializer.Deserialize<Dictionary<string, object>>(json ?? "{}");
                if (update != null && update.ContainsKey("Game") && update["Game"].ToString() == "Roulette") {
                    await RefreshStats();
                }
            } catch { }
        };
    }

    private async Task LoadInitialData() {
        try {
            var sessionResponse = await GameService.StartSession("roulette");
            sessionId = sessionResponse.SessionId;
            var user = await AuthService.GetMe();
            if (user != null) {
                balance = user.TotalBalance;
                var prefs = JsonSerializer.Deserialize<Dictionary<string, object>>(user.PreferencesJson) ?? new();
                if (prefs.TryGetValue("TurboMode", out var turbo)) turboMode = turbo.ToString()?.ToLower() == "true";
                if (prefs.TryGetValue("LowGraphics", out var low)) lowGraphics = low.ToString()?.ToLower() == "true";
            }
            await RefreshStats();
        } catch { }
    }

    private async Task HandleMouseDown(string type, string value) { isMouseDown = true; await AddBet(type, value); }
    private async Task HandleMouseEnter(string type, string value) { if (isMouseDown) await AddBet(type, value); }
    private string GetCursorClass(string type, string value) => currentBets.Any(b => b.Type == type && b.Value == value && b.Amount >= 100) ? "limit-reached" : "";

    private async Task AddBet(string type, string value) {
        if (isSpinning) return;
        var existing = currentBets.FirstOrDefault(b => b.Type == type && b.Value == value);
        decimal currentAmount = existing?.Amount ?? 0;
        if (currentAmount >= 100) return;
        decimal allowedToAdd = Math.Min(chipValue, 100 - currentAmount);
        await Audio.PlayClick();
        if (existing != null) existing.Amount += allowedToAdd;
        else currentBets.Add(new RouletteBetDto { Type = type, Value = value, Amount = allowedToAdd });
        StateHasChanged();
    }

    private void ClearBets() { currentBets.Clear(); StateHasChanged(); }

    private async Task OnSpin() {
        if (sessionId == null || isSpinning || !currentBets.Any()) return;
        decimal totalWager = currentBets.Sum(x => x.Amount);
        if (totalWager > balance) { Snackbar.Add("Insufficient balance!", Severity.Warning); return; }
        isSpinning = true; winningNumber = null; currentLuckyNumbers.Clear();
        balance -= totalWager;
        layoutService.DeductOptimisticBalance(totalWager);
        layoutService.SetBalanceUpdateSuppression(true);
        StateHasChanged();
        try {
            await Audio.PlaySpin();
            var result = await GameService.PlaceBet("roulette", sessionId.Value, totalWager, new { Bets = currentBets, Mode = selectedMode });
            var resultData = JsonSerializer.Deserialize<RouletteResult>(result.RandomResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (resultData != null) {
                await JSRuntime.InvokeVoidAsync("roulettePro.spin", resultData.Number);
                await Task.Delay(turboMode ? 200 : 1500);
                if (resultData.LuckyNumbers != null) { currentLuckyNumbers = resultData.LuckyNumbers; StateHasChanged(); }
            }
            await Task.Delay(turboMode ? 1500 : 5500);
            winningNumber = resultData?.Number;
            lastWinAmount = result.TotalWin;

            if (result.TotalWin > 0) {
                string winMsg = (resultData?.Multiplier > 0) ? $"LIGHTNING WIN! {resultData.Multiplier}x! Total: {result.TotalWin:C2}" : $"WINNER! {winningNumber} paid {result.TotalWin:C2}";
                Snackbar.Add(winMsg, resultData?.Multiplier > 0 ? Severity.Warning : Severity.Success);
                await Audio.PlayWin();
            }
            var user = await AuthService.GetMe();
            if (user != null) balance = user.TotalBalance;
            currentBets.Clear();
            await RefreshStats();
        } catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { isSpinning = false; layoutService.SetBalanceUpdateSuppression(false); StateHasChanged(); }
    }

    private string GetNumberColor(int num) {
        if (num == 0) return "zero";
        int[] redNumbers = { 1, 3, 5, 7, 9, 12, 14, 16, 18, 19, 21, 23, 25, 27, 30, 32, 34, 36 };
        return redNumbers.Contains(num) ? "red" : "black";
    }

    private RenderFragment? GetBetBadge(string type, string value) {
        var bet = currentBets.FirstOrDefault(b => b.Type == type && b.Value == value);
        if (bet == null) return null;
        return builder => {
            builder.OpenElement(0, "div"); builder.AddAttribute(1, "class", "bet-badge");
            builder.AddContent(2, bet.Amount.ToString("N0")); builder.CloseElement();
        };
    }

    private RenderFragment? GetLuckyBadge(int number) {
        if (!currentLuckyNumbers.TryGetValue(number, out int mult)) return null;
        return builder => {
            builder.OpenElement(0, "div"); builder.AddAttribute(1, "class", "lucky-badge animate-bounce");
            builder.AddContent(2, $"x{mult}"); builder.CloseElement();
        };
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;

    public class RouletteResult { 
        public int Number { get; set; } 
        public string Mode { get; set; } = "Classic";
        public Dictionary<int, int>? LuckyNumbers { get; set; }
        public int Multiplier { get; set; }
    }
}
