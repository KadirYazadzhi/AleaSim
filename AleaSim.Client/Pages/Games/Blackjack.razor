@page "/game/blackjack"
@using System.Text.Json
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@implements IAsyncDisposable
@inject IGameService GameService
@inject AudioService Audio
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IAuthService AuthService
@inject LayoutService LayoutService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" lg="9">
            <MudPaper Class="pa-8" Style="background: radial-gradient(circle, #006400 0%, #004d00 100%); border: 12px solid #3d2b1f; border-radius: 50% 50% 10% 10% / 20% 20% 10% 10%; min-height: 500px; position: relative; color: white;">
                
                <div class="text-center mb-16">
                    <MudText Typo="Typo.h6" Class="mb-2" Style="opacity: 0.7;">DEALER</MudText>
                    <div class="d-flex justify-center gap-2">
                        @for (int j = 0; j < dealerHand.Count; j++)
                        {
                            var card = dealerHand[j];
                            <div @key='@($"dealer_card_{j}_{card}")' class="playing-card @(card.Contains('H') || card.Contains('D') ? "red" : "")">
                                @FormatCard(card)
                            </div>
                        }
                        @if (dealerHand.Count == 1 && !isRoundOver)
                        {
                            <div class="playing-card back">?</div>
                        }
                    </div>
                    @if (isRoundOver) {
                        <MudText Typo="Typo.h5" Color="Color.Warning" Class="mt-2">Dealer Value: @CalculateValue(dealerHand)</MudText>
                    }
                </div>

                <div class="table-center">
                    <MudText Typo="Typo.h4" Style="opacity: 0.2; font-weight: 900; letter-spacing: 5px;">BLACKJACK PAY 3 TO 2</MudText>
                    <MudText Typo="Typo.subtitle1" Style="opacity: 0.2;">Dealer must stand on 17 and draw to 16</MudText>
                </div>

                <div class="d-flex justify-center gap-12 mt-16">
                    @for (int i = 0; i < playerHands.Count; i++)
                    {
                        var hand = playerHands[i];
                        bool isActive = !isRoundOver && i == activeHandIndex;
                        <div class='@($"hand-container {(isActive ? "active-hand" : "")} {(CalculateValue(hand.Cards) > 21 ? "bust-hand" : "")}")'>
                            <div class="d-flex justify-center gap-2 mb-2">
                                @for (int j = 0; j < hand.Cards.Count; j++)
                                {
                                    var card = hand.Cards[j];
                                    <div @key='@($"player_card_{i}_{j}_{card}")' class="playing-card @(card.Contains('H') || card.Contains('D') ? "red" : "")">
                                        @FormatCard(card)
                                    </div>
                                }
                            </div>
                            <MudText Typo="Typo.h6" Class="fw-bold">
                                Value: @CalculateValue(hand.Cards) 
                                @if (hand.IsDoubled) { <span class="ml-2 color-warning">x2</span> }
                            </MudText>
                            @if (isActive) {
                                <div class="active-indicator animate-pulse">YOUR TURN</div>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(gameResult))
                {
                    <div class="result-overlay">
                        <MudText Typo="Typo.h2" Style="font-weight: 900; text-shadow: 2px 2px 10px black;">@gameResult</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="3">
            <MudPaper Class="pa-6 d-flex flex-column gap-4">
                <MudText Typo="Typo.h5">Balance: <span style="color: #4caf50;">@balance.ToString("C2")</span></MudText>
                
                <MudNumericField @bind-Value="betAmount" Label="Bet" Variant="Variant.Outlined" Min="1" Max="500" Disabled="@(!isRoundOver && playerHands.Any())" />

                @if (isRoundOver || !playerHands.Any())
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="OnDeal" Style="height: 80px;">DEAL</MudButton>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" OnClick='() => OnAction("hit")' Style="height: 60px;">HIT</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" OnClick='() => OnAction("stand")' Style="height: 60px;">STAND</MudButton>
                        </div>
                        <div class="d-flex gap-2">
                            @if (CanSplit()) {
                                <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true" OnClick='() => OnAction("split")'>SPLIT</MudButton>
                            }
                            @if (CanDouble()) {
                                <MudButton Variant="Variant.Outlined" Color="Color.Warning" FullWidth="true" OnClick='() => OnAction("double")'>DOUBLE</MudButton>
                            }
                        </div>
                        @if (CanInsurance()) {
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" OnClick='() => OnAction("insurance")'>INSURANCE</MudButton>
                        }
                    </div>
                }

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.caption" Align="Align.Center">RPG XP per Deal: @(betAmount * 10)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .playing-card {
        width: 80px; height: 120px; background: white; border-radius: 8px; color: black;
        display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold;
        box-shadow: 3px 3px 5px rgba(0,0,0,0.5); border: 1px solid #ddd;
    }
    .playing-card.red { color: #b30000; }
    .playing-card.back { background: #b30000; color: white; border: 2px solid white; }
    
    .table-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; width: 100%; pointer-events: none; }
    .result-overlay { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100; text-align: center; width: 100%; animation: bounce 0.5s ease; }
    
    @@keyframes bounce {
        0% { transform: translate(-50%, -50%) scale(0.5); }
        70% { transform: translate(-50%, -50%) scale(1.1); }
        100% { transform: translate(-50%, -50%) scale(1.0); }
    }

    .hand-container { text-align: center; padding: 16px; border-radius: 16px; transition: all 0.3s ease; position: relative; }
    .active-hand { background: rgba(255,255,255,0.1); border: 2px solid var(--mud-palette-info); transform: scale(1.05); }
    .bust-hand { opacity: 0.5; filter: grayscale(1); }
    .active-indicator { position: absolute; top: -25px; left: 50%; transform: translateX(-50%); font-size: 0.7rem; font-weight: 900; color: var(--mud-palette-info); background: white; padding: 2px 8px; border-radius: 4px; }
    .color-warning { color: #ff9800; }
</style>

@code {
    private List<BlackjackHandUI> playerHands = new();
    private List<string> dealerHand = new();
    private int activeHandIndex = 0;
    private decimal balance = 0;
    private decimal betAmount = 10.0m;
    private bool isRoundOver = true;
    private string gameResult = "";
    private Guid? sessionId;
    
    // Performance Flags
    private bool turboMode = false;
    private bool lowGraphics = false;

    protected override async Task OnInitializedAsync() {
        await Audio.Init();
        await LoadData();
    }

    private async Task LoadData() {
        await RefreshBalance();
        try {
            var session = await GameService.ResumeSession("blackjack");
            if (session != null) {
                sessionId = session.SessionId;
                if (session.GameState != null) {
                    var state = JsonSerializer.Deserialize<BlackjackStateUI>(session.GameState.ToString() ?? "{}", new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (state != null) await UpdateUI(state);
                }
                Snackbar.Add("Session Resumed!", Severity.Info);
            }
        } catch { }
    }

    private async Task RefreshBalance() {
        try {
            var user = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (user != null) {
                balance = user.TotalBalance;
                var prefs = JsonSerializer.Deserialize<Dictionary<string, object>>(user.PreferencesJson) ?? new();
                if (prefs.TryGetValue("TurboMode", out var turbo)) turboMode = turbo.ToString()?.ToLower() == "true";
                if (prefs.TryGetValue("LowGraphics", out var low)) lowGraphics = low.ToString()?.ToLower() == "true";
            }
            StateHasChanged();
        } catch { }
    }

    private async Task OnDeal() {
        if (sessionId == null) {
            try {
                var sessionResponse = await GameService.StartSession("blackjack");
                sessionId = sessionResponse.SessionId;
            } catch { Snackbar.Add("Failed to start session", Severity.Error); return; }
        }

        if (betAmount > balance) {
            Snackbar.Add("Insufficient funds", Severity.Warning);
            return;
        }
        
        gameResult = "";
        isRoundOver = false;
        playerHands.Clear();
        dealerHand.Clear();
        
        LayoutService.SetBalanceUpdateSuppression(true);
        StateHasChanged();

        try {
            await Audio.PlaySpin();
            balance -= betAmount;
            LayoutService.DeductOptimisticBalance(betAmount); 
            
            var result = await GameService.PlaceBet("blackjack", sessionId.Value, betAmount, new { });
            var state = JsonSerializer.Deserialize<BlackjackStateUI>(result.RandomResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (state != null) await UpdateUI(state);
            
            if (!isRoundOver) {
                LayoutService.SetBalanceUpdateSuppression(false);
                var user = await AuthService.GetMe();
                if (user != null) balance = user.TotalBalance;
            }
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
            isRoundOver = true;
            LayoutService.SetBalanceUpdateSuppression(false);
            await RefreshBalance();
        }
    }

    private async Task OnAction(string action) {
        if (sessionId == null || isRoundOver) return;
        await Audio.PlayClick();
        LayoutService.SetBalanceUpdateSuppression(true);
        
        try {
            var response = await GameService.PerformAction("blackjack", sessionId.Value, action);
            if (response.Success) {
                var state = JsonSerializer.Deserialize<BlackjackStateUI>(response.UpdatedStateJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (state != null) await UpdateUI(state);
            }
            if (!isRoundOver) LayoutService.SetBalanceUpdateSuppression(false);
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
            LayoutService.SetBalanceUpdateSuppression(false);
        }
    }

    private async Task UpdateUI(BlackjackStateUI state) {
        playerHands = state.PlayerHands;
        dealerHand = state.DealerHand;
        activeHandIndex = state.ActiveHandIndex;
        isRoundOver = state.IsRoundOver;
        
        if (isRoundOver) {
            bool anyWin = false;
            foreach(var hand in playerHands) {
                int pVal = CalculateValue(hand.Cards);
                int dVal = CalculateValue(dealerHand);
                if (pVal <= 21 && (dVal > 21 || pVal >= dVal)) anyWin = true;
            }
            
            if (anyWin && state.TotalWin > 0) {
                gameResult = $"YOU WON {state.TotalWin:C2}!";
                await Audio.PlayWin();
            } else if (state.TotalWin > 0) {
                gameResult = $"PUSH! RETURNED {state.TotalWin:C2}";
            } else {
                gameResult = "DEALER WINS!";
            }
            
            // Wait for animations
            await Task.Delay(turboMode ? 200 : 1000);
            
            var user = await AuthService.GetMe();
            if (user != null) balance = user.TotalBalance;
            LayoutService.SetBalanceUpdateSuppression(false);
        }
        StateHasChanged();
    }

    private string FormatCard(string card) {
        if (string.IsNullOrEmpty(card)) return "";
        string rank = card.Substring(0, card.Length - 1);
        string suit = card.Substring(card.Length - 1) switch { "H" => "♥", "D" => "♦", "C" => "♣", "S" => "♠", _ => "" };
        return rank + suit;
    }

    private int CalculateValue(List<string> hand) {
        int value = 0; int aces = 0;
        foreach (var card in hand) {
            string rank = card.Substring(0, card.Length - 1);
            if (rank == "A") aces++;
            else if (new[] { "J", "Q", "K", "10" }.Contains(rank)) value += 10;
            else value += int.Parse(rank);
        }
        for (int i = 0; i < aces; i++) value += (value + 11 <= 21) ? 11 : 1;
        return value;
    }

    private bool CanSplit() {
        if (isRoundOver || playerHands.Count != 1) return false;
        var hand = playerHands[0];
        if (hand.Cards.Count != 2) return false;
        string r1 = hand.Cards[0].Substring(0, hand.Cards[0].Length - 1);
        string r2 = hand.Cards[1].Substring(0, hand.Cards[1].Length - 1);
        return r1 == r2 || (new[] { "10", "J", "Q", "K" }.Contains(r1) && new[] { "10", "J", "Q", "K" }.Contains(r2));
    }

    private bool CanDouble() {
        if (isRoundOver || activeHandIndex >= playerHands.Count) return false;
        var hand = playerHands[activeHandIndex];
        if (hand.Cards.Count != 2 || playerHands.Count > 1) return false;
        int val = CalculateValue(hand.Cards);
        return val == 10 || val == 11;
    }

    private bool CanInsurance() {
        if (isRoundOver || playerHands.Count > 1 || dealerHand.Count != 2) return false;
        return dealerHand[0].StartsWith("A");
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
    public class BlackjackHandUI { 
        public List<string> Cards { get; set; } = new(); 
        public decimal Bet { get; set; } 
        public bool IsDoubled { get; set; } 
        public bool IsStand { get; set; } 
        public bool IsSplitHand { get; set; }
    }
    public class BlackjackStateUI { 
        public List<BlackjackHandUI> PlayerHands { get; set; } = new(); 
        public List<string> DealerHand { get; set; } = new(); 
        public int ActiveHandIndex { get; set; }
        public bool IsRoundOver { get; set; } 
        public decimal TotalWin { get; set; }
    }
}
