@page "/game/cloverchase"
@using System.Text.Json
@using Blazored.LocalStorage
@using AleaSim.Client.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@implements IAsyncDisposable
@inject IGameService GameService
@inject AudioService Audio
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4" Style="position: relative;">
    <AuthorizeView Roles="Admin">
        <Authorized>
            <div class="admin-overlay pa-4">
                <MudText Typo="Typo.subtitle2" Color="Color.Error"><b>DEV MODE ACTIVE</b></MudText>
                <MudText Typo="Typo.caption">Target RTP: 95.0%</MudText>
            </div>
        </Authorized>
    </AuthorizeView>

    <CelebrationOverlay @ref="localCelebration" />
    <MudGrid>
        <MudItem xs="12" lg="9">
            <div class="d-flex justify-space-between align-center mb-2 px-2">
                <MudText Typo="Typo.caption" Style="color: #666;">SESSION ID: @sessionId?.ToString().Substring(0, 8)</MudText>
            </div>

            <MudPaper Class="pa-4 bg-dark text-center mb-4" Elevation="4" Style="@(jackpot.IsHot ? "background: #4a0000; border: 2px solid #ff4500; animation: pulse-red 1s infinite;" : "background: #2c3e50; border: 2px solid #ffD700;")">
                <MudText Typo="Typo.h4" Style="color: #ffD700; font-weight: bold; text-shadow: 0 0 10px rgba(255,215,0,0.5);">
                    @jackpot.Name: $@jackpot.CurrentValue.ToString("N2")
                </MudText>
            </MudPaper>

            <MudPaper Class="pa-2" Style="background: #0f0f0f; border: 6px solid #3d2b1f; border-radius: 15px; box-shadow: inset 0 0 50px #000;">
                <div class="slot-container">
                    <MudGrid Spacing="1">
                        @for (int c = 0; c < 5; c++)
                        {
                            var colIndex = c;
                            bool isAnticipating = IsAnticipating(colIndex);
                            <MudItem xs="2" Style="flex-basis: 20%; max-width: 20%;">
                                <div class="reel @(isSpinning ? "spinning" : "") @(isAnticipating ? "anticipation" : "")" 
                                     style="animation-delay: @(colIndex * (isAnticipating ? 0.6 : 0.1))s">
                                    @for (int r = 0; r < 4; r++)
                                    {
                                        var rowIndex = r;
                                        <div class="symbol-cell @(GetSymbolClass(grid[rowIndex, colIndex]))">
                                            @GetSymbolContent(grid[rowIndex, colIndex])
                                        </div>
                                    }
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </div>
            </MudPaper>

            <MudPaper Class="mt-4 pa-4 d-flex justify-space-between align-center" Style="background: #1a1a1a; color: white;">
                <MudText Typo="Typo.h6">LAST WIN: <span style="color: #ffD700;">$@lastWin.ToString("N2")</span></MudText>
                <div class="d-flex gap-4">
                    @if (gameState.IsBonusActive) {
                        <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Favorite">LIVES: @gameState.BonusLives</MudChip>
                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled">BONUS MODE</MudChip>
                    }
                    @if (gameState.IsRespinActive) {
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled">RESPIN LIVES: @gameState.RespinLives</MudChip>
                    }
                </div>
                <MudText Typo="Typo.h6">BET: $@betAmount.ToString("N2")</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="3">
            <MudStack Spacing="4">
                <MudPaper Class="pa-6" Elevation="3">
                    <MudText Typo="Typo.h5" Class="mb-4">Credits: <span style="color: #4caf50; font-weight: bold;">$@balance.ToString("N2")</span></MudText>
                    <MudNumericField @bind-Value="betAmount" Label="Stake" Variant="Variant.Outlined" Min="0.1m" Max="100" Step="0.5m" Format="C2" />
                    <MudButton Variant="Variant.Filled" Color="@(gameState.IsBonusActive ? Color.Error : Color.Primary)" Size="Size.Large" OnClick="OnSpin" Disabled="@(isSpinning)" FullWidth="true" Class="mt-4" Style="height: 100px; font-size: 2rem; font-weight: 900;">
                        @(isSpinning ? "..." : (gameState.IsBonusActive ? "FREE SPIN" : "SPIN"))
                    </MudButton>
                    <div class="d-flex gap-2 mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" OnClick='() => OnAction("gamble")' Disabled="@(lastWin == 0 || isSpinning)">GAMBLE</MudButton>
                    </div>
                </MudPaper>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .slot-container { padding: 10px; }
    .symbol-cell { height: 110px; display: flex; align-items: center; justify-content: center; background: linear-gradient(#333, #111); margin-bottom: 6px; border-radius: 8px; font-size: 2.8rem; border: 1px solid #444; }
    .symbol-high { border: 2px solid #ffD700; }
    .symbol-clover { border: 2px solid #4caf50; }
    .spinning { animation: reel-spin 0.1s infinite linear; }
    .anticipation { border: 2px solid #ff4500; box-shadow: 0 0 20px #ff4500; animation: reel-spin 0.05s infinite linear !important; }
    @@keyframes reel-spin { 0% { transform: translateY(0); } 100% { transform: translateY(10px); } }
</style>

@code {
    private int[,] grid = new int[4, 5];
    private bool isSpinning = false;
    private CelebrationOverlay localCelebration = default!;
    private decimal balance = 0;
    private decimal lastWin = 0;
    private decimal betAmount = 1.0m;
    private JackpotDto jackpot = new() { Name = "GLOBAL JACKPOT", CurrentValue = 12450.23m };
    private Guid? sessionId;
    private SlotGameStateUI gameState = new();
    private List<QuestUI> activeQuests = new();
    private UserProfileResponse? profile;

    protected override async Task OnInitializedAsync() {
        for(int r=0; r<4; r++) for(int c=0; c<5; c++) grid[r,c] = 1;
        RealTime.OnJackpotUpdated += HandleJackpotUpdate;
        await LoadInitialData();
    }

    private void HandleJackpotUpdate(JackpotDto dto) { if (dto.IsGlobal) { jackpot = dto; InvokeAsync(StateHasChanged); } }

    private async Task LoadInitialData() {
        try {
            var sessionResponse = await GameService.StartSession("slot");
            sessionId = sessionResponse.SessionId;
            profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (profile != null) {
                balance = profile.Balance;
                if (!string.IsNullOrEmpty(profile.ActiveGameStateJson)) {
                    var recovered = JsonSerializer.Deserialize<RecoveredState>(profile.ActiveGameStateJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (recovered != null && recovered.Grid != null) {
                        for(int r=0; r<4; r++) for(int c=0; c<5; c++) grid[r,c] = recovered.Grid[r][c];
                        gameState.IsBonusActive = recovered.IsBonusActive;
                        gameState.IsRespinActive = recovered.IsRespinActive;
                        betAmount = recovered.LockedBet > 0 ? recovered.LockedBet : betAmount;
                    }
                }
            }
        } catch { }
    }

    private bool IsAnticipating(int col) {
        if (!isSpinning || col < 3) return false;
        int clovers = 0;
        for (int c = 0; c < col; c++) {
            for (int r = 0; r < 4; r++) if (grid[r, c] == 8) { clovers++; break; }
        }
        return clovers >= 3;
    }

    private async Task OnSpin() {
        if (sessionId == null || isSpinning) return;
        isSpinning = true; lastWin = 0; StateHasChanged();
        try {
            await Audio.PlaySpin();
            var result = await GameService.PlaceBet("slot", sessionId.Value, betAmount);
            await Task.Delay(2000);
            var gridData = JsonSerializer.Deserialize<SlotResultGrid>(result.RandomResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (gridData != null && gridData.Grid != null) {
                for (int r = 0; r < 4; r++) for (int c = 0; c < 5; c++) grid[r, c] = gridData.Grid[r][c];
            }
            lastWin = result.TotalWin;
            profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (profile != null) balance = profile.Balance;
            if (lastWin > betAmount * 20) localCelebration.Show(profile?.Username ?? "You", "Clover Chase", lastWin, lastWin/betAmount);
        } catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { isSpinning = false; StateHasChanged(); }
    }

    private async Task OnAction(string action) {
        await GameService.PerformAction("slot", sessionId!.Value, action);
        await LoadInitialData();
    }

    private string GetSymbolClass(int id) => id switch { 7 => "symbol-high", 8 => "symbol-clover", 10 => "symbol-clover symbol-high", _ => "" };
    private string GetSymbolContent(int id) => id switch { 1 => "🍒", 2 => "🍋", 3 => "🍊", 4 => "🍇", 5 => "🔔", 6 => "💎", 7 => "7️⃣", 8 => "🍀", 10 => "💰", 11 => "🥈", 12 => "🥉", _ => "🍃" };

    public async ValueTask DisposeAsync() { RealTime.OnJackpotUpdated -= HandleJackpotUpdate; }
    public class QuestUI { public string Description { get; set; } = ""; public int TargetValue { get; set; } public int CurrentProgress { get; set; } }
    public class RecoveredState { public int[][] Grid { get; set; } = null!; public bool IsRespinActive { get; set; } public bool IsBonusActive { get; set; } public decimal LockedBet { get; set; } }
}