@page "/game/cloverchase"
@using System.Text.Json
@using AleaSim.Client.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@implements IAsyncDisposable
@inject IGameService GameService
@inject AudioService Audio
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject LayoutService layoutService
@inject IAuthService AuthService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" lg="9">
            <div class="mb-4">
                <MultiJackpotWidget Denomination="@denomination" />
            </div>

            <!-- PixiJS Slot Machine View -->
            <MudPaper Class="pa-2" Style="background: #000; border: 10px solid #3d2b1f; border-radius: 20px; box-shadow: 0 0 30px rgba(0,0,0,0.8); position: relative;">
                <div id="pixi-slot-container" style="width: 100%; height: 480px; background: #000; display: flex; justify-content: center; align-items: center;">
                    <!-- Canvas will be injected here by PixiJS -->
                </div>
                <div class="win-light @(lastWin > 0 ? "active" : "")"></div>
                
                @if (gameState.IsRespinActive) {
                    <div class="overlay-text" style="top: 20px;">RESPIN ACTIVE!</div>
                }
                @if (wasNudged) {
                    <div class="overlay-text nudged" style="bottom: 20px;">MYSTERY NUDGE!</div>
                }
            </MudPaper>

            <!-- Status Bar -->
            <MudPaper Class="mt-4 pa-4 d-flex justify-space-between align-center" Style="background: linear-gradient(#1a1a1a, #000); color: white; border-bottom: 4px solid #d4af37;">
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.caption" Style="color: #888;">LAST WIN</MudText>
                    <MudText Typo="Typo.h4" Style="color: #ffD700; font-weight: 900; text-shadow: 0 0 10px rgba(255,215,0,0.5);">@lastWin.ToString("C2")</MudText>
                </div>
                
                <div class="d-flex gap-4">
                    @if (gameState.IsBonusActive) {
                        <div class="feature-badge bonus">BELL BONUS: @gameState.BonusLives LIVES</div>
                    }
                    @if (gameState.IsGambleActive) {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="OpenGamble">GAMBLE @gameState.PendingGambleWin.ToString("C2")</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="CollectWin">COLLECT</MudButton>
                    }
                </div>

                <div class="text-right d-flex flex-column">
                    <MudText Typo="Typo.caption" Style="color: #888;">BALANCE</MudText>
                    <MudText Typo="Typo.h4" Style="color: #4caf50; font-weight: 900;">@balance.ToString("C2")</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Controls -->
        <MudItem xs="12" lg="3">
            <MudPaper Class="pa-6" Style="background: #222; color: white; height: 100%; border-left: 4px solid #444;">
                <div class="credits-display mb-6">
                    <MudText Typo="Typo.h5" Align="Align.Center" Style="color: #ffeb3b; font-weight: 900; font-family: monospace;">
                        CREDITS: @((balance / (denomination > 0 ? denomination : 0.01m)).ToString("N0"))
                    </MudText>
                </div>

                <MudSelect T="decimal" Label="Denomination" @bind-Value="denomination" Variant="Variant.Filled" Class="mb-4" 
                           Disabled="@(isSpinning || gameState.IsBonusActive || gameState.IsRespinActive || gameState.IsGambleActive)">
                    <MudSelectItem Value="@(0.01m)">@((0.01m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(0.05m)">@((0.05m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(0.10m)">@((0.10m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(0.50m)">@((0.50m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(1.00m)">@((1.00m).ToString("C2"))</MudSelectItem>
                </MudSelect>

                <MudNumericField @bind-Value="creditsBet" Label="Bet (Credits)" Variant="Variant.Filled" Min="10" Max="100" Step="10" 
                                 Disabled="@(isSpinning || gameState.IsBonusActive || gameState.IsRespinActive)" />
                
                <div class="mt-2 text-center">
                    <MudText Typo="Typo.subtitle1" Style="color: #aaa;">Total Stake: <b>@((creditsBet * denomination).ToString("C2"))</b></MudText>
                </div>

                <MudButton Variant="Variant.Filled" 
                           Color="@(gameState.IsBonusActive ? Color.Error : (gameState.IsRespinActive ? Color.Warning : Color.Primary))" 
                           OnClick="OnSpin" 
                           Disabled="@(isSpinning || (balance < (creditsBet * denomination) && !gameState.IsRespinActive && !gameState.IsBonusActive))" 
                           FullWidth="true" 
                           Class="mt-8 spin-button"
                           Style="height: 100px; font-size: 2rem; font-weight: 900;">
                    @if (gameState.IsBonusActive) { <text>BONUS</text> }
                    else if (gameState.IsRespinActive) { <text>RESPIN</text> }
                    else if (isSpinning) { <text>WAIT</text> }
                    else { <text>SPIN</text> }
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .spin-button { box-shadow: 0 8px 0 #1565c0, 0 15px 20px rgba(0,0,0,.35); transition: all .1s; }
    .spin-button:active { transform: translateY(4px); box-shadow: 0 4px 0 #1565c0, 0 8px 10px rgba(0,0,0,.3); }
    .feature-badge { padding: 8px 20px; border-radius: 4px; font-weight: 900; border: 2px solid white; box-shadow: 0 0 15px rgba(255,255,255,0.5); }
    .bonus { background: #d32f2f; color: white; animation: pulse 1s infinite; }
    .overlay-text { position: absolute; left: 50%; transform: translateX(-50%); font-size: 3rem; color: #ffeb3b; font-weight: 900; text-shadow: 0 0 20px black; z-index: 100; pointer-events: none; }
    .nudged { color: #e91e63; animation: bounce 0.5s; }
    @@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
    @@keyframes bounce { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-20px); } }
</style>

@code {
    private bool isSpinning = false;
    private decimal balance = 0;
    private decimal lastWin = 0;
    private decimal denomination = 0.01m;
    private int creditsBet = 10;
    private Guid? sessionId;
    private SlotState gameState = new();
    private bool wasNudged = false;
    
    // Performance Flags
    private bool turboMode = false;
    private bool lowGraphics = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try {
                // Small delay to ensure PIXI container is fully ready in DOM
                await Task.Delay(500); 
                await LoadData();
                await JSRuntime.InvokeVoidAsync("slotEngine.init", "pixi-slot-container", turboMode, lowGraphics);
                
                // Keep this for subsequent runtime changes
                await SetEnginePerformance();
            } catch (Exception ex) {
                Console.WriteLine($"JS Init Error: {ex.Message}");
            }
        }
    }

    private async Task SetEnginePerformance() {
        try {
            await JSRuntime.InvokeVoidAsync("slotEngine.setPerformanceMode", turboMode, lowGraphics);
        } catch {
            // Fallback if script hasn't updated in browser cache yet
        }
    }

    private async Task LoadData()
    {
        try {
            var profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (profile != null) {
                balance = profile.TotalBalance;
                
                // Parse preferences for performance
                var prefs = JsonSerializer.Deserialize<Dictionary<string, object>>(profile.PreferencesJson) ?? new();
                if (prefs.TryGetValue("TurboMode", out var turbo)) turboMode = turbo.ToString()?.ToLower() == "true";
                if (prefs.TryGetValue("LowGraphics", out var low)) lowGraphics = low.ToString()?.ToLower() == "true";
            }

            var session = await GameService.ResumeSession("slot");
            if (session != null) {
                sessionId = session.SessionId;
                if (session.GameState != null) {
                    string json = session.GameState.ToString() ?? "{}";
                    gameState = JsonSerializer.Deserialize<SlotState>(json) ?? new();
                    
                    if (gameState.Denomination > 0) denomination = gameState.Denomination;
                    
                    if (gameState.IsGambleActive) lastWin = gameState.PendingGambleWin;
                }
                Snackbar.Add("Session Resumed!", Severity.Info);
            } else {
                var newSession = await GameService.StartSession("slot");
                sessionId = newSession.SessionId;
            }
        } catch (Exception ex) {
            Snackbar.Add("Error loading game: " + ex.Message, Severity.Error);
        }
    }

    private async Task OnSpin()
    {
        if (isSpinning || sessionId == null) return;
        isSpinning = true;
        wasNudged = false;
        
        // Sync performance mode just in case it was changed in settings dialog
        await SetEnginePerformance();

        // Logic: Bonus features are FREE, but Respins are PAID (as per Design Specs)
        var betAmount = gameState.IsBonusActive ? 0 : (creditsBet * denomination);

        // Optimistic local update area
        if (betAmount > 0) {
            if (balance < betAmount) {
                Snackbar.Add("Insufficient Balance for Respin!", Severity.Warning);
                isSpinning = false;
                return;
            }
            balance -= betAmount;
            layoutService.DeductOptimisticBalance(betAmount); // Update Navbar immediately
            StateHasChanged();
        }

        // Suppress Navbar updates to prevent spoilers
        layoutService.SetBalanceUpdateSuppression(true);
        
        try {
            await Audio.PlaySpin();
            
            var result = await GameService.PlaceBet("slot", sessionId.Value, betAmount, new { Denomination = denomination });
            
            await JSRuntime.InvokeVoidAsync("slotEngine.spin", result.RandomResultJson);
            
            // Wait for animation to finish (much shorter in turbo mode)
            var waitTime = turboMode ? 1000 : 3500;
            await Task.Delay(waitTime); 

            // Fetch official balance from server to ensure perfect sync
            var profile = await AuthService.GetMe();
            if (profile != null) balance = profile.TotalBalance;

            lastWin = result.TotalWin;
            
            var gridData = JsonSerializer.Deserialize<SlotStateResponse>(result.RandomResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (gridData != null) {
                gameState.IsBonusActive = gridData.IsBonusActive;
                gameState.IsRespinActive = gridData.IsRespinActive;
                gameState.IsGambleActive = lastWin > 0 && !gameState.IsBonusActive && !gameState.IsRespinActive; 
                gameState.PendingGambleWin = lastWin;
                wasNudged = gridData.WasNudged;
                
                if (wasNudged) await Audio.PlayBonus(); 
            }

            StateHasChanged();

            if (gameState.IsGambleActive) {
                await OpenGamble();
            }

        } catch (Exception ex) { 
            if (ex.Message.Contains("402") || ex.Message.Contains("Insufficient")) {
                Snackbar.Add("Insufficient Funds! Please Deposit.", Severity.Warning);
            } else {
                Snackbar.Add(ex.Message, Severity.Error); 
            }
        }
        finally { 
            isSpinning = false; 
            // Release Navbar updates
            layoutService.SetBalanceUpdateSuppression(false);
            StateHasChanged(); 
        }
    }

    private async Task OpenGamble() {
        if (gameState == null) return;
        var parameters = new DialogParameters { ["Amount"] = gameState.PendingGambleWin, ["SessionId"] = sessionId };
        var dialog = await DialogService.ShowAsync<GambleDialog>("Double or Nothing", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled) {
            var profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (profile != null) balance = profile.TotalBalance;
            gameState.IsGambleActive = false; 
        } else if (gameState != null) {
            gameState.IsGambleActive = false;
            var profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (profile != null) balance = profile.TotalBalance;
        }
        StateHasChanged();
    }

    private async Task CollectWin() {
        if (sessionId == null || gameState == null) return;
        await GameService.PerformAction("slot", sessionId.Value, "collect", "{}");
        gameState.IsGambleActive = false;
        var profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
        if (profile != null) balance = profile.TotalBalance;
        StateHasChanged();
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;

    public class SlotState {
        public bool IsBonusActive { get; set; }
        public int BonusLives { get; set; }
        public bool IsRespinActive { get; set; }
        public bool IsGambleActive { get; set; }
        public decimal PendingGambleWin { get; set; }
        public decimal Denomination { get; set; } = 0.01m;
    }
    
    public class SlotStateResponse {
        public bool IsBonusActive { get; set; }
        public bool IsRespinActive { get; set; }
        public bool WasNudged { get; set; }
    }
}