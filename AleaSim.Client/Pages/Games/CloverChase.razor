@page "/game/cloverchase"
@using System.Text.Json
@using AleaSim.Client.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@attribute [Authorize]
@implements IAsyncDisposable
@inject IGameService GameService
@inject AudioService Audio
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject LayoutService LayoutService
@inject IAuthService AuthService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" lg="9">
            <div class="mb-4">
                <MultiJackpotWidget Denomination="@denomination" FullGridMode="true" />
            </div>

            <!-- PixiJS Slot Machine View -->
            <div class='@($"game-viewport-v4 {(LayoutService.IsDarkMode ? "dark" : "light")}")'>
                <div id="pixi-slot-container" style="width: 100%; height: 540px; display: flex; justify-content: center; align-items: center;">
                    <!-- Canvas will be injected here by PixiJS -->
                </div>
                
                <!-- Info Button -->
                <div style="position: absolute; top: 15px; right: 15px; z-index: 101;">
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Inherit" Class="glass-panel rounded-circle" OnClick="OpenPaytable" />
                </div>

                <div class="win-light @(lastWin > 0 ? "active" : "")"></div>
                
                @if (gameState.IsRespinActive || (isSpinning && wasInRespin)) {
                    <div class="overlay-text" style="top: 20px;">
                        RESPIN: @(gameState.RespinLives) @(gameState.RespinLives == 1 ? "LIFE" : "LIVES")
                    </div>
                }
                @if (wasNudged) {
                    <div class="overlay-text nudged" style="bottom: 20px;">MYSTERY NUDGE!</div>
                }

                <!-- Giant Win Display -->
                <div class="giant-win-overlay @(showWinDisplay ? "visible" : "") @(animationSpeed >= 2 ? "compact-win" : "")">
                    <div class="win-content">
                        <div class="win-header">TOTAL WIN</div>
                        <div class="win-sum">@lastWin.ToString("C2")</div>
                    </div>
                </div>
            </div>

            <!-- Status Bar -->
            <div class='@($"status-bar-v4 {(LayoutService.IsDarkMode ? "dark" : "light")}")'>
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.caption" Class="label">LAST WIN</MudText>
                    <MudText Typo="Typo.h4" Class="value win">@lastWin.ToString("C2")</MudText>
                </div>
                
                <div class="d-flex gap-4">
                    @if (gameState.IsBonusActive) {
                        <div class="feature-badge bonus">BELL BONUS: @gameState.BonusLives LIVES</div>
                    }
                    @if (gameState.IsGambleActive) {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="OpenGamble" Class="fw-black">GAMBLE @gameState.PendingGambleWin.ToString("C2")</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="CollectWin" Class="fw-black ml-2">COLLECT</MudButton>
                    }
                </div>

                <div class="text-right d-flex flex-column">
                    <MudText Typo="Typo.caption" Class="label">BALANCE</MudText>
                    <MudText Typo="Typo.h4" Class="value bal">@balance.ToString("C2")</MudText>
                </div>
            </div>
        </MudItem>

        <!-- Controls -->
        <MudItem xs="12" lg="3">
            <MudPaper Class='@($"control-panel-v4 pa-6 h-100 {(LayoutService.IsDarkMode ? "dark" : "light")}")' Elevation="0">
                <div class="credits-display mb-2">
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="credits-val">
                        CREDITS: @((balance / (denomination > 0 ? denomination : 0.01m)).ToString("N0"))
                    </MudText>
                </div>
                <MudText Typo="Typo.caption" Class="d-block text-center opacity-50 mb-4" Style="letter-spacing: 1px;">20 FIXED PAYLINES</MudText>

                <MudSelect T="decimal" Label="Denomination" @bind-Value="denomination" Variant="Variant.Filled" Class="mb-4" 
                           Disabled="@(isSpinning || gameState.IsBonusActive || gameState.IsRespinActive || gameState.IsGambleActive)">
                    <MudSelectItem Value="@(0.01m)">@((0.01m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(0.05m)">@((0.05m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(0.10m)">@((0.10m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(0.50m)">@((0.50m).ToString("C2"))</MudSelectItem>
                    <MudSelectItem Value="@(1.00m)">@((1.00m).ToString("C2"))</MudSelectItem>
                </MudSelect>

                <MudNumericField @bind-Value="creditsBet" Label="Bet (Credits)" Variant="Variant.Filled" Min="10" Max="100" Step="10" 
                                 Disabled="@(isSpinning || gameState.IsBonusActive || gameState.IsRespinActive)" />
                
                <div class="mt-2 text-center">
                    <MudText Typo="Typo.subtitle1" Class="opacity-70">Total Stake: <b>@((creditsBet * denomination).ToString("C2"))</b></MudText>
                </div>

                <div class="d-flex flex-column gap-2 mt-8">
                    <MudButton Variant="Variant.Filled" 
                               Color="@(gameState.IsBonusActive ? Color.Error : (gameState.IsRespinActive ? Color.Warning : Color.Primary))" 
                               OnClick="OnSpin" 
                               Disabled="@(isSpinning || (balance < (creditsBet * denomination) && !gameState.IsRespinActive && !gameState.IsBonusActive))" 
                               FullWidth="true" 
                               Class="spin-button-v4"
                               Style="height: 100px; font-size: 2.2rem; font-weight: 950;">
                        @if (gameState.IsBonusActive) { <text>BONUS</text> }
                        else if (gameState.IsRespinActive) { <text>RESPIN</text> }
                        else if (isSpinning && !isAutoSpinning) { <text>WAIT</text> }
                        else { <text>SPIN</text> }
                    </MudButton>

                    <MudButton Variant="@(isAutoSpinning ? Variant.Filled : Variant.Outlined)" 
                               Color="@(isAutoSpinning ? Color.Secondary : Color.Primary)" 
                               OnClick="ToggleAutoSpin" 
                               Disabled="@(isSpinning && !isAutoSpinning)"
                               Class="py-3 fw-black rounded-lg">
                        @(isAutoSpinning ? "STOP AUTO" : "AUTO SPIN")
                    </MudButton>

                    <div class="d-flex justify-space-between gap-2 mt-2">
                        <button class='@($"speed-btn-v4 {(animationSpeed == 1 ? "active" : "")}")' @onclick="() => SetSpeed(1)">1X</button>
                        <button class='@($"speed-btn-v4 {(animationSpeed == 2 ? "active" : "")}")' @onclick="() => SetSpeed(2)">2X</button>
                        <button class='@($"speed-btn-v4 {(animationSpeed == 3 ? "active" : "")}")' @onclick="() => SetSpeed(3)">TURBO</button>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    /* --- VIEWPORT --- */
    .game-viewport-v4 { position: relative; border-radius: 24px; overflow: hidden; border: 8px solid; box-shadow: 0 0 40px rgba(0,0,0,0.5); }
    .game-viewport-v4.dark { background: #000; border-color: #334155; }
    .game-viewport-v4.light { background: #fff; border-color: #cbd5e1; }

    /* --- STATUS BAR --- */
    .status-bar-v4 { margin-top: 16px; padding: 16px 24px; border-radius: 16px; display: flex; justify-content: space-between; align-items: center; }
    .status-bar-v4.dark { background: #1e293b; color: white; }
    .status-bar-v4.light { background: #f8fafc; color: #1e293b; border: 1px solid #e2e8f0; }
    .status-bar-v4 .label { opacity: 0.6; font-weight: 700; }
    .status-bar-v4 .value { font-weight: 950; font-family: 'JetBrains Mono', monospace; }
    .status-bar-v4 .value.win { color: #eab308; }
    .status-bar-v4 .value.bal { color: #22c55e; }

    /* --- CONTROL PANEL --- */
    .control-panel-v4 { border-radius: 24px !important; border: 2px solid transparent; }
    .control-panel-v4.dark { background: #0f172a; color: white; border-color: #334155; }
    .control-panel-v4.light { background: #f8fafc; color: #1e293b; border-color: #e2e8f0; }
    .credits-val { font-weight: 950; font-family: 'JetBrains Mono', monospace; color: #fbbf24; }
    .light .credits-val { color: #b45309; }

    /* --- BUTTONS --- */
    .spin-button-v4 { box-shadow: 0 8px 0 rgba(0,0,0,0.3); transition: transform 0.1s; }
    .spin-button-v4:active { transform: translateY(4px); box-shadow: 0 2px 0 rgba(0,0,0,0.3); }
    
    .speed-btn-v4 { flex: 1; height: 40px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #888; font-weight: 900; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; }
    .light .speed-btn-v4 { background: #fff; border-color: #cbd5e1; color: #64748b; }
    .speed-btn-v4.active { background: var(--mud-palette-primary); color: white; border-color: var(--mud-palette-primary); box-shadow: 0 0 15px rgba(var(--mud-palette-primary-rgb), 0.4); }

    .feature-badge { padding: 8px 20px; border-radius: 8px; font-weight: 950; border: 2px solid white; }
    .bonus { background: #ef4444; color: white; animation: pulse 1s infinite; }
    .overlay-text { position: absolute; left: 50%; transform: translateX(-50%); font-size: 3rem; color: #ffeb3b; font-weight: 950; text-shadow: 0 0 20px black; z-index: 100; pointer-events: none; text-transform: uppercase; }
    .nudged { color: #ec4899; animation: bounce 0.5s; }
    
    /* --- WIN OVERLAY --- */
    .giant-win-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2000; pointer-events: none; opacity: 0; transition: opacity 0.4s; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); }
    .giant-win-overlay.visible { opacity: 1; pointer-events: auto; }
    .giant-win-overlay.compact-win { background: transparent; backdrop-filter: none; top: auto; bottom: 40px; height: 120px; }
    .compact-win .win-content { transform: scale(0.5) !important; background: rgba(0,0,0,0.7); padding: 15px 40px; border-radius: 20px; border: 2px solid #ffeb3b; }
    .win-content { text-align: center; transform: scale(0.5); transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .visible .win-content { transform: scale(1.2); }
    .win-header { font-size: 2rem; font-weight: 950; color: white; text-shadow: 0 0 15px #d4af37; }
    .win-sum { font-size: 5rem; font-weight: 950; color: #ffeb3b; text-shadow: 0 0 30px black; line-height: 1; }

    @@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
    @@keyframes bounce { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-20px); } }
    .fw-black { font-weight: 900; }
    .glass-panel { background: rgba(255,255,255,0.1) !important; backdrop-filter: blur(4px); }
</style>

@code {
    private bool isSpinning = false;
    private bool isAutoSpinning = false;
    private int animationSpeed = 1; 
    private bool showWinDisplay = false;
    private decimal balance = 0;
    private decimal lastWin = 0;
    private decimal nextWinBuffer = 0;
    private decimal denomination = 0.01m; 
    private int creditsBet = 10; 
    private Guid sessionId = Guid.NewGuid(); 
    private SlotState gameState = new();
    private bool wasNudged = false;
    private bool wasInRespin = false;
    private bool lowGraphics = false;
    private DotNetObjectReference<CloverChase>? _objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try {
                _objRef = DotNetObjectReference.Create(this);
                await LoadData();
                await JSRuntime.InvokeVoidAsync("slotEngine.init", "pixi-slot-container", animationSpeed, lowGraphics, _objRef);
            } catch (Exception ex) {
                Console.WriteLine($"JS Init Error: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public void OnAnimationFinished() {
        isSpinning = false;
        
        // APPLY WIN FROM BUFFER ONLY AFTER ANIMATION
        lastWin = nextWinBuffer;

        if (lastWin > 0.01m) {
            showWinDisplay = true;
            StateHasChanged();
            
            var winDelay = animationSpeed switch { 3 => 800, 2 => 1500, _ => 3500 };
            _ = Task.Delay(winDelay).ContinueWith(_ => {
                showWinDisplay = false;
                InvokeAsync(StateHasChanged);
            });
        } else {
            StateHasChanged();
        }
    }

    private void SetSpeed(int speed) {
        animationSpeed = speed;
        _ = JSRuntime.InvokeVoidAsync("slotEngine.setPerformanceMode", animationSpeed, lowGraphics);
    }

    private async Task ToggleAutoSpin() {
        if (isAutoSpinning) isAutoSpinning = false;
        else {
            isAutoSpinning = true;
            if (!isSpinning) await OnSpin();
        }
    }

    private async Task OpenPaytable() {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, NoHeader = true };
        await DialogService.ShowAsync<PaytableDialog>("", options);
    }

    private async Task LoadData()
    {
        try {
            var profile = await AuthService.GetMe();
            if (profile != null) {
                balance = profile.TotalBalance;
                var prefs = JsonSerializer.Deserialize<Dictionary<string, object>>(profile.PreferencesJson) ?? new();
                if (prefs.TryGetValue("LowGraphics", out var low)) lowGraphics = low.ToString()?.ToLower() == "true";
            }

            var session = await GameService.ResumeSession("slot");
            if (session != null) {
                sessionId = session.SessionId;
                if (session.GameState != null) {
                    string json = session.GameState.ToString() ?? "{}";
                    gameState = JsonSerializer.Deserialize<SlotState>(json) ?? new();
                    if (gameState.Denomination > 0) denomination = gameState.Denomination;
                    if (gameState.IsGambleActive) lastWin = gameState.PendingGambleWin;
                    await JSRuntime.InvokeVoidAsync("slotEngine.restoreState", json);
                }
            } else {
                var newSession = await GameService.StartSession("slot");
                sessionId = newSession.SessionId;
            }
            StateHasChanged();
        } catch { }
    }

    private async Task OnSpin()
    {
        if (isSpinning) return;
        
        do {
            isSpinning = true; wasNudged = false; showWinDisplay = false;
            wasInRespin = gameState.IsRespinActive;
            nextWinBuffer = 0; // Reset buffer
            
            var betAmount = gameState.IsBonusActive ? 0 : (creditsBet * denomination);

            if (betAmount > 0) {
                if (balance < betAmount) {
                    Snackbar.Add("Insufficient Balance", Severity.Warning);
                    isAutoSpinning = false; isSpinning = false;
                    break;
                }
                balance -= betAmount;
                LayoutService.DeductOptimisticBalance(betAmount);
                StateHasChanged();
            }

            LayoutService.SetBalanceUpdateSuppression(true);
            
            try {
                await Audio.PlaySpin();
                var result = await GameService.PlaceBet("slot", sessionId, betAmount, new { Denomination = denomination });
                
                // BUFFER THE WIN (Don't update UI until animation ends)
                nextWinBuffer = result.TotalWin;

                // UPDATE STATE IMMEDIATELY (especially for RespinLives)
                var gridData = JsonSerializer.Deserialize<SlotStateResponse>(result.RandomResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (gridData != null) {
                    bool bonusJustStarted = !gameState.IsBonusActive && gridData.IsBonusActive;
                    
                    gameState.IsBonusActive = gridData.IsBonusActive;
                    gameState.IsRespinActive = gridData.IsRespinActive;
                    gameState.BonusLives = gridData.BonusLives;
                    gameState.RespinLives = gridData.RespinLives; // SYNC COUNTER IMMEDIATELY
                    
                    gameState.IsGambleActive = lastWin > 0 && !gameState.IsBonusActive && !gameState.IsRespinActive; 
                    gameState.PendingGambleWin = lastWin;
                    wasNudged = gridData.WasNudged;
                    
                    if (wasNudged) await Audio.PlayBonus(); 
                    if (bonusJustStarted) isAutoSpinning = false; 
                    StateHasChanged(); // Force UI update for counters
                }

                await JSRuntime.InvokeVoidAsync("slotEngine.spin", result.RandomResultJson);
                
                // wait for JS callback (OnAnimationFinished) or timeout
                int timeout = animationSpeed switch { 3 => 4000, 2 => 8000, _ => 15000 };
                var start = DateTime.Now;
                while (isSpinning && (DateTime.Now - start).TotalMilliseconds < timeout) {
                    await Task.Delay(50);
                }

                var profile = await AuthService.GetMe();
                if (profile != null) balance = profile.TotalBalance;

                if (lastWin > 0.01m) {
                    await Audio.PlayWin();
                }

                StateHasChanged(); // Force UI update for counters before animation ends if needed

                if (gameState.IsGambleActive && isAutoSpinning) {
                    await CollectWin(); 
                }

            } catch (Exception ex) { 
                Snackbar.Add(ex.Message, Severity.Error); 
                isAutoSpinning = false;
            }
            finally { 
                LayoutService.SetBalanceUpdateSuppression(false);
                StateHasChanged(); 
            }

            if (isAutoSpinning) await Task.Delay(animationSpeed == 1 ? 1000 : 200);

        } while (isAutoSpinning);
    }

    private async Task OpenGamble() {
        if (gameState == null) return;
        var parameters = new DialogParameters { ["Amount"] = gameState.PendingGambleWin, ["SessionId"] = sessionId };
        var dialog = await DialogService.ShowAsync<GambleDialog>("Double or Nothing", parameters);
        var result = await dialog.Result;
        if (result != null) {
            var profile = await AuthService.GetMe();
            if (profile != null) balance = profile.TotalBalance;
            gameState.IsGambleActive = false; 
        }
        StateHasChanged();
    }

    private async Task CollectWin() {
        if (gameState == null) return;
        await GameService.PerformAction("slot", sessionId, "collect", "{}");
        gameState.IsGambleActive = false;
        var profile = await AuthService.GetMe();
        if (profile != null) balance = profile.TotalBalance;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync() {
        if (_objRef != null) _objRef.Dispose();
        await Task.CompletedTask;
    }

    public class SlotState {
        public bool IsBonusActive { get; set; }
        public int BonusLives { get; set; }
        public bool IsRespinActive { get; set; }
        public int RespinLives { get; set; }
        public bool IsGambleActive { get; set; }
        public decimal PendingGambleWin { get; set; }
        public decimal Denomination { get; set; } = 0.01m;
    }
    
    public class SlotStateResponse {
        public bool IsBonusActive { get; set; }
        public bool IsRespinActive { get; set; }
        public int BonusLives { get; set; }
        public int RespinLives { get; set; }
        public bool WasNudged { get; set; }
    }
}
