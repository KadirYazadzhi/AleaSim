@page "/game/cloverchase"
@using System.Text.Json
@inject IGameService GameService
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid Justify="Justify.Center">
        <!-- Jackpot Display -->
        <MudItem xs="12">
            <MudPaper Class="pa-4 bg-dark text-center" Elevation="4">
                <MudText Typo="Typo.h4" Style="color: #ffD700; font-weight: bold;">
                    GLOBAL JACKPOT: $12,450.23
                </MudText>
            </MudPaper>
        </MudItem>

        <!-- Slot Grid -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-2" Style="background: #1a1a1a; border: 4px solid #444; border-radius: 12px;">
                <div class="slot-machine">
                    <MudGrid Spacing="1">
                        @for (int c = 0; c < 5; c++)
                        {
                            <MudItem xs="2" Style="flex-basis: 20%; max-width: 20%;">
                                <div class="reel @(isSpinning ? "spinning" : "")">
                                    @for (int r = 0; r < 4; r++)
                                    {
                                        <div class="symbol-cell">
                                            @GetSymbolContent(grid[r, c])
                                        </div>
                                    }
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Controls -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-6 d-flex flex-column gap-4" Elevation="2">
                <MudText Typo="Typo.h5">Balance: <span style="color: #4caf50;">$@balance.ToString("N2")</span></MudText>
                
                <MudNumericField @bind-Value="betAmount" Label="Bet Amount" Variant="Variant.Outlined" Min="1" Max="100" />
                
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           OnClick="OnSpin" 
                           Disabled="isSpinning"
                           Style="height: 80px; font-size: 1.5rem;">
                    @(isSpinning ? "SPINNING..." : "SPIN")
                </MudButton>

                <MudDivider Class="my-2"/>

                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="OnBuyBonus">
                    BUY BONUS ($@(betAmount * 100))
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .slot-machine {
        padding: 10px;
        overflow: hidden;
    }
    .symbol-cell {
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #222;
        margin-bottom: 4px;
        border-radius: 4px;
        font-size: 2.5rem;
        border: 1px solid #333;
    }
    .spinning {
        animation: blur 0.1s infinite linear;
    }
    @@keyframes blur {
        0% { filter: blur(0px); transform: translateY(0); }
        50% { filter: blur(2px); transform: translateY(5px); }
        100% { filter: blur(0px); transform: translateY(0); }
    }
</style>

@code {
    private int[,] grid = new int[4, 5];
    private bool isSpinning = false;
    private decimal balance = 1000.00m;
    private decimal betAmount = 1.0m;
    private Guid? sessionId;

    protected override async Task OnInitializedAsync() {
        // Mock grid initialization
        for(int r=0; r<4; r++) for(int c=0; c<5; c++) grid[r,c] = new Random().Next(1, 8);
        
        try {
            var response = await GameService.StartSession("slot");
            sessionId = response.SessionId;
        } catch (Exception ex) {
            Snackbar.Add("Failed to connect to game server: " + ex.Message, Severity.Error);
        }
    }

    private async Task OnSpin() {
        if (sessionId == null) return;
        
        isSpinning = true;
        StateHasChanged();

        try {
            // Artificial delay for animation
            await Task.Delay(800);

            var result = await GameService.PlaceBet("slot", sessionId.Value, betAmount);
            
            // Parse grid from result (assuming it's in the JSON)
            // This needs a proper parser for our specific SlotResult
            
            if (result.TotalWin > 0) {
                Snackbar.Add($"WIN: ${result.TotalWin:N2}!", Severity.Success);
                balance += result.TotalWin;
            }
            balance -= betAmount;
        }
        catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally {
            isSpinning = false;
        }
    }

    private async Task OnBuyBonus() {
        // Logic for feature buy
    }

    private RenderFragment GetSymbolContent(int symbolId) => builder => {
        string content = symbolId switch {
            1 => "🍒",
            2 => "🍋",
            3 => "🍊",
            4 => "🍇",
            5 => "🔔",
            6 => "💎",
            7 => "7️⃣",
            8 => "🍀",
            10 => "💰",
            _ => "❓"
        };
        builder.AddContent(0, content);
    };
}
