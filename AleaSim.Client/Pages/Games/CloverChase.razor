@page "/game/cloverchase"
@using System.Text.Json
@using AleaSim.Client.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@implements IAsyncDisposable
@inject IGameService GameService
@inject AudioService Audio
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" lg="9">
            <div class="mb-4">
                <MultiJackpotWidget />
            </div>

            <!-- PixiJS Slot Machine View -->
            <MudPaper Class="pa-2" Style="background: #000; border: 10px solid #3d2b1f; border-radius: 20px; box-shadow: 0 0 30px rgba(0,0,0,0.8); position: relative;">
                <div id="pixi-slot-container" style="width: 100%; height: 480px; background: #000; display: flex; justify-content: center; align-items: center;">
                    <!-- Canvas will be injected here by PixiJS -->
                </div>
                <div class="win-light @(lastWin > 0 ? "active" : "")"></div>
            </MudPaper>

            <!-- Status Bar -->
            <MudPaper Class="mt-4 pa-4 d-flex justify-space-between align-center" Style="background: linear-gradient(#1a1a1a, #000); color: white; border-bottom: 4px solid #d4af37;">
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.caption" Style="color: #888;">LAST WIN</MudText>
                    <MudText Typo="Typo.h4" Style="color: #ffD700; font-weight: 900; text-shadow: 0 0 10px rgba(255,215,0,0.5);">@lastWin.ToString("C2")</MudText>
                </div>
                
                <div class="d-flex gap-4">
                    @if (gameState.IsBonusActive) {
                        <div class="feature-badge bonus">BELL BONUS: @gameState.BonusLives LIVES</div>
                    }
                </div>

                <div class="text-right d-flex flex-column">
                    <MudText Typo="Typo.caption" Style="color: #888;">BALANCE</MudText>
                    <MudText Typo="Typo.h4" Style="color: #4caf50; font-weight: 900;">@balance.ToString("C2")</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Controls -->
        <MudItem xs="12" lg="3">
            <MudPaper Class="pa-6" Style="background: #222; color: white; height: 100%; border-left: 4px solid #444;">
                <div class="credits-display mb-6">
                    <MudText Typo="Typo.h5" Align="Align.Center" Style="color: #ffeb3b; font-weight: 900; font-family: monospace;">
                        CREDITS: @((balance / denomination).ToString("N0"))
                    </MudText>
                </div>

                <MudSelect T="decimal" Label="Denomination" @bind-Value="denomination" Variant="Variant.Filled" Class="mb-4" Disabled="isSpinning">
                    <MudSelectItem Value="0.01m">$0.01</MudSelectItem>
                    <MudSelectItem Value="0.05m">$0.05</MudSelectItem>
                    <MudSelectItem Value="0.10m">$0.10</MudSelectItem>
                    <MudSelectItem Value="0.50m">$0.50</MudSelectItem>
                    <MudSelectItem Value="1.00m">$1.00</MudSelectItem>
                </MudSelect>

                <MudNumericField @bind-Value="creditsBet" Label="Bet (Credits)" Variant="Variant.Filled" Min="10" Max="100" Step="10" Disabled="isSpinning" />
                <div class="mt-2 text-center">
                    <MudText Typo="Typo.subtitle1" Style="color: #aaa;">Total Stake: <b>@((creditsBet * denomination).ToString("C2"))</b></MudText>
                </div>

                <MudButton Variant="Variant.Filled" 
                           Color="@(gameState.IsBonusActive ? Color.Error : Color.Primary)" 
                           OnClick="OnSpin" 
                           Disabled="@(isSpinning || balance < (creditsBet * denomination))" 
                           FullWidth="true" 
                           Class="mt-8 spin-button"
                           Style="height: 100px; font-size: 2rem; font-weight: 900;">
                    @(isSpinning ? "WAIT" : "SPIN")
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .spin-button {
        box-shadow: 0 8px 0 #1565c0, 0 15px 20px rgba(0,0,0,.35);
        transition: all .1s;
    }
    .spin-button:active {
        transform: translateY(4px);
        box-shadow: 0 4px 0 #1565c0, 0 8px 10px rgba(0,0,0,.3);
    }
    .feature-badge { padding: 8px 20px; border-radius: 4px; font-weight: 900; border: 2px solid white; box-shadow: 0 0 15px rgba(255,255,255,0.5); }
    .bonus { background: #d32f2f; color: white; animation: pulse 1s infinite; }
    @@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
</style>

@code {
    private bool isSpinning = false;
    private decimal balance = 0;
    private decimal lastWin = 0;
    private decimal denomination = 0.01m;
    private int creditsBet = 10;
    private Guid? sessionId;
    private SlotGameStateUI gameState = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("slotEngine.init", "pixi-slot-container");
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        try {
            var resp = await GameService.StartSession("slot");
            sessionId = resp.SessionId;
            var profile = await Http.GetFromJsonAsync<UserProfileResponse>("api/Auth/me");
            if (profile != null) balance = profile.Balance;
        } catch {}
    }

    private async Task OnSpin()
    {
        if (isSpinning || sessionId == null) return;
        isSpinning = true;
        
        try {
            await Audio.PlaySpin();
            var betAmount = creditsBet * denomination;
            var result = await GameService.PlaceBet("slot", sessionId.Value, betAmount, $"{{\"Denomination\":{denomination}}}");
            
            // Start Pixi Animation
            await JSRuntime.InvokeVoidAsync("slotEngine.spin", (object?)null);
            
            await Task.Delay(3500); // Pixi Duration match

            lastWin = result.TotalWin;
            balance += lastWin - betAmount;
            StateHasChanged();

            var gridData = JsonSerializer.Deserialize<SlotResultGrid>(result.RandomResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (gridData != null) gameState.IsBonusActive = gridData.IsBonusActive;

        } catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { isSpinning = false; StateHasChanged(); }
    }

    public async ValueTask DisposeAsync() { }

    public class SlotGameStateUI { public bool IsBonusActive { get; set; } public int BonusLives { get; set; } }
    public class SlotResultGrid { public bool IsBonusActive { get; set; } }
}
