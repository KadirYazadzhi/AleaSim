@page "/leaderboard"
@using AleaSim.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6">Hall of Fame</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <MudTabPanel Text="Current Tournament" Icon="@Icons.Material.Filled.EmojiEvents">
            <MudTable Items="@topPlayers" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading" Elevation="0">
                <HeaderContent>
                    <MudTh>Rank</MudTh>
                    <MudTh>Player</MudTh>
                    <MudTh Style="text-align: right;">Potential Prize</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Rank">
                        <MudText Style="font-weight: bold; color: #ffD700;">#@context.Rank</MudText>
                    </MudTd>
                    <MudTd DataLabel="Player">
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Size="Size.Small">
                                <MudImage Src="@context.AvatarUrl" />
                            </MudAvatar>
                            @context.Username
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Prize" Style="text-align: right;">
                        <MudText Color="Color.Success" Style="font-weight: bold;">
                            @GetEstimatedPrize(context.Rank).ToString("C2")
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Past Champions" Icon="@Icons.Material.Filled.History">
            @if (pastWinners == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            }
            else if (!pastWinners.Any())
            {
                <MudAlert Severity="Severity.Info">No tournament history available yet.</MudAlert>
            }
            else
            {
                <MudGrid>
                    @foreach (var winner in pastWinners)
                    {
                        <MudItem xs="12" md="6" lg="4">
                            <MudPaper Class="pa-4 d-flex align-center gap-4" Style="background: #1a1a1a; border-left: 4px solid #ffD700;">
                                <MudAvatar Size="Size.Large">
                                    <MudImage Src="@winner.AvatarUrl" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle2" Style="color: #aaa;">@winner.MonthName</MudText>
                                    <MudText Typo="Typo.h6">@winner.WinnerName</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Success">Won @winner.Prize.ToString("C0") (@winner.Multiplier.ToString("F0")x)</MudText>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private List<TournamentRankDto> topPlayers = new();
    private List<TournamentHistoryDto>? pastWinners;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLeaderboard();
        await LoadHistory();
    }

    private async Task LoadLeaderboard()
    {
        isLoading = true;
        try {
            topPlayers = await Http.GetFromJsonAsync<List<TournamentRankDto>>("api/Game/leaderboard/tournament") ?? new();
        } catch {
            Snackbar.Add("Failed to load rankings.", Severity.Error);
        } finally {
            isLoading = false;
        }
    }

    private async Task LoadHistory()
    {
        try {
            pastWinners = await Http.GetFromJsonAsync<List<TournamentHistoryDto>>("api/Game/leaderboard/history");
        } catch { }
    }

    private decimal GetEstimatedPrize(int rank) {
        decimal[] prizes = { 5000, 3000, 2000, 1500, 1000, 800, 700, 600, 500, 400 };
        return rank > 0 && rank <= 10 ? prizes[rank - 1] : 0;
    }
}
