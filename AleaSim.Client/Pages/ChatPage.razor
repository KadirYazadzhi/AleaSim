@page "/chat"
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@attribute [Authorize]
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LayoutService LayoutService

<div class='@($"chat-atomic-wrapper {(showSidebar ? "state-list" : "state-chat")}")'>
    <!-- LEFT PANE: CONVERSATION DIRECTORY -->
    <aside class="chat-pane-sidebar">
        <div class="chat-ui-header px-6">
            <MudText Typo="Typo.h5" Class="fw-black text-gradient">MESSAGES</MudText>
        </div>
        <div class="sidebar-scroll custom-scroll">
            <div class="section-label px-6 py-4">NETWORKS</div>
            <div class='@($"conv-item {(activeChatType == "Global" ? "active" : "")}")' @onclick='() => SelectChat("Global")'>
                <div class="conv-icon global"><MudIcon Icon="@Icons.Material.Filled.Public" /></div>
                <div class="conv-details">
                    <span class="conv-name">Global Chat</span>
                    <span class="conv-preview">Live stream</span>
                </div>
            </div>
            
            <div class="section-label px-6 py-4">DIRECT MESSAGES</div>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    @foreach (var user in activeConversations) {
                        <div class='@($"conv-item {(activeChatType == "Private" && selectedUserId == user.Id ? "active" : "")}")' 
                             @onclick='() => SelectPrivateChat(user.Id, user.Username)'>
                            <MudAvatar Size="Size.Small"><MudImage Src='@($"https://api.dicebear.com/7.x/bottts/svg?seed={user.Username}")'/></MudAvatar>
                            <div class="conv-details">
                                <span class="conv-name">@user.Username</span>
                                <span class="conv-preview">Private</span>
                            </div>
                        </div>
                    }
                </Authorized>
                <NotAuthorized>
                    <div class='@($"conv-item {(activeChatType == "Private" && selectedUserId == adminGuid ? "active" : "")}")' 
                         @onclick="SelectSupportChat">
                        <div class="conv-icon support"><MudIcon Icon="@Icons.Material.Filled.SupportAgent" /></div>
                        <div class="conv-details">
                            <span class="conv-name">System Admin</span>
                            <span class="conv-preview">Official Support</span>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- RIGHT PANE: ACTIVE CONVERSATION -->
    <main class="chat-pane-main">
        <header class="chat-ui-header px-4 px-md-8">
            <div class="d-flex align-center gap-3 w-100 overflow-hidden">
                <button class="mobile-back-btn mr-1" @onclick="BackToList">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBackIosNew" Size="Size.Small" />
                </button>
                
                @if (activeChatType == "Private") {
                    <MudAvatar Size="Size.Medium" Class="head-avatar"><MudImage Src='@($"https://api.dicebear.com/7.x/bottts/svg?seed={selectedUserName}")'/></MudAvatar>
                } else {
                    <div class="head-icon-box"><MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" /></div>
                }
                
                <div class="text-truncate">
                    <MudText Typo="Typo.h6" Class="fw-black text-truncate">@activeChatTitle.ToUpper()</MudText>
                    <div class="d-flex align-center gap-1">
                        <div class="dot-online"></div>
                        <MudText Typo="Typo.caption" Class="opacity-50">Active</MudText>
                    </div>
                </div>
            </div>
        </header>

        <div class="chat-viewport-v4">
            @if (activeChatType == "Global") {
                <ChatWidget />
            } else if (activeChatType == "Private" && selectedUserId != null) {
                <PrivateChatContainer OtherUserId="@selectedUserId.Value" OtherUserName="@selectedUserName" />
            }
        </div>
    </main>
</div>

<style>
    /* DESKTOP ARCHITECTURE */
    .chat-atomic-wrapper {
        display: flex;
        width: 100%;
        height: calc(100vh - 100px); /* Taller top margin */
        background: transparent;
        position: relative;
        max-width: 1800px;
        margin: 32px auto 0 auto; /* More space from top */
        border: none;
    }

    .chat-pane-sidebar {
        width: 380px;
        border-right: 1px solid var(--mud-palette-divider);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        z-index: 10;
        background: transparent;
    }

    .chat-pane-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background: transparent;
        min-width: 0;
        box-shadow: none;
    }

    .chat-ui-header {
        height: 80px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--mud-palette-divider);
        background: transparent;
        flex-shrink: 0;
        padding: 0 2rem;
    }

    .chat-viewport-v4 { 
        flex-grow: 1; 
        overflow: hidden; 
        display: flex; 
        flex-direction: column;
        position: relative;
    }
    
    .sidebar-scroll { flex-grow: 1; overflow-y: auto; padding-bottom: 2rem; }
    .mobile-back-btn { display: none; background: none; border: none; color: inherit; cursor: pointer; padding: 8px; }

    .conv-item { 
        display: flex; 
        align-items: center; 
        gap: 16px; 
        padding: 14px 20px; 
        margin: 4px 12px; 
        border-radius: 16px; 
        cursor: pointer; 
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); 
        border: 1px solid transparent;
    }
    .conv-item:hover { background: var(--mud-palette-action-default-hover); transform: translateX(4px); }
    .conv-item.active { 
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-darken) 100%); 
        color: white; 
        box-shadow: 0 4px 12px rgba(var(--mud-palette-primary-rgb), 0.3);
        border-color: rgba(255,255,255,0.1);
    }
    
    .conv-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: 0.3s; }
    .conv-icon.global { background: rgba(var(--mud-palette-primary-rgb), 0.1); color: var(--mud-palette-primary); }
    .conv-icon.support { background: rgba(var(--mud-palette-secondary-rgb), 0.1); color: var(--mud-palette-secondary); }
    .active .conv-icon { background: rgba(255,255,255,0.2); color: white; transform: scale(0.9); }
    
    .conv-details { display: flex; flex-direction: column; overflow: hidden; }
    .conv-name { font-weight: 900; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: -0.2px; }
    .conv-preview { font-size: 0.75rem; color: var(--mud-palette-text-secondary); opacity: 0.7; font-weight: 500; }
    .active .conv-preview { color: white; opacity: 0.8; }
    
    .head-icon-box { width: 44px; height: 44px; background: var(--mud-palette-action-default-hover); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .dot-online { width: 10px; height: 10px; border-radius: 50%; background: #4ade80; border: 2px solid var(--mud-palette-surface); }
    .section-label { font-size: 0.65rem; font-weight: 900; letter-spacing: 2px; color: var(--mud-palette-text-secondary); opacity: 0.5; text-transform: uppercase; }

    /* MOBILE REVOLUTION */
    @@media (max-width: 960px) {
        .chat-atomic-wrapper { border: none; height: calc(100vh - 56px); margin-top: 0; }
        .chat-pane-sidebar, .chat-pane-main { width: 100% !important; border: none !important; }
        .chat-ui-header { padding: 0 1rem; }
    }
</style>

@code {
    private string activeChatType = "Global";
    private string activeChatTitle = "Global Community";
    private string selectedUserName = "";
    private Guid? selectedUserId;
    private Guid adminGuid = Guid.Parse("00000000-0000-0000-0000-000000000001");
    private List<UserSummary> activeConversations = new();
    private bool isLoadingPlayers = false;
    
    private bool showSidebar = true;

    [Parameter] [SupplyParameterFromQuery] public string? userId { get; set; }

    protected override async Task OnInitializedAsync() {
        await LoadActiveConversations();
        
        if (!string.IsNullOrEmpty(userId) && Guid.TryParse(userId, out var targetId)) {
            var player = activeConversations.FirstOrDefault(p => p.Id == targetId);
            if (player != null) {
                SelectPrivateChat(player.Id, player.Username);
            } else {
                try {
                    var p = await Http.GetFromJsonAsync<UserSummary>($"api/Admin/players/{targetId}/summary");
                    if (p != null) {
                        activeConversations.Insert(0, p);
                        SelectPrivateChat(p.Id, p.Username);
                    }
                } catch {}
            }
        }
    }

    private void SelectChat(string type) {
        activeChatType = type;
        activeChatTitle = type == "Global" ? "Global Community" : selectedUserName;
        if (type == "Global") selectedUserId = null;
        showSidebar = false;
        StateHasChanged();
    }

    private void SelectPrivateChat(Guid id, string name) {
        activeChatType = "Private";
        selectedUserId = id;
        selectedUserName = name;
        activeChatTitle = name;
        showSidebar = false;
        StateHasChanged();
    }

    private void SelectSupportChat() => SelectPrivateChat(adminGuid, "System Admin");
    private void BackToList() => showSidebar = true;

    private async Task LoadActiveConversations() {
        isLoadingPlayers = true;
        try {
            // Fetch people this user has active DMs with
            var interlocutors = await Http.GetFromJsonAsync<List<UserSummary>>("api/Chat/conversations"); 
            if (interlocutors != null) activeConversations = interlocutors.Where(p => p.Id != Guid.Empty).ToList();
        } catch { }
        finally { isLoadingPlayers = false; }
    }

    public class UserSummary {
        public Guid Id { get; set; }
        public string Username { get; set; } = "";
    }
}
