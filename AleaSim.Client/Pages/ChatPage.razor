@page "/chat"
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@attribute [Authorize]
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LayoutService LayoutService

<div class='@($"chat-atomic-wrapper {(showSidebar ? "state-list" : "state-chat")}")'>
    <!-- LEFT PANE: CONVERSATION DIRECTORY -->
    <aside class="chat-pane-sidebar">
        <div class="chat-ui-header px-6">
            <MudText Typo="Typo.h5" Class="fw-black text-gradient">MESSAGES</MudText>
        </div>
        <div class="sidebar-scroll custom-scroll">
            <div class="section-label px-6 py-4">NETWORKS</div>
            <div class='@($"conv-item {(activeChatType == "Global" ? "active" : "")}")' @onclick='() => SelectChat("Global")'>
                <div class="conv-icon global"><MudIcon Icon="@Icons.Material.Filled.Public" /></div>
                <div class="conv-details">
                    <span class="conv-name">Global Chat</span>
                    <span class="conv-preview">Live stream</span>
                </div>
            </div>
            
            <div class="section-label px-6 py-4">DIRECT MESSAGES</div>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    @foreach (var user in activeConversations) {
                        <div class='@($"conv-item {(activeChatType == "Private" && selectedUserId == user.Id ? "active" : "")}")' 
                             @onclick='() => SelectPrivateChat(user.Id, user.Username)'>
                            <MudAvatar Size="Size.Small"><MudImage Src='@($"https://api.dicebear.com/7.x/bottts/svg?seed={user.Username}")'/></MudAvatar>
                            <div class="conv-details">
                                <span class="conv-name">@user.Username</span>
                                <span class="conv-preview">Private</span>
                            </div>
                        </div>
                    }
                </Authorized>
                <NotAuthorized>
                    <div class='@($"conv-item {(activeChatType == "Private" && selectedUserId == adminGuid ? "active" : "")}")' 
                         @onclick="SelectSupportChat">
                        <div class="conv-icon support"><MudIcon Icon="@Icons.Material.Filled.SupportAgent" /></div>
                        <div class="conv-details">
                            <span class="conv-name">System Admin</span>
                            <span class="conv-preview">Official Support</span>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- RIGHT PANE: ACTIVE CONVERSATION -->
    <main class="chat-pane-main">
        <header class="chat-ui-header px-4 px-md-8">
            <div class="d-flex align-center gap-3 w-100 overflow-hidden">
                <button class="mobile-back-btn mr-1" @onclick="BackToList">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBackIosNew" Size="Size.Small" />
                </button>
                
                @if (activeChatType == "Private") {
                    <MudAvatar Size="Size.Medium" Class="head-avatar"><MudImage Src='@($"https://api.dicebear.com/7.x/bottts/svg?seed={selectedUserName}")'/></MudAvatar>
                } else {
                    <div class="head-icon-box"><MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" /></div>
                }
                
                <div class="text-truncate">
                    <MudText Typo="Typo.h6" Class="fw-black text-truncate">@activeChatTitle.ToUpper()</MudText>
                    <div class="d-flex align-center gap-1">
                        <div class="dot-online"></div>
                        <MudText Typo="Typo.caption" Class="opacity-50">Active</MudText>
                    </div>
                </div>
            </div>
        </header>

        <div class="chat-viewport-v4">
            @if (activeChatType == "Global") {
                <ChatWidget />
            } else if (activeChatType == "Private" && selectedUserId != null) {
                <PrivateChatContainer OtherUserId="@selectedUserId.Value" OtherUserName="@selectedUserName" />
            }
        </div>
    </main>
</div>

<style>
    /* DESKTOP ARCHITECTURE */
    .chat-atomic-wrapper {
        display: flex;
        width: 100%;
        height: calc(100vh - 64px);
        background: var(--mud-palette-surface);
        position: relative;
    }

    .chat-pane-sidebar {
        width: 360px;
        border-right: 1px solid var(--mud-palette-divider);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
    }

    .chat-pane-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background: var(--mud-palette-background-grey);
        min-width: 0;
    }

    .chat-ui-header {
        height: 80px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-surface);
        flex-shrink: 0;
    }

    .chat-viewport-v4 { flex-grow: 1; overflow: hidden; display: flex; flex-direction: column; }
    .sidebar-scroll { flex-grow: 1; overflow-y: auto; }
    .mobile-back-btn { display: none; background: none; border: none; color: inherit; cursor: pointer; padding: 8px; }

    .conv-item { display: flex; align-items: center; gap: 16px; padding: 12px 24px; margin: 4px 12px; border-radius: 12px; cursor: pointer; transition: 0.2s; }
    .conv-item:hover { background: var(--mud-palette-action-default-hover); }
    .conv-item.active { background: var(--mud-palette-primary); color: white; }
    
    .conv-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .conv-icon.global { background: rgba(124, 58, 237, 0.1); color: var(--mud-palette-primary); }
    .conv-icon.support { background: rgba(236, 72, 153, 0.1); color: var(--mud-palette-secondary); }
    .active .conv-icon { background: rgba(255,255,255,0.2); color: white; }
    
    .conv-details { display: flex; flex-direction: column; overflow: hidden; }
    .conv-name { font-weight: 800; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .conv-preview { font-size: 0.75rem; color: var(--mud-palette-text-secondary); opacity: 0.7; }
    .active .conv-preview { color: white; opacity: 0.8; }
    
    .head-icon-box { width: 40px; height: 40px; background: var(--mud-palette-action-default-hover); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .dot-online { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 8px #4ade80; }
    .section-label { font-size: 0.65rem; font-weight: 900; letter-spacing: 2px; color: var(--mud-palette-text-secondary); opacity: 0.6; }

    /* MOBILE REVOLUTION (INSTAGRAM MODE) */
    @@media (max-width: 960px) {
        .chat-atomic-wrapper {
            position: relative;
            width: 100%;
            height: calc(100vh - 56px); /* Adjusted for mobile navbar */
            background: transparent !important;
            overflow: hidden;
            margin-top: 8px !important;
        }

        .chat-pane-sidebar, .chat-pane-main {
            width: 100% !important;
            height: 100% !important;
            position: absolute;
            top: 0;
            left: 0;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: transparent !important;
            border-right: none !important;
        }

        .chat-ui-header { 
            background: transparent !important;
            border-bottom: 1px solid var(--mud-palette-divider);
            height: 60px; 
        }

        /* State: List View */
        .state-list .chat-pane-sidebar { transform: translateX(0); }
        .state-list .chat-pane-main { transform: translateX(100%); }

        /* State: Chat View */
        .state-chat .chat-pane-sidebar { transform: translateX(-100%); }
        .state-chat .chat-pane-main { transform: translateX(0); }

        .mobile-back-btn { display: block; }
        .conv-item { padding: 12px 16px; margin: 4px 8px; background: rgba(var(--mud-palette-surface-rgb), 0.5); }
        .head-avatar { width: 32px !important; height: 32px !important; }
    }

    .text-gradient { background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .fw-black { font-weight: 950; }
    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
</style>

@code {
    private string activeChatType = "Global";
    private string activeChatTitle = "Global Community";
    private string selectedUserName = "";
    private Guid? selectedUserId;
    private Guid adminGuid = Guid.Parse("00000000-0000-0000-0000-000000000001");
    private List<UserSummary> activeConversations = new();
    private bool isLoadingPlayers = false;
    
    // THE MASTER TOGGLE
    private bool showSidebar = true;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin")) {
            await LoadActiveConversations();
        }
    }

    private void SelectChat(string type) {
        activeChatType = type;
        activeChatTitle = type == "Global" ? "Global Community" : selectedUserName;
        if (type == "Global") selectedUserId = null;
        showSidebar = false;
        StateHasChanged();
    }

    private void SelectPrivateChat(Guid id, string name) {
        activeChatType = "Private";
        selectedUserId = id;
        selectedUserName = name;
        activeChatTitle = name;
        showSidebar = false;
        StateHasChanged();
    }

    private void SelectSupportChat() => SelectPrivateChat(adminGuid, "System Admin");
    private void BackToList() => showSidebar = true;

    private async Task LoadActiveConversations() {
        isLoadingPlayers = true;
        try {
            var players = await Http.GetFromJsonAsync<List<UserSummary>>("api/Admin/players/search/ "); 
            if (players != null) activeConversations = players.Where(p => p.Id != adminGuid).ToList();
        } catch { }
        finally { isLoadingPlayers = false; }
    }

    public class UserSummary {
        public Guid Id { get; set; }
        public string Username { get; set; } = "";
    }
}
