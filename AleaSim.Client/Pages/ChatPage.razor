@page "/chat"
@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using AleaSim.Client.Components
@attribute [Authorize]
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<div class="chat-page-root animate-fade-in">
    <div class="chat-app-container shadow-2xl">
        <!-- Sidebar: Contact List -->
        <div class="chat-sidebar d-flex flex-column">
            <div class="sidebar-header pa-6">
                <MudText Typo="Typo.h5" Class="fw-black text-gradient">MESSAGES</MudText>
            </div>
            
            <div class="sidebar-content flex-grow-1 px-2">
                <div class="nav-item @(activeChatType == "Global" ? "active" : "")" @onclick='() => SelectChat("Global")'>
                    <div class="nav-icon global"><MudIcon Icon="@Icons.Material.Filled.Public" /></div>
                    <div class="nav-info">
                        <span class="nav-title">Global Community</span>
                        <span class="nav-subtitle">Live chat with everyone</span>
                    </div>
                </div>
                
                <MudDivider Class="my-4 mx-4 opacity-10" />
                
                <div class="px-6 py-2 mb-2"><MudText Typo="Typo.caption" Class="fw-bold tracking-widest opacity-40">DIRECT MESSAGES</MudText></div>
                
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        @if (isLoadingPlayers) {
                            <div class="d-flex justify-center pa-4"><MudProgressCircular Size="Size.Small" Indeterminate="true" /></div>
                        }
                        @foreach (var user in activeConversations)
                        {
                            <div class="nav-item @(activeChatType == "Private" && selectedUserId == user.Id ? "active" : "")" 
                                 @onclick='() => SelectPrivateChat(user.Id, user.Username)'>
                                <MudAvatar Size="Size.Small" Class="mr-3"><MudImage Src='@($"https://api.dicebear.com/7.x/bottts/svg?seed={user.Username}")'/></MudAvatar>
                                <div class="nav-info">
                                    <span class="nav-title">@user.Username</span>
                                    <span class="nav-subtitle">Player</span>
                                </div>
                            </div>
                        }
                    </Authorized>
                    <NotAuthorized>
                        <div class="nav-item @(activeChatType == "Private" && selectedUserId == adminGuid ? "active" : "")" 
                             @onclick="SelectSupportChat">
                            <div class="nav-icon support"><MudIcon Icon="@Icons.Material.Filled.SupportAgent" /></div>
                            <div class="nav-info">
                                <span class="nav-title">System Admin</span>
                                <span class="nav-subtitle">Official Support</span>
                            </div>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <!-- Main Chat Area -->
        <div class="chat-main">
            <div class="chat-app-header d-flex align-center justify-space-between px-6">
                <div class="d-flex align-center gap-3">
                    @if (activeChatType == "Private") {
                        <MudAvatar Size="Size.Medium"><MudImage Src='@($"https://api.dicebear.com/7.x/bottts/svg?seed={activeChatTitle}")'/></MudAvatar>
                    } else {
                        <div class="nav-icon global small"><MudIcon Icon="@Icons.Material.Filled.Public" /></div>
                    }
                    <div>
                        <MudText Typo="Typo.h6" Class="fw-bold lh-1">@activeChatTitle.ToUpper()</MudText>
                        <div class="d-flex align-center gap-1">
                            <div class="online-indicator"></div>
                            <MudText Typo="Typo.caption" Class="opacity-50">Online</MudText>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <MudIconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="opacity-50" />
                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Class="opacity-50" />
                </div>
            </div>

            <div class="chat-app-body flex-grow-1 overflow-hidden">
                @if (activeChatType == "Global")
                {
                    <ChatWidget />
                }
                else if (activeChatType == "Private" && selectedUserId != null)
                {
                    <PrivateChatContainer OtherUserId="@selectedUserId.Value" OtherUserName="@selectedUserName" />
                }
            </div>
        </div>
    </div>
</div>

<style>
    .chat-page-root {
        height: calc(100vh - 64px); /* Full height minus appbar */
        padding: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: var(--mud-palette-background);
    }

    .chat-app-container {
        width: 100%;
        max-width: 1400px;
        height: 100%;
        display: flex;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 24px;
        overflow: hidden;
    }

    /* Sidebar */
    .chat-sidebar {
        width: 350px;
        background: var(--mud-palette-surface);
        border-right: 1px solid var(--mud-palette-divider);
    }
    
    .nav-item {
        display: flex;
        align-items: center;
        padding: 12px 24px;
        margin: 4px 12px;
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .nav-item:hover { background: var(--mud-palette-action-default-hover); }
    .nav-item.active { background: var(--mud-palette-primary); color: white; }
    .nav-item.active .nav-subtitle { color: rgba(255,255,255,0.7); }
    .nav-item.active .nav-icon { background: rgba(255,255,255,0.2); color: white; }

    .nav-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-right: 16px;
    }
    .nav-icon.global { background: rgba(124, 58, 237, 0.1); color: var(--mud-palette-primary); }
    .nav-icon.support { background: rgba(236, 72, 153, 0.1); color: var(--mud-palette-secondary); }
    .nav-icon.small { width: 36px; height: 36px; }

    .nav-info { display: flex; flex-direction: column; }
    .nav-title { font-weight: 800; font-size: 0.95rem; }
    .nav-subtitle { font-size: 0.75rem; color: var(--mud-palette-text-secondary); }

    /* Main Area */
    .chat-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background: var(--mud-palette-background-grey);
    }

    .chat-app-header {
        height: 80px;
        background: var(--mud-palette-surface);
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .online-indicator { width: 8px; height: 8px; background: #4ade80; border-radius: 50%; }
    .fw-black { font-weight: 900; }
    .lh-1 { line-height: 1; }
    
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

@code {
    private string activeChatType = "Global";
    private string activeChatTitle = "Global Community";
    private string selectedUserName = "";
    private Guid? selectedUserId;
    private Guid adminGuid = Guid.Parse("00000000-0000-0000-0000-000000000001");
    private List<UserSummary> activeConversations = new();
    private bool isLoadingPlayers = false;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin")) {
            await LoadActiveConversations();
        }
    }

    private void SelectChat(string type) {
        activeChatType = type;
        if (type == "Global") {
            activeChatTitle = "Global Community";
            selectedUserId = null;
        }
    }

    private void SelectPrivateChat(Guid id, string name) {
        activeChatType = "Private";
        selectedUserId = id;
        selectedUserName = name;
        activeChatTitle = $"{name}";
    }

    private void SelectSupportChat() => SelectPrivateChat(adminGuid, "System Admin");

    private async Task LoadActiveConversations() {
        isLoadingPlayers = true;
        try {
            var players = await Http.GetFromJsonAsync<List<UserSummary>>("api/Admin/players/search/ "); 
            if (players != null) activeConversations = players.Where(p => p.Id != adminGuid).ToList();
        } catch { }
        finally { isLoadingPlayers = false; }
    }

    public class UserSummary {
        public Guid Id { get; set; }
        public string Username { get; set; } = "";
    }
}
