@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@using System.Security.Claims
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject LayoutService LayoutService
@inject IAuthService AuthService
@implements IDisposable

<div class="chat-main-container">
    <div class="chat-messages-viewport custom-scroll" id="chat-box-global">
        @if (!messages.Any() && !isLoading)
        {
            <div class="no-messages-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Class="mb-2" />
                <MudText Typo="Typo.body2">No messages yet. Be the first!</MudText>
            </div>
        }
        @foreach (var msg in messages)
        {
            bool isMe = IsMessageMine(msg);
            
            <div class='@($"chat-bubble-row {(isMe ? "me" : "others")}")'>
                <div class="avatar-col">
                    <MudAvatar Size="Size.Small" Class="bubble-avatar shadow-sm">
                        @* Priority: LayoutService (fresh) -> Internal effective (fallback) -> Server Provided (others) *@
                        <MudImage Src="@(isMe ? (LayoutService.AvatarUrl ?? effectiveAvatarUrl ?? GetDefaultAvatar(effectiveUsername)) : msg.SenderAvatarUrl)" />
                    </MudAvatar>
                </div>
                
                <div class="content-col">
                    @if (!isMe)
                    {
                        <MudText Typo="Typo.caption" Class="bubble-username">@msg.SenderUsername</MudText>
                    }
                    <div class="bubble-payload-wrap">
                        <div class="bubble-payload">
                            @if (msg.IsDeleted) {
                                <MudText Typo="Typo.body2" Style="font-style: italic; opacity: 0.6;">[Message Purged]</MudText>
                            } else {
                                <MudText Typo="Typo.body2">@msg.Message</MudText>
                                @if (msg.IsEdited) {
                                    <span class="edited-flag">(edited)</span>
                                }
                            }
                            <MudText Typo="Typo.caption" Class="bubble-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</MudText>
                        </div>

                        @if (isMe && !msg.IsDeleted) {
                            <div class="msg-actions">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight">
                                    <MudMenuItem OnClick="() => StartEdit(msg)" Icon="@Icons.Material.Filled.Edit">Edit</MudMenuItem>
                                    <MudMenuItem OnClick="() => DeleteMsg(msg.Id)" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
                                </MudMenu>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-footer-input">
        <div class="input-glass-wrap">
            <MudTextField @bind-Value="newMessage" 
                         Placeholder="@(editingMessageId != null ? "Edit message..." : "Write a message...")" 
                         Variant="Variant.Text" 
                         Underline="false"
                         OnKeyDown="HandleKeyDown"
                         Immediate="true"
                         Class="chat-input-field" />
            
            @if (editingMessageId != null) {
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="CancelEdit" />
            }
            
            <MudIconButton Icon="@(editingMessageId == null ? Icons.Material.Filled.Send : Icons.Material.Filled.Check)" 
                          Color="Color.Primary" 
                          Size="Size.Medium" 
                          OnClick="SendMessage"
                          Disabled="@string.IsNullOrWhiteSpace(newMessage)"
                          Class="send-btn" />
        </div>
    </div>
</div>

<style>
    .chat-main-container { 
        display: flex; 
        flex-direction: column; 
        height: 100%; 
        width: 100%;
        background: transparent;
        overflow: hidden;
        position: relative;
    }

    .chat-messages-viewport { 
        flex: 1 1 0%;
        overflow-y: auto; 
        overflow-x: hidden; 
        padding: 16px;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    
    .no-messages-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        opacity: 0.3;
    }

    .chat-bubble-row { 
        display: flex; 
        align-items: flex-end; 
        gap: 8px; 
        margin-bottom: 16px; 
        width: 100%;
        flex-shrink: 0;
    }
    
    .chat-bubble-row.me { flex-direction: row-reverse; }
    
    .avatar-col { flex-shrink: 0; }
    .bubble-avatar { border: 2px solid var(--mud-palette-surface); }
    .me .bubble-avatar { border-color: var(--mud-palette-primary); }
    
    .content-col { 
        display: flex; 
        flex-direction: column; 
        max-width: 85%; 
    }
    .me .content-col { align-items: flex-end; }
    .others .content-col { align-items: flex-start; }
    
    .bubble-username { font-weight: 800; color: var(--mud-palette-primary); margin: 0 4px 2px 4px; font-size: 0.75rem; }
    
    .bubble-payload-wrap { display: flex; align-items: center; gap: 4px; width: 100%; }
    .me .bubble-payload-wrap { flex-direction: row-reverse; }

    .bubble-payload {
        padding: 10px 14px;
        position: relative;
        word-break: break-word;
        font-size: 0.9rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        max-width: 100%;
    }

    .others .bubble-payload {
        background: rgba(var(--mud-palette-surface-rgb), 0.9);
        color: var(--mud-palette-text-primary);
        border-radius: 18px 18px 18px 4px;
        border: 1px solid var(--mud-palette-divider);
    }
    
    .me .bubble-payload {
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-darken) 100%);
        color: white;
        border-radius: 18px 18px 4px 18px;
    }
    
    .bubble-time { font-size: 0.6rem; display: block; margin-top: 4px; opacity: 0.7; text-align: right; }
    .edited-flag { font-size: 0.6rem; opacity: 0.5; margin-left: 4px; }

    .msg-actions { opacity: 0; transition: opacity 0.2s; flex-shrink: 0; }
    .chat-bubble-row:hover .msg-actions { opacity: 1; }

    .chat-footer-input {
        padding: 12px;
        flex-shrink: 0;
        background: var(--mud-palette-surface);
        border-top: 1px solid var(--mud-palette-divider);
    }

    .input-glass-wrap {
        display: flex;
        align-items: center;
        background: rgba(var(--mud-palette-surface-rgb), 0.6);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 24px;
        padding: 2px 4px 2px 12px;
        backdrop-filter: blur(10px);
    }
    
    .chat-input-field { color: var(--mud-palette-text-primary) !important; }

    .send-btn {
        background: var(--mud-palette-primary) !important;
        color: white !important;
    }

    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
</style>

@code {
    [Parameter] public Guid CurrentUserId { get; set; }
    [Parameter] public string CurrentUsername { get; set; } = "";
    [Parameter] public string? CurrentAvatarUrl { get; set; }

    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private bool isLoading = true;
    private Guid? editingMessageId;

    private Guid effectiveUserId;
    private string effectiveUsername = "";
    private string? effectiveAvatarUrl;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        effectiveUsername = user.Identity?.Name ?? "";
        var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
        if (idClaim != null && Guid.TryParse(idClaim.Value, out var parsedId)) {
            effectiveUserId = parsedId;
        }

        // Use cached avatar from LayoutService if available to skip GetMe() call here
        effectiveAvatarUrl = LayoutService.AvatarUrl;

        LayoutService.OnAvatarChanged += HandleAvatarChanged;
        RealTime.OnChatMessageReceived += HandleGlobalMessage;
        RealTime.OnMessageDeleted += HandleMessageDeleted;
        RealTime.OnMessageEdited += HandleMessageEdited;
        
        await LoadHistory();
    }

    private void HandleAvatarChanged(string newUrl) {
        effectiveAvatarUrl = newUrl;
        InvokeAsync(StateHasChanged);
    }

    private bool IsMessageMine(ChatMessageDto msg) {
        if (effectiveUserId != Guid.Empty && msg.SenderId != Guid.Empty && msg.SenderId == effectiveUserId) return true;
        if (!string.IsNullOrEmpty(effectiveUsername) && !string.IsNullOrEmpty(msg.SenderUsername) && 
            string.Equals(msg.SenderUsername, effectiveUsername, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    private string GetDefaultAvatar(string username) => $"https://api.dicebear.com/7.x/bottts/svg?seed={username}";

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessageDto>>("api/Chat/global");
            if (history != null) {
                messages = history;
                _ = ScrollToBottom();
            }
        } catch { }
        finally { isLoading = false; StateHasChanged(); }
    }

    private void HandleGlobalMessage(string user, string msg, DateTime time, string avatar, Guid id) {
        var existing = messages.FirstOrDefault(m => m.Id == id || 
            (IsMessageMine(new ChatMessageDto { SenderUsername = user }) && 
             (m.Message == msg || Math.Abs((m.Timestamp - time).TotalSeconds) < 20)));
            
        if (existing != null) {
            existing.Id = id; 
            existing.Timestamp = time;
            existing.SenderAvatarUrl = avatar;
            if (existing.Message != msg) existing.Message = msg;
            StateHasChanged();
            return;
        }

        messages.Add(new ChatMessageDto {
            Id = id,
            SenderUsername = user,
            Message = msg,
            Timestamp = time,
            SenderAvatarUrl = avatar,
            SenderId = string.Equals(user, effectiveUsername, StringComparison.OrdinalIgnoreCase) ? effectiveUserId : Guid.Empty
        });
        
        InvokeAsync(async () => {
            StateHasChanged();
            await ScrollToBottom();
        });
    }

    private void HandleMessageDeleted(Guid msgId) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.IsDeleted = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleMessageEdited(Guid msgId, string newText) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.Message = newText;
            m.IsEdited = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void StartEdit(ChatMessageDto msg) {
        editingMessageId = msg.Id;
        newMessage = msg.Message;
        StateHasChanged();
    }

    private void CancelEdit() {
        editingMessageId = null;
        newMessage = "";
    }

    private async Task DeleteMsg(Guid msgId) {
        await RealTime.DeleteChatMessage(msgId);
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msgText = newMessage;
        newMessage = "";
        
        if (editingMessageId != null) {
            var id = editingMessageId.Value;
            editingMessageId = null;
            
            var m = messages.FirstOrDefault(x => x.Id == id);
            if (m != null) {
                m.Message = msgText;
                m.IsEdited = true;
            }
            StateHasChanged();

            await RealTime.EditChatMessage(id, msgText);
        } else {
            var tempId = Guid.NewGuid();
            messages.Add(new ChatMessageDto {
                Id = tempId,
                SenderUsername = effectiveUsername,
                SenderId = effectiveUserId,
                Message = msgText,
                Timestamp = DateTime.UtcNow,
                SenderAvatarUrl = LayoutService.AvatarUrl ?? effectiveAvatarUrl ?? GetDefaultAvatar(effectiveUsername)
            });
            
            StateHasChanged();
            await ScrollToBottom();
            await RealTime.SendChatMessage(msgText);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") _ = SendMessage();
        if (e.Key == "Escape" && editingMessageId != null) CancelEdit();
    }

    private async Task ScrollToBottom() {
        await Task.Delay(200);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "chat-box-global");
    }

    public void Dispose() {
        RealTime.OnChatMessageReceived -= HandleGlobalMessage;
        RealTime.OnMessageDeleted -= HandleMessageDeleted;
        RealTime.OnMessageEdited -= HandleMessageEdited;
        LayoutService.OnAvatarChanged -= HandleAvatarChanged;
    }
}
