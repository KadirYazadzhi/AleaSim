@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<div class="chat-main-container d-flex flex-column h-100">
    <div class="chat-messages-viewport flex-grow-1 custom-scroll pa-4" id="chat-box">
        @foreach (var msg in messages)
        {
            bool isMe = msg.SenderUsername == currentUsername;
            <div class='@($"chat-bubble-row mb-4 animate-fade-in {(isMe ? "me" : "others")}")'>
                @if (!isMe)
                {
                    <MudAvatar Size="Size.Small" Class="bubble-avatar shadow-sm">
                        <MudImage Src="@msg.SenderAvatarUrl" />
                    </MudAvatar>
                }
                <div class="bubble-content-wrapper">
                    @if (!isMe)
                    {
                        <MudText Typo="Typo.caption" Class="bubble-username">@msg.SenderUsername</MudText>
                    }
                    <div class="bubble-payload shadow-md">
                        <MudText Typo="Typo.body2">@msg.Message</MudText>
                        <MudText Typo="Typo.caption" Class="bubble-time">@msg.Timestamp.ToString("HH:mm")</MudText>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-footer-input pa-3">
        <div class="input-glass-wrap d-flex align-center gap-2 pa-1">
            <MudTextField @bind-Value="newMessage" 
                         Placeholder="Write a message..." 
                         Variant="Variant.Text" 
                         DisableUnderLine="true"
                         OnKeyDown="HandleKeyDown"
                         Immediate="true"
                         Class="chat-input-field flex-grow-1 px-4" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" 
                          Color="Color.Primary" 
                          Size="Size.Medium" 
                          OnClick="SendMessage"
                          Disabled="@string.IsNullOrWhiteSpace(newMessage)"
                          Class="send-fab shadow-lg" />
        </div>
    </div>
</div>

<style>
    .chat-main-container { background: transparent; }
    .chat-messages-viewport { overflow-y: auto; overflow-x: hidden; }
    
    .chat-bubble-row { display: flex; align-items: flex-end; gap: 8px; width: 100%; }
    .chat-bubble-row.me { flex-direction: row-reverse; }
    
    .bubble-avatar { border: 2px solid var(--mud-palette-surface); }
    
    .bubble-content-wrapper { display: flex; flex-direction: column; max-width: 75%; }
    .me .bubble-content-wrapper { align-items: flex-end; }
    
    .bubble-username { font-weight: 800; color: var(--mud-palette-primary); margin-left: 12px; margin-bottom: 2px; font-size: 0.7rem; }
    
    .bubble-payload {
        padding: 10px 14px;
        position: relative;
        word-break: break-word;
    }
    
    .others .bubble-payload {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 18px 18px 18px 4px;
        color: var(--mud-palette-text-primary);
    }
    
    .me .bubble-payload {
        background: var(--mud-palette-primary);
        border-radius: 18px 18px 4px 18px;
        color: white;
    }
    
    .bubble-time { font-size: 0.6rem; opacity: 0.6; display: block; margin-top: 4px; text-align: right; }
    .me .bubble-time { color: rgba(255,255,255,0.8); }

    .input-glass-wrap {
        background: var(--mud-palette-background-grey);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 30px;
        transition: all 0.3s ease;
    }
    .input-glass-wrap:focus-within {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 15px rgba(124, 58, 237, 0.2);
    }
    
    .send-fab {
        background: var(--mud-palette-primary) !important;
        color: white !important;
        width: 40px; height: 40px;
    }
    .send-fab:disabled { background: var(--mud-palette-action-disabled) !important; }

    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
    
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private string currentUsername = "";

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name ?? "";

        RealTime.OnChatMessageReceived += HandleGlobalMessage;
        await LoadHistory();
    }

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessage>>("api/Chat/global");
            if (history != null) {
                messages = history.Select(m => new ChatMessageDto {
                    SenderUsername = m.SenderUsername,
                    SenderAvatarUrl = m.SenderAvatarUrl,
                    Message = m.Message,
                    Timestamp = m.Timestamp
                }).ToList();
                _ = ScrollToBottom();
            }
        } catch { }
    }

    private void HandleGlobalMessage(string user, string msg, DateTime time, string avatar) {
        messages.Add(new ChatMessageDto {
            SenderUsername = user,
            Message = msg,
            Timestamp = time,
            SenderAvatarUrl = avatar
        });
        if (messages.Count > 100) messages.RemoveAt(0);
        InvokeAsync(async () => {
            StateHasChanged();
            await ScrollToBottom();
        });
    }

    private async Task ScrollToBottom() {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "chat-box");
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msg = newMessage;
        newMessage = "";
        await RealTime.SendChatMessage(msg);
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") {
            _ = SendMessage();
        }
    }

    public void Dispose() {
        RealTime.OnChatMessageReceived -= HandleGlobalMessage;
    }

    public class ChatMessage {
        public string SenderUsername { get; set; } = "";
        public string SenderAvatarUrl { get; set; } = "";
        public string Message { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
