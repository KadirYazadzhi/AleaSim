@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<div class="chat-container glass-panel rounded-xl d-flex flex-column">
    <div class="chat-header pa-3 border-b border-solid var(--mud-palette-divider) d-flex align-center justify-space-between">
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Small" Class="mr-2 text-primary" />
            <MudText Typo="Typo.subtitle2" Class="fw-bold">Global Chat</MudText>
        </div>
        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@OnlineCount Online</MudChip>
    </div>

    <div class="chat-messages flex-grow-1 pa-3 custom-scroll" id="chat-box">
        @foreach (var msg in messages)
        {
            <div class="chat-msg mb-3 animate-fade-in">
                <div class="d-flex align-start gap-2">
                    <MudAvatar Size="Size.Small">
                        <MudImage Src="@msg.SenderAvatarUrl" />
                    </MudAvatar>
                    <div class="msg-content">
                        <div class="d-flex align-center gap-2 mb-1">
                            <MudText Typo="Typo.caption" Class="fw-black mud-text-primary">@msg.SenderUsername</MudText>
                            <MudText Typo="Typo.caption" Style="font-size: 0.6rem; opacity: 0.5;">@msg.Timestamp.ToString("HH:mm")</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Class="msg-text">@msg.Message</MudText>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-input pa-2 border-t border-solid var(--mud-palette-divider)">
        <div class="d-flex gap-2">
            <MudTextField @bind-Value="newMessage" 
                         Placeholder="Type a message..." 
                         Variant="Variant.Outlined" 
                         Margin="Margin.Dense" 
                         OnKeyDown="HandleKeyDown"
                         Immediate="true"
                         Class="chat-field" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" 
                          Color="Color.Primary" 
                          Size="Size.Small" 
                          OnClick="SendMessage"
                          Disabled="@string.IsNullOrWhiteSpace(newMessage)" />
        </div>
    </div>
</div>

<style>
    .chat-container { height: 400px; background: rgba(15, 23, 42, 0.4); }
    .chat-messages { overflow-y: auto; display: flex; flex-direction: column; }
    .msg-content { background: rgba(255,255,255,0.03); padding: 6px 10px; border-radius: 0 12px 12px 12px; max-width: 85%; }
    .msg-text { word-break: break-word; line-height: 1.4; font-size: 0.85rem; }
    .chat-field .mud-input-outlined-border { border-radius: 20px; }
    
    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
    
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private int OnlineCount = 1; // Placeholder

    protected override async Task OnInitializedAsync() {
        RealTime.OnChatMessageReceived += HandleGlobalMessage;
        await LoadHistory();
    }

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessage>>("api/Chat/global");
            if (history != null) {
                messages = history.Select(m => new ChatMessageDto {
                    SenderUsername = m.SenderUsername,
                    SenderAvatarUrl = m.SenderAvatarUrl,
                    Message = m.Message,
                    Timestamp = m.Timestamp
                }).ToList();
                _ = ScrollToBottom();
            }
        } catch { }
    }

    private void HandleGlobalMessage(string user, string msg, DateTime time, string avatar) {
        messages.Add(new ChatMessageDto {
            SenderUsername = user,
            Message = msg,
            Timestamp = time,
            SenderAvatarUrl = avatar
        });
        if (messages.Count > 100) messages.RemoveAt(0);
        InvokeAsync(async () => {
            StateHasChanged();
            await ScrollToBottom();
        });
    }

    private async Task ScrollToBottom() {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "chat-box");
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msg = newMessage;
        newMessage = "";
        await RealTime.SendChatMessage(msg);
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") {
            _ = SendMessage();
        }
    }

    public void Dispose() {
        RealTime.OnChatMessageReceived -= HandleGlobalMessage;
    }

    public class ChatMessage {
        public string SenderUsername { get; set; } = "";
        public string SenderAvatarUrl { get; set; } = "";
        public string Message { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
