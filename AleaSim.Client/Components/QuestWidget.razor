@using AleaSim.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@implements IDisposable

<MudPaper Class="glass-panel pa-3 rounded-xl compact-missions" Elevation="0">
    <div class="d-flex align-center mb-3">
        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Color="Color.Warning" Size="Size.Small" Class="mr-2" />
        <MudText Typo="Typo.caption" Class="fw-black tracking-wider uppercase">Active Missions</MudText>
    </div>

    @if (isLoading && !quests.Any())
    {
        <div class="d-flex justify-center pa-2">
            <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
        </div>
    }
    else if (!quests.Any())
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block text-center pa-2 opacity-50">No missions available.</MudText>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var q in quests)
            {
                <div @key="q.Id" class="mission-item animate-fade-in">
                    <div class="d-flex justify-space-between mb-1">
                        <MudText Typo="Typo.caption" Class="fw-bold mission-title">@q.Title</MudText>
                        <MudText Typo="Typo.caption" Class="fw-black text-success" Style="font-size: 0.65rem;">+@q.RewardAmount.ToString("C0")</MudText>
                    </div>
                    <div class="progress-wrapper">
                        <MudProgressLinear Color="@(q.IsCompleted ? Color.Success : Color.Info)" 
                                         Value="@q.Percentage" 
                                         Size="Size.Small" 
                                         Class="rounded-pill quest-bar" />
                        <div class="progress-text">
                            @($"{q.CurrentValue:N0}/{q.TargetValue:N0}")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</MudPaper>

<style>
    .compact-missions {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
    }
    .fw-black { font-weight: 900; }
    .mission-title { font-size: 0.7rem !important; opacity: 0.8; }
    
    .progress-wrapper { position: relative; height: 12px; }
    .quest-bar { height: 12px !important; }
    
    .progress-text {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 900;
        color: white;
        text-shadow: 0 1px 2px rgba(0,0,0,0.5);
        pointer-events: none;
    }

    .mission-item {
        transition: all 0.5s ease;
    }

    .animate-fade-in {
        animation: questFadeIn 0.6s ease-out forwards;
    }

    @@keyframes questFadeIn {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>

@code {
    private List<QuestProgressDto> quests = new();
    private bool isLoading = true;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuests();
        // Poll every 5 seconds for snappier updates and auto-replacement
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(LoadQuests), null, 5000, 5000);
    }

    private async Task LoadQuests()
    {
        try {
            var newQuests = await Http.GetFromJsonAsync<List<QuestProgressDto>>("api/Game/quests") ?? new();
            
            // Check for completions to show snackbar
            foreach(var nq in newQuests) {
                var old = quests.FirstOrDefault(oq => oq.Id == nq.Id);
                if (old != null && !old.IsCompleted && nq.IsCompleted) {
                    Snackbar.Add($"Mission Completed: {nq.Title}! +{nq.RewardAmount:C} Bonus.", Severity.Success);
                }
            }

            quests = newQuests;
        } catch { }
        finally { 
            isLoading = false; 
            StateHasChanged();
        }
    }

    public void Dispose() => _timer?.Dispose();

    public class QuestProgressDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal CurrentValue { get; set; }
        public decimal TargetValue { get; set; }
        public bool IsCompleted { get; set; }
        public decimal RewardAmount { get; set; }
        public double Percentage { get; set; }
    }
}
