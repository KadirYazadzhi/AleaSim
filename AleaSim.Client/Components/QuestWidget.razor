@using AleaSim.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@implements IDisposable

@if (Compact)
{
    <!-- COMPACT SIDEBAR DESIGN -->
    <MudPaper Class="pa-3 compact-missions" Elevation="0" Style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
        <div class="d-flex align-center mb-2">
            <MudIcon Icon="@Icons.Material.Filled.FlashOn" Color="Color.Warning" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.caption" Class="fw-black tracking-wider uppercase opacity-70">Missions</MudText>
        </div>

        @if (isLoading && !quests.Any())
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Small" Class="rounded-pill" />
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var q in quests)
                {
                    <div @key="q.Id" class="mission-item animate-fade-in">
                        <div class="progress-wrapper">
                            <MudProgressLinear Color="@(q.IsCompleted ? Color.Success : Color.Info)" 
                                             Value="@q.Percentage" 
                                             Size="Size.Small" 
                                             Rounded="true"
                                             Class="quest-bar-compact" />
                            <div class="progress-text-compact">
                                @q.Title (@q.Percentage.ToString("F0")%)
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </MudPaper>
}
else
{
    <!-- CLASSIC HOME PAGE DESIGN -->
    <MudPaper Class="pa-4 rounded-xl glass-panel" Elevation="0">
        <div class="d-flex align-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Class="fw-black">ACTIVE MISSIONS</MudText>
        </div>

        @if (isLoading && !quests.Any())
        {
            <div class="d-flex justify-center pa-2">
                <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
            </div>
        }
        else if (!quests.Any())
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary text-center d-block">No active missions.</MudText>
        }
        else
        {
            <div class="d-flex flex-column gap-4">
                @foreach (var q in quests)
                {
                    <div @key="q.Id" class="mission-item animate-fade-in">
                        <div class="d-flex justify-space-between align-center mb-1">
                            <div>
                                <MudText Typo="Typo.caption" Class="fw-bold mb-0">@q.Title</MudText>
                            </div>
                            <div class="text-end">
                                <MudText Typo="Typo.caption" Color="Color.Success" Class="fw-black">+@q.RewardAmount.ToString("C0")</MudText>
                            </div>
                        </div>
                        <MudProgressLinear Color="@(q.IsCompleted ? Color.Success : Color.Info)" 
                                         Value="@q.Percentage" 
                                         Size="Size.Small" 
                                         Rounded="true"
                                         Class="quest-bar-classic" />
                        <div class="d-flex justify-space-between mt-1">
                            <MudText Typo="Typo.caption" Class="opacity-50" Style="font-size: 0.65rem;">@q.Description</MudText>
                            <MudText Typo="Typo.caption" Class="fw-bold" Style="font-size: 0.65rem;">@($"{q.CurrentValue:N0}/{q.TargetValue:N0}")</MudText>
                        </div>
                    </div>
                }
            </div>
        }
    </MudPaper>
}

<style>
    .fw-black { font-weight: 900; }
    
    /* Rounded Bars */
    .quest-bar-compact .mud-progress-linear-bar, .quest-bar-classic .mud-progress-linear-bar {
        border-radius: 50px !important;
    }
    .quest-bar-compact, .quest-bar-classic {
        border-radius: 50px !important;
        background-color: rgba(255,255,255,0.05) !important;
    }

    .progress-wrapper { position: relative; height: 16px; }
    .quest-bar-compact { height: 16px !important; }
    
    .progress-text-compact {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 900;
        color: white;
        text-shadow: 0 1px 2px rgba(0,0,0,0.8);
        pointer-events: none;
        text-transform: uppercase;
    }

    .mission-item { cursor: pointer; }

    .animate-fade-in { animation: questFadeIn 0.6s ease-out forwards; }
    @@keyframes questFadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    [Parameter] public bool Compact { get; set; } = false;

    private List<QuestProgressDto> quests = new();
    private bool isLoading = true;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuests();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(LoadQuests), null, 5000, 5000);
    }

    private async Task LoadQuests()
    {
        try {
            var newQuests = await Http.GetFromJsonAsync<List<QuestProgressDto>>("api/Game/quests") ?? new();
            
            // Notification Logic
            foreach(var nq in newQuests) {
                var old = quests.FirstOrDefault(oq => oq.Id == nq.Id);
                if (old != null && !old.IsCompleted && nq.IsCompleted) {
                    Snackbar.Add($"Mission Completed: {nq.Title}! +{nq.RewardAmount:C} Bonus.", Severity.Success);
                }
            }

            quests = newQuests;
        } catch { }
        finally { 
            isLoading = false; 
            StateHasChanged();
        }
    }

    public void Dispose() => _timer?.Dispose();

    public class QuestProgressDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal CurrentValue { get; set; }
        public decimal TargetValue { get; set; }
        public bool IsCompleted { get; set; }
        public decimal RewardAmount { get; set; }
        public double Percentage { get; set; }
    }
}
