@using AleaSim.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@implements IDisposable

<MudPaper Class="glass-panel pa-4 rounded-xl" Elevation="0">
    <div class="d-flex align-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Size="Size.Small" Class="mr-2" />
        <MudText Typo="Typo.subtitle2" Class="fw-bold">ACTIVE MISSIONS</MudText>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-center pa-4">
            <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
        </div>
    }
    else if (!quests.Any())
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block text-center pa-2">No active missions. Check back later!</MudText>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var q in quests)
            {
                <div>
                    <div class="d-flex justify-space-between mb-1">
                        <MudText Typo="Typo.caption" Class="fw-bold">@q.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Success">@q.RewardAmount.ToString("C0")</MudText>
                    </div>
                    <MudProgressLinear Color="@(q.IsCompleted ? Color.Success : Color.Info)" 
                                     Value="@q.Percentage" 
                                     Size="Size.Small" 
                                     Class="rounded-pill" />
                    <MudText Typo="Typo.caption" Class="opacity-60" Style="font-size: 0.65rem;">
                        @(q.IsCompleted ? "COMPLETED" : $"{q.CurrentValue:N0} / {q.TargetValue:N0}")
                    </MudText>
                </div>
            }
        </div>
    }
</MudPaper>

@code {
    private List<QuestProgressDto> quests = new();
    private bool isLoading = true;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuests();
        // Poll every 30 seconds for progress updates
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(LoadQuests), null, 30000, 30000);
    }

    private async Task LoadQuests()
    {
        try {
            quests = await Http.GetFromJsonAsync<List<QuestProgressDto>>("api/Game/quests") ?? new();
        } catch { }
        finally { 
            isLoading = false; 
            StateHasChanged();
        }
    }

    public void Dispose() => _timer?.Dispose();

    public class QuestProgressDto
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal CurrentValue { get; set; }
        public decimal TargetValue { get; set; }
        public bool IsCompleted { get; set; }
        public decimal RewardAmount { get; set; }
        public double Percentage { get; set; }
    }
}
