@using AleaSim.Shared.Models
@using System.Text.Json
@using AleaSim.Client.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5">Round Details: @Round.GameName</MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper Class="pa-4 mb-4" Style="background: #f5f5f5;">
            <MudGrid>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Date:</MudText>
                    <MudText Typo="Typo.body2">@Round.PlayedAt.ToString("g")</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Bet Amount:</MudText>
                    <MudText Typo="Typo.body2">@Round.BetAmount.ToString("C2")</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Win Amount:</MudText>
                    <MudText Typo="Typo.body2" Color="@(Round.WinAmount > 0 ? Color.Success : Color.Default)" Style="font-weight: bold;">
                        @Round.WinAmount.ToString("C2")
                    </MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Decision Type:</MudText>
                    <MudText Typo="Typo.body2">@Round.ResultSummary</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">Visual Replay</MudText>
        <div class="replay-area d-flex justify-center pa-4" style="background: #111; border-radius: 8px;">
            @if (Round.GameName.Contains("Slot"))
            {
                <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 4px;">
                    @foreach (var row in ParseSlotGrid())
                    {
                        @foreach (var cell in row)
                        {
                            <div style="width: 40px; height: 40px; background: #222; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 1px solid #333;">
                                @GetEmoji(cell)
                            </div>
                        }
                    }
                </div>
            }
            else if (Round.GameName.Contains("Roulette"))
            {
                <div style="width: 80px; height: 80px; border-radius: 50%; background: #b30000; border: 4px solid white; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold;">
                    @ParseRouletteResult()
                </div>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Visual replay not available for this game type.</MudText>
            }
        </div>

        <MudText Typo="Typo.h6" Class="mb-2 mt-6">Provably Fair Verification</MudText>
        <MudExpansionPanels Elevation="0">
            <MudExpansionPanel Text="Verification Details" Style="background: #fafafa;">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Server Seed Hash:</MudText>
                        <MudText Typo="Typo.body2" Style="word-break: break-all; font-family: monospace;">@Round.ServerSeedHash</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Client Seed:</MudText>
                        <MudText Typo="Typo.body2">@Round.ClientSeed</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Nonce:</MudText>
                        <MudText Typo="Typo.body2">@Round.Nonce</MudText>
                    </MudItem>
                </MudGrid>
                <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
                    You can verify the fairness of this round by hashing the revealed Server Seed once the session is closed.
                </MudAlert>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public GameRoundDto Round { get; set; } = new();

    private void Close() => MudDialog.Close();

    private int[][] ParseSlotGrid() {
        try {
            var data = JsonSerializer.Deserialize<SlotResultGrid>(Round.FullResultJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            return data?.Grid ?? Array.Empty<int[]>();
        } catch { return Array.Empty<int[]>(); }
    }

    private string ParseRouletteResult() {
        try {
            // Logic to parse roulette JSON
            return "17"; 
        } catch { return "?"; }
    }

    private string GetEmoji(int id) => id switch {
        1 => "🍒", 2 => "🍋", 3 => "🍊", 4 => "🍇",
        5 => "🔔", 6 => "💎", 7 => "7️⃣", 8 => "🍀",
        10 => "💰", _ => "🍃"
    };
}
