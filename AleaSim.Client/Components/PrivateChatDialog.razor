@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudAvatar Size="Size.Small" Class="mr-3"><MudImage Src="@OtherUserAvatar"/></MudAvatar>
            <MudText Typo="Typo.h6">Chat with @OtherUserName</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="chat-box pa-4 custom-scroll" id="private-chat-box" style="height: 400px; overflow-y: auto; background: var(--mud-palette-background-grey); border-radius: 8px;">
            @foreach (var msg in messages)
            {
                bool isMe = msg.SenderId == currentUserId;
                <div class='@($"d-flex mb-4 {(isMe ? "justify-end" : "justify-start")}")'>
                    <div class='@($"pa-3 rounded-lg {(isMe ? "bg-primary text-white" : "bg-dark-lighten")}")' style="max-width: 80%;">
                        <MudText Typo="Typo.body2">@msg.Message</MudText>
                        <MudText Typo="Typo.caption" Class="d-block mt-1 opacity-50" Align="@(isMe ? Align.Right : Align.Left)">@msg.Timestamp.ToString("HH:mm")</MudText>
                    </div>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="d-flex gap-2 pa-4 w-100">
            <MudTextField @bind-Value="newMessage" Placeholder="Type a private message..." Variant="Variant.Outlined" Margin="Margin.Dense" OnKeyDown="HandleKeyDown" Immediate="true" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" OnClick="SendMessage" Disabled="@string.IsNullOrWhiteSpace(newMessage)" />
        </div>
    </DialogActions>
</MudDialog>

<style>
    .bg-dark-lighten { background: rgba(255,255,255,0.05); }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid OtherUserId { get; set; }
    [Parameter] public string OtherUserName { get; set; } = "";
    [Parameter] public string OtherUserAvatar { get; set; } = "";

    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private Guid currentUserId;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (idClaim != null) currentUserId = Guid.Parse(idClaim.Value);

        RealTime.OnPrivateMessageReceived += HandlePrivateMessage;
        await LoadHistory();
    }

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessageDto>>($"api/Chat/private/{OtherUserId}");
            if (history != null) {
                messages = history;
                _ = ScrollToBottom();
            }
        } catch { }
    }

    private void HandlePrivateMessage(string user, string msg, DateTime time, string avatar, Guid senderId) {
        // Only add if it belongs to this conversation
        if (senderId == OtherUserId || senderId == currentUserId) {
            messages.Add(new ChatMessageDto {
                SenderUsername = user,
                Message = msg,
                Timestamp = time,
                SenderAvatarUrl = avatar,
                SenderId = senderId
            });
            InvokeAsync(async () => {
                StateHasChanged();
                await ScrollToBottom();
            });
        }
    }

    private async Task ScrollToBottom() {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "private-chat-box");
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msg = newMessage;
        newMessage = "";
        await RealTime.SendPrivateMessage(OtherUserId, msg);
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") _ = SendMessage();
    }

    public void Dispose() {
        RealTime.OnPrivateMessageReceived -= HandlePrivateMessage;
    }
}
