@using AleaSim.Client.Services
@implements IDisposable

<MudPaper Elevation="0" Class="d-flex flex-column h-100" Style="background: transparent;">
    <MudText Typo="Typo.h6" Class="pa-4" Style="color: white;">Global Chat</MudText>
    
    <div class="chat-messages pa-4 flex-grow-1" id="chat-container">
        @foreach (var msg in messages)
        {
            <div class="message-item mb-2 d-flex gap-2">
                <MudAvatar Size="Size.Small" Image="@msg.AvatarUrl" Class="mt-1" />
                <div class="flex-grow-1">
                    <MudText Typo="Typo.caption" Style="color: #ffD700; font-weight: bold;">@msg.User</MudText>
                    <div class="message-bubble">
                        <MudText Typo="Typo.body2" Style="color: white;">@msg.Text</MudText>
                    </div>
                    <MudText Typo="Typo.caption" Style="color: #666; font-size: 0.6rem;">@msg.Time.ToShortTimeString()</MudText>
                </div>
            </div>
        }
    </div>

    <MudDivider />
    
    <div class="pa-2 d-flex gap-2">
        <MudTextField @bind-Value="currentMessage" 
                      Placeholder="Type a message..." 
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense"
                      OnKeyDown="@(async (e) => { if(e.Key == "Enter") await Send(); })"
                      Style="background: #222; color: white;" />
        <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" OnClick="Send" />
    </div>
</MudPaper>

<style>
    .chat-messages { overflow-y: auto; max-height: calc(100vh - 250px); display: flex; flex-direction: column-reverse; }
    .message-bubble { background: rgba(255,255,255,0.05); padding: 8px 12px; border-radius: 0 12px 12px 12px; margin: 2px 0; border: 1px solid rgba(255,255,255,0.1); }
    .message-item { display: flex; flex-direction: column; align-items: flex-start; }
</style>

@code {
    [Inject] RealTimeClient RealTime { get; set; } = default!;
    private List<ChatMessage> messages = new();
    private string currentMessage = "";

    protected override void OnInitialized()
    {
        RealTime.OnChatMessageReceived += HandleNewMessage;
    }

    private void HandleNewMessage(string user, string text, DateTime time, string avatar)
    {
        messages.Insert(0, new ChatMessage(user, text, time, avatar));
        if (messages.Count > 50) messages.RemoveAt(50);
        InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(currentMessage)) return;
        await RealTime.SendChatMessage(currentMessage);
        currentMessage = "";
    }

    public void Dispose()
    {
        RealTime.OnChatMessageReceived -= HandleNewMessage;
    }

    private record ChatMessage(string User, string Text, DateTime Time, string AvatarUrl);
}
