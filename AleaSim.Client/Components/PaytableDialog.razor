@using AleaSim.Client.Services
@inject LayoutService LayoutService

<MudDialog Class="paytable-dialog">
    <TitleContent>
        <MudText Typo="Typo.h5" Class="fw-black text-gradient">CLOVER CHASE PAYTABLE</MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
            <!-- Tab 1: Symbol Payouts -->
            <MudTabPanel Text="SYMBOLS" Icon="@Icons.Material.Filled.TableChart">
                <MudGrid Spacing="2">
                    @foreach (var sym in SymbolPayouts) {
                        <MudItem xs="6" sm="4">
                            <MudPaper Class="pa-3 text-center glass-panel h-100">
                                <img src="images/slots/@(sym.File)" style="width: 50px; height: 50px;" class="mb-2" />
                                <div class="d-flex flex-column gap-1">
                                    <MudText Typo="Typo.caption" Class="d-flex justify-space-between"><span>5x</span> <b class="mud-text-primary">@sym.P5.ToString("F1")x</b></MudText>
                                    <MudText Typo="Typo.caption" Class="d-flex justify-space-between"><span>4x</span> <b class="mud-text-secondary">@sym.P4.ToString("F1")x</b></MudText>
                                    <MudText Typo="Typo.caption" Class="d-flex justify-space-between"><span>3x</span> <b class="opacity-70">@sym.P3.ToString("F1")x</b></MudText>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
                <MudAlert Severity="Severity.Info" Class="mt-4 rounded-lg" Dense="true" Style="font-size: 0.7rem;">
                    Multipliers apply to the TOTAL STAKE.
                </MudAlert>
            </MudTabPanel>

            <!-- Tab 2: Paylines -->
            <MudTabPanel Text="PAYLINES" Icon="@Icons.Material.Filled.LinearScale">
                <div class="paylines-grid mt-4">
                    @for (int i = 0; i < 20; i++) {
                        <div class="line-mini-map">
                            <div class="line-number">@(i + 1)</div>
                            <div class="dots-grid">
                                @{ var line = Paylines[i]; }
                                @for (int r = 0; r < 4; r++) {
                                    @for (int c = 0; c < 5; c++) {
                                        <div class='@($"dot {(line[c] == r ? "active" : "")}")'></div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled" Class="rounded-pill px-8">GOT IT</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .paytable-dialog { background: rgba(15, 23, 42, 0.95) !important; backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px !important; }
    .fw-black { font-weight: 900; }
    .paylines-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
    .line-mini-map { background: rgba(255,255,255,0.05); border-radius: 8px; padding: 8px; position: relative; }
    .line-number { position: absolute; top: 2px; right: 4px; font-size: 0.6rem; font-weight: 900; color: var(--mud-palette-primary); }
    .dots-grid { display: grid; grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(4, 1fr); gap: 2px; }
    .dot { width: 4px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 50%; }
    .dot.active { background: #00f2ff; box-shadow: 0 0 5px #00f2ff; transform: scale(1.5); }
</style>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    void Close() => MudDialog.Close();

    private record SymbolInfo(string File, decimal P3, decimal P4, decimal P5);
    private List<SymbolInfo> SymbolPayouts = new() {
        new SymbolInfo("seven.png", 20m, 100m, 1000m),
        new SymbolInfo("clover.png", 10m, 50m, 500m),
        new SymbolInfo("apple.png", 5m, 25m, 100m),
        new SymbolInfo("bell.png", 3m, 15m, 50m),
        new SymbolInfo("watermelon.png", 2m, 10m, 25m),
        new SymbolInfo("grape.png", 2m, 10m, 25m),
        new SymbolInfo("plum.png", 1m, 5m, 10m),
        new SymbolInfo("orange.png", 1m, 5m, 10m),
        new SymbolInfo("lemon.png", 0.5m, 2m, 5m),
        new SymbolInfo("cherries.png", 0.5m, 2m, 5m)
    };

    private int[][] Paylines = new[] {
        new[] {0,0,0,0,0}, new[] {1,1,1,1,1}, new[] {2,2,2,2,2}, new[] {3,3,3,3,3},
        new[] {0,1,2,1,0}, new[] {1,2,3,2,1}, new[] {2,1,0,1,2}, new[] {3,2,1,2,3},
        new[] {0,1,0,1,0}, new[] {1,0,1,0,1}, new[] {2,3,2,3,2}, new[] {3,2,3,2,3},
        new[] {0,0,1,0,0}, new[] {1,1,2,1,1}, new[] {2,2,3,2,2}, new[] {1,1,0,1,1},
        new[] {2,2,1,2,2}, new[] {1,0,0,0,1}, new[] {2,3,3,3,2}, new[] {0,1,1,1,0}
    };
}
