@using AleaSim.Client.Services
@using MudBlazor
@inject LayoutService LayoutService

<MudDialog Class="paytable-dialog">
    <TitleContent>
        <MudText Typo="Typo.h5" Class="fw-black text-gradient">CLOVER CHASE PAYTABLE</MudText>
    </TitleContent>
    <DialogContent>
        <div class="dialog-fixed-container">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <!-- Tab 1: Symbol Payouts -->
                <MudTabPanel Text="SYMBOLS" Icon="@Icons.Material.Filled.TableChart">
                    <MudGrid Spacing="2">
                        @foreach (var sym in SymbolPayouts) {
                            <MudItem xs="6" sm="4">
                                <MudPaper Class="pa-4 text-center glass-panel h-100 position-relative symbol-card">
                                    @if (!string.IsNullOrEmpty(sym.Description))
                                    {
                                        <div class="info-btn-container">
                                            <MudTooltip Text="@sym.Description" Placement="Placement.Top" Arrow="true" Color="Color.Dark" Inline="true">
                                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" />
                                            </MudTooltip>
                                        </div>
                                    }
                                    <img src="images/slots/@(sym.File)" style="width: 60px; height: 60px;" class="mb-2 symbol-img" />
                                    <div class="d-flex flex-column gap-1">
                                        <MudText Typo="Typo.caption" Class="d-flex justify-space-between"><span>5x</span> <b class="mud-text-primary">@sym.P5.ToString("F1")x</b></MudText>
                                        <MudText Typo="Typo.caption" Class="d-flex justify-space-between"><span>4x</span> <b class="mud-text-secondary">@sym.P4.ToString("F1")x</b></MudText>
                                        <MudText Typo="Typo.caption" Class="d-flex justify-space-between"><span>3x</span> <b class="opacity-70">@sym.P3.ToString("F1")x</b></MudText>
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                    <MudAlert Severity="Severity.Info" Class="mt-4 rounded-lg" Dense="true" Style="font-size: 0.7rem;">
                        Multipliers apply to the TOTAL STAKE.
                    </MudAlert>
                </MudTabPanel>

                <!-- Tab 2: Paylines -->
                <MudTabPanel Text="PAYLINES" Icon="@Icons.Material.Filled.LinearScale">
                    <div class="paylines-grid mt-4">
                        @for (int i = 0; i < 20; i++) {
                            <div class="line-mini-map">
                                <div class="line-number">@(i + 1)</div>
                                <div class="dots-grid">
                                    @{ var line = Paylines[i]; }
                                    @for (int r = 0; r < 4; r++) {
                                        @for (int c = 0; c < 5; c++) {
                                            <div class='@($"dot {(line[c] == r ? "active" : "")}")'></div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </MudTabPanel>
            </MudTabs>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled" Class="rounded-pill px-8 mb-4 mr-4">GOT IT</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .paytable-dialog { 
        background: var(--mud-palette-surface) !important; 
        backdrop-filter: blur(20px); 
        border: 1px solid var(--mud-palette-divider); 
        border-radius: 24px !important;
        width: 850px !important;
        max-width: 95vw;
    }
    .dialog-fixed-container {
        min-height: 600px;
        width: 100%;
        overflow-x: hidden;
    }
    .fw-black { font-weight: 900; }
    .symbol-card { 
        transition: transform 0.2s; 
        overflow: visible !important; 
        border: 1px solid var(--mud-palette-divider) !important;
    }
    .symbol-card:hover { 
        transform: translateY(-4px); 
        background: var(--mud-palette-action-default-hover) !important; 
    }
    
    .info-btn-container { 
        position: absolute; 
        top: 8px; 
        right: 8px; 
        z-index: 50;
        cursor: help;
        opacity: 0.6;
    }
    .info-btn-container:hover { opacity: 1; }

    .paylines-grid { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); 
        gap: 24px; 
    }
    .line-mini-map { 
        background: var(--mud-palette-background-grey); 
        border-radius: 12px; 
        padding: 20px; 
        position: relative; 
        border: 1px solid var(--mud-palette-divider);
    }
    .line-number { 
        position: absolute; 
        top: 6px; 
        right: 10px; 
        font-size: 0.9rem; 
        font-weight: 900; 
        color: var(--mud-palette-primary); 
    }
    .dots-grid { display: grid; grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(4, 1fr); gap: 8px; }
    .dot { 
        width: 12px; 
        height: 12px; 
        background: var(--mud-palette-action-disabled); 
        border-radius: 50%; 
        transition: all 0.3s; 
    }
    .dot.active { 
        background: var(--mud-palette-primary); 
        box-shadow: 0 0 15px var(--mud-palette-primary); 
        transform: scale(1.4); 
    }
    
    .text-gradient {
        background: linear-gradient(to right, var(--mud-palette-primary), var(--mud-palette-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    void Close() => MudDialog.Close();

    private record SymbolInfo(string File, decimal P3, decimal P4, decimal P5, string? Description = null);
    private List<SymbolInfo> SymbolPayouts = new() {
        new SymbolInfo("seven.png", 20m, 100m, 1000m, "Golden Seven: The highest paying symbol. Acts as Wild for all fruit symbols."),
        new SymbolInfo("clover.png", 10m, 50m, 500m, "Clover Wild: Substitutes for all symbols except Scatter. 4+ trigger Respins phase."),
        new SymbolInfo("bell.png", 3m, 15m, 50m, "Bell Scatter: Triggers the Bell Bonus during Respins if 5+ Clovers are collected."),
        new SymbolInfo("apple.png", 5m, 25m, 100m),
        new SymbolInfo("watermelon.png", 2m, 10m, 25m),
        new SymbolInfo("grape.png", 2m, 10m, 25m),
        new SymbolInfo("plum.png", 1m, 5m, 10m),
        new SymbolInfo("orange.png", 1m, 5m, 10m),
        new SymbolInfo("lemon.png", 0.5m, 2m, 5m),
        new SymbolInfo("cherries.png", 0.5m, 2m, 5m)
    };

    private int[][] Paylines = new[] {
        new[] {0,0,0,0,0}, new[] {1,1,1,1,1}, new[] {2,2,2,2,2}, new[] {3,3,3,3,3},
        new[] {0,1,2,1,0}, new[] {1,2,3,2,1}, new[] {2,1,0,1,2}, new[] {3,2,1,2,3},
        new[] {0,1,0,1,0}, new[] {1,0,1,0,1}, new[] {2,3,2,3,2}, new[] {3,2,3,2,3},
        new[] {0,0,1,0,0}, new[] {1,1,2,1,1}, new[] {2,2,3,2,2}, new[] {1,1,0,1,1},
        new[] {2,2,1,2,2}, new[] {1,0,0,0,1}, new[] {2,3,3,3,2}, new[] {0,1,1,1,0}
    };
}
