@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AudioService Audio
@inject IJSRuntime JS

<MudDialog Class="bonus-wheel-dialog">
    <TitleContent>
        <div class="d-flex flex-column align-center pa-4">
            <MudText Typo="Typo.h4" Class="fw-black text-gradient">DAILY LUCK WHEEL</MudText>
            <MudText Typo="Typo.caption" Class="opacity-60 text-center">Spin every 24 hours for guaranteed rewards!</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="wheel-outer-wrap">
            <div class="wheel-main-container">
                <!-- Pointer -->
                <div class="wheel-pointer-modern">
                    <svg viewBox="0 0 30 40" width="40" height="50">
                        <path d="M15 40 L30 10 L15 0 L0 10 Z" fill="#ffeb3b" stroke="#000" stroke-width="2" />
                    </svg>
                </div>

                <!-- Rotating Body -->
                <div class="wheel-body" style="transform: rotate(@(_currentRotation)deg); transition: @(_transitionStyle)">
                    @for (int i = 0; i < _slices.Count; i++)
                    {
                        var slice = _slices[i];
                        double rotation = i * 45;
                        
                        <!-- Wedge Background -->
                        <div class="wedge" style="transform: rotate(@(rotation)deg) skewY(-45deg); background: @slice.Color;"></div>
                        
                        <!-- Label: Centered in wedge, pointing towards center -->
                        <div class="wedge-label-wrapper" style="transform: rotate(@(rotation + 22.5)deg)">
                            <div class="wedge-label-content">
                                <MudIcon Icon="@slice.Icon" Size="Size.Small" Class="mb-1" />
                                <span class="slice-text">@slice.Label</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Center Hub -->
                <div class="wheel-center-hub">
                    <div class="hub-inner">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                    </div>
                </div>
            </div>
        </div>

        <div class="results-area mt-4" style="min-height: 80px;">
            @if (result != null && !isSpinning)
            {
                <div class="result-display animate-pop-in">
                    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="rounded-xl py-3 shadow-lg border-2 border-solid border-white-10">
                        <div class="d-flex align-center justify-center gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Class="fw-black">@result.Message</MudText>
                        </div>
                    </MudAlert>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="pa-6 pt-0 w-100">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       OnClick="Spin" 
                       Disabled="isSpinning || result != null" 
                       FullWidth="true"
                       Class="py-4 rounded-xl fw-black hover-scale shadow-lg glow-button"
                       Style="font-size: 1.2rem; letter-spacing: 1px;">
                @(isSpinning ? "SPINNING..." : (result != null ? "COME BACK TOMORROW" : "SPIN FOR FREE!"))
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .bonus-wheel-dialog { background: rgba(15, 23, 42, 0.98) !important; backdrop-filter: blur(25px); border-radius: 40px !important; border: 1px solid rgba(255,255,255,0.1); max-width: 480px !important; }
    .fw-black { font-weight: 900; }
    .text-gradient { background: linear-gradient(to right, #ffeb3b, #f44336); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .wheel-outer-wrap { display: flex; justify-content: center; padding: 20px 0; overflow: hidden; }
    
    .wheel-main-container { 
        position: relative; 
        width: 320px; 
        height: 320px; 
        min-width: 320px;
        min-height: 320px;
        border-radius: 50%; 
        border: 10px solid #1e293b;
        background: #0f172a;
        box-shadow: 0 20px 60px rgba(0,0,0,0.7);
        overflow: hidden;
    }

    .wheel-body {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        overflow: hidden;
        z-index: 1;
    }

    .wedge {
        position: absolute;
        width: 100%;
        height: 100%;
        left: 50%;
        top: -50%;
        transform-origin: 0 100%;
        border: 1px solid rgba(0,0,0,0.1);
    }

    /* New Label Positioning */
    .wedge-label-wrapper {
        position: absolute;
        top: 0;
        left: 50%;
        width: 40px;
        height: 50%; /* From center to edge */
        margin-left: -20px;
        transform-origin: 50% 100%;
        display: flex;
        justify-content: center;
        z-index: 10;
        pointer-events: none;
    }

    .wedge-label-content {
        padding-top: 25px;
        display: flex;
        flex-direction: column;
        align-items: center;
        color: white;
        text-shadow: 0 2px 8px rgba(0,0,0,1);
    }

    .slice-text {
        font-weight: 900;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .wheel-pointer-modern {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
    }

    .wheel-center-hub {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        background: #1e293b;
        border-radius: 50%;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 20px rgba(0,0,0,0.6);
        border: 4px solid #334155;
    }

    .hub-inner {
        width: 30px; height: 30px;
        background: #0f172a; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }

    .glow-button { box-shadow: 0 0 20px rgba(124, 58, 237, 0.3); }
    .glow-button:not(:disabled):hover { box-shadow: 0 0 30px rgba(124, 58, 237, 0.6); }

    .animate-pop-in { animation: popIn 0.4s cubic-bezier(0.17, 0.89, 0.32, 1.49) forwards; }
    @@keyframes popIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private bool isSpinning = false;
    private SpinResult? result;
    private double _currentRotation = 0;
    private string _transitionStyle = "none";

    private class SliceInfo {
        public string Label { get; set; } = "";
        public string Color { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Type { get; set; } = "";
        public decimal Value { get; set; }
    }

    private List<SliceInfo> _slices = new() {
        new SliceInfo { Label = "$5.00", Color = "#312e81", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m },
        new SliceInfo { Label = "500 XP", Color = "#1e1b4b", Icon = Icons.Material.Filled.Bolt, Type = "XP", Value = 500m },
        new SliceInfo { Label = "$5.00", Color = "#312e81", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m },
        new SliceInfo { Label = "$50.00", Color = "#7c3aed", Icon = Icons.Material.Filled.EmojiEvents, Type = "BonusCash", Value = 50m },
        new SliceInfo { Label = "500 XP", Color = "#312e81", Icon = Icons.Material.Filled.Bolt, Type = "XP", Value = 500m },
        new SliceInfo { Label = "$5.00", Color = "#1e1b4b", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m },
        new SliceInfo { Label = "500 XP", Color = "#312e81", Icon = Icons.Material.Filled.Bolt, Type = "XP", Value = 500m },
        new SliceInfo { Label = "$5.00", Color = "#1e1b4b", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m }
    };

    private async Task Spin() {
        if (isSpinning) return;
        
        try {
            var response = await Http.PostAsync("api/Game/daily-spin", null);
            if (!response.IsSuccessStatusCode) {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add(error, Severity.Warning);
                MudDialog.Close();
                return;
            }

            result = await response.Content.ReadFromJsonAsync<SpinResult>();
            if (result == null) return;

            int targetIdx = _slices.FindIndex(s => s.Type == result.Type && s.Value == result.Value);
            if (targetIdx == -1) targetIdx = 0;

            await DoSpinAnimation(targetIdx);
        } catch {
            Snackbar.Add("Error spinning the wheel.", Severity.Error);
        }
    }

    private async Task DoSpinAnimation(int targetIdx) {
        isSpinning = true;
        _transitionStyle = "none";
        _currentRotation %= 360; // Normalize
        StateHasChanged();
        await Task.Delay(10);

        double sliceDeg = 360.0 / _slices.Count;
        double extraRotations = 10 * 360; 
        
        // Target angle logic:
        // Pointer is at TOP (0 deg).
        // Slice 0 starts at 0 deg. Its center is at 22.5 deg.
        // To bring the center of slice i to the top, we need to rotate the wheel by (360 - center_i).
        double targetAngle = 360 - (targetIdx * sliceDeg + (sliceDeg / 2));
        
        _currentRotation += extraRotations + (targetAngle - (_currentRotation % 360));
        _transitionStyle = "transform 5s cubic-bezier(0.15, 0, 0.15, 1)";
        
        StateHasChanged();
        await Task.Delay(5000);
        
        isSpinning = false;
        await Audio.PlayWin();
        StateHasChanged();
    }

    public class SpinResult {
        public string Type { get; set; } = "";
        public decimal Value { get; set; }
        public string Message { get; set; } = "";
    }
}
