@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AudioService Audio
@inject IJSRuntime JS

<MudDialog Class="bonus-wheel-dialog">
    <TitleContent>
        <div class="d-flex flex-column align-center pa-4">
            <MudText Typo="Typo.h4" Class="fw-black text-gradient">DAILY LUCK WHEEL</MudText>
            <MudText Typo="Typo.caption" Class="opacity-60">Spin every 24 hours for guaranteed rewards!</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="wheel-outer-wrap">
            <div class="wheel-main-container">
                <!-- Pointer -->
                <div class="wheel-pointer-modern">
                    <svg viewBox="0 0 30 40">
                        <path d="M15 0 L30 20 L15 40 L0 20 Z" fill="#ffeb3b" />
                    </svg>
                </div>

                <!-- The Wheel -->
                <div class="wheel-body" style="transform: rotate(@(_currentRotation)deg); transition: @(_transitionStyle)">
                    @for (int i = 0; i < _slices.Count; i++)
                    {
                        var slice = _slices[i];
                        <div class="wheel-slice" style="--i: @i; --count: @_slices.Count; --color: @slice.Color;">
                            <div class="slice-content">
                                <MudIcon Icon="@slice.Icon" Size="Size.Medium" Class="mb-1" />
                                <span>@slice.Label</span>
                            </div>
                        </div>
                    }
                    <div class="wheel-center-hub">
                        <div class="hub-inner">
                            <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" />
                        </div>
                    </div>
                </div>
                
                <!-- Glow Effect -->
                <div class="wheel-glow"></div>
            </div>
        </div>

        @if (result != null && !isSpinning)
        {
            <div class="result-display animate-pop-in mt-6">
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="rounded-xl py-4 shadow-lg">
                    <div class="d-flex align-center justify-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Class="fw-black">@result.Message</MudText>
                    </div>
                </MudAlert>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <div class="pa-4 w-100">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       OnClick="Spin" 
                       Disabled="isSpinning || result != null" 
                       FullWidth="true"
                       Class="py-4 rounded-xl fw-black hover-scale shadow-lg"
                       Style="font-size: 1.2rem; letter-spacing: 1px;">
                @(isSpinning ? "SPINNING..." : (result != null ? "COME BACK TOMORROW!" : "SPIN FOR FREE!"))
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .bonus-wheel-dialog { background: rgba(15, 23, 42, 0.95) !important; backdrop-filter: blur(20px); border-radius: 32px !important; border: 1px solid rgba(255,255,255,0.1); }
    .fw-black { font-weight: 900; }
    .text-gradient { background: linear-gradient(to right, #ffeb3b, #f44336); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    .wheel-outer-wrap { display: flex; justify-content: center; padding: 20px 0; perspective: 1000px; }
    
    .wheel-main-container { 
        position: relative; 
        width: 320px; 
        height: 320px; 
        border-radius: 50%; 
        border: 8px solid #1e293b;
        box-shadow: 0 0 0 4px #334155, 0 20px 50px rgba(0,0,0,0.5);
    }

    .wheel-body {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        background: #0f172a;
    }

    .wheel-slice {
        position: absolute;
        width: 50%;
        height: 50%;
        transform-origin: 100% 100%;
        transform: rotate(calc(var(--i) * (360deg / var(--count)))) skewY(calc(90deg - (360deg / var(--count))));
        background: var(--color);
        border: 1px solid rgba(0,0,0,0.1);
    }

    .slice-content {
        position: absolute;
        left: -100%;
        width: 200%;
        height: 200%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transform: skewY(calc((360deg / var(--count)) - 90deg)) rotate(calc(180deg / var(--count)));
        padding-bottom: 80px;
        color: white;
        font-weight: 900;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        font-size: 0.8rem;
    }

    .wheel-pointer-modern {
        position: absolute;
        top: -25px;
        left: 50%;
        transform: translateX(-50%);
        width: 30px;
        height: 40px;
        z-index: 100;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
    }

    .wheel-center-hub {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        background: #1e293b;
        border-radius: 50%;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 20px rgba(0,0,0,0.5);
        border: 4px solid #334155;
    }

    .hub-inner {
        width: 30px; height: 30px;
        background: #0f172a; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }

    .wheel-glow {
        position: absolute; inset: -15px; border-radius: 50%;
        background: radial-gradient(circle, transparent 60%, rgba(124, 58, 237, 0.1) 100%);
        pointer-events: none;
    }

    .animate-pop-in { animation: popIn 0.5s cubic-bezier(0.17, 0.89, 0.32, 1.49); }
    @@keyframes popIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private bool isSpinning = false;
    private SpinResult? result;
    private double _currentRotation = 0;
    private string _transitionStyle = "none";

    private class SliceInfo {
        public string Label { get; set; } = "";
        public string Color { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Type { get; set; } = "";
        public decimal Value { get; set; }
    }

    private List<SliceInfo> _slices = new() {
        new SliceInfo { Label = "$5.00", Color = "#312e81", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m },
        new SliceInfo { Label = "500 XP", Color = "#1e1b4b", Icon = Icons.Material.Filled.Bolt, Type = "XP", Value = 500m },
        new SliceInfo { Label = "$5.00", Color = "#312e81", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m },
        new SliceInfo { Label = "$50.00", Color = "#7c3aed", Icon = Icons.Material.Filled.EmojiEvents, Type = "BonusCash", Value = 50m },
        new SliceInfo { Label = "500 XP", Color = "#1e1b4b", Icon = Icons.Material.Filled.Bolt, Type = "XP", Value = 500m },
        new SliceInfo { Label = "$5.00", Color = "#312e81", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m },
        new SliceInfo { Label = "500 XP", Color = "#1e1b4b", Icon = Icons.Material.Filled.Bolt, Type = "XP", Value = 500m },
        new SliceInfo { Label = "$5.00", Color = "#312e81", Icon = Icons.Material.Filled.AttachMoney, Type = "BonusCash", Value = 5m }
    };

    private async Task Spin() {
        if (isSpinning) return;
        
        try {
            var response = await Http.PostAsync("api/Game/daily-spin", null);
            if (!response.IsSuccessStatusCode) {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add(error, Severity.Warning);
                MudDialog.Close();
                return;
            }

            result = await response.Content.ReadFromJsonAsync<SpinResult>();
            if (result == null) return;

            // Find matching slice index
            int targetIdx = _slices.FindIndex(s => s.Type == result.Type && s.Value == result.Value);
            if (targetIdx == -1) targetIdx = 0;

            await DoSpinAnimation(targetIdx);
        } catch {
            Snackbar.Add("Error spinning the wheel.", Severity.Error);
        }
    }

    private async Task DoSpinAnimation(int targetIdx) {
        isSpinning = true;
        await Audio.PlaySpin();

        // Animation logic:
        // Slices are 360 / 8 = 45 degrees each.
        // We want the target slice to be at the TOP (where the pointer is).
        // The rotation is clockwise.
        double sliceDeg = 360.0 / _slices.Count;
        
        // Final angle: Multiple full rotations + offset to land on slice
        // Offset = (slices - index) * sliceDeg - (sliceDeg / 2) to center it
        double extraRotations = 5 * 360; 
        double targetAngle = (_slices.Count - targetIdx) * sliceDeg - (sliceDeg / 2);
        
        _currentRotation += extraRotations + (targetAngle - (_currentRotation % 360));
        _transitionStyle = "transform 4s cubic-bezier(0.15, 0, 0.15, 1)";
        
        StateHasChanged();
        await Task.Delay(4000);
        
        isSpinning = false;
        await Audio.PlayWin();
        StateHasChanged();
    }

    public class SpinResult {
        public string Type { get; set; } = "";
        public decimal Value { get; set; }
        public string Message { get; set; } = "";
    }
}