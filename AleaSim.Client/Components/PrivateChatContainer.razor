@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<div class="chat-main-container d-flex flex-column h-100">
    <div class="chat-messages-viewport flex-grow-1 custom-scroll pa-4" id="private-page-chat-box">
        @if (!messages.Any() && !isLoading)
        {
            <div class="d-flex flex-column align-center justify-center h-100 opacity-30 py-12">
                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Style="font-size: 3rem;" class="mb-2" />
                <MudText Typo="Typo.body2">No private messages yet.</MudText>
            </div>
        }
        @foreach (var msg in messages)
        {
            bool isMe = msg.SenderId.Equals(currentUserId);
            <div class='@($"chat-bubble-row mb-4 animate-fade-in {(isMe ? "me" : "others")}")'>
                @if (!isMe)
                {
                    <MudAvatar Size="Size.Small" Class="bubble-avatar shadow-sm">
                        <MudImage Src="@msg.SenderAvatarUrl" />
                    </MudAvatar>
                }
                
                <div class="bubble-content-wrapper">
                    <div class="bubble-payload shadow-md">
                        @if (msg.IsDeleted) {
                            <MudText Typo="Typo.body2" Class="opacity-50 font-italic"><MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Small" Class="mr-1"/>Message deleted</MudText>
                        } else {
                            <MudText Typo="Typo.body2">@msg.Message</MudText>
                            @if (msg.IsEdited) {
                                <MudText Typo="Typo.caption" Class="opacity-50 font-italic d-block mt-1 text-right" Style="font-size: 0.55rem;">(edited)</MudText>
                            }
                        }
                        
                        <div class="d-flex align-center justify-end gap-1 mt-1">
                            <MudText Typo="Typo.caption" Class="bubble-time">@msg.Timestamp.ToString("HH:mm")</MudText>
                            @if (isMe) {
                                <MudIcon Icon="@(msg.IsRead ? Icons.Material.Filled.DoneAll : Icons.Material.Filled.Check)" Size="Size.Small" Class='@($"read-receipt {(msg.IsRead ? "text-info" : "opacity-50")}")' />
                            }
                        </div>
                    </div>
                    
                    @if (isMe && !msg.IsDeleted && (DateTime.UtcNow - msg.Timestamp).TotalMinutes <= 5) {
                        <div class="msg-actions">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => StartEdit(msg)" Class="action-icon-btn" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="() => DeleteMsg(msg.Id)" Class="action-icon-btn" />
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="chat-footer-input pa-3">
        <div class="input-glass-wrap d-flex align-center gap-2 pa-1">
            <MudTextField @bind-Value="newMessage" 
                         Placeholder='@(editingMessageId == null ? $"Message {OtherUserName}..." : "Edit message...")' 
                         Variant="Variant.Text" 
                         Underline="false"
                         OnKeyDown="HandleKeyDown"
                         Immediate="true"
                         Class="chat-input-field flex-grow-1 px-4" />
                         
            @if (editingMessageId != null) {
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Medium" OnClick="CancelEdit" />
            }
            
            <MudIconButton Icon="@(editingMessageId == null ? Icons.Material.Filled.Send : Icons.Material.Filled.Check)" 
                          Color="Color.Primary" 
                          Size="Size.Medium" 
                          OnClick="SendMessage"
                          Disabled="@string.IsNullOrWhiteSpace(newMessage)"
                          Class="send-fab shadow-lg" />
        </div>
    </div>
</div>

<style>
    .chat-main-container { background: transparent; }
    .chat-messages-viewport { overflow-y: auto; overflow-x: hidden; }
    
    .chat-bubble-row { display: flex; align-items: flex-end; gap: 8px; width: 100%; }
    .chat-bubble-row.me { flex-direction: row; justify-content: flex-end; }
    
    .bubble-avatar { border: 2px solid var(--mud-palette-surface); flex-shrink: 0; }
    
    .bubble-content-wrapper { display: flex; flex-direction: column; max-width: 85%; position: relative; }
    .me .bubble-content-wrapper { align-items: flex-end; }
    
    .bubble-payload {
        padding: 8px 12px;
        position: relative;
        word-break: break-word;
        font-size: 0.9rem;
    }

    @@media (max-width: 600px) {
        .bubble-content-wrapper { max-width: 90%; }
        .bubble-payload { padding: 6px 10px; font-size: 0.85rem; }
        .chat-footer-input { padding: 8px !important; }
    }
    
    .others .bubble-payload {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 18px 18px 18px 4px;
        color: var(--mud-palette-text-primary);
    }
    
    .me .bubble-payload {
        background: var(--mud-palette-primary);
        border-radius: 18px 18px 4px 18px;
        color: white;
    }
    
    .bubble-time { font-size: 0.6rem; opacity: 0.6; }
    .me .bubble-time { color: rgba(255,255,255,0.8); }
    
    .read-receipt { font-size: 0.8rem; margin-left: 2px; }
    .text-info { color: #2196f3 !important; }

    .msg-actions { 
        display: flex; gap: 2px; opacity: 0; transition: 0.2s; position: absolute; 
        bottom: -24px; right: 0; background: var(--mud-palette-surface); border-radius: 12px; padding: 2px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1); border: 1px solid var(--mud-palette-divider);
    }
    .chat-bubble-row:hover .msg-actions { opacity: 1; z-index: 10; }
    .action-icon-btn { padding: 4px; }

    .input-glass-wrap {
        background: var(--mud-palette-background-grey);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 30px;
        transition: all 0.3s ease;
    }
    .input-glass-wrap:focus-within {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 15px rgba(124, 58, 237, 0.2);
    }
    
    .send-fab {
        background: var(--mud-palette-primary) !important;
        color: white !important;
        width: 40px; height: 40px;
    }
    .send-fab:disabled { background: var(--mud-palette-action-disabled) !important; }

    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
    
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    [Parameter] public Guid OtherUserId { get; set; }
    [Parameter] public string OtherUserName { get; set; } = "";

    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private Guid? editingMessageId;
    private Guid currentUserId;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (idClaim != null) currentUserId = Guid.Parse(idClaim.Value);

        RealTime.OnPrivateMessageReceived += HandlePrivateMessage;
        RealTime.OnMessageDeleted += HandleMessageDeleted;
        RealTime.OnMessageEdited += HandleMessageEdited;
        await LoadHistory();
    }

    protected override async Task OnParametersSetAsync() {
        await LoadHistory();
    }

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessageDto>>($"api/Chat/private/{OtherUserId}");
            if (history != null) {
                messages = history;
                _ = ScrollToBottom();
            }
            // Mark as read
            await Http.PostAsync($"api/Chat/private/{OtherUserId}/read", null);
        } catch { }
        finally { isLoading = false; }
    }

    private void HandlePrivateMessage(string user, string msg, DateTime time, string avatar, Guid senderId, Guid messageId) {
        if (senderId == OtherUserId || senderId == currentUserId) {
            messages.Add(new ChatMessageDto {
                Id = messageId,
                SenderUsername = user,
                Message = msg,
                Timestamp = time,
                SenderAvatarUrl = avatar,
                SenderId = senderId,
                IsRead = senderId == OtherUserId // Auto-read if we are viewing
            });
            
            if (senderId == OtherUserId) {
                // Mark as read since we are actively viewing
                _ = Http.PostAsync($"api/Chat/private/{OtherUserId}/read", null);
            }
            
            InvokeAsync(async () => {
                StateHasChanged();
                await ScrollToBottom();
            });
        }
    }

    private void HandleMessageDeleted(Guid msgId) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.IsDeleted = true;
            m.Message = "[Message Deleted]";
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleMessageEdited(Guid msgId, string newText) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.Message = newText;
            m.IsEdited = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void StartEdit(ChatMessageDto msg) {
        editingMessageId = msg.Id;
        newMessage = msg.Message;
    }

    private void CancelEdit() {
        editingMessageId = null;
        newMessage = "";
    }

    private async Task DeleteMsg(Guid msgId) {
        await RealTime.DeleteChatMessage(msgId);
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msgText = newMessage;
        newMessage = "";
        
        if (editingMessageId != null) {
            var id = editingMessageId.Value;
            editingMessageId = null;
            await RealTime.EditChatMessage(id, msgText);
        } else {
            await RealTime.SendPrivateMessage(OtherUserId, msgText);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") _ = SendMessage();
    }

    private async Task ScrollToBottom() {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "private-page-chat-box");
    }

    public void Dispose() {
        RealTime.OnPrivateMessageReceived -= HandlePrivateMessage;
        RealTime.OnMessageDeleted -= HandleMessageDeleted;
        RealTime.OnMessageEdited -= HandleMessageEdited;
    }
}
