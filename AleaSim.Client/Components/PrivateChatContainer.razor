@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<div class="emergency-chat-root">
    <div class="emergency-chat-viewport custom-scroll" id="private-page-chat-box">
        @if (!messages.Any() && !isLoading)
        {
            <div class="no-messages-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.Chat" Style="font-size: 4rem;" />
                <MudText Typo="Typo.h6">NO TRANSMISSIONS</MudText>
            </div>
        }
        
        @foreach (var msg in messages)
        {
            bool isMe = msg.SenderId == effectiveUserId || msg.SenderUsername == "Me" || msg.SenderUsername == effectiveUsername;
            
            <div class='@($"bubble-row-outer {(isMe ? "me" : "others")}")'>
                <div class="avatar-col">
                    <MudAvatar Size="Size.Small" Class="bubble-avatar shadow-sm">
                        <MudImage Src="@(isMe ? (CurrentAvatarUrl ?? "https://api.dicebear.com/7.x/bottts/svg?seed=" + effectiveUserId) : msg.SenderAvatarUrl)" />
                    </MudAvatar>
                </div>
                
                <div class="content-col">
                    <div class="bubble-payload-wrap">
                        <div class="bubble-payload">
                            @if (msg.IsDeleted) {
                                <MudText Typo="Typo.body2" Style="font-style: italic; opacity: 0.6;">[Purged Message]</MudText>
                            } else {
                                <MudText Typo="Typo.body2">@msg.Message</MudText>
                                @if (msg.IsEdited) {
                                    <span class="edited-flag">(edited)</span>
                                }
                            }
                            
                            <div class="bubble-meta">
                                <span>@msg.Timestamp.ToString("HH:mm")</span>
                                @if (isMe) {
                                    <MudIcon Icon="@(msg.IsRead ? Icons.Material.Filled.DoneAll : Icons.Material.Filled.Check)" Size="Size.Small" Class="read-indicator" Style='@($"color: {(msg.IsRead ? "#00ffcc" : "rgba(255,255,255,0.4)")} !important;")' />
                                }
                            </div>
                        </div>
                        
                        @if (isMe && !msg.IsDeleted) {
                            <div class="msg-actions">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight">
                                    <MudMenuItem OnClick="() => StartEdit(msg)" Icon="@Icons.Material.Filled.Edit">Edit</MudMenuItem>
                                    <MudMenuItem OnClick="() => DeleteMsg(msg.Id)" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
                                </MudMenu>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="emergency-chat-footer">
        <div class="emergency-input-wrap">
            <MudTextField @bind-Value="newMessage" 
                         Placeholder="@(editingMessageId != null ? "Updating transmission..." : "Enter command...")" 
                         Variant="Variant.Text" 
                         Underline="false"
                         OnKeyDown="HandleKeyDown"
                         Immediate="true"
                         Class="flex-grow-1 px-4 chat-input" />
                         
            @if (editingMessageId != null) {
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="CancelEdit" />
            }
            
            <MudIconButton Icon="@(editingMessageId == null ? Icons.Material.Filled.Send : Icons.Material.Filled.Check)" 
                          Color="Color.Primary" 
                          OnClick="SendMessage"
                          Disabled="@string.IsNullOrWhiteSpace(newMessage)"
                          Class="send-btn" />
        </div>
    </div>
</div>

<style>
    .emergency-chat-root {
        display: flex;
        flex-direction: column;
        height: 100%;
        width: 100%;
        background: transparent;
        overflow: hidden;
    }

    .emergency-chat-viewport {
        flex-grow: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
    }

    .no-messages-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        opacity: 0.1;
    }

    .bubble-row-outer { 
        display: flex; 
        align-items: flex-end; 
        gap: 12px; 
        margin-bottom: 24px; 
        width: 100%; 
    }
    
    .bubble-row-outer.me { flex-direction: row-reverse; }
    
    .avatar-col { flex-shrink: 0; }
    .bubble-avatar { border: 2px solid rgba(255,255,255,0.1); }
    .me .bubble-avatar { border-color: #7c3aed; }

    .content-col { 
        display: flex; 
        flex-direction: column; 
        max-width: 80%; 
    }
    .me .content-col { align-items: flex-end; }
    .others .content-col { align-items: flex-start; }

    .bubble-payload-wrap { display: flex; align-items: center; gap: 4px; }
    .me .bubble-payload-wrap { flex-direction: row-reverse; }

    .bubble-payload {
        padding: 12px 16px;
        position: relative;
        word-break: break-word;
        font-size: 0.95rem;
    }

    .others .bubble-payload {
        background: #f1f5f9;
        color: #1e293b;
        border-radius: 20px 20px 20px 2px;
    }
    
    .me .bubble-payload {
        background: #7c3aed;
        color: white;
        border-radius: 20px 20px 2px 20px;
    }

    .bubble-meta { 
        display: flex; 
        align-items: center; 
        justify-content: flex-end; 
        gap: 4px; 
        margin-top: 4px; 
        font-size: 0.65rem; 
        opacity: 0.7; 
    }
    
    .edited-flag { font-size: 0.6rem; opacity: 0.5; margin-left: 4px; }
    .read-indicator { font-size: 1rem !important; }

    .msg-actions { opacity: 0; transition: opacity 0.2s; }
    .bubble-row-outer:hover .msg-actions { opacity: 1; }

    .emergency-chat-footer {
        padding: 20px;
        flex-shrink: 0;
    }

    .emergency-input-wrap {
        display: flex;
        align-items: center;
        background: rgba(30, 41, 59, 0.7);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 100px;
        backdrop-filter: blur(20px);
        padding: 4px;
    }
    
    .chat-input { color: white !important; }

    .send-btn {
        background: #7c3aed !important;
        color: white !important;
        margin: 4px;
        border-radius: 50% !important;
        width: 42px;
        height: 42px;
    }

    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
</style>

@code {
    [Parameter] public Guid OtherUserId { get; set; }
    [Parameter] public string OtherUserName { get; set; } = "";
    [Parameter] public Guid CurrentUserId { get; set; }
    [Parameter] public string? CurrentAvatarUrl { get; set; }

    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private string effectiveUsername = "";
    private Guid effectiveUserId;
    private Guid? editingMessageId;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        effectiveUsername = authState.User.Identity?.Name ?? "";
        effectiveUserId = CurrentUserId != Guid.Empty ? CurrentUserId : 
            (Guid.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty);
        
        RealTime.OnPrivateMessageReceived += HandlePrivateMessage;
        RealTime.OnMessageDeleted += HandleMessageDeleted;
        RealTime.OnMessageEdited += HandleMessageEdited;
        await LoadHistory();
    }

    protected override async Task OnParametersSetAsync() {
        await LoadHistory();
    }

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessageDto>>($"api/Chat/private/{OtherUserId}");
            if (history != null) {
                messages = history;
                _ = ScrollToBottom();
            }
        } catch { }
        finally { isLoading = false; }
    }

    private void HandlePrivateMessage(string user, string msg, DateTime time, string avatar, Guid senderId, Guid messageId) {
        if (senderId == OtherUserId || senderId == effectiveUserId) {
            // Check for optimistic duplicate
            var opt = messages.FirstOrDefault(m => m.Id == messageId || ((m.SenderId == effectiveUserId || m.SenderUsername == "Me") && m.Message == msg && Math.Abs((m.Timestamp - time).TotalSeconds) < 5));
            if (opt != null) {
                opt.Id = messageId;
                opt.SenderUsername = user;
                opt.SenderAvatarUrl = avatar;
                opt.Timestamp = time;
                opt.SenderId = senderId;
                InvokeAsync(StateHasChanged);
                return;
            }

            messages.Add(new ChatMessageDto {
                Id = messageId,
                SenderUsername = user,
                Message = msg,
                Timestamp = time,
                SenderAvatarUrl = avatar,
                SenderId = senderId,
                IsRead = senderId == OtherUserId
            });
            
            InvokeAsync(async () => {
                StateHasChanged();
                await ScrollToBottom();
            });
        }
    }

    private void HandleMessageDeleted(Guid msgId) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.IsDeleted = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleMessageEdited(Guid msgId, string newText) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.Message = newText;
            m.IsEdited = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void StartEdit(ChatMessageDto msg) {
        editingMessageId = msg.Id;
        newMessage = msg.Message;
    }

    private void CancelEdit() {
        editingMessageId = null;
        newMessage = "";
    }

    private async Task DeleteMsg(Guid msgId) {
        await RealTime.DeleteChatMessage(msgId);
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msgText = newMessage;
        newMessage = "";
        
        if (editingMessageId != null) {
            var id = editingMessageId.Value;
            editingMessageId = null;
            await RealTime.EditChatMessage(id, msgText);
        } else {
            // Optimistic update
            var tempId = Guid.NewGuid();
            messages.Add(new ChatMessageDto {
                Id = tempId,
                SenderId = effectiveUserId,
                SenderUsername = "Me",
                Message = msgText,
                Timestamp = DateTime.UtcNow,
                SenderAvatarUrl = ""
            });
            StateHasChanged();
            await ScrollToBottom();
            
            await RealTime.SendPrivateMessage(OtherUserId, msgText);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") _ = SendMessage();
        if (e.Key == "Escape" && editingMessageId != null) CancelEdit();
    }

    private async Task ScrollToBottom() {
        await Task.Delay(150);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "private-page-chat-box");
    }

    public void Dispose() {
        RealTime.OnPrivateMessageReceived -= HandlePrivateMessage;
        RealTime.OnMessageDeleted -= HandleMessageDeleted;
        RealTime.OnMessageEdited -= HandleMessageEdited;
    }
}
