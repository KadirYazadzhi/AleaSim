@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@inject RealTimeClient RealTime
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<div class="chat-main-container d-flex flex-column h-100">
    <div class="chat-messages-viewport flex-grow-1 custom-scroll pa-4" id="private-page-chat-box">
        @if (!messages.Any() && !isLoading)
        {
            <div class="d-flex flex-column align-center justify-center h-100 opacity-30 py-12">
                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Style="font-size: 3rem;" class="mb-2" />
                <MudText Typo="Typo.body2">No private messages yet.</MudText>
            </div>
        }
        @foreach (var msg in messages)
        {
            // MEGA-FAILSAFE ME IDENTIFICATION
            bool isMe = msg.SenderId == CurrentUserId || 
                        (msg.SenderUsername != null && (msg.SenderUsername.Equals("Me", StringComparison.OrdinalIgnoreCase) || msg.SenderUsername.Equals(currentUsername, StringComparison.OrdinalIgnoreCase)));
            
            <div class='@($"chat-bubble-row mb-6 animate-fade-in {(isMe ? "me-aligned" : "others-aligned")}")' 
                 style='@(isMe ? "justify-content: flex-end !important;" : "justify-content: flex-start !important;")'>
                
                @if (!isMe)
                {
                    <MudAvatar Size="Size.Small" Class="bubble-avatar shadow-sm">
                        <MudImage Src="@msg.SenderAvatarUrl" />
                    </MudAvatar>
                }
                
                <div class="bubble-content-wrapper" style='@(isMe ? "align-items: flex-end !important;" : "align-items: flex-start !important;")'>
                    <div class="bubble-payload shadow-md" style='@(isMe ? "background: #7c3aed !important; color: white !important; border-radius: 20px 20px 4px 20px !important;" : "background: rgba(255,255,255,0.9) !important; color: #111 !important; border-radius: 20px 20px 20px 4px !important;")'>
                        @if (msg.IsDeleted) {
                            <MudText Typo="Typo.body2" Class="opacity-50 font-italic" Style="color: inherit !important;">Message deleted</MudText>
                        } else {
                            <MudText Typo="Typo.body2" Style="color: inherit !important;">@msg.Message</MudText>
                            @if (msg.IsEdited) {
                                <MudText Typo="Typo.caption" Class="opacity-50 font-italic d-block mt-1 text-right" Style="font-size: 0.55rem; color: inherit !important;">(edited)</MudText>
                            }
                        }
                        
                        <div class="d-flex align-center justify-end gap-1 mt-1">
                            <MudText Typo="Typo.caption" Class="bubble-time" Style="color: inherit !important; opacity: 0.7;">@msg.Timestamp.ToString("HH:mm")</MudText>
                            @if (isMe) {
                                <MudIcon Icon="@(msg.IsRead ? Icons.Material.Filled.DoneAll : Icons.Material.Filled.Check)" Size="Size.Small" Style='@($"color: {(msg.IsRead ? "#00ffcc" : "rgba(255,255,255,0.5)")} !important;")' />
                            }
                        </div>
                    </div>
                    
                    @if (isMe && !msg.IsDeleted && (DateTime.UtcNow - msg.Timestamp).TotalMinutes <= 15) {
                        <div class="msg-actions-static">
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Class="ma-0">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="() => StartEdit(msg)">Edit</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="() => DeleteMsg(msg.Id)" IconColor="Color.Error">Delete</MudMenuItem>
                            </MudMenu>
                        </div>
                    }
                </div>

                @if (isMe)
                {
                    <MudAvatar Size="Size.Small" Class="bubble-avatar shadow-sm">
                        <MudImage Src="@(currentAvatarUrl ?? "https://api.dicebear.com/7.x/bottts/svg?seed=" + currentUsername)" />
                    </MudAvatar>
                }
            </div>
        }
    </div>

    <div class="chat-footer-input pa-4">
        <div class="input-glass-wrap d-flex align-center gap-2 pa-1">
            <MudTextField @bind-Value="newMessage" 
                         Placeholder='@(editingMessageId == null ? $"Message {OtherUserName}..." : "Edit message...")' 
                         Variant="Variant.Text" 
                         Underline="false"
                         OnKeyDown="HandleKeyDown"
                         Immediate="true"
                         Class="chat-input-field flex-grow-1 px-4" />
                         
            @if (editingMessageId != null) {
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Medium" OnClick="CancelEdit" />
            }
            
            <MudIconButton Icon="@(editingMessageId == null ? Icons.Material.Filled.Send : Icons.Material.Filled.Check)" 
                          Color="Color.Primary" 
                          Size="Size.Medium" 
                          OnClick="SendMessage"
                          Disabled="@string.IsNullOrWhiteSpace(newMessage)"
                          Class="send-fab shadow-lg" />
        </div>
    </div>
</div>

<style>
    .chat-main-container { background: transparent; }
    .chat-messages-viewport { overflow-y: auto; overflow-x: hidden; }
    
    .chat-bubble-row { display: flex; width: 100%; position: relative; margin-bottom: 24px; align-items: flex-end; }
    
    .bubble-avatar { border: 2px solid var(--mud-palette-surface); flex-shrink: 0; margin: 0 8px; }
    .bubble-content-wrapper { display: flex; flex-direction: column; max-width: 75%; position: relative; }
    
    .bubble-payload { padding: 10px 16px; position: relative; word-break: break-word; font-size: 0.95rem; }

    .msg-actions-static { position: absolute; bottom: 0; opacity: 0.3; transition: opacity 0.2s; }
    .me-aligned .msg-actions-static { right: 100%; margin-right: 8px; }
    .others-aligned .msg-actions-static { left: 100%; margin-left: 8px; }
    .chat-bubble-row:hover .msg-actions-static { opacity: 1; }

    .input-glass-wrap {
        background: rgba(var(--mud-palette-surface-rgb), 0.5);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 30px;
        transition: all 0.3s ease;
        backdrop-filter: blur(15px);
    }
    
    .send-fab { background: var(--mud-palette-primary) !important; color: white !important; width: 44px; height: 44px; }
    .custom-scroll::-webkit-scrollbar { width: 6px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    [Parameter] public Guid OtherUserId { get; set; }
    [Parameter] public string OtherUserName { get; set; } = "";
    [Parameter] public Guid CurrentUserId { get; set; }

    private List<ChatMessageDto> messages = new();
    private string newMessage = "";
    private string currentUsername = "";
    private string? currentAvatarUrl;
    private Guid? editingMessageId;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name ?? "";
        
        RealTime.OnPrivateMessageReceived += HandlePrivateMessage;
        RealTime.OnMessageDeleted += HandleMessageDeleted;
        RealTime.OnMessageEdited += HandleMessageEdited;
        await LoadHistory();
    }

    protected override async Task OnParametersSetAsync() {
        await LoadHistory();
    }

    private async Task LoadHistory() {
        try {
            var history = await Http.GetFromJsonAsync<List<ChatMessageDto>>($"api/Chat/private/{OtherUserId}");
            if (history != null) {
                messages = history;
                _ = ScrollToBottom();
            }
            await Http.PostAsync($"api/Chat/private/{OtherUserId}/read", null);
        } catch { }
        finally { isLoading = false; }
    }

    private void HandlePrivateMessage(string user, string msg, DateTime time, string avatar, Guid senderId, Guid messageId) {
        if (senderId == OtherUserId || senderId == CurrentUserId) {
            // Check for optimistic duplicate
            var opt = messages.FirstOrDefault(m => (m.SenderId == CurrentUserId) && m.Message == msg && Math.Abs((m.Timestamp - time).TotalSeconds) < 5);
            if (opt != null) {
                opt.Id = messageId;
                opt.SenderUsername = user;
                opt.SenderAvatarUrl = avatar;
                opt.Timestamp = time;
                opt.SenderId = senderId;
                InvokeAsync(StateHasChanged);
                return;
            }

            messages.Add(new ChatMessageDto {
                Id = messageId,
                SenderUsername = user,
                Message = msg,
                Timestamp = time,
                SenderAvatarUrl = avatar,
                SenderId = senderId,
                IsRead = senderId == OtherUserId
            });
            
            if (senderId == OtherUserId) _ = Http.PostAsync($"api/Chat/private/{OtherUserId}/read", null);
            
            InvokeAsync(async () => {
                StateHasChanged();
                await ScrollToBottom();
            });
        }
    }

    private void HandleMessageDeleted(Guid msgId) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.IsDeleted = true;
            m.Message = "[Message Deleted]";
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleMessageEdited(Guid msgId, string newText) {
        var m = messages.FirstOrDefault(x => x.Id == msgId);
        if (m != null) {
            m.Message = newText;
            m.IsEdited = true;
            InvokeAsync(StateHasChanged);
        }
    }

    private void StartEdit(ChatMessageDto msg) {
        editingMessageId = msg.Id;
        newMessage = msg.Message;
    }

    private void CancelEdit() {
        editingMessageId = null;
        newMessage = "";
    }

    private async Task DeleteMsg(Guid msgId) {
        await RealTime.DeleteChatMessage(msgId);
    }

    private async Task SendMessage() {
        if (string.IsNullOrWhiteSpace(newMessage)) return;
        var msgText = newMessage;
        newMessage = "";
        
        if (editingMessageId != null) {
            var id = editingMessageId.Value;
            editingMessageId = null;
            await RealTime.EditChatMessage(id, msgText);
        } else {
            // Optimistic update
            var temp = new ChatMessageDto {
                Id = Guid.NewGuid(),
                SenderId = CurrentUserId,
                SenderUsername = currentUsername,
                Message = msgText,
                Timestamp = DateTime.UtcNow,
                SenderAvatarUrl = ""
            };
            messages.Add(temp);
            StateHasChanged();
            await ScrollToBottom();
            
            await RealTime.SendPrivateMessage(OtherUserId, msgText);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") _ = SendMessage();
    }

    private async Task ScrollToBottom() {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("aleaChat.scrollToBottom", "private-page-chat-box");
    }

    public void Dispose() {
        RealTime.OnPrivateMessageReceived -= HandlePrivateMessage;
        RealTime.OnMessageDeleted -= HandleMessageDeleted;
        RealTime.OnMessageEdited -= HandleMessageEdited;
    }
}
