@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@implements IDisposable
@inject RealTimeClient RealTime
@inject LayoutService LayoutService
@inject HttpClient Http

<div class='@($"jackpot-stack {(FullGridMode ? "grid-mode" : "")}")'>
    <!-- MEGA JACKPOT CARD -->
    <div class="jackpot-card mega-card animate-pulse-slow">
        <div class="card-overlay"></div>
        <div class="card-content">
            <div class="icon-section">
                <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Large" class="jackpot-icon mega-gold" />
                <span class="suit-bg">♠</span>
            </div>
            <div class="info-section">
                <div class="d-flex align-center gap-1">
                    <MudText Typo="Typo.caption" Class="jackpot-label ma-0">MEGA JACKPOT</MudText>
                    <MudTooltip Text="The ultimate prize! Accumulates from every spin across the platform. Can be won in any original game.">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="info-icon-tweak" />
                    </MudTooltip>
                </div>
                <MudText Typo="Typo.h4" Class='@($"jackpot-value mega-text {(FullGridMode ? "text-compact" : "")}")'>@spades.ToString("C2")</MudText>
            </div>
        </div>
        <div class="card-footer">
            <div class="progress-bar-container">
                <div class="progress-bar mega-bg" style="width: 85%;"></div>
            </div>
        </div>
    </div>

    <!-- MAJOR JACKPOT CARD -->
    <div class="jackpot-card major-card animate-glow-red">
        <div class="card-overlay"></div>
        <div class="card-content">
            <div class="icon-section">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Size="Size.Large" class="jackpot-icon major-red" />
                <span class="suit-bg">♥</span>
            </div>
            <div class="info-section">
                <div class="d-flex align-center gap-1">
                    <MudText Typo="Typo.caption" Class="jackpot-label ma-0">MAJOR WEEKLY</MudText>
                    <MudTooltip Text="A massive weekly reward! Grows every second and is guaranteed to drop to one lucky player every Sunday.">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="info-icon-tweak" />
                    </MudTooltip>
                </div>
                <MudText Typo="Typo.h4" Class='@($"jackpot-value major-text {(FullGridMode ? "text-compact" : "")}")'>@hearts.ToString("C2")</MudText>
            </div>
        </div>
        <div class="card-footer">
            <div class="progress-bar-container">
                <div class="progress-bar major-bg" style="width: 60%;"></div>
            </div>
        </div>
    </div>
    
    @if (FullGridMode)
    {
        <!-- MINOR JACKPOT CARD -->
        <div class="jackpot-card minor-card">
            <div class="card-overlay"></div>
            <div class="card-content">
                <div class="icon-section">
                    <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Size="Size.Large" class="jackpot-icon minor-blue" />
                    <span class="suit-bg">♦</span>
                </div>
                <div class="info-section">
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.caption" Class="jackpot-label ma-0">MINOR DAILY</MudText>
                        <MudTooltip Text="Daily prize pool. Drops every 24 hours to a random active player. Higher bets increase your chances!">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="info-icon-tweak" />
                        </MudTooltip>
                    </div>
                    <MudText Typo="Typo.h4" Class="jackpot-value minor-text text-compact">@GetMinorValue().ToString("C2")</MudText>
                </div>
            </div>
            <div class="card-footer">
                <div class="progress-bar-container">
                    <div class="progress-bar minor-bg" style="width: 45%;"></div>
                </div>
            </div>
        </div>

        <!-- MINI JACKPOT CARD -->
        <div class="jackpot-card mini-card">
            <div class="card-overlay"></div>
            <div class="card-content">
                <div class="icon-section">
                    <MudIcon Icon="@Icons.Material.Filled.Stars" Size="Size.Large" class="jackpot-icon mini-green" />
                    <span class="suit-bg">♣</span>
                </div>
                <div class="info-section">
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.caption" Class="jackpot-label ma-0">MINI HOURLY</MudText>
                        <MudTooltip Text="Fast-paced hourly jackpot! Drops 24 times a day. Perfect for consistent players.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="info-icon-tweak" />
                        </MudTooltip>
                    </div>
                    <MudText Typo="Typo.h4" Class="jackpot-value mini-text text-compact">@GetMiniValue().ToString("C2")</MudText>
                </div>
            </div>
            <div class="card-footer">
                <div class="progress-bar-container">
                    <div class="progress-bar mini-bg" style="width: 30%;"></div>
                </div>
            </div>
        </div>
    }
    else if (!SimpleMode)
    {
        <div class="mini-jackpots-grid mt-2">
            <div class="mini-jackpot diamond-border">
                <span class="mini-suit">♦</span>
                <span class="mini-val">@GetMinorValue().ToString("C0")</span>
            </div>
            <div class="mini-jackpot club-border">
                <span class="mini-suit">♣</span>
                <span class="mini-val">@GetMiniValue().ToString("C0")</span>
            </div>
        </div>
    }
</div>

<style>
    .jackpot-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 4px;
    }

    .jackpot-stack.grid-mode {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .jackpot-card {
        position: relative;
        height: 100px;
        border-radius: 16px;
        overflow: hidden;
        background: #0f172a;
        border: 1px solid rgba(255,255,255,0.1);
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: 0 10px 20px rgba(0,0,0,0.4);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer !important;
    }

    .grid-mode .jackpot-card {
        height: 85px; /* Slightly shorter for grid */
    }

    .jackpot-card:hover {
        transform: scale(1.03) translateY(-2px);
        z-index: 10;
    }

    .card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(45deg, rgba(0,0,0,0.7) 0%, transparent 100%);
        z-index: 1;
    }

    .card-content {
        position: relative;
        z-index: 2;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .grid-mode .card-content {
        padding: 10px 15px;
        gap: 12px;
    }

    .icon-section {
        position: relative;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .grid-mode .icon-section {
        width: 40px;
        height: 40px;
    }

    .suit-bg {
        position: absolute;
        font-size: 3.5rem;
        opacity: 0.1;
        font-weight: 900;
        z-index: 0;
    }

    .grid-mode .suit-bg {
        font-size: 2.5rem;
    }

    .jackpot-icon {
        font-size: 2.5rem !important;
        z-index: 1;
        filter: drop-shadow(0 0 8px currentColor);
    }

    .grid-mode .jackpot-icon {
        font-size: 2rem !important;
    }

    .info-section {
        display: flex;
        flex-direction: column;
    }

    .jackpot-label {
        font-weight: 900;
        letter-spacing: 2px;
        opacity: 0.7;
        color: #fff;
        font-size: 0.7rem !important;
        line-height: 0.7rem !important;
        margin: 0 !important;
        display: inline-block;
        vertical-align: middle;
    }

    .info-icon-tweak {
        font-size: 0.7rem !important;
        opacity: 0.5;
        cursor: help;
        display: inline-block !important;
        vertical-align: middle;
        margin-left: 2px;
    }

    .jackpot-value {
        font-weight: 900;
        font-family: 'Rajdhani', sans-serif;
        letter-spacing: -1px;
    }

    .text-compact {
        font-size: 1.5rem !important;
    }

    .card-footer {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: rgba(255,255,255,0.05);
    }

    .progress-bar-container { width: 100%; height: 100%; }
    .progress-bar { height: 100%; transition: width 1s ease-in-out; }

    /* Themes */
    .mega-card { background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%); border-color: rgba(212, 175, 55, 0.3); }
    .mega-gold { color: #fbbf24; }
    .mega-text { color: #fbbf24; text-shadow: 0 0 15px rgba(251, 191, 36, 0.5); }
    .mega-bg { background: #fbbf24; box-shadow: 0 0 10px #fbbf24; }

    .major-card { background: linear-gradient(135deg, #450a0a 0%, #991b1b 100%); border-color: rgba(239, 68, 68, 0.3); }
    .major-red { color: #ef4444; }
    .major-text { color: #fff; text-shadow: 0 0 15px rgba(239, 68, 68, 0.5); }
    .major-bg { background: #ef4444; box-shadow: 0 0 10px #ef4444; }

    .minor-card { background: linear-gradient(135deg, #0c4a6e 0%, #0369a1 100%); border-color: rgba(59, 130, 246, 0.3); }
    .minor-blue { color: #3b82f6; }
    .minor-text { color: #fff; text-shadow: 0 0 15px rgba(59, 130, 246, 0.5); }
    .minor-bg { background: #3b82f6; box-shadow: 0 0 10px #3b82f6; }

    .mini-card { background: linear-gradient(135deg, #064e3b 0%, #047857 100%); border-color: rgba(34, 197, 94, 0.3); }
    .mini-green { color: #22c55e; }
    .mini-text { color: #fff; text-shadow: 0 0 15px rgba(34, 197, 94, 0.5); }
    .mini-bg { background: #22c55e; box-shadow: 0 0 10px #22c55e; }

    /* Mini Grid */
    .mini-jackpots-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .mini-jackpot {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 8px;
        padding: 6px 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .mini-suit { font-weight: 900; font-size: 1.1rem; }
    .mini-val { font-weight: 800; font-size: 0.85rem; color: #94a3b8; }

    .diamond-border { border-left: 3px solid #3b82f6; .mini-suit { color: #3b82f6; } }
    .club-border { border-left: 3px solid #22c55e; .mini-suit { color: #22c55e; } }

    /* Animations */
    .animate-pulse-slow { animation: pulseSlow 4s infinite; }
    @@keyframes pulseSlow {
        0%, 100% { box-shadow: 0 10px 20px rgba(0,0,0,0.4); }
        50% { box-shadow: 0 10px 30px rgba(251, 191, 36, 0.2); }
    }

    .animate-glow-red { animation: glowRed 3s infinite; }
    @@keyframes glowRed {
        0%, 100% { border-color: rgba(239, 68, 68, 0.3); }
        50% { border-color: rgba(239, 68, 68, 0.8); }
    }
</style>

@code {
    [Parameter] public bool SimpleMode { get; set; } = false;
    [Parameter] public bool FullGridMode { get; set; } = false;
    [Parameter] public decimal Denomination { get; set; } = 0.01m;

    private decimal spades = 10000m;
    private decimal hearts = 2500m;

    protected override async Task OnInitializedAsync() {
        RealTime.OnJackpotUpdated += HandleUpdate;
        LayoutService.OnMajorUpdate += StateHasChanged;
        
        await LoadInitialJackpots();
    }

    private async Task LoadInitialJackpots() {
        try {
            var jackpots = await Http.GetFromJsonAsync<List<JackpotDto>>("api/Game/jackpots");
            if (jackpots != null) {
                foreach (var j in jackpots) {
                    UpdateLocalValue(j);
                }
                StateHasChanged();
            }
        } catch { /* Fail silently, keep defaults */ }
    }

    private void HandleUpdate(JackpotDto dto) {
        UpdateLocalValue(dto);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateLocalValue(JackpotDto dto) {
        if (dto.Tier == "Spades") spades = dto.CurrentValue;
        else if (dto.Tier == "Hearts") hearts = dto.CurrentValue;
        else if (dto.Name.Contains("Spades")) spades = dto.CurrentValue;
        else if (dto.Name.Contains("Hearts")) hearts = dto.CurrentValue;
    }

    private decimal GetMinorValue() => Denomination * 5000;
    private decimal GetMiniValue() => Denomination * 1000;

    public void Dispose() {
        RealTime.OnJackpotUpdated -= HandleUpdate;
        LayoutService.OnMajorUpdate -= StateHasChanged;
    }
}