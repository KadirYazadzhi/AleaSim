@using AleaSim.Shared.Models
@using AleaSim.Client.Services
@implements IDisposable
@inject RealTimeClient RealTime
@inject LayoutService LayoutService
@inject HttpClient Http

<div class="jackpot-container">
    <div class="jackpot-row spades">
        <div class="suit">♠</div>
        <div class="name">MEGA</div>
        <div class="value">@spades.ToString("C2")</div>
    </div>
    <div class="jackpot-row hearts">
        <div class="suit">♥</div>
        <div class="name">MAJOR</div>
        <div class="value">@hearts.ToString("C2")</div>
    </div>
    
    @if (!SimpleMode)
    {
        <div class="jackpot-row diamonds">
            <div class="suit">♦</div>
            <div class="name">MINOR</div>
            <div class="value">@((Denomination * 5000).ToString("C2"))</div>
        </div>
        <div class="jackpot-row clubs">
            <div class="suit">♣</div>
            <div class="name">MINI</div>
            <div class="value">@((Denomination * 1000).ToString("C2"))</div>
        </div>
    }
</div>

<style>
    .jackpot-container {
        background: transparent;
        border: 2px solid var(--mud-palette-warning);
        border-radius: 12px;
        padding: 12px;
        color: var(--mud-palette-text-primary);
        font-family: 'Courier New', Courier, monospace;
        box-shadow: 0 0 20px rgba(255, 152, 0, 0.1);
    }
    .jackpot-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 12px;
        margin-bottom: 4px;
        background: rgba(124, 58, 237, 0.05);
        border-radius: 8px;
        align-items: center;
        transition: transform 0.2s ease;
    }
    .jackpot-row:hover { transform: scale(1.02); background: rgba(124, 58, 237, 0.1); }
    .suit { font-size: 1.8rem; width: 35px; line-height: 1; }
    .name { flex-grow: 1; text-align: left; margin-left: 10px; font-weight: 900; font-size: 0.9rem; letter-spacing: 1px; color: var(--mud-palette-text-secondary); }
    .value { font-weight: 900; font-size: 1.3rem; color: var(--mud-palette-warning); text-shadow: 0 0 10px rgba(255, 152, 0, 0.3); }
    
    .spades { border-left: 5px solid var(--mud-palette-text-primary); }
    .hearts { border-left: 5px solid #ff1744; .suit { color: #ff1744; } }
    .diamonds { border-left: 5px solid #2979ff; .suit { color: #2979ff; } }
    .clubs { border-left: 5px solid #00e676; .suit { color: #00e676; } }
</style>

@code {
    [Parameter] public bool SimpleMode { get; set; } = false;
    [Parameter] public decimal Denomination { get; set; } = 0.01m;

    private decimal spades = 10000m;
    private decimal hearts = 2500m;
    private decimal diamonds = 500m;
    private decimal clubs = 50m;

    protected override async Task OnInitializedAsync() {
        RealTime.OnJackpotUpdated += HandleUpdate;
        LayoutService.OnMajorUpdate += StateHasChanged;
        
        await LoadInitialJackpots();
    }

    private async Task LoadInitialJackpots() {
        try {
            var jackpots = await Http.GetFromJsonAsync<List<JackpotDto>>("api/Game/jackpots");
            if (jackpots != null) {
                foreach (var j in jackpots) {
                    UpdateLocalValue(j);
                }
                StateHasChanged();
            }
        } catch { /* Fail silently, keep defaults */ }
    }

    private void HandleUpdate(JackpotDto dto) {
        UpdateLocalValue(dto);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateLocalValue(JackpotDto dto) {
        if (dto.Tier == "Spades") spades = dto.CurrentValue;
        else if (dto.Tier == "Hearts") hearts = dto.CurrentValue;
        else if (dto.Tier == "Diamonds") diamonds = dto.CurrentValue;
        else if (dto.Tier == "Clubs") clubs = dto.CurrentValue;
        else if (dto.Name.Contains("Spades")) spades = dto.CurrentValue;
        else if (dto.Name.Contains("Hearts")) hearts = dto.CurrentValue;
    }

    public void Dispose() {
        RealTime.OnJackpotUpdated -= HandleUpdate;
        LayoutService.OnMajorUpdate -= StateHasChanged;
    }
}